require open
  pp2lp.B pp2lp.Eq
  pp2lp.NonFree;

// esub rules
// (sequential Рђћ order matters).
sequential symbol psub :
  String Рєњ Exp Рєњ Prd Рєњ Prd;
sequential symbol esub :
  String Рєњ Exp Рєњ Exp Рєњ Exp;


// SUB 1: substituting x in
// eid x gives E.
rule esub $x $E (eid $x)
  Рєф $E;
// SUB 2: substituting x in
// eid y (x РЅа y) Рђћ unchanged.
rule esub _ _ (eid $y)
  Рєф eid $y;
// esub for pairs (cf. ┬Д1.5).
rule esub $x $E ($D Рєд $F)
  Рєф (esub $x $E $D)
    Рєд (esub $x $E $F);
// esub for arithmetic.
rule esub $x $E ($D + $F)
  Рєф (esub $x $E $D)
    + (esub $x $E $F);
rule esub $x $E ($D - $F)
  Рєф (esub $x $E $D)
    - (esub $x $E $F);
rule esub $x $E (Реф $D)
  Рєф Реф (esub $x $E $D);
// esub for constants.
rule esub _ _ ­ЮЪј Рєф ­ЮЪј;
rule esub _ _ ­ЮЪЈ Рєф ­ЮЪЈ;
rule esub _ _ BTRUE Рєф BTRUE;
rule esub _ _ BFALSE
  Рєф BFALSE;
// esub for functional image.
rule esub $x $E (eapp $f $D)
  Рєф eapp $f
    (esub $x $E $D);

// psub rules
// (sequential Рђћ order matters).

// SUB 6/7: quantifier binder.
// If x Рѕѕ vs, shadowed
// (return unchanged).
// Otherwise, sub in body.
symbol ?sub_binder :
  (Prd Рєњ Prd) Рєњ String Рєњ
  Exp Рєњ Var Рєњ Prd Рєњ
  ­Юћ╣ Рєњ Prd;
rule ?sub_binder
  $Q _ _ _ $P true
  Рєф $Q $P;
rule ?sub_binder
  $Q $x $E _ $P false
  Рєф $Q (psub $x $E $P);

rule psub $x $E
    (pp2lp.B.Рѕђ $vs $P)
  Рєф ?sub_binder
    (pp2lp.B.Рѕђ $vs)
    $x $E $vs $P
    (str_mem $x $vs);
// SUB 3, 4, 5.
rule psub $x $E ($P РѕД $Q)
  Рєф (psub $x $E $P)
    РѕД (psub $x $E $Q);
rule psub $x $E ($P РЄњ $Q)
  Рєф (psub $x $E $P)
    РЄњ (psub $x $E $Q);
rule psub $x $E (┬г $P)
  Рєф ┬г (psub $x $E $P);
// SUB for Рѕе, РЄћ.
rule psub $x $E ($P Рѕе $Q)
  Рєф (psub $x $E $P)
    Рѕе (psub $x $E $Q);
rule psub $x $E ($P РЄћ $Q)
  Рєф (psub $x $E $P)
    РЄћ (psub $x $E $Q);
// SUB 12.
rule psub $x $E ($D РЅЃ $F)
  Рєф (esub $x $E $D)
    РЅЃ (esub $x $E $F);
// SUB for РЅц, РЅф, eql_set.
rule psub $x $E ($D РЅц $F)
  Рєф (esub $x $E $D)
    РЅц (esub $x $E $F);
rule psub $x $E ($D РЅф $F)
  Рєф (esub $x $E $D)
    РЅф (esub $x $E $F);
rule psub $x $E
    (eql_set $D $F)
  Рєф eql_set
    (esub $x $E $D)
    (esub $x $E $F);
// SUB for constants.
rule psub _ _ TRUE Рєф TRUE;
rule psub _ _ FALSE Рєф FALSE;
// SUB for pred identifiers
// (no vars to substitute).
rule psub _ _ (pid $y)
  Рєф pid $y;
// SUB for pred application:
// substitute in exp arg only.
rule psub $x $E (papp $f $D)
  Рєф papp $f
    (esub $x $E $D);
// SUB for membership:
// substitute in both exps.
rule psub $x $E ($D Рѕѕ $s)
  Рєф (esub $x $E $D)
    Рѕѕ (esub $x $E $s);
// SUB for РѕЃ (same as Рѕђ).
rule psub $x $E (РѕЃ $vs $P)
  Рєф ?sub_binder
    (РѕЃ $vs) $x $E $vs $P
    (str_mem $x $vs);

// ---- Compound variable substitution ----
// vpsub/vesub generalise psub/esub to
// compound Var, decomposing
//   [(x РеЙ y) := (E Рєд F)]P
// into [x := E]([y := F]P).
symbol vpsub : Var Рєњ Exp Рєњ Prd Рєњ Prd;
symbol vesub : Var Рєњ Exp Рєњ Exp Рєњ Exp;

rule vpsub (id $s) $E $P
  Рєф psub $s $E $P;
rule vpsub ($x РеЙ $y) ($E Рєд $F) $P
  Рєф vpsub $x $E (vpsub $y $F $P);

rule vesub (id $s) $E $D
  Рєф esub $s $E $D;
rule vesub ($x РеЙ $y) ($E Рєд $F) $D
  Рєф vesub $x $E (vesub $y $F $D);
