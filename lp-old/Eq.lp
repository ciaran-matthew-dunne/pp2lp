require open pp2lp.B;

// syntactic equality.
sequential symbol str_eq :
  String вҶ’ String вҶ’ рқ”№;
rule str_eq $s $s вҶӘ true
with str_eq _ _   вҶӘ false;

// variable equality:
// structural string-list cmp.
sequential symbol veq :
  Var вҶ’ Var вҶ’ рқ”№;
rule veq (id $s) (id $s')
  вҶӘ str_eq $s $s'
with veq ($x вЁҫ $y) ($x' вЁҫ $y')
  вҶӘ (veq $x $x') and (veq $y $y')
with veq (id _) (_ вЁҫ _) вҶӘ false
with veq (_ вЁҫ _) (id _) вҶӘ false;

symbol vneq (x y : Var) вү” not (veq x y);

// expression equality.
sequential symbol exp_eq :
  Exp вҶ’ Exp вҶ’ рқ”№;
sequential symbol prd_eq :
  Prd вҶ’ Prd вҶ’ рқ”№;
rule exp_eq (eid $x) (eid $y)
  вҶӘ str_eq $x $y
with exp_eq
    ($E вҶҰ $F) ($G вҶҰ $H)
  вҶӘ (exp_eq $E $G)
    and (exp_eq $F $H)
with exp_eq рқҹҺ рқҹҺ вҶӘ true
with exp_eq рқҹҸ рқҹҸ вҶӘ true
with exp_eq BTRUE BTRUE
  вҶӘ true
with exp_eq BFALSE BFALSE
  вҶӘ true
with exp_eq
    ($x1 + $x2) ($y1 + $y2)
  вҶӘ (exp_eq $x1 $y1)
    and (exp_eq $x2 $y2)
with exp_eq
    ($x1 - $x2) ($y1 - $y2)
  вҶӘ (exp_eq $x1 $y1)
    and (exp_eq $x2 $y2)
with exp_eq (вЁӘ $x) (вЁӘ $y)
  вҶӘ (exp_eq $x $y)
with exp_eq
    (eapp $f $E) (eapp $g $F)
  вҶӘ (str_eq $f $g)
    and (exp_eq $E $F)
with exp_eq $e $e вҶӘ true
with exp_eq _ _ вҶӘ false
with prd_eq
    ($p вҲ§ $q) ($r вҲ§ $s)
  вҶӘ (prd_eq $p $r)
    and (prd_eq $q $s)
with prd_eq
    ($p вҲЁ $q) ($r вҲЁ $s)
  вҶӘ (prd_eq $p $r)
    and (prd_eq $q $s)
with prd_eq
    ($p вҮ’ $q) ($r вҮ’ $s)
  вҶӘ (prd_eq $p $r)
    and (prd_eq $q $s)
with prd_eq
    ($p вҮ” $q) ($r вҮ” $s)
  вҶӘ (prd_eq $p $r)
    and (prd_eq $q $s)
with prd_eq (В¬ $p) (В¬ $q)
  вҶӘ (prd_eq $p $q)
with prd_eq (pid $x) (pid $y)
  вҶӘ str_eq $x $y
with prd_eq
    (вҲҖ $x $p) (вҲҖ $y $q)
  вҶӘ (veq $x $y)
    and (prd_eq $p $q)
with prd_eq
    (вҲғ $x $p) (вҲғ $y $q)
  вҶӘ (veq $x $y)
    and (prd_eq $p $q)
with prd_eq
    (вҷў $x $p) (вҷў $y $q)
  вҶӘ (veq $x $y)
    and (prd_eq $p $q)
with prd_eq
    (вҷЎ $x $p) (вҷЎ $y $q)
  вҶӘ (veq $x $y)
    and (prd_eq $p $q)
with prd_eq
    ($e вүғ $f) ($g вүғ $h)
  вҶӘ (exp_eq $e $g)
    and (exp_eq $f $h)
with prd_eq
    (eql_set $e $f)
    (eql_set $g $h)
  вҶӘ (exp_eq $e $g)
    and (exp_eq $f $h)
with prd_eq
    ($e вүӨ $f) ($g вүӨ $h)
  вҶӘ (exp_eq $e $g)
    and (exp_eq $f $h)
with prd_eq
    ($e вүӘ $f) ($g вүӘ $h)
  вҶӘ (exp_eq $e $g)
    and (exp_eq $f $h)

with prd_eq
    (papp $f $E) (papp $g $F)
  вҶӘ (str_eq $f $g)
    and (exp_eq $E $F)
with prd_eq
    ($E вҲҲ $s) ($F вҲҲ $t)
  вҶӘ (exp_eq $E $F)
    and (exp_eq $s $t)
with prd_eq TRUE TRUE вҶӘ true
with prd_eq FALSE FALSE
  вҶӘ true
with prd_eq _ _ вҶӘ false;
