// Trace reconstructions using
// the PP inference rules.
require open
  pp2lp.rules.Conj pp2lp.rules.Disj
  pp2lp.rules.Impl pp2lp.rules.Equiv
  pp2lp.rules.Neg pp2lp.rules.Axm
  pp2lp.rules.All pp2lp.rules.Xst
  pp2lp.rules.TrueFalse
  pp2lp.rules.Nrm pp2lp.rules.Eq;
// shorthand: prove P from
// empty hypotheses.
symbol Thm (P : Prd) ‚ČĒ ‚Ė° ‚ä© P;

// Trace 01:
//   ¬¨(p ‚ąß q) ‚áí (¬¨p ‚ą® ¬¨q)
// [AND1]
//   {[IMP4] [OR4] [AXM4]}
//   {[IMP4] [OR4] [NOT1]
//    [AXM1]}
symbol {|01.trace|} :
  Thm (¬¨ ("p" ‚ąß "q") ‚áí
    ((¬¨ "p") ‚ą® (¬¨ "q"))) ‚ČĒ
begin
  simplify;
  apply AND1
  { apply IMP4;
    apply OR4;
    apply AXM4 ‚ä§ŠĶĘ; }
  { apply IMP4;
    apply OR4;
    apply NOT1;
    apply AXM1 ‚ä§ŠĶĘ }
end;
// Trace 02: ¬¨(p ‚ąß ¬¨p)
// [AND2] [IMP4] [NOT2] [AXM3]
symbol {|02.trace|} :
  Thm (¬¨ ("p" ‚ąß (¬¨ "p"))) ‚ČĒ
begin
  simplify;
  apply AND2;
  apply IMP4;
  apply NOT2;
  apply AXM3 ‚ä§ŠĶĘ
end;

// Trace 03:
//   (p ‚ąß q) ‚áí (q ‚ąß p)
// [AND3] [IMP4]
//   [AR10(q)] [IMP4] [AND4]
//   {[AXM3]} {[AXM3]}
symbol {|03.trace|} :
  Thm (("p" ‚ąß "q") ‚áí
    ("q" ‚ąß "p")) ‚ČĒ
begin
  simplify;
  apply AND3;
  apply IMP4;
  // AR10 is a no-op here
  // (solver confirms Q ‚ČÉ Q),
  // so just IMP4.
  apply IMP4;
  apply AND4
  { apply AXM3 ‚ä§ŠĶĘ }
  { apply AXM3 ‚ä§ŠĶĘ }
end;

// Trace 04:
//   (A ‚ąß P ‚ąß (P ‚áí Q) ‚ąß C)
//   ‚áí Q
// [AND5] [AXM8]
symbol {|04.trace|} :
  Thm (("a" ‚ąß "p"
    ‚ąß ("p" ‚áí "q") ‚ąß "c")
    ‚áí "q") ‚ČĒ
begin
  simplify;
  apply AND5
    "p" "q" ‚ä§ŠĶĘ ‚ä§ŠĶĘ;
  apply AXM8 ‚ä§ŠĶĘ
end;

// Trace 05:
//   ¬¨(p ‚ą® q) ‚áí ¬¨p
// [OR1] [IMP4] [AXM4]
symbol {|05.trace|} :
  Thm (¬¨ ("p" ‚ą® "q") ‚áí
    ¬¨ "p") ‚ČĒ
begin
  simplify;
  apply OR1;
  apply IMP4;
  apply AXM4 ‚ä§ŠĶĘ
end;

// Trace 06:
//   ¬¨(p ‚ąß ¬¨p ‚ą® (q ‚ąß ¬¨q))
// [OR2]
//   {[AND2] [IMP4] [NOT2]
//    [AXM3]}
//   {[AND2] [IMP4] [NOT2]
//    [AXM3]}
symbol {|06.trace|} :
  Thm (¬¨ (("p" ‚ąß ¬¨ "p")
    ‚ą® ("q" ‚ąß ¬¨ "q"))) ‚ČĒ
begin
  simplify;
  apply OR2
  { apply AND2;
    apply IMP4;
    apply NOT2;
    apply AXM3 ‚ä§ŠĶĘ }
  { apply AND2;
    apply IMP4;
    apply NOT2;
    apply AXM3 ‚ä§ŠĶĘ }
end;

// Trace 07:
//   (p ‚ą® q) ‚áí (q ‚ą® p)
// [OR3]
//   {[IMP4] [OR4] [AXM2]}
//   {[IMP4] [OR4] [AXM4]}
symbol {|07.trace|} :
  Thm (("p" ‚ą® "q") ‚áí
    ("q" ‚ą® "p")) ‚ČĒ
begin
  simplify;
  apply OR3
  { apply IMP4;
    apply OR4;
    apply AXM2 ‚ä§ŠĶĘ }
  { apply IMP4;
    apply OR4;
    apply AXM4 ‚ä§ŠĶĘ }
end;

// Trace 08:
//   ¬¨(p ‚áí q) ‚áí ¬¨q
// [IMP1] [IMP4] [AXM7]
symbol {|08.trace|} :
  Thm (¬¨ ("p" ‚áí "q") ‚áí
    ¬¨ "q") ‚ČĒ
begin
  simplify;
  apply IMP1;
  apply IMP4;
  apply AXM7
end;

// Trace 09:
//   ¬¨((p ‚ą® ¬¨p) ‚áí (p ‚ąß ¬¨p))
// [IMP2]
//   {[AND2] [IMP4] [NOT2]
//    [AXM3]}
//   {[OR4] [AXM7]}
symbol {|09.trace|} :
  Thm (¬¨ (("p" ‚ą® ¬¨ "p") ‚áí
    ("p" ‚ąß ¬¨ "p"))) ‚ČĒ
begin
  simplify;
  apply IMP2
  { apply AND2;
    apply IMP4;
    apply NOT2;
    apply AXM3 ‚ä§ŠĶĘ }
  { apply OR4;
    apply AXM7 }
end;

// Trace 10:
//   p ‚áí ¬¨p ‚áí ¬¨p
// [IMP3] {[AXM7]} {[AXM7]}
symbol {|10.trace|} :
  Thm ("p" ‚áí
    (¬¨ "p") ‚áí (¬¨ "p")) ‚ČĒ
begin
  simplify;
  apply IMP3
  { apply AXM7 }
  { apply AXM7 }
end;

// Trace 11:
//   p ‚áí (p ‚áí p ‚ąß p)
// [IMP4] [IMP5(1)] [AND4]
//   {[AXM3]} {[AXM3]}
symbol {|11.trace|} :
  Thm ("p" ‚áí
    ("p" ‚áí ("p" ‚ąß "p"))) ‚ČĒ
begin
  simplify;
  apply IMP4;
  apply IMP5 ‚ä§ŠĶĘ;
  apply AND4
  { apply AXM3 ‚ä§ŠĶĘ }
  { apply AXM3 ‚ä§ŠĶĘ }
end;

// Trace 12:
//   ¬¨(p ‚áĒ p) ‚áí q
// [EQV1]
//   {[IMP4] [AXM2]}
//   {[IMP4] [AXM1]}
symbol {|12.trace|} :
  Thm (¬¨ ("p" ‚áĒ "p") ‚áí
    "q") ‚ČĒ
begin
  simplify;
  apply EQV1
  { apply IMP4;
    apply AXM2 ‚ä§ŠĶĘ }
  { apply IMP4;
    apply AXM1 ‚ä§ŠĶĘ }
end;

// Trace 13: ¬¨(p ‚áĒ ¬¨p)
// [EQV2]
//   {[IMP4] [NOT2] [AXM3]}
//   {[NOT1] [AXM7]}
symbol {|13.trace|} :
  Thm (¬¨ ("p" ‚áĒ ¬¨ "p")) ‚ČĒ
begin
  simplify;
  apply EQV2
  { apply IMP4;
    apply NOT2;
    apply AXM3 ‚ä§ŠĶĘ }
  { apply NOT1;
    apply AXM7 }
end;


// Trace 14:
//   (p ‚áĒ ¬¨p) ‚áí q
// [EQV3]
//   {[IMP4] [AXM2]}
//   {[IMP4] [NOT1] [AXM1]}
symbol {|14.trace|} :
  Thm (("p" ‚áĒ ¬¨ "p") ‚áí
    "q") ‚ČĒ
begin
  simplify;
  apply EQV3
  { apply IMP4;
    apply AXM2 ‚ä§ŠĶĘ }
  { apply IMP4;
    apply NOT1;
    apply AXM1 ‚ä§ŠĶĘ }
end;

// Trace 15: p ‚áĒ p
// [EQV4] {[AXM7]} {[AXM7]}
symbol {|15.trace|} :
  Thm ("p" ‚áĒ "p") ‚ČĒ
begin
  simplify;
  apply EQV4
  { apply AXM7 }
  { apply AXM7 }
end;

// Trace 16:
//   ¬¨q ‚áí (p ‚áí (q ‚áí r))
// [IMP4] [AXM5]
symbol {|16.trace|} :
  Thm (¬¨ "q" ‚áí
    ("p" ‚áí
      ("q" ‚áí "r"))) ‚ČĒ
begin
  simplify;
  apply IMP4;
  apply AXM5 ‚ä§ŠĶĘ
end;

// Trace 17:
//   q ‚áí (p ‚áí (¬¨q ‚áí r))
// [IMP4] [AXM6]
symbol {|17.trace|} :
  Thm ("q" ‚áí
    ("p" ‚áí
      (¬¨ "q" ‚áí "r"))) ‚ČĒ
begin
  simplify;
  apply IMP4;
  apply AXM6 ‚ä§ŠĶĘ
end;

// Traces 18-27:
//   quantifier/set traces

// Trace 18:
//   ‚ąÄa.(‚ąÄx.¬¨(TRUE ‚ąß x ‚ČÉ x))
//   ‚áí (a ‚ČÉ a ‚áí p)
// [ALL8(1)] [ALL7(1)]
//   [FIN(FALSE)] [NRM1] [FX3]
symbol {|18.trace|} :
  Thm (‚ąÄ "a"
    ((‚ąÄ "x"
      (¬¨ (TRUE ‚ąß
        ("x" ‚ČÉ "x"))))
    ‚áí ("a" ‚ČÉ "a" ‚áí
      "p"))) ‚ČĒ
begin
  simplify;
  apply ALL8;
  apply ALL7
  { apply AND2_1;
    apply VR3_1;
    apply EVR2_1;
    apply STOP_1 }
  { apply NRM1 ‚ä§ŠĶĘ;
    apply FX3 }
end;

// Trace 19:
//   ‚ąÄa.(‚ąÄx.¬¨(TRUE ‚ąß p(x))
//   ‚ąß ‚ąÄ(x$4).(‚ąÉ(x$5).
//     (x$4,x$5: p)
//     ‚áí x$4,p(x$4): p)
//   ‚áí (p(a) ‚áí q))
symbol {|19.trace|} :
  Thm (‚ąÄ "a"
    ((‚ąÄ "x"
      (¬¨ (TRUE ‚ąß
        papp "p" "x"))
    ‚ąß ‚ąÄ "x$4"
      (‚ąÉ "x$5"
        (("x$4" ‚Ü¶ "x$5")
          ‚ąą "p")
      ‚áí ("x$4" ‚Ü¶
        eapp "p" "x$4")
          ‚ąą "p"))
    ‚áí (papp "p" "a" ‚áí
      "q"))) ‚ČĒ
begin
  simplify;
  apply ALL8;
  apply AND3;
  apply ALL7
  { apply AND2_1;
    apply VR3_1;
    apply STOP_1 }
  { apply NRM14;
    apply ALL9;
    apply ALL7
    { apply XST7_1 ‚ä§ŠĶĘ;
      apply ALL8_1;
      apply IMP4_1;
      apply STOP_1 }
    { apply NRM8 ‚ä§ŠĶĘ;
      apply NRM13;
      apply ALL9;
      apply AXM9
        "x" "a"
        (papp "p" "x")
        ‚ä§ŠĶĘ ‚ä§ŠĶĘ } }
end;

// Trace 20:
//   ¬¨(‚ąÄx.‚ąÄy.(x ‚ČÉ y))
//   ‚áí P ‚ą® ¬¨P
// [ALL1] [ALL5(2)]
//   [ALL8(1)] [IMP4]
//   [OR4] [AXM7]
symbol {|20.trace|} :
  Thm (¬¨ (‚ąÄ "x"
    (‚ąÄ "y"
      ("x" ‚ČÉ "y")))
    ‚áí "p" ‚ą® ¬¨ "p") ‚ČĒ
begin
  simplify;
  apply ALL1 ‚ä§ŠĶĘ;
  apply ALL5 ‚ä§ŠĶĘ;
  apply ALL8;
  apply IMP4;
  apply OR4;
  apply AXM7
end;

// Trace 21:
//   ‚ąÄx.‚ąÄy.q(x,y) ‚ąß set_hyp
//   ‚áí p ‚ą® ¬¨p
symbol {|21.trace|} :
  Thm ((‚ąÄ "x"
    (‚ąÄ "y"
      (papp "q"
        ("x" ‚Ü¶ "y")))
    ‚ąß ‚ąÄ ("x$6" ‚®ĺ "x$5")
      (‚ąÉ "x$7"
        (("x$6" ‚Ü¶ "x$5"
          ‚Ü¶ "x$7") ‚ąą "q")
      ‚áí ("x$6" ‚Ü¶ "x$5" ‚Ü¶
        eapp "q"
          ("x$6" ‚Ü¶ "x$5"))
        ‚ąą "q"))
    ‚áí "p" ‚ą® ¬¨ "p") ‚ČĒ
begin
  simplify;
  apply AND3;
  apply ALL3 ‚ä§ŠĶĘ;
  apply ALL7
  { apply STOP_1 }
  { apply NRM15;
    apply ALL9;
    apply ALL7
    { apply XST7_1 ‚ä§ŠĶĘ;
      apply ALL8_1;
      apply IMP4_1;
      apply STOP_1 }
    { apply NRM8 ‚ä§ŠĶĘ;
      apply NRM13;
      apply ALL9;
      apply OR4;
      apply AXM7 } }
end;

// Trace 22:
//   ¬¨(‚ąÄx.‚ąÄy.¬¨(x ‚ČÉ x))
// [ALL2] [ALL6] [ALL7(1)]
//   [FIN(FAUX)] [NRM1]
//   [AXM7]
symbol {|22.trace|} :
  Thm (¬¨ (‚ąÄ "x"
    (‚ąÄ "y"
      (¬¨ ("x" ‚ČÉ "x"))))) ‚ČĒ
begin
  simplify;
  apply ALL2 ‚ä§ŠĶĘ;
  apply ALL6;
  apply ALL7
  { apply EVR2_1;
    apply STOP_1 }
  { apply NRM1 ‚ä§ŠĶĘ;
    apply AXM7 }
end;

// Trace 23:
//   ‚ąÄ(a,b).(¬¨(‚ąÉx.‚ąÉy.p(x,y))
//   ‚ąß set_hyp
//   ‚áí ¬¨p(a,b))
symbol {|23.trace|} :
  Thm (‚ąÄ ("a" ‚®ĺ "b")
    ((¬¨ (‚ąÉ "x"
      (‚ąÉ "y"
        (papp "p"
          ("x" ‚Ü¶ "y"))))
    ‚ąß ‚ąÄ ("x$6" ‚®ĺ "x$5")
      (‚ąÉ "x$7"
        (("x$6" ‚Ü¶ "x$5"
          ‚Ü¶ "x$7") ‚ąą "p")
      ‚áí ("x$6" ‚Ü¶ "x$5" ‚Ü¶
        eapp "p"
          ("x$6" ‚Ü¶ "x$5"))
        ‚ąą "p"))
    ‚áí ¬¨ (papp "p"
      ("a" ‚Ü¶ "b")))) ‚ČĒ
begin
  simplify;
  apply ALL8;
  apply AND3;
  apply XST1 ‚ä§ŠĶĘ;
  apply XST5;
  apply ALL7
  { apply STOP_1 }
  { apply NRM14;
    apply ALL9;
    apply ALL7
    { apply XST7_1 ‚ä§ŠĶĘ;
      apply ALL8_1;
      apply IMP4_1;
      apply STOP_1 }
    { apply NRM8 ‚ä§ŠĶĘ;
      apply NRM13;
      apply ALL9;
      apply STOP;
      apply NOT1;
      apply AXM9
        ("x" ‚®ĺ "y")
        ("a" ‚Ü¶ "b")
        (papp "p"
          ("x" ‚Ü¶ "y"))
        ‚ä§ŠĶĘ ‚ä§ŠĶĘ } }
end;

// Trace 24:
//   ‚ąÉx.‚ąÉy.p(x,y) ‚ąß set_hyp
//   ‚áí q ‚ą® ¬¨q
symbol {|24.trace|} :
  Thm ((‚ąÉ "x"
    (‚ąÉ "y"
      (papp "p"
        ("x" ‚Ü¶ "y")))
    ‚ąß ‚ąÄ ("x$6" ‚®ĺ "x$5")
      (‚ąÉ "x$7"
        (("x$6" ‚Ü¶ "x$5"
          ‚Ü¶ "x$7") ‚ąą "p")
      ‚áí ("x$6" ‚Ü¶ "x$5" ‚Ü¶
        eapp "p"
          ("x$6" ‚Ü¶ "x$5"))
        ‚ąą "p"))
    ‚áí "q" ‚ą® ¬¨ "q") ‚ČĒ
begin
  simplify;
  apply AND3;
  apply XST3 ‚ä§ŠĶĘ;
  apply XST7 ‚ä§ŠĶĘ;
  apply ALL8;
  apply IMP4;
  apply ALL7
  { apply XST7_1 ‚ä§ŠĶĘ;
    apply ALL8_1;
    apply IMP4_1;
    apply STOP_1 }
  { apply NRM8 ‚ä§ŠĶĘ;
    apply NRM13;
    apply ALL9;
    apply OR4;
    apply AXM7 }
end;

// Trace 25:
//   ‚ąÄ(x$6,x$5).
//   (‚ąÉ(x$7).
//     (x$6,x$5,x$7: p)
//     ‚áí x$6,x$5,
//       p(x$6,x$5): p)
//   ‚áí ¬¨(‚ąÉx.‚ąÉy.
//     (p(x,y) ‚ąß ¬¨p(x,y)))
symbol {|25.trace|} :
  Thm (‚ąÄ ("x$6" ‚®ĺ "x$5")
    (‚ąÉ "x$7"
      (("x$6" ‚Ü¶ "x$5"
        ‚Ü¶ "x$7") ‚ąą "p")
    ‚áí ("x$6" ‚Ü¶ "x$5" ‚Ü¶
      eapp "p"
        ("x$6" ‚Ü¶ "x$5"))
      ‚ąą "p")
    ‚áí ¬¨ (‚ąÉ "x"
      (‚ąÉ "y"
        (papp "p"
          ("x" ‚Ü¶ "y")
        ‚ąß ¬¨ (papp "p"
          ("x" ‚Ü¶
            "y")))))) ‚ČĒ
begin
  simplify;
  apply ALL7
  { apply XST7_1 ‚ä§ŠĶĘ;
    apply ALL8_1;
    apply IMP4_1;
    apply STOP_1 }
  { apply NRM8 ‚ä§ŠĶĘ;
    apply NRM13;
    apply ALL9;
    apply XST2 ‚ä§ŠĶĘ;
    apply XST6;
    apply ALL8;
    apply AND2;
    apply IMP4;
    apply NOT2;
    apply AXM3 ‚ä§ŠĶĘ }
end;

// Trace 26:
//   ‚ąÄ(a,b).(a ‚ČÉ b ‚áí
//   ‚ąÄx.‚ąÄy.(x ‚ČÉ y ‚áí
//     (x ‚ČÉ a ‚áí y ‚ČÉ b)))
// [ALL8(1)] [OPR1(1)]
//   [ALL4] [ALL8(1)]
//   [OPR1(1)] [AXM7]
symbol {|26.trace|} :
  Thm (‚ąÄ ("a" ‚®ĺ "b")
    ("a" ‚ČÉ "b" ‚áí
      ‚ąÄ "x" (‚ąÄ "y"
        ("x" ‚ČÉ "y" ‚áí
          ("x" ‚ČÉ "a" ‚áí
            "y" ‚ČÉ
              "b"))))) ‚ČĒ
begin
  simplify;
  apply ALL8;
  apply OPR1 ‚ä§ŠĶĘ;
  apply ALL4 ‚ä§ŠĶĘ;
  apply ALL8;
  apply OPR1 ‚ä§ŠĶĘ;
  apply AXM7
end;

// Trace 27:
//   ‚ąÄ(a,b).(p(a,b)
//   ‚ąß set_hyp
//   ‚áí ‚ąÉx.‚ąÉy.p(x,y))
symbol {|27.trace|} :
  Thm (‚ąÄ ("a" ‚®ĺ "b")
    ((papp "p"
      ("a" ‚Ü¶ "b")
    ‚ąß ‚ąÄ ("x$6" ‚®ĺ "x$5")
      (‚ąÉ "x$7"
        (("x$6" ‚Ü¶ "x$5"
          ‚Ü¶ "x$7") ‚ąą "p")
      ‚áí ("x$6" ‚Ü¶ "x$5" ‚Ü¶
        eapp "p"
          ("x$6" ‚Ü¶ "x$5"))
        ‚ąą "p"))
    ‚áí ‚ąÉ "x"
      (‚ąÉ "y"
        (papp "p"
          ("x" ‚Ü¶
            "y"))))) ‚ČĒ
begin
  simplify;
  apply ALL8;
  apply AND3;
  apply IMP4;
  apply ALL7
  { apply XST7_1 ‚ä§ŠĶĘ;
    apply ALL8_1;
    apply IMP4_1;
    apply STOP_1 }
  { apply NRM8 ‚ä§ŠĶĘ;
    apply NRM13;
    apply ALL9;
    apply XST4 ‚ä§ŠĶĘ;
    apply XST8
    { apply STOP_1 }
    { apply ALL7
      { apply STOP_1 }
      { apply NRM14;
        apply NRM19
          (papp "p"
            ("a" ‚Ü¶ "b"))
          ("a" ‚Ü¶ "b")
          ‚ä§ŠĶĘ ‚ä§ŠĶĘ } } }
end;

// TRUE/FALSE traces
// (28-30)

// Trace 28: ¬¨TRUE ‚áí p
// [VR1]
symbol {|28.trace|} :
  Thm (¬¨ TRUE ‚áí "p") ‚ČĒ
begin
  simplify;
  apply VR1
end;

// Trace 29:
//   ¬¨FALSE ‚áí TRUE
// [FX1] [VR4]
symbol {|29.trace|} :
  Thm (¬¨ FALSE ‚áí TRUE) ‚ČĒ
begin
  simplify;
  apply FX1;
  apply VR4
end;

// Trace 30: ¬¨FALSE
// [FX2]
symbol {|30.trace|} :
  Thm (¬¨ FALSE) ‚ČĒ
begin
  simplify;
  apply FX2
end;
