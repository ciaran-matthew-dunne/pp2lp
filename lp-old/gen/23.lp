require open pp2lp.Rules;
symbol Thm (P : Prd) РЅћ РќА РіЕ P;

symbol {|23.trace|} :
  Thm ((Рѕђ ("a" РеЙ "b") (((┬г (РѕЃ "x" (РѕЃ "y" (papp "p" ("x" Рєд "y"))))) РѕД (Рѕђ ("x$6" РеЙ "x$5") ((РѕЃ "x$7" (("x$6" Рєд "x$5" Рєд "x$7") Рѕѕ "p")) РЄњ (("x$6" Рєд "x$5" Рєд (eapp "p" ("x$6" Рєд "x$5"))) Рѕѕ "p")))) РЄњ (┬г (papp "p" ("a" Рєд "b")))))) РЅћ
begin
  simplify;
  apply ALL8;
  apply AND3;
  apply XST1 Ріцрхб;
  apply XST5;
  apply ALL7
  { apply STOP_1 }
  { apply NRM14;
    apply ALL9;
    apply ALL7
    { apply XST7_1 Ріцрхб;
      apply ALL8_1;
      apply IMP4_1;
      apply STOP_1 }
    { apply NRM8 Ріцрхб;
      apply NRM13;
      apply ALL9;
      apply STOP;
      apply NOT1;
      apply AXM9 ("x" РеЙ "y") ("a" Рєд "b") ((papp "p" ("x" Рєд "y"))) Ріцрхб Ріцрхб } }
end;
