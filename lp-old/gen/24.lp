require open pp2lp.Rules;
symbol Thm (P : Prd) РЅћ РќА РіЕ P;

symbol {|24.trace|} :
  Thm ((((РѕЃ "x" (РѕЃ "y" (papp "p" ("x" Рєд "y")))) РѕД (Рѕђ ("x$6" РеЙ "x$5") ((РѕЃ "x$7" (("x$6" Рєд "x$5" Рєд "x$7") Рѕѕ "p")) РЄњ (("x$6" Рєд "x$5" Рєд (eapp "p" ("x$6" Рєд "x$5"))) Рѕѕ "p")))) РЄњ ("q" Рѕе (┬г "q")))) РЅћ
begin
  simplify;
  apply AND3;
  apply XST3 Ріцрхб;
  apply XST7 Ріцрхб;
  apply ALL8;
  apply IMP4;
  apply ALL7
  { apply XST7_1 Ріцрхб;
    apply ALL8_1;
    apply IMP4_1;
    apply STOP_1 }
  { apply NRM8 Ріцрхб;
    apply NRM13;
    apply ALL9;
    apply OR4;
    apply AXM7 }
end;
