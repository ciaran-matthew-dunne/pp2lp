require open pp2lp.Rules;
symbol Thm (P : Prd) РЅћ РќА РіЕ P;

symbol {|21.trace|} :
  Thm ((((Рѕђ "x" (Рѕђ "y" (papp "q" ("x" Рєд "y")))) РѕД (Рѕђ ("x$6" РеЙ "x$5") ((РѕЃ "x$7" (("x$6" Рєд "x$5" Рєд "x$7") Рѕѕ "q")) РЄњ (("x$6" Рєд "x$5" Рєд (eapp "q" ("x$6" Рєд "x$5"))) Рѕѕ "q")))) РЄњ ("p" Рѕе (┬г "p")))) РЅћ
begin
  simplify;
  apply AND3;
  apply ALL3 Ріцрхб;
  apply ALL7
  { apply STOP_1 }
  { apply NRM15;
    apply ALL9;
    apply ALL7
    { apply XST7_1 Ріцрхб;
      apply ALL8_1;
      apply IMP4_1;
      apply STOP_1 }
    { apply NRM8 Ріцрхб;
      apply NRM13;
      apply ALL9;
      apply OR4;
      apply AXM7 } }
end;
