// Existential quantification (┬ДA.8)
require open
  pp2lp.B pp2lp.Eq
  pp2lp.NonFree pp2lp.Subst
  pp2lp.Proof;

// ---- Base rules ----

// Spec: "x and y are distinct".
symbol XST1 [H] [x y : Var] [P R]
  : РЂЄ (vneq x y)
  Рєњ Рќи (H РЪЮ ┬г (РѕЃ (x РеЙ y) P) РЄњ R)
  Рєњ Рќи (H РЪЮ ┬г (РѕЃ x (РѕЃ y P)) РЄњ R);

symbol XST2 [H] [x y : Var] [P]
  : РЂЄ (vneq x y)
  Рєњ Рќи (H РЪЮ ┬г (РѕЃ (x РеЙ y) P))
  Рєњ Рќи (H РЪЮ ┬г (РѕЃ x (РѕЃ y P)));

symbol XST3 [H] [x y : Var] [P R]
  : РЂЄ (vneq x y)
  Рєњ Рќи (H РЪЮ (РѕЃ (x РеЙ y) P) РЄњ R)
  Рєњ Рќи (H РЪЮ (РѕЃ x (РѕЃ y P)) РЄњ R);

symbol XST4 [H] [x y : Var] [P]
  : РЂЄ (vneq x y)
  Рєњ Рќи (H РЪЮ РѕЃ (x РеЙ y) P)
  Рєњ Рќи (H РЪЮ РѕЃ x (РѕЃ y P));

symbol XST5 [H x P R]
  : Рќи (H РЪЮ (Рѕђ x (┬г P)) РЄњ R)
  Рєњ Рќи (H РЪЮ ┬г (РѕЃ x P) РЄњ R);

symbol XST51 [H x P R]
  : Рќи (H РЪЮ (Рѕђ x P) РЄњ R)
  Рєњ Рќи (H РЪЮ ┬г (РѕЃ x (┬г P)) РЄњ R);

symbol XST6 [H x P]
  : Рќи (H РЪЮ Рѕђ x (┬г P))
  Рєњ Рќи (H РЪЮ ┬г (РѕЃ x P));

symbol XST61 [H x P]
  : Рќи (H РЪЮ Рѕђ x P)
  Рєњ Рќи (H РЪЮ ┬г (РѕЃ x (┬г P)));

symbol XST7 [H x P R]
  : РЂЄ (vpnf x R)
  Рєњ Рќи (H РЪЮ Рѕђ x (P РЄњ R))
  Рєњ Рќи (H РЪЮ (РѕЃ x P) РЄњ R);

// Spec: "x free in R; y free in
// neither P nor R; Q = [x:=y]P".
symbol XST7f [H] [x : String] [y : String] [P Q : Prd] [R]
  : РЂЄ (pnf x R and pnf y P and pnf y R)
  Рєњ РЂЄ (prd_eq (psub x (eid y) P) Q)
  Рєњ Рќи (H РЪЮ Рѕђ y (Q РЄњ R))
  Рєњ Рќи (H РЪЮ (РѕЃ x P) РЄњ R);

// Spec: "x not free in H".
// TODO: "x nf H" not checked.
symbol XST8 [H x P]
  : ╬а R : Res (H РЪЮ ┬г P),
    Рќи (H РЪЮ (Рѕђ x (obtain R)) РЄњ FALSE)
  Рєњ Рќи (H РЪЮ РѕЃ x P);

// Spec: "x free in H; y free in
// neither A nor H; P = [x:=y]A".
// TODO: "y nf H" not checked.
symbol XST8f [H] [x : String] [y : String] [A P : Prd]
  : РЂЄ (pnf y A)
  Рєњ РЂЄ (prd_eq (psub x (eid y) A) P)
  Рєњ ╬а R : Res (H РЪЮ ┬г P),
    Рќи (H РЪЮ (Рѕђ x (obtain R)) РЄњ FALSE)
  Рєњ Рќи (H РЪЮ РѕЃ x A);

// ---- Primed variants ----

// XST8Рђ▓: like ALL7Рђ▓ for existential quantification.
symbol XST8_1 [H x P]
  : ╬а R : Res (H РЪЮ ┬г P),
    Res (H РЪЮ (Рѕђ x (obtain R)) РЄњ FALSE)
  Рєњ Res (H РЪЮ РѕЃ x P);
rule obtain (XST8_1 _ $r) Рєф obtain $r;

// XST8fРђ▓: like ALL7fРђ▓ for existential quantification.
symbol XST8f_1 [H] [x : String] [y : String] [A P : Prd]
  : РЂЄ (pnf y A)
  Рєњ РЂЄ (prd_eq (psub x (eid y) A) P)
  Рєњ ╬а R : Res (H РЪЮ ┬г P),
    Res (H РЪЮ (Рѕђ x (obtain R)) РЄњ FALSE)
  Рєњ Res (H РЪЮ РѕЃ x A);
rule obtain (XST8f_1 _ _ _ $r) Рєф obtain $r;

symbol XST1_1 [H] [x y : Var] [P R]
  : РЂЄ (vneq x y)
  Рєњ Res (H РЪЮ ┬г (РѕЃ (x РеЙ y) P) РЄњ R)
  Рєњ Res (H РЪЮ ┬г (РѕЃ x (РѕЃ y P)) РЄњ R);
rule obtain (XST1_1 _ $r) Рєф obtain $r;

symbol XST2_1 [H] [x y : Var] [P]
  : РЂЄ (vneq x y)
  Рєњ Res (H РЪЮ ┬г (РѕЃ (x РеЙ y) P))
  Рєњ Res (H РЪЮ ┬г (РѕЃ x (РѕЃ y P)));
rule obtain (XST2_1 _ $r) Рєф obtain $r;

symbol XST3_1 [H] [x y : Var] [P R]
  : РЂЄ (vneq x y)
  Рєњ Res (H РЪЮ (РѕЃ (x РеЙ y) P) РЄњ R)
  Рєњ Res (H РЪЮ (РѕЃ x (РѕЃ y P)) РЄњ R);
rule obtain (XST3_1 _ $r) Рєф obtain $r;

symbol XST4_1 [H] [x y : Var] [P]
  : РЂЄ (vneq x y)
  Рєњ Res (H РЪЮ РѕЃ (x РеЙ y) P)
  Рєњ Res (H РЪЮ РѕЃ x (РѕЃ y P));
rule obtain (XST4_1 _ $r) Рєф obtain $r;

symbol XST5_1 [H x P R]
  : Res (H РЪЮ (Рѕђ x (┬г P)) РЄњ R)
  Рєњ Res (H РЪЮ ┬г (РѕЃ x P) РЄњ R);
rule obtain (XST5_1 $r) Рєф obtain $r;

symbol XST51_1 [H x P R]
  : Res (H РЪЮ (Рѕђ x P) РЄњ R)
  Рєњ Res (H РЪЮ ┬г (РѕЃ x (┬г P)) РЄњ R);
rule obtain (XST51_1 $r) Рєф obtain $r;

symbol XST6_1 [H x P]
  : Res (H РЪЮ Рѕђ x (┬г P))
  Рєњ Res (H РЪЮ ┬г (РѕЃ x P));
rule obtain (XST6_1 $r) Рєф obtain $r;

symbol XST61_1 [H x P]
  : Res (H РЪЮ Рѕђ x P)
  Рєњ Res (H РЪЮ ┬г (РѕЃ x (┬г P)));
rule obtain (XST61_1 $r) Рєф obtain $r;

symbol XST7_1 [H x P R]
  : РЂЄ (vpnf x R)
  Рєњ Res (H РЪЮ Рѕђ x (P РЄњ R))
  Рєњ Res (H РЪЮ (РѕЃ x P) РЄњ R);
rule obtain (XST7_1 _ $r) Рєф obtain $r;

symbol XST7f_1 [H] [x : String] [y : String] [P Q : Prd] [R]
  : РЂЄ (pnf y P and pnf y R)
  Рєњ РЂЄ (prd_eq (psub x (eid y) P) Q)
  Рєњ Res (H РЪЮ Рѕђ y (Q РЄњ R))
  Рєњ Res (H РЪЮ (РѕЃ x P) РЄњ R);
rule obtain (XST7f_1 _ _ $r) Рєф obtain $r;
