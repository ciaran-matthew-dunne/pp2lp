# Build artefacts
ocaml/_build
*.lpo

# pp2lp run artifacts (per-run suite results)
lp/bench/results/

# Per-suite inputs/outputs.
# Tracked: lp/bench/og/*.trace + *.replay (og has no .but, traces are source)
#          lp/bench/{prv,claude}/**/*.but
# Generated artifacts (.trace/.replay) for any suite with .but inputs
# are reproducible via `pp2lp gen`, so they're ignored.
lp/bench/prv/**/*.trace
lp/bench/prv/**/*.replay
lp/bench/claude/**/*.trace
lp/bench/claude/**/*.replay

# Emitted/generated Lambdapi/PP files under the pp2lp package.
lp/bench/**/*.lp
# auto-generated lambdapi debug traces (<name>.lp.unif, <name>.lp.rewrite, …)
lp/bench/**/*.lp.*
lp/bench/**/*.lpo
# provenance map `pp2lp run` writes next to each .lp (read back by `pp2lp check`)
lp/bench/**/*.provmap
lp/bench/**/*.tmp
lp/bench/**/*.goal
lp/bench/**/*.res

# apero suite — generated from the CLEARSY POG corpus (Zenodo
# 10.5281/zenodo.7050797) via `pp2lp gen apero`; the dataset itself lives
# at vendor/apero/pog (gitignored) and the suite dirs are reproducible.
vendor/apero/
lp/bench/apero/
# apero-mini — the <=24-premise slice of apero, rebuilt by `pp2lp gen apero-mini`.
lp/bench/apero-mini/

# Local environment
.envrc

# Private / large binary files
admin/
doc/*.pdf
doc/*.tar.gz
tex/**/*.pdf

