# Build artefacts
ocaml/_build
*.lpo

# Per-suite inputs/outputs.
# Tracked: bench/claude/goals.txt
#          bench/og/*.replay + *.trace + *.but
#          bench/claude-arith/*.but (committed test goals)
#          bench/prv/*.but
bench/*/.cache/
bench/*/.gen_status.tsv
bench/claude/*.but
bench/claude/*.trace
bench/claude/*.replay
bench/claude-arith/*.trace
bench/claude-arith/*.replay
bench/prv/*.trace
bench/prv/*.replay

# Emitted Lambdapi files for every suite live under the pp2lp package
# (see Suite.lp_dir). They're regenerated from .replay; don't commit.
lp/bench/

# Experimental / scratch
lp/quant_test.lp
ocaml-new/

# Local environment
.envrc

