# Build artefacts
ocaml/_build
*.lpo

# pp2lp run artifacts (per-run suite results)
bench/results/

# Per-suite inputs/outputs.
# Tracked: lp/bench/og/*.trace + *.replay (og has no .but, traces are source)
#          lp/bench/{prv,prv-no-arith,synth,nrm_test}/**/*.but
# Generated artifacts (.trace/.replay) for any suite with .but inputs
# are reproducible via `pp2lp gen`, so they're ignored.
lp/bench/prv/**/*.trace
lp/bench/prv/**/*.replay
lp/bench/prv-no-arith/**/*.trace
lp/bench/prv-no-arith/**/*.replay
lp/bench/synth/**/*.trace
lp/bench/synth/**/*.replay
lp/bench/nrm_test/**/*.trace
lp/bench/nrm_test/**/*.replay
lp/bench/gemini/**/*.trace
lp/bench/gemini/**/*.replay

# Emitted/generated Lambdapi/PP files under the pp2lp package.
lp/bench/**/*.lp
# auto-generated lambdapi debug traces (<name>.lp.unif, <name>.lp.rewrite, …)
lp/bench/**/*.lp.*
lp/bench/**/*.lpo
lp/bench/**/*.tmp
lp/bench/**/*.goal
lp/bench/**/*.res

# Experimental / scratch
lp/quant_test.lp
ocaml-new/

# Local environment
.envrc

# Private / large binary files
admin/
doc/*.pdf
doc/*.tar.gz
tex/**/*.pdf

