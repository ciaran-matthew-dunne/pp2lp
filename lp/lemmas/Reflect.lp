// lemmas/Reflect.lp вЂ” reflective decision procedure for в„¤-linear equalities,
// with scalar coefficients (kВ·x).  The emitter discharges a generated arithmetic
// equality `e1 = e2` (П„ О№) by reflecting onto `to_int` (Stdlib.Z) via [toint_eq]
// (lemmas/Int.lp) and proving the residual в„¤ equality reflectively: reify each
// side to an [LE] over an environment ПЃ of the distinct atoms, COMPUTE a canonical
// coefficient-monomial [NF], close with `eq_refl` when they agree.  Coefficients
// (from `prod(k,x)` and combination) are true в„¤ scalars; the combine/scale
// soundness rests on the в„¤ ring laws in [lemmas/Zmul.lp].
require open pp2lp.B;
require open pp2lp.lemmas.Int;
require open pp2lp.lemmas.Zmul;
require open Stdlib.List;
require Stdlib.Nat;
// reified linear expr with scalar multiplication
inductive LE : TYPE в‰”
  | Lvar : в„• в†’ LE
  | Llit : в„¤ в†’ LE
  | Ladd : LE в†’ LE в†’ LE
  | Lneg : LE в†’ LE
  | Lmul : в„¤ в†’ LE в†’ LE;

symbol den : рќ•ѓ int в†’ LE в†’ в„¤;
rule den $ПЃ (Lvar $i) в†Є nth Z0 $ПЃ $i
with den _  (Llit $z) в†Є $z
with den $ПЃ (Ladd $a $b) в†Є den $ПЃ $a + den $ПЃ $b
with den $ПЃ (Lneg $a) в†Є вЂ” (den $ПЃ $a)
with den $ПЃ (Lmul $c $a) в†Є $c * den $ПЃ $a;

// monomial list (coeff, index), sorted by index ascending, combined, nonzero coeffs
inductive ML : TYPE в‰” | mnil : ML | mcons : в„¤ в†’ в„• в†’ ML в†’ ML;
symbol mlcode : Set; rule П„ mlcode в†Є ML;
inductive NF : TYPE в‰” | mkNF : ML в†’ в„¤ в†’ NF;
symbol nfcode : Set; rule П„ nfcode в†Є NF;

symbol sumML : рќ•ѓ int в†’ ML в†’ в„¤;
rule sumML _  mnil           в†Є Z0
with sumML $ПЃ (mcons $c $i $r) в†Є $c * nth Z0 $ПЃ $i + sumML $ПЃ $r;

symbol denNF : рќ•ѓ int в†’ NF в†’ в„¤;
rule denNF $ПЃ (mkNF $ml $k) в†Є sumML $ПЃ $ml + $k;

symbol nlt : в„• в†’ в„• в†’ рќ”№;   // в„• < (own; avoids clashes)
rule nlt _ _0 в†Є false
with nlt _0 (_ +1) в†Є true
with nlt ($x +1) ($y +1) в†Є nlt $x $y;

// insert (c, i): combine same index (drop if 0), else sort by index
symbol minsert : в„¤ в†’ в„• в†’ ML в†’ ML;
rule minsert $c $i mnil в†Є if (isZ0 $c) mnil (mcons $c $i mnil)
with minsert $c $i (mcons $c' $j $r) в†Є
  if (Stdlib.Nat.eqn $i $j)
     (if (isZ0 ($c + $c')) $r (mcons ($c + $c') $i $r))
     (if (nlt $i $j) (mcons $c $i (mcons $c' $j $r)) (mcons $c' $j (minsert $c $i $r)));

symbol maddML : ML в†’ ML в†’ ML;
rule maddML mnil $l в†Є $l
with maddML (mcons $c $i $r) $l в†Є minsert $c $i (maddML $r $l);

symbol mscaleML : в„¤ в†’ ML в†’ ML;
rule mscaleML _ mnil в†Є mnil
with mscaleML $c (mcons $c' $i $r) в†Є
  if (isZ0 ($c * $c')) (mscaleML $c $r) (mcons ($c * $c') $i (mscaleML $c $r));

symbol addNF : NF в†’ NF в†’ NF;
rule addNF (mkNF $l1 $k1) (mkNF $l2 $k2) в†Є mkNF (maddML $l1 $l2) ($k1 + $k2);
symbol mulNF : в„¤ в†’ NF в†’ NF;
rule mulNF $c (mkNF $l $k) в†Є mkNF (mscaleML $c $l) ($c * $k);

symbol norm : LE в†’ NF;
rule norm (Lvar $i) в†Є mkNF (mcons (Zpos H) $i mnil) Z0
with norm (Llit $z) в†Є mkNF mnil $z
with norm (Ladd $a $b) в†Є addNF (norm $a) (norm $b)
with norm (Lneg $a) в†Є mulNF (Zneg H) (norm $a)
with norm (Lmul $c $a) в†Є mulNF $c (norm $a);

// ============ soundness ============

opaque symbol isZ0_eq : О  c, ПЂ (isZ0 c = true) в†’ ПЂ (c = Z0) в‰”
begin
  induction
  { assume h; reflexivity }
  { assume p h; refine вЉҐв‚‘ (falseв‰ true h) }
  { assume p h; refine вЉҐв‚‘ (falseв‰ true h) }
end;

// (a+b)+(c+d) = (a+c)+(b+d) on в„¤ (reuse pattern)
opaque symbol zadd4 a b c d : ПЂ ((a + b) + (c + d) = (a + c) + (b + d)) в‰”
begin assume a b c d;
  rewrite +_assoc; rewrite left +_assoc b c d; rewrite (+_com b c);
  rewrite +_assoc c b d; rewrite left +_assoc a c (b + d); reflexivity end;

opaque symbol minsert_sound (ПЃ : рќ•ѓ int) (c : в„¤) (i : в„•) :
  О  ml, ПЂ (sumML ПЃ (minsert c i ml) = c * nth Z0 ПЃ i + sumML ПЃ ml) в‰”
begin
  assume ПЃ c i;
  induction
  { // mnil: if (isZ0 c) mnil (mcons c i mnil)
    refine ind_рќ”№_eq (О» b, sumML ПЃ (if b mnil (mcons c i mnil)) = c * nth Z0 ПЃ i + Z0) (isZ0 c) _ _
    { assume h; rewrite h; simplify; have e : ПЂ (c = Z0) { refine isZ0_eq c h }; rewrite e; reflexivity }
    { assume h; rewrite h; reflexivity } }
  { assume c' j r ih;
    refine ind_рќ”№_eq (О» b, sumML ПЃ (if b (if (isZ0 (c + c')) r (mcons (c + c') i r)) (if (nlt i j) (mcons c i (mcons c' j r)) (mcons c' j (minsert c i r)))) = c * nth Z0 ПЃ i + (c' * nth Z0 ПЃ j + sumML ПЃ r)) (Stdlib.Nat.eqn i j) _ _
    { assume heq; rewrite heq; simplify;
      have eij : ПЂ (i = j) { refine Stdlib.Nat.eqn_correct i j _; rewrite heq; refine вЉ¤бµў };
      rewrite eij;
      refine ind_рќ”№_eq (О» b, sumML ПЃ (if b r (mcons (c + c') j r)) = c * nth Z0 ПЃ j + (c' * nth Z0 ПЃ j + sumML ПЃ r)) (isZ0 (c + c')) _ _
      { assume hz; rewrite hz; simplify;
        have ez : ПЂ (c + c' = Z0) { refine isZ0_eq (c + c') hz };
        rewrite left +_assoc (c * nth Z0 ПЃ j) (c' * nth Z0 ПЃ j) (sumML ПЃ r);
        rewrite left zmul_add_distr_r; rewrite ez; reflexivity }
      { assume hz; rewrite hz; simplify;
        rewrite zmul_add_distr_r; rewrite +_assoc; reflexivity } }
    { assume heq; rewrite heq; simplify;
      refine ind_рќ”№_eq (О» b, sumML ПЃ (if b (mcons c i (mcons c' j r)) (mcons c' j (minsert c i r))) = c * nth Z0 ПЃ i + (c' * nth Z0 ПЃ j + sumML ПЃ r)) (nlt i j) _ _
      { assume hlt; rewrite hlt; simplify; reflexivity }
      { assume hlt; rewrite hlt; simplify; rewrite ih;
        rewrite left +_assoc (c' * nth Z0 ПЃ j) (c * nth Z0 ПЃ i) (sumML ПЃ r);
        rewrite left +_assoc (c * nth Z0 ПЃ i) (c' * nth Z0 ПЃ j) (sumML ПЃ r);
        rewrite (+_com (c' * nth Z0 ПЃ j) (c * nth Z0 ПЃ i)); reflexivity } } }
end;

opaque symbol maddML_sound (ПЃ : рќ•ѓ int) (l2 : ML) :
  О  l1, ПЂ (sumML ПЃ (maddML l1 l2) = sumML ПЃ l1 + sumML ПЃ l2) в‰”
begin
  assume ПЃ l2;
  induction
  { reflexivity }
  { assume c i r ih; simplify; rewrite minsert_sound; rewrite ih; rewrite +_assoc; reflexivity }
end;

opaque symbol mscaleML_sound (ПЃ : рќ•ѓ int) (c : в„¤) :
  О  l, ПЂ (sumML ПЃ (mscaleML c l) = c * sumML ПЃ l) в‰”
begin
  assume ПЃ c;
  induction
  { simplify; symmetry; refine zmul_0_r c }
  { assume c' i r ih;
    refine ind_рќ”№_eq (О» b, sumML ПЃ (if b (mscaleML c r) (mcons (c * c') i (mscaleML c r))) = c * (c' * nth Z0 ПЃ i + sumML ПЃ r)) (isZ0 (c * c')) _ _
    { assume hz; rewrite hz; simplify; rewrite ih;
      have ez : ПЂ (c * c' = Z0) { refine isZ0_eq (c * c') hz };
      rewrite zmul_add_distr_l; rewrite left (zmul_assoc c c' (nth Z0 ПЃ i)); rewrite ez; reflexivity }
    { assume hz; rewrite hz; simplify; rewrite ih;
      rewrite zmul_add_distr_l; rewrite (zmul_assoc c c' (nth Z0 ПЃ i)); reflexivity } }
end;

opaque symbol addNF_sound (ПЃ : рќ•ѓ int) (n2 : NF) :
  О  n1, ПЂ (denNF ПЃ (addNF n1 n2) = denNF ПЃ n1 + denNF ПЃ n2) в‰”
begin
  assume ПЃ n2 n1;
  refine ind_NF (О» n1, denNF ПЃ (addNF n1 n2) = denNF ПЃ n1 + denNF ПЃ n2) _ n1;
  assume l1 k1;
  refine ind_NF (О» n2, denNF ПЃ (addNF (mkNF l1 k1) n2) = denNF ПЃ (mkNF l1 k1) + denNF ПЃ n2) _ n2;
  assume l2 k2; simplify;
  rewrite maddML_sound; refine zadd4 (sumML ПЃ l1) (sumML ПЃ l2) k1 k2
end;

opaque symbol mulNF_sound (ПЃ : рќ•ѓ int) (c : в„¤) (n : NF) :
  ПЂ (denNF ПЃ (mulNF c n) = c * denNF ПЃ n) в‰”
begin
  assume ПЃ c n;
  refine ind_NF (О» n, denNF ПЃ (mulNF c n) = c * denNF ПЃ n) _ n;
  assume l k; simplify; rewrite mscaleML_sound; rewrite zmul_add_distr_l; reflexivity
end;

opaque symbol norm_sound (ПЃ : рќ•ѓ int) : О  e, ПЂ (den ПЃ e = denNF ПЃ (norm e)) в‰”
begin
  assume ПЃ;
  induction
  { assume i; simplify; symmetry; refine zmul_1_l (nth Z0 ПЃ i) }
  { assume z; reflexivity }
  { assume a iha b ihb; simplify; rewrite iha; rewrite ihb;
    symmetry; refine addNF_sound ПЃ (norm b) (norm a) }
  { assume a iha; simplify; rewrite iha;
    symmetry; rewrite (mulNF_sound ПЃ (Zneg H) (norm a)); refine zmul_neg1_l (denNF ПЃ (norm a)) }
  { assume c a iha; simplify; rewrite iha;
    symmetry; refine mulNF_sound ПЃ c (norm a) }
end;

opaque symbol reflect (ПЃ : рќ•ѓ int) (a b : LE) : ПЂ (norm a = norm b) в†’ ПЂ (den ПЃ a = den ПЃ b) в‰”
begin
  assume ПЃ a b h;
  rewrite norm_sound ПЃ a; rewrite norm_sound ПЃ b; rewrite h; reflexivity
end;
