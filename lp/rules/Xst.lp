// Existential quantification (┬зA.8) тАФ tuple-based encoding.
//
// PP traces emit only singleton existentials in practice (prv: every
// `#(x)` is arity-1), but we encode the compoundтЖФnested conversions
// XST1тАУ4 for completeness.
//
// As with ALL1тАУ4, we read `(x,y)` in the spec as "n-tuple x + 1-tuple
// y", so the rule peels one variable at a time. Unlike `!!`, `??` is
// a defined symbol that reduces to nested тИГ, so the compound and
// nested forms are *definitionally equal* тАФ XST1тАУ4 are identity in
// HOAS.

require open pp2lp.B pp2lp.Quant pp2lp.rules.Res;

// Helper: compound тЖТ nested for `??`. Defined by rewrite rule on
// the tuple constructor; pattern-match exposes (w ти╛ a) shape.
symbol compound_to_nested_тИГ [n] (P : Tuple (+1 n) тЖТ Prop)
  : ╬а v : Tuple (+1 n), ╧А (P v)
  тЖТ ╧А (`?? w : Tuple n, `?? y : Tuple 1, P (w ти╛ prj 0 y));
rule compound_to_nested_тИГ [$n] $P ($w ти╛ $a) $h тЖк
  pi_to_??_intro (╬╗ w', `?? y : Tuple 1, $P (w' ти╛ prj 0 y))
                 $w
                 (pi_to_??_intro (╬╗ y, $P ($w ти╛ prj 0 y))
                                 (unit ти╛ $a) $h);

// Helper: nested тЖТ compound for `??`.
opaque symbol nested_to_compound_тИГ [n] (P : Tuple (+1 n) тЖТ Prop)
  : ╧А (`?? w : Tuple n, `?? y : Tuple 1, P (w ти╛ prj 0 y))
  тЖТ ╧А (`?? v : Tuple (+1 n), P v) тЙФ
begin
  assume n P h;
  refine pi_to_??_elim
    (╬╗ w : Tuple n, `?? y : Tuple 1, P (w ти╛ prj 0 y))
    _ h;
  assume w hw;
  refine pi_to_??_elim (╬╗ y : Tuple 1, P (w ти╛ prj 0 y)) _ hw;
  assume y hy;
  refine pi_to_??_intro P (w ти╛ prj 0 y) hy
end;

// XST1: H тКв ┬м(тИГ(x,y)┬╖P) тЗТ R тЖТ H тКв ┬м(тИГx┬╖тИГy┬╖P) тЗТ R
opaque symbol XST1 [n] [P : Tuple (+1 n) тЖТ Prop] [R : Prop]
  : ╧А (┬м (`?? v : Tuple (+1 n), P v) тЗТ R)
  тЖТ ╧А (┬м (`?? w : Tuple n, `?? y : Tuple 1, P (w ти╛ prj 0 y)) тЗТ R) тЙФ
begin
  assume n P R h hnnested;
  refine h _;
  assume hcompound;
  refine hnnested _;
  refine pi_to_??_elim P _ hcompound;
  assume v hv;
  refine compound_to_nested_тИГ P v hv
end;

// XST2: H тКв ┬м(тИГ(x,y)┬╖P) тЖТ H тКв ┬м(тИГx┬╖тИГy┬╖P)
opaque symbol XST2 [n] [P : Tuple (+1 n) тЖТ Prop]
  : ╧А (┬м (`?? v : Tuple (+1 n), P v))
  тЖТ ╧А (┬м (`?? w : Tuple n, `?? y : Tuple 1, P (w ти╛ prj 0 y))) тЙФ
begin
  assume n P h hnested;
  refine h (nested_to_compound_тИГ P hnested)
end;

// XST3: H тКв (тИГ(x,y)┬╖P) тЗТ R тЖТ H тКв (тИГx┬╖тИГy┬╖P) тЗТ R
opaque symbol XST3 [n] [P : Tuple (+1 n) тЖТ Prop] [R : Prop]
  : ╧А ((`?? v : Tuple (+1 n), P v) тЗТ R)
  тЖТ ╧А ((`?? w : Tuple n, `?? y : Tuple 1, P (w ти╛ prj 0 y)) тЗТ R) тЙФ
begin
  assume n P R h hnested;
  refine h (nested_to_compound_тИГ P hnested)
end;

// XST4: H тКв тИГ(x,y)┬╖P тЖТ H тКв тИГx┬╖тИГy┬╖P
opaque symbol XST4 [n] [P : Tuple (+1 n) тЖТ Prop]
  : ╧А (`?? v : Tuple (+1 n), P v)
  тЖТ ╧А (`?? w : Tuple n, `?? y : Tuple 1, P (w ти╛ prj 0 y)) тЙФ
begin
  assume n P h;
  refine pi_to_??_elim P _ h;
  assume v hv;
  refine compound_to_nested_тИГ P v hv
end;

// ---- Negative side: ┬м(тИГ тАж) тЗТ R / ┬м(тИГ тАж) ----------------------

// XST5: H тКв (тИА-block, ┬мP) тЗТ R тЖТ H тКв ┬м(тИГ-block, P) тЗТ R

opaque symbol XST5 [n] [P : Tuple n тЖТ Prop] [R : Prop]
  : ╧А ((`!! v, ┬м (P v)) тЗТ R)
  тЖТ ╧А (┬м (`?? v, P v) тЗТ R) тЙФ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_!! (╬╗ v, ┬м (P v))
    (╬╗ v hpv, h2 (pi_to_??_intro P v hpv)))
end;

// XST51: H тКв (тИА-block, P) тЗТ R тЖТ H тКв ┬м(тИГ-block, ┬мP) тЗТ R

opaque symbol XST51 [n] [P : Tuple n тЖТ Prop] [R : Prop]
  : ╧А ((`!! v, P v) тЗТ R)
  тЖТ ╧А (┬м (`?? v, ┬м (P v)) тЗТ R) тЙФ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_!! P (╬╗ v,
    ┬м┬мтВС (P v) (╬╗ hnpv, h2 (pi_to_??_intro (╬╗ v, ┬м (P v)) v hnpv))))
end;

// XST6: H тКв тИА-block, ┬мP тЖТ H тКв ┬м(тИГ-block, P)

opaque symbol XST6 [n] [P : Tuple n тЖТ Prop]
  : ╧А (`!! v, ┬м (P v))
  тЖТ ╧А (┬м (`?? v, P v)) тЙФ
begin
  assume n P h1 h2;
  refine pi_to_??_elim P
    (╬╗ v hpv, !!_to_pi (╬╗ v, ┬м (P v)) h1 v hpv) h2
end;

// XST61: H тКв тИА-block, P тЖТ H тКв ┬м(тИГ-block, ┬мP)

opaque symbol XST61 [n] [P : Tuple n тЖТ Prop]
  : ╧А (`!! v, P v)
  тЖТ ╧А (┬м (`?? v, ┬м (P v))) тЙФ
begin
  assume n P h1 h2;
  refine pi_to_??_elim (╬╗ v, ┬м (P v))
    (╬╗ v hnpv, hnpv (!!_to_pi P h1 v)) h2
end;

// ---- Positive side: тИГ тАж тЗТ R / тИГ тАж ----------------------------

// XST7: H тКв тИА-block, P тЗТ R тЖТ H тКв (тИГ-block, P) тЗТ R
// "x not free in R" means R : Prop.

opaque symbol XST7 [n] [P : Tuple n тЖТ Prop] [R : Prop]
  : ╧А (`!! v, P v тЗТ R)
  тЖТ ╧А ((`?? v, P v) тЗТ R) тЙФ
begin
  assume n P R h1 h2;
  refine pi_to_??_elim P
    (╬╗ v hPv, !!_to_pi (╬╗ v, P v тЗТ R) h1 v hPv) h2
end;

// XST8: result-based тИГ-introduction.
//   premise 1: per-tuple Res chain ╧Б producing res_tm (╧Б v) for each v
//              (where each ╧Б v normalises ┬м(P v) to res_tm (╧Б v))
//   premise 2: ((`!! v, res_tm (╧Б v)) тЗТ тКе)
//   conclusion: (`?? v, P v)

opaque symbol XST8 [n] [P : Tuple n тЖТ Prop]
  (╧Б : ╬а v : Tuple n, Res (┬м (P v)))
  : ╧А ((`!! v, res_tm (╧Б v)) тЗТ тКе) тЖТ ╧А (`?? v, P v) тЙФ
begin
  assume n P ╧Б h_after;
  refine ┬м┬мтВС (`?? v, P v) _;
  assume hne;
  refine h_after (pi_to_!! (╬╗ v, res_tm (╧Б v)) (╬╗ v,
    =тЗТ (res_eq (╧Б v))
       (╬╗ hpv, hne (pi_to_??_intro P v hpv))))
end;

// ---- `_1` (Result-form) variants тАФ ┬з8.13 ----
//
// XST1тАУXST4: compoundтЖФnested conversions for `??` тАФ HOAS-identity at
// the value level; res_tm propagates via a trusted equality bridge.
// XST5тАУXST6 and XST51/XST61: Schema 1 passthrough.
// XST7_1: Schema 1 via the `xst7_eq` bridge.
// XST8_1: special тАФ chain-shaped, see below.

symbol XST1_1 [n] [P : Tuple (+1 n) тЖТ Prop] [R : Prop]
  (r : Res (┬м (`?? v : Tuple (+1 n), P v) тЗТ R))
  : Res (┬м (`?? w : Tuple n, `?? y : Tuple 1, P (w ти╛ prj 0 y)) тЗТ R)
  тЙФ mk_1 (res_tm r) trust;

symbol XST2_1 [n] [P : Tuple (+1 n) тЖТ Prop]
  (r : Res (┬м (`?? v : Tuple (+1 n), P v)))
  : Res (┬м (`?? w : Tuple n, `?? y : Tuple 1, P (w ти╛ prj 0 y)))
  тЙФ mk_1 (res_tm r) trust;

symbol XST3_1 [n] [P : Tuple (+1 n) тЖТ Prop] [R : Prop]
  (r : Res ((`?? v : Tuple (+1 n), P v) тЗТ R))
  : Res ((`?? w : Tuple n, `?? y : Tuple 1, P (w ти╛ prj 0 y)) тЗТ R)
  тЙФ mk_1 (res_tm r) trust;

symbol XST4_1 [n] [P : Tuple (+1 n) тЖТ Prop]
  (r : Res (`?? v : Tuple (+1 n), P v))
  : Res (`?? w : Tuple n, `?? y : Tuple 1, P (w ти╛ prj 0 y))
  тЙФ mk_1 (res_tm r) trust;

symbol XST5_1 [n] [P : Tuple n тЖТ Prop] [R : Prop]
  (r : Res ((`!! v, ┬м (P v)) тЗТ R))
  : Res (┬м (`?? v, P v) тЗТ R)
  тЙФ mk_1 (res_tm r) trust;

symbol XST51_1 [n] [P : Tuple n тЖТ Prop] [R : Prop]
  (r : Res ((`!! v, P v) тЗТ R))
  : Res (┬м (`?? v, ┬м (P v)) тЗТ R)
  тЙФ mk_1 (res_tm r) trust;

symbol XST6_1 [n] [P : Tuple n тЖТ Prop]
  (r : Res (`!! v, ┬м (P v)))
  : Res (┬м (`?? v, P v))
  тЙФ mk_1 (res_tm r) trust;

symbol XST61_1 [n] [P : Tuple n тЖТ Prop]
  (r : Res (`!! v, P v))
  : Res (┬м (`?? v, ┬м (P v)))
  тЙФ mk_1 (res_tm r) trust;

// XST7_1: (тИГ-block, P) тЗТ R via (тИА-block, P тЗТ R).
symbol XST7_1 [n] [P : Tuple n тЖТ Prop] [R : Prop]
  (r : Res (`!! v, P v тЗТ R)) : Res ((`?? v, P v) тЗТ R)
  тЙФ mk_1 (res_tm r) (eq_trans xst7_eq (res_eq r));

// XST8_1 (XST8'): result-form тИГ-introduction, mirroring XST8 (cf. ALL7_1).
// Per-tuple Res chain ╧Б (normalising ┬м(P v)) + continuation r packaging
// ((`!! v, res_tm (╧Б v)) тЗТ тКе).  The chain emitter supplies ╧Б under the
// bound v, so ╧Б is non-trivial in general (not the identity the old
// 1-argument form assumed).
symbol XST8_1 [n] [P : Tuple n тЖТ Prop]
  (╧Б : ╬а v : Tuple n, Res (┬м (P v)))
  (r : Res ((`!! v, res_tm (╧Б v)) тЗТ тКе)) : Res (`?? v, P v) тЙФ
begin
  assume n P ╧Б r;
  refine mk_1 (res_tm r) _;
  have h1 : ╧А ((`?? v, P v) = ((`!! v, res_tm (╧Б v)) тЗТ тКе))
    { refine eq_trans (@xst8_eq n P) (imp_cong_l (!!_cong (╬╗ v, res_eq (╧Б v)))) };
  refine eq_trans h1 (res_eq r)
end;
