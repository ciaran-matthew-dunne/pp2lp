// Existential quantification (¬ІA.8) вАФ shallow encoding
//
// With HOAS:
// - Variable renaming (XST7f, XST8f) collapses into XST7, XST8.
// - Compound variables (XST1-4) don't exist; nested вИГ IS
//   the only form. The OCaml emitter should skip XST1-4.
require open pp2lp.B;

// ---- Identity rules (compound variable flattening) ----
//
// XST7f, XST8f: Variable renaming variants of XST7, XST8.
//   In HOAS, ќ±-equivalence is automatic, so these collapse
//   into their base forms.

// XST1: ¬ђ(вИГ(x,y)¬ЈP) вЗТ R вЖТ ¬ђ(вИГx¬ЈвИГy¬ЈP) вЗТ R (identity in HOAS)
opaque symbol XST1 [P : ѕД ќє вЖТ ѕД ќє вЖТ Prop] [R : Prop] (nf : ѕА вК§)
  : ѕА (¬ђ (`вИГ x, `вИГ y, P x y) вЗТ R)
  вЖТ ѕА (¬ђ (`вИГ x, `вИГ y, P x y) вЗТ R) вЙФ
begin assume P R nf h; refine h end;

// XST2: вИГ(x,y)¬ЈP вЗТ R вЖТ вИГx¬ЈвИГy¬ЈP вЗТ R (identity in HOAS)
opaque symbol XST2 [P : ѕД ќє вЖТ ѕД ќє вЖТ Prop] [R : Prop] (nf : ѕА вК§)
  : ѕА ((`вИГ x, `вИГ y, P x y) вЗТ R)
  вЖТ ѕА ((`вИГ x, `вИГ y, P x y) вЗТ R) вЙФ
begin assume P R nf h; refine h end;

// XST3: Compound вИГ flattening (identity in HOAS).
// Used both with and without вИІ context.
opaque symbol XST3 [P : ѕД ќє вЖТ ѕД ќє вЖТ Prop] [R : Prop] (nf : ѕА вК§)
  : ѕА ((`вИГ x, `вИГ y, P x y) вЗТ R)
  вЖТ ѕА ((`вИГ x, `вИГ y, P x y) вЗТ R) вЙФ
begin assume P R nf h; refine h end;

opaque symbol XST4 [P : ѕД ќє вЖТ ѕД ќє вЖТ Prop](nf : ѕА вК§)
  : ѕА (`вИГ x, `вИГ y, P x y)
  вЖТ ѕА (`вИГ x, `вИГ y, P x y) вЙФ
begin assume P nf h; refine h end;

// ---- Base rules ----

// XST5: H вКҐ (вИАx¬Ј¬ђP) вЗТ R вЖТ H вКҐ ¬ђ(вИГx¬ЈP) вЗТ R
opaque symbol XST5 [P : ѕД ќє вЖТ Prop] [R : Prop]
  : ѕА ((`вИА x, ¬ђ (P x)) вЗТ R)
  вЖТ ѕА (¬ђ (`вИГ x, P x) вЗТ R) вЙФ
begin
  assume P R h1 h2;
  refine h1 (ќї x hpx, h2 (вИГбµҐ x hpx))
end;

// XST5_2: Two-variable version. H вКҐ (вИАx y¬Ј¬ђP) вЗТ R вЖТ H вКҐ ¬ђ(вИГx¬ЈвИГy¬ЈP) вЗТ R
opaque symbol XST5_2 [P : ѕД ќє вЖТ ѕД ќє вЖТ Prop] [R : Prop]
  : ѕА ((`вИА x, `вИА y, ¬ђ (P x y)) вЗТ R)
  вЖТ ѕА (¬ђ (`вИГ x, `вИГ y, P x y) вЗТ R) вЙФ
begin
  assume P R h1 h2;
  refine h1 (ќї x y hpxy, h2 (вИГбµҐ x (вИГбµҐ y hpxy)))
end;

// XST51: H вКҐ (вИАx¬ЈP) вЗТ R вЖТ H вКҐ ¬ђ(вИГx¬Ј¬ђP) вЗТ R
opaque symbol XST51 [P : ѕД ќє вЖТ Prop] [R : Prop]
  : ѕА ((`вИА x, P x) вЗТ R)
  вЖТ ѕА (¬ђ (`вИГ x, ¬ђ (P x)) вЗТ R) вЙФ
begin
  assume P R h1 h2;
  refine h1 (ќї x, ¬ђ¬ђвВС (P x) (ќї hnpx, h2 (вИГбµҐ x hnpx)))
end;

// XST6: H вКҐ вИАx¬Ј¬ђP вЖТ H вКҐ ¬ђ(вИГx¬ЈP)
opaque symbol XST6 [P : ѕД ќє вЖТ Prop]
  : ѕА (`вИА x, ¬ђ (P x))
  вЖТ ѕА (¬ђ (`вИГ x, P x)) вЙФ
begin
  assume P h1 h2;
  refine вИГвВС h2 (ќї x hpx, h1 x hpx)
end;

// XST61: H вКҐ вИАx¬ЈP вЖТ H вКҐ ¬ђ(вИГx¬Ј¬ђP)
// XST6_2: Two-variable version.
opaque symbol XST6_2 [P : ѕД ќє вЖТ ѕД ќє вЖТ Prop]
  : ѕА (`вИА x, `вИА y, ¬ђ (P x y))
  вЖТ ѕА (¬ђ (`вИГ x, `вИГ y, P x y)) вЙФ
begin
  assume P h1 h2;
  refine вИГвВС h2 (ќї x hx, вИГвВС hx (ќї y hpxy, h1 x y hpxy))
end;

opaque symbol XST61 [P : ѕД ќє вЖТ Prop]
  : ѕА (`вИА x, P x)
  вЖТ ѕА (¬ђ (`вИГ x, ¬ђ (P x))) вЙФ
begin
  assume P h1 h2;
  refine вИГвВС h2 (ќї x hnpx, hnpx (h1 x))
end;

// XST7: x not free in R; H вКҐ вИАx¬Ј(P вЗТ R) вЖТ H вКҐ (вИГx¬ЈP) вЗТ R
// "x not free in R" means R : Prop (not ѕД ќє вЖТ Prop).
opaque symbol XST7 [P : ѕД ќє вЖТ Prop] [R : Prop]
  : ѕА (`вИА x, P x вЗТ R)
  вЖТ ѕА ((`вИГ x, P x) вЗТ R) вЙФ
begin
  assume P R h1 h2;
  refine вИГвВС h2 h1
end;

// XST8: x not free in H; (H вКҐ ¬ђP) вЗЭ R; H вКҐ (вИАx¬ЈR) вЗТ FALSE вЖТ H вКҐ вИГx¬ЈP
// First premise: ¬ђP(x) = R(x) for all x (equality-based normalisation result).
// Second premise: (вИАx R(x)) вЗТ вК•.
opaque symbol XST8 [P : ѕД ќє вЖТ Prop] (R : ѕД ќє вЖТ Prop)
  : ѕА (`вИА x, ¬ђ (P x) = R x)
  вЖТ ѕА ((`вИА x, R x) вЗТ вК•)
  вЖТ ѕА (`вИГ x, P x) вЙФ
begin
  assume P R h1 h2;
  refine ¬ђ¬ђвВС (`вИГ x, P x) _;
  assume hne;
  refine h2 (ќї x, =вЗТ (h1 x) (ќї hpx, hne (вИГбµҐ x hpx)))
end;

// XST8_2: Two-variable version for compound вИГ(x,y).
opaque symbol XST8_2 [P : ѕД ќє вЖТ ѕД ќє вЖТ Prop] (R : ѕД ќє вЖТ ѕД ќє вЖТ Prop)
  : ѕА (`вИА x, `вИА y, ¬ђ (P x y) = R x y)
  вЖТ ѕА ((`вИА x, `вИА y, R x y) вЗТ вК•)
  вЖТ ѕА (`вИГ x, `вИГ y, P x y) вЙФ
begin
  assume P R h1 h2;
  refine ¬ђ¬ђвВС (`вИГ x, `вИГ y, P x y) _;
  assume hne;
  refine h2 (ќї x y, =вЗТ (h1 x y) (ќї hpxy, hne (вИГбµҐ x (вИГбµҐ y hpxy))))
end;

// ---- Primed variants (equality-based) ----

// XST7_1: pass-through. (вИГx.P(x))вЗТR = (вИАx.P(x)вЗТR).
opaque symbol XST7_1 [P : ѕД ќє вЖТ Prop] [R : Prop] [S : Prop]
  : ѕА (((`вИА x, P x вЗТ R)) = S)
  вЖТ ѕА (((`вИГ x, P x) вЗТ R) = S) вЙФ
begin
  assume P R S h;
  have eq : ѕА (((`вИГ x, P x) вЗТ R) = (`вИА x, P x вЗТ R))
    { refine propExt _ _ _ _
      { assume h1 x hpx; refine h1 (вИГбµҐ x hpx) }
      { assume h1 hex; refine вИГвВС hex h1 } };
  rewrite eq; refine h
end;
