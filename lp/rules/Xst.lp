// Existential quantification (¬ІA.8) вАФ tuple-based encoding.
//
// PP traces emit only singleton existentials in practice (prv: every
// `#(x)` is arity-1), but we encode the compoundвЖФnested conversions
// XST1вАУ4 for completeness.
//
// As with ALL1вАУ4, we read `(x,y)` in the spec as "n-tuple x + 1-tuple
// y", so the rule peels one variable at a time. Unlike `!!`, `??` is
// a defined symbol that reduces to nested вИГ, so the compound and
// nested forms are *definitionally equal* вАФ XST1вАУ4 are identity in
// HOAS.

require open pp2lp.B pp2lp.Quant pp2lp.rules.Res;

// Helper: compound вЖТ nested for `??`. Defined by rewrite rule on
// the tuple constructor; pattern-match exposes (w в®Њ a) shape.
symbol compound_to_nested_вИГ [n] (P : Tuple (+1 n) вЖТ Prop)
  : ќ† v : Tuple (+1 n), ѕА (P v)
  вЖТ ѕА (`?? w : Tuple n, `?? y : Tuple 1, P (w в®Њ prj 0 y));
rule compound_to_nested_вИГ [$n] $P ($w в®Њ $a) $h вЖ™
  pi_to_??_intro (ќї w', `?? y : Tuple 1, $P (w' в®Њ prj 0 y))
                 $w
                 (pi_to_??_intro (ќї y, $P ($w в®Њ prj 0 y))
                                 (unit в®Њ $a) $h);

// Helper: nested вЖТ compound for `??`.
opaque symbol nested_to_compound_вИГ [n] (P : Tuple (+1 n) вЖТ Prop)
  : ѕА (`?? w : Tuple n, `?? y : Tuple 1, P (w в®Њ prj 0 y))
  вЖТ ѕА (`?? v : Tuple (+1 n), P v) вЙФ
begin
  assume n P h;
  refine pi_to_??_elim
    (ќї w : Tuple n, `?? y : Tuple 1, P (w в®Њ prj 0 y))
    _ h;
  assume w hw;
  refine pi_to_??_elim (ќї y : Tuple 1, P (w в®Њ prj 0 y)) _ hw;
  assume y hy;
  refine pi_to_??_intro P (w в®Њ prj 0 y) hy
end;

// XST1: H вКҐ ¬ђ(вИГ(x,y)¬ЈP) вЗТ R вЖТ H вКҐ ¬ђ(вИГx¬ЈвИГy¬ЈP) вЗТ R
opaque symbol XST1 [n] [P : Tuple (+1 n) вЖТ Prop] [R : Prop]
  : ѕА (¬ђ (`?? v : Tuple (+1 n), P v) вЗТ R)
  вЖТ ѕА (¬ђ (`?? w : Tuple n, `?? y : Tuple 1, P (w в®Њ prj 0 y)) вЗТ R) вЙФ
begin
  assume n P R h hnnested;
  refine h _;
  assume hcompound;
  refine hnnested _;
  refine pi_to_??_elim P _ hcompound;
  assume v hv;
  refine compound_to_nested_вИГ P v hv
end;

// XST2: H вКҐ ¬ђ(вИГ(x,y)¬ЈP) вЖТ H вКҐ ¬ђ(вИГx¬ЈвИГy¬ЈP)
opaque symbol XST2 [n] [P : Tuple (+1 n) вЖТ Prop]
  : ѕА (¬ђ (`?? v : Tuple (+1 n), P v))
  вЖТ ѕА (¬ђ (`?? w : Tuple n, `?? y : Tuple 1, P (w в®Њ prj 0 y))) вЙФ
begin
  assume n P h hnested;
  refine h (nested_to_compound_вИГ P hnested)
end;

// XST3: H вКҐ (вИГ(x,y)¬ЈP) вЗТ R вЖТ H вКҐ (вИГx¬ЈвИГy¬ЈP) вЗТ R
opaque symbol XST3 [n] [P : Tuple (+1 n) вЖТ Prop] [R : Prop]
  : ѕА ((`?? v : Tuple (+1 n), P v) вЗТ R)
  вЖТ ѕА ((`?? w : Tuple n, `?? y : Tuple 1, P (w в®Њ prj 0 y)) вЗТ R) вЙФ
begin
  assume n P R h hnested;
  refine h (nested_to_compound_вИГ P hnested)
end;

// XST4: H вКҐ вИГ(x,y)¬ЈP вЖТ H вКҐ вИГx¬ЈвИГy¬ЈP
opaque symbol XST4 [n] [P : Tuple (+1 n) вЖТ Prop]
  : ѕА (`?? v : Tuple (+1 n), P v)
  вЖТ ѕА (`?? w : Tuple n, `?? y : Tuple 1, P (w в®Њ prj 0 y)) вЙФ
begin
  assume n P h;
  refine pi_to_??_elim P _ h;
  assume v hv;
  refine compound_to_nested_вИГ P v hv
end;

// ---- Negative side: ¬ђ(вИГ вА¶) вЗТ R / ¬ђ(вИГ вА¶) ----------------------

// XST5: H вКҐ (вИА-block, ¬ђP) вЗТ R вЖТ H вКҐ ¬ђ(вИГ-block, P) вЗТ R

opaque symbol XST5 [n] [P : Tuple n вЖТ Prop] [R : Prop]
  : ѕА ((`!! v, ¬ђ (P v)) вЗТ R)
  вЖТ ѕА (¬ђ (`?? v, P v) вЗТ R) вЙФ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_!! (ќї v, ¬ђ (P v))
    (ќї v hpv, h2 (pi_to_??_intro P v hpv)))
end;

// XST51: H вКҐ (вИА-block, P) вЗТ R вЖТ H вКҐ ¬ђ(вИГ-block, ¬ђP) вЗТ R

opaque symbol XST51 [n] [P : Tuple n вЖТ Prop] [R : Prop]
  : ѕА ((`!! v, P v) вЗТ R)
  вЖТ ѕА (¬ђ (`?? v, ¬ђ (P v)) вЗТ R) вЙФ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_!! P (ќї v,
    ¬ђ¬ђвВС (P v) (ќї hnpv, h2 (pi_to_??_intro (ќї v, ¬ђ (P v)) v hnpv))))
end;

// XST6: H вКҐ вИА-block, ¬ђP вЖТ H вКҐ ¬ђ(вИГ-block, P)

opaque symbol XST6 [n] [P : Tuple n вЖТ Prop]
  : ѕА (`!! v, ¬ђ (P v))
  вЖТ ѕА (¬ђ (`?? v, P v)) вЙФ
begin
  assume n P h1 h2;
  refine pi_to_??_elim P
    (ќї v hpv, !!_to_pi (ќї v, ¬ђ (P v)) h1 v hpv) h2
end;

// XST61: H вКҐ вИА-block, P вЖТ H вКҐ ¬ђ(вИГ-block, ¬ђP)

opaque symbol XST61 [n] [P : Tuple n вЖТ Prop]
  : ѕА (`!! v, P v)
  вЖТ ѕА (¬ђ (`?? v, ¬ђ (P v))) вЙФ
begin
  assume n P h1 h2;
  refine pi_to_??_elim (ќї v, ¬ђ (P v))
    (ќї v hnpv, hnpv (!!_to_pi P h1 v)) h2
end;

// ---- Positive side: вИГ вА¶ вЗТ R / вИГ вА¶ ----------------------------

// XST7: H вКҐ вИА-block, P вЗТ R вЖТ H вКҐ (вИГ-block, P) вЗТ R
// "x not free in R" means R : Prop.

opaque symbol XST7 [n] [P : Tuple n вЖТ Prop] [R : Prop]
  : ѕА (`!! v, P v вЗТ R)
  вЖТ ѕА ((`?? v, P v) вЗТ R) вЙФ
begin
  assume n P R h1 h2;
  refine pi_to_??_elim P
    (ќї v hPv, !!_to_pi (ќї v, P v вЗТ R) h1 v hPv) h2
end;

// XST8: result-based вИГ-introduction.
//   premise 1: per-tuple Res chain ѕБ producing res_tm (ѕБ v) for each v
//              (where each ѕБ v normalises ¬ђ(P v) to res_tm (ѕБ v))
//   premise 2: ((`!! v, res_tm (ѕБ v)) вЗТ вК•)
//   conclusion: (`?? v, P v)

opaque symbol XST8 [n] [P : Tuple n вЖТ Prop]
  (ѕБ : ќ† v : Tuple n, Res (¬ђ (P v)))
  : ѕА ((`!! v, res_tm (ѕБ v)) вЗТ вК•) вЖТ ѕА (`?? v, P v) вЙФ
begin
  assume n P ѕБ h_after;
  refine ¬ђ¬ђвВС (`?? v, P v) _;
  assume hne;
  refine h_after (pi_to_!! (ќї v, res_tm (ѕБ v)) (ќї v,
    =вЗТ (res_eq (ѕБ v))
       (ќї hpv, hne (pi_to_??_intro P v hpv))))
end;

// ---- `_1` (Result-form) variants вАФ ¬І8.13 ----
//
// XST1вАУXST4: compoundвЖФnested conversions for `??` вАФ HOAS-identity at
// the value level; res_tm propagates via a trusted equality bridge.
// XST5вАУXST6 and XST51/XST61: Schema 1 passthrough.
// XST7_1: Schema 1 via the `xst7_eq` bridge.
// XST8_1: special вАФ chain-shaped, see below.

symbol XST1_1 [n] [P : Tuple (+1 n) вЖТ Prop] [R : Prop]
  (r : Res (¬ђ (`?? v : Tuple (+1 n), P v) вЗТ R))
  : Res (¬ђ (`?? w : Tuple n, `?? y : Tuple 1, P (w в®Њ prj 0 y)) вЗТ R)
  вЙФ mk_1 (res_tm r) trust;

symbol XST2_1 [n] [P : Tuple (+1 n) вЖТ Prop]
  (r : Res (¬ђ (`?? v : Tuple (+1 n), P v)))
  : Res (¬ђ (`?? w : Tuple n, `?? y : Tuple 1, P (w в®Њ prj 0 y)))
  вЙФ mk_1 (res_tm r) trust;

symbol XST3_1 [n] [P : Tuple (+1 n) вЖТ Prop] [R : Prop]
  (r : Res ((`?? v : Tuple (+1 n), P v) вЗТ R))
  : Res ((`?? w : Tuple n, `?? y : Tuple 1, P (w в®Њ prj 0 y)) вЗТ R)
  вЙФ mk_1 (res_tm r) trust;

symbol XST4_1 [n] [P : Tuple (+1 n) вЖТ Prop]
  (r : Res (`?? v : Tuple (+1 n), P v))
  : Res (`?? w : Tuple n, `?? y : Tuple 1, P (w в®Њ prj 0 y))
  вЙФ mk_1 (res_tm r) trust;

symbol XST5_1 [n] [P : Tuple n вЖТ Prop] [R : Prop]
  (r : Res ((`!! v, ¬ђ (P v)) вЗТ R))
  : Res (¬ђ (`?? v, P v) вЗТ R)
  вЙФ mk_1 (res_tm r) (eq_trans (imp_cong_l xst6_eq) (res_eq r));

symbol XST51_1 [n] [P : Tuple n вЖТ Prop] [R : Prop]
  (r : Res ((`!! v, P v) вЗТ R))
  : Res (¬ђ (`?? v, ¬ђ (P v)) вЗТ R)
  вЙФ mk_1 (res_tm r) (eq_trans (imp_cong_l xst61_eq) (res_eq r));

symbol XST6_1 [n] [P : Tuple n вЖТ Prop]
  (r : Res (`!! v, ¬ђ (P v)))
  : Res (¬ђ (`?? v, P v))
  вЙФ mk_1 (res_tm r) (eq_trans xst6_eq (res_eq r));

symbol XST61_1 [n] [P : Tuple n вЖТ Prop]
  (r : Res (`!! v, P v))
  : Res (¬ђ (`?? v, ¬ђ (P v)))
  вЙФ mk_1 (res_tm r) (eq_trans xst61_eq (res_eq r));

// XST7_1: (вИГ-block, P) вЗТ R via (вИА-block, P вЗТ R).
symbol XST7_1 [n] [P : Tuple n вЖТ Prop] [R : Prop]
  (r : Res (`!! v, P v вЗТ R)) : Res ((`?? v, P v) вЗТ R)
  вЙФ mk_1 (res_tm r) (eq_trans xst7_eq (res_eq r));

// XST8_1 (XST8'): result-form вИГ-introduction, mirroring XST8 (cf. ALL7_1).
// Per-tuple Res chain ѕБ (normalising ¬ђ(P v)) + continuation r packaging
// ((`!! v, res_tm (ѕБ v)) вЗТ вК•).  The chain emitter supplies ѕБ under the
// bound v, so ѕБ is non-trivial in general (not the identity the old
// 1-argument form assumed).
symbol XST8_1 [n] [P : Tuple n вЖТ Prop]
  (ѕБ : ќ† v : Tuple n, Res (¬ђ (P v)))
  (r : Res ((`!! v, res_tm (ѕБ v)) вЗТ вК•)) : Res (`?? v, P v) вЙФ
begin
  assume n P ѕБ r;
  refine mk_1 (res_tm r) _;
  have h1 : ѕА ((`?? v, P v) = ((`!! v, res_tm (ѕБ v)) вЗТ вК•))
    { refine eq_trans (@xst8_eq n P) (imp_cong_l (!!_cong (ќї v, res_eq (ѕБ v)))) };
  refine eq_trans h1 (res_eq r)
end;
