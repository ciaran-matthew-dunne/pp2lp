// Implication (┬ДA.3) Рђћ shallow encoding
require open pp2lp.B pp2lp.lemmas.Int pp2lp.lemmas.ConjList pp2lp.lemmas.Tuple pp2lp.rules.Res;

// ---- Base rules ----

// IMP1: H Ріб P РЄњ (┬гQ РЄњ R) Рєњ H Ріб ┬г(P РЄњ Q) РЄњ R
opaque symbol IMP1 [P Q R]
  : ¤ђ (P РЄњ (┬г Q РЄњ R))
  Рєњ ¤ђ (┬г (P РЄњ Q) РЄњ R) РЅћ
begin
  assume P Q R h1 h2;
  have hp : ¤ђ P {
    refine ┬г┬гРѓЉ P _;
    assume hnp;
    refine h2 (╬╗ p, РіЦРѓЉ (hnp p))
  };
  have hnq : ¤ђ (┬г Q) {
    assume hq;
    refine h2 (╬╗ _, hq)
  };
  refine h1 hp hnq
end;

// IMP2: H Ріб ┬гQ; H Ріб P Рєњ H Ріб ┬г(P РЄњ Q)
opaque symbol IMP2 [P Q]
  : ¤ђ (┬г Q)
  Рєњ ¤ђ P
  Рєњ ¤ђ (┬г (P РЄњ Q)) РЅћ
begin
  assume P Q hnq hp hpq;
  refine hnq (hpq hp)
end;

// IMP3: H Ріб Q РЄњ R; H Ріб ┬гP РЄњ R Рєњ H Ріб (P РЄњ Q) РЄњ R
opaque symbol IMP3 [P Q R]
  : ¤ђ (Q РЄњ R)
  Рєњ ¤ђ (┬г P РЄњ R)
  Рєњ ¤ђ ((P РЄњ Q) РЄњ R) РЅћ
begin
  assume P Q R hqr hnpr hpq;
  refine РѕеРѓЉ (em P) _ _ {
    assume hp; refine hqr (hpq hp)
  } {
    assume hnp; refine hnpr hnp
  }
end;

// IMP4: H, P Ріб Q Рєњ H Ріб P РЄњ Q
opaque symbol IMP4 [P Q]
  : (¤ђ P Рєњ ¤ђ Q)
  Рєњ ¤ђ (P РЄњ Q) РЅћ
begin
  assume P Q h; refine h
end;

// IMP5: P is in H; H Ріб Q Рєњ H Ріб P РЄњ Q
opaque symbol IMP5 [P Q]
  : ¤ђ Q
  Рєњ ¤ђ (P РЄњ Q) РЅћ
begin
  assume P Q hq hp; refine hq
end;

// ---- `_1` (Result-form) variants Рђћ ┬Д8.13 ----

// IMP1_1: Schema 1 Рђћ passthrough.  Preserve the child's РІђ-list (`mk_res (res_ts r)`
// rather than collapsing to the singleton `mk_1 (res_tm r)`): when this result
// feeds an outer IMP3_1/IMP2_1 `concat`, the list must stay flat so a РЅЦ3-conjunct
// cascade body becomes `РІђ(РѕјРѕиAРѕиBРѕиC)`, not `РІђ(РѕјРѕиAРѕи(BРѕДC))` Рђћ the latter mis-associates
// the continuation's NRM7 snoc-peel.  `res_tm` is unchanged (singleton-collapse),
// so the proof term and every res_tm-consuming use site are identical.
symbol IMP1_1 [P Q R : Prop]
  (r : Res (P РЄњ ┬г Q РЄњ R)) : Res (┬г (P РЄњ Q) РЄњ R)
  РЅћ mk_res (res_ts r) (eq_trans imp1_eq (res_eq r));

// IMP2_1: Schema 2 Рђћ combine.
symbol IMP2_1 [P Q : Prop]
  (r1 : Res (┬г Q)) (r2 : Res P) : Res (┬г (P РЄњ Q))
  РЅћ mk_res (concat (res_ts r1) (res_ts r2))
      (eq_trans imp2_eq
        (eq_trans (conj_eq (res_eq r1) (res_eq r2))
                  (conj_concat_eq (res_ts r1) (res_ts r2))));

// IMP3_1: Schema 2 Рђћ combine.
symbol IMP3_1 [P Q R : Prop]
  (r1 : Res (Q РЄњ R)) (r2 : Res (┬г P РЄњ R))
  : Res ((P РЄњ Q) РЄњ R)
  РЅћ mk_res (concat (res_ts r1) (res_ts r2))
      (eq_trans imp3_eq
        (eq_trans (conj_eq (res_eq r1) (res_eq r2))
                  (conj_concat_eq (res_ts r1) (res_ts r2))));

// IMP4_1: special case Рђћ result is P РЄњ R (the antecedent prepended to
// the child's result).
symbol IMP4_1 [P Q : Prop]
  (r : Res Q) : Res (P РЄњ Q)
  РЅћ mk_1 (P РЄњ res_tm r) (imp_cong_r (res_eq r));

// IMP4_1U: IMP4_1 whose child chain uses the antecedent Рђћ PP holds the assumed
// antecedent in its hypothesis store, so a chain-local AXM3_1 discharges a
// conjunct equal to it.  Take the child as the *equality under the hypothesis*
// `¤ђ P Рєњ ¤ђ (Q = R)`; `imp_cong_r_under` lifts it to the unconditional
// implication equality.  R (the child's result) is inferred: it is
// `conj (res_ts (child hp))`, and `res_ts` reduces through the `mk_0`/`concat`
// structure without touching `hp`, so it closes to a hypothesis-free formula.
symbol IMP4_1U [P Q R : Prop]
  (f : ¤ђ P Рєњ ¤ђ (Q = R)) : Res (P РЄњ Q)
  РЅћ mk_1 (P РЄњ R) (imp_cong_r_under f);

// IMP5_1: strip a known antecedent (hp : ¤ђ P) Рђћ collapses the РЄњ.
symbol IMP5_1 [P Q : Prop]
  (hp : ¤ђ P) (r : Res Q) : Res (P РЄњ Q)
  РЅћ mk_1 (res_tm r) (eq_trans (imp_known_drop hp) (res_eq r));
