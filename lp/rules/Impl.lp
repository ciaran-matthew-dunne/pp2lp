// Implication (¬ІA.3) вАФ shallow encoding
require open pp2lp.B;

// ---- Base rules ----

// IMP1: H вКҐ P вЗТ (¬ђQ вЗТ R) вЖТ H вКҐ ¬ђ(P вЗТ Q) вЗТ R
opaque symbol IMP1 [P Q R]
  : ѕА (P вЗТ (¬ђ Q вЗТ R))
  вЖТ ѕА (¬ђ (P вЗТ Q) вЗТ R) вЙФ
begin
  assume P Q R h1 h2;
  have hp : ѕА P {
    refine ¬ђ¬ђвВС P _;
    assume hnp;
    refine h2 (ќї p, вК•вВС (hnp p))
  };
  have hnq : ѕА (¬ђ Q) {
    assume hq;
    refine h2 (ќї _, hq)
  };
  refine h1 hp hnq
end;

// IMP2: H вКҐ ¬ђQ; H вКҐ P вЖТ H вКҐ ¬ђ(P вЗТ Q)
opaque symbol IMP2 [P Q]
  : ѕА (¬ђ Q)
  вЖТ ѕА P
  вЖТ ѕА (¬ђ (P вЗТ Q)) вЙФ
begin
  assume P Q hnq hp hpq;
  refine hnq (hpq hp)
end;

// IMP3: H вКҐ Q вЗТ R; H вКҐ ¬ђP вЗТ R вЖТ H вКҐ (P вЗТ Q) вЗТ R
opaque symbol IMP3 [P Q R]
  : ѕА (Q вЗТ R)
  вЖТ ѕА (¬ђ P вЗТ R)
  вЖТ ѕА ((P вЗТ Q) вЗТ R) вЙФ
begin
  assume P Q R hqr hnpr hpq;
  refine вИ®вВС (em P) _ _ {
    assume hp; refine hqr (hpq hp)
  } {
    assume hnp; refine hnpr hnp
  }
end;

// IMP4: H, P вКҐ Q вЖТ H вКҐ P вЗТ Q
opaque symbol IMP4 [P Q]
  : (ѕА P вЖТ ѕА Q)
  вЖТ ѕА (P вЗТ Q) вЙФ
begin
  assume P Q h; refine h
end;

// IMP5: P is in H; H вКҐ Q вЖТ H вКҐ P вЗТ Q
opaque symbol IMP5 [P Q]
  : ѕА Q
  вЖТ ѕА (P вЗТ Q) вЙФ
begin
  assume P Q hq hp; refine hq
end;

// ---- Primed variants (equality-based) ----

// IMP1_1: pass-through. ¬ђ(PвЗТQ)вЗТR = PвЗТ(¬ђQвЗТR).
opaque symbol IMP1_1 [P Q R S : Prop]
  : ѕА ((P вЗТ (¬ђ Q вЗТ R)) = S)
  вЖТ ѕА ((¬ђ (P вЗТ Q) вЗТ R) = S) вЙФ
begin
  assume P Q R S h;
  have eq : ѕА ((¬ђ (P вЗТ Q) вЗТ R) = (P вЗТ (¬ђ Q вЗТ R)))
    { rewrite ¬ђвЗТ=вИІ¬ђ;
      refine propExt _ _ _ _
      { assume h1 hp hnq; refine h1 (вИІбµҐ hp hnq) }
      { assume h1 h2; refine h1 (вИІвВСвВБ h2) (вИІвВСвВВ h2) } };
  rewrite eq; refine h
end;

// IMP2_1: multi-premise. ¬ђ(PвЗТQ) = ¬ђQ вИІ P.
opaque symbol IMP2_1 [P Q S1 S2 : Prop]
  : ѕА (¬ђ Q = S1)
  вЖТ ѕА (P = S2)
  вЖТ ѕА (¬ђ (P вЗТ Q) = (S1 вИІ S2)) вЙФ
begin
  assume P Q S1 S2 h1 h2;
  rewrite ¬ђвЗТ=вИІ¬ђ;
  have eq : ѕА ((P вИІ ¬ђ Q) = (¬ђ Q вИІ P))
    { refine вИІ_com P (¬ђ Q) };
  rewrite eq; rewrite h1; rewrite h2; reflexivity
end;

// IMP3_1: multi-premise. (PвЗТQ)вЗТR = (QвЗТR) вИІ (¬ђPвЗТR).
opaque symbol IMP3_1 [P Q R S1 S2 : Prop]
  : ѕА ((Q вЗТ R) = S1)
  вЖТ ѕА ((¬ђ P вЗТ R) = S2)
  вЖТ ѕА (((P вЗТ Q) вЗТ R) = (S1 вИІ S2)) вЙФ
begin
  assume P Q R S1 S2 h1 h2;
  have eq : ѕА (((P вЗТ Q) вЗТ R) = ((Q вЗТ R) вИІ (¬ђ P вЗТ R)))
    { refine propExt _ _ _ _
      { assume h; refine вИІбµҐ
        (ќї hq, h (ќї _, hq))
        (ќї hnp, h (ќї hp, вК•вВС (hnp hp))) }
      { assume h hpq; refine вИ®вВС (em P) _ _
        { assume hp; refine вИІвВСвВБ h (hpq hp) }
        { assume hnp; refine вИІвВСвВВ h hnp } } };
  rewrite eq; rewrite h1; rewrite h2; reflexivity
end;

// IMP4_1: structural. (PвЗТQ) = (PвЗТR) from Q = R under hypothesis P.
opaque symbol IMP4_1 [P Q R : Prop]
  : (ѕА P вЖТ ѕА (Q = R))
  вЖТ ѕА ((P вЗТ Q) = (P вЗТ R)) вЙФ
begin
  assume P Q R h;
  refine propExt _ _ _ _
    { assume h1 hp; refine =вЗТ (h hp) (h1 hp) }
    { assume h1 hp; refine =вЗТ (eq_sym (h hp)) (h1 hp) }
end;

// IMP5_1: pass-through. PвЗТQ from Q (P is known).
opaque symbol IMP5_1 [P Q S : Prop]
  : ѕА P
  вЖТ ѕА (Q = S)
  вЖТ ѕА ((P вЗТ Q) = (P вЗТ S)) вЙФ
begin
  assume P Q S hp h;
  rewrite h; reflexivity
end;
