// Rewrite lemmas for normalisation chains.
// These replace the primed (_1) rule mechanism: instead of equality-chaining
// symbols, the emitter uses `rewrite lemma; ...` sequences.
require open pp2lp.B;

// ---- Structural connectors ----

// Schema 2: lift independent equalities into a conjunction equality.
opaque symbol conj_eq [A B S1 S2 : Prop]
  : œÄ (A = S1) ‚Üí œÄ (B = S2) ‚Üí œÄ ((A ‚àß B) = (S1 ‚àß S2)) ‚âî
begin
  assume A B S1 S2 h1 h2;
  rewrite h1; rewrite h2; reflexivity
end;

// Conjunction associativity (right ‚Üí left).
// Applied via `rewrite ‚àß_assoc` inside ALL7_2/XST8_2 continuations to
// reshape the right-associated R (as produced by the _1 chain) into the
// left-associated form that the PP-recorded tactics expect.
opaque symbol ‚àß_assoc [A B C : Prop]
  : œÄ ((A ‚àß (B ‚àß C)) = ((A ‚àß B) ‚àß C)) ‚âî
begin
  assume A B C;
  refine propExt _ _ _ _
  { assume h; refine ‚àß·µ¢ (‚àß·µ¢ (‚àß‚Çë‚ÇÅ h) (‚àß‚Çë‚ÇÅ (‚àß‚Çë‚ÇÇ h))) (‚àß‚Çë‚ÇÇ (‚àß‚Çë‚ÇÇ h)) }
  { assume h; refine ‚àß·µ¢ (‚àß‚Çë‚ÇÅ (‚àß‚Çë‚ÇÅ h)) (‚àß·µ¢ (‚àß‚Çë‚ÇÇ (‚àß‚Çë‚ÇÅ h)) (‚àß‚Çë‚ÇÇ h)) }
end;

// AND5': lift antecedent equivalence into implication equality.
opaque symbol ante_cong [C C' R : Prop]
  : (œÄ C ‚Üí œÄ C') ‚Üí (œÄ C' ‚Üí œÄ C) ‚Üí œÄ ((C ‚áí R) = (C' ‚áí R)) ‚âî
begin
  assume C C' R fwd bwd;
  refine propExt _ _ _ _
    { assume h hc'; refine h (bwd hc') }
    { assume h hc; refine h (fwd hc) }
end;

// ---- Conjunction (¬ßA.1) ----

// AND1: ¬¨(P‚àßQ)‚áíR = (¬¨Q‚áíR) ‚àß (¬¨P‚áíR)
opaque symbol and1_eq [P Q R : Prop]
  : œÄ ((¬¨ (P ‚àß Q) ‚áí R) = ((¬¨ Q ‚áí R) ‚àß (¬¨ P ‚áí R))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢
      (Œª hnq, h (Œª hpq, hnq (‚àß‚Çë‚ÇÇ hpq)))
      (Œª hnp, h (Œª hpq, hnp (‚àß‚Çë‚ÇÅ hpq))) }
    { assume h hnpq;
      have hnpnq : œÄ (¬¨ P ‚à® ¬¨ Q) { refine =‚áí (deMorgan_‚àß P Q) hnpq };
      refine ‚à®‚Çë hnpnq _ _
      { assume hnp; refine ‚àß‚Çë‚ÇÇ h hnp }
      { assume hnq; refine ‚àß‚Çë‚ÇÅ h hnq } }
end;

// AND2: ¬¨(P‚àßQ) = (P‚áí¬¨Q)
opaque symbol and2_eq [P Q : Prop]
  : œÄ (¬¨ (P ‚àß Q) = (P ‚áí ¬¨ Q)) ‚âî
begin
  assume P Q;
  refine propExt _ _ _ _
    { assume h1 hp hq; refine h1 (‚àß·µ¢ hp hq) }
    { assume h1 h2; refine h1 (‚àß‚Çë‚ÇÅ h2) (‚àß‚Çë‚ÇÇ h2) }
end;

// AND3: (P‚àßQ)‚áíR = (P‚áíQ‚áíR)
opaque symbol and3_eq [P Q R : Prop]
  : œÄ (((P ‚àß Q) ‚áí R) = (P ‚áí Q ‚áí R)) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h1 hp hq; refine h1 (‚àß·µ¢ hp hq) }
    { assume h1 h2; refine h1 (‚àß‚Çë‚ÇÅ h2) (‚àß‚Çë‚ÇÇ h2) }
end;

// ---- Disjunction (¬ßA.2) ----

// OR1: ¬¨(P‚à®Q)‚áíR = (¬¨P‚áí¬¨Q‚áíR)
opaque symbol or1_eq [P Q R : Prop]
  : œÄ ((¬¨ (P ‚à® Q) ‚áí R) = (¬¨ P ‚áí (¬¨ Q ‚áí R))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h1 hnp hnq;
      have hnpq : œÄ (¬¨ (P ‚à® Q))
        { assume hpq; refine ‚à®‚Çë hpq _ _
          { assume hp; refine hnp hp }
          { assume hq; refine hnq hq } };
      refine h1 hnpq }
    { assume h1 hnpq;
      have hnpnq : œÄ (¬¨ P ‚àß ¬¨ Q) { refine =‚áí (deMorgan_‚à® P Q) hnpq };
      refine h1 (‚àß‚Çë‚ÇÅ hnpnq) (‚àß‚Çë‚ÇÇ hnpnq) }
end;

// OR2: ¬¨(P‚à®Q) = (¬¨Q ‚àß ¬¨P)
opaque symbol or2_eq [P Q : Prop]
  : œÄ (¬¨ (P ‚à® Q) = (¬¨ Q ‚àß ¬¨ P)) ‚âî
begin
  assume P Q;
  rewrite deMorgan_‚à®;
  rewrite ‚àß_com;
  reflexivity
end;

// OR3: (P‚à®Q)‚áíR = (Q‚áíR) ‚àß (P‚áíR)
opaque symbol or3_eq [P Q R : Prop]
  : œÄ (((P ‚à® Q) ‚áí R) = ((Q ‚áí R) ‚àß (P ‚áí R))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢ (Œª hq, h (‚à®·µ¢‚ÇÇ hq)) (Œª hp, h (‚à®·µ¢‚ÇÅ hp)) }
    { assume h hpq; refine ‚à®‚Çë hpq _ _
      { assume hp; refine ‚àß‚Çë‚ÇÇ h hp }
      { assume hq; refine ‚àß‚Çë‚ÇÅ h hq } }
end;

// OR4: P‚à®Q = (¬¨P‚áíQ). P and Q explicit to avoid HO unification issues.
opaque symbol or4_eq (P Q : Prop)
  : œÄ ((P ‚à® Q) = (¬¨ P ‚áí Q)) ‚âî
begin
  assume P Q;
  refine propExt _ _ _ _
    { assume hpq hnp; refine ‚à®‚Çë hpq _ _
      { assume hp; refine ‚ä•‚Çë (hnp hp) }
      { assume hq; refine hq } }
    { assume h1; refine ‚à®‚Çë (em P) _ _
      { assume hp; refine ‚à®·µ¢‚ÇÅ hp }
      { assume hnp; refine ‚à®·µ¢‚ÇÇ (h1 hnp) } }
end;

// AND4: (P ‚àß Q) = (Q ‚àß P) (commutativity ‚Äî no connective transformation)
// No dedicated lemma needed: emit `rewrite ‚àß_com; refine conj_eq ...`

// IMP2: ¬¨(P‚áíQ) = (¬¨Q ‚àß P)
opaque symbol imp2_eq [P Q : Prop]
  : œÄ (¬¨ (P ‚áí Q) = (¬¨ Q ‚àß P)) ‚âî
begin
  assume P Q;
  rewrite ¬¨‚áí=‚àß¬¨;
  rewrite ‚àß_com;
  reflexivity
end;

// ---- Implication (¬ßA.3) ----

// IMP1: ¬¨(P‚áíQ)‚áíR = (P‚áí¬¨Q‚áíR)
opaque symbol imp1_eq [P Q R : Prop]
  : œÄ ((¬¨ (P ‚áí Q) ‚áí R) = (P ‚áí (¬¨ Q ‚áí R))) ‚âî
begin
  assume P Q R;
  rewrite ¬¨‚áí=‚àß¬¨;
  refine propExt _ _ _ _
    { assume h1 hp hnq; refine h1 (‚àß·µ¢ hp hnq) }
    { assume h1 h2; refine h1 (‚àß‚Çë‚ÇÅ h2) (‚àß‚Çë‚ÇÇ h2) }
end;

// IMP3: (P‚áíQ)‚áíR = (Q‚áíR) ‚àß (¬¨P‚áíR)
opaque symbol imp3_eq [P Q R : Prop]
  : œÄ (((P ‚áí Q) ‚áí R) = ((Q ‚áí R) ‚àß (¬¨ P ‚áí R))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢
      (Œª hq, h (Œª h0, hq))
      (Œª hnp, h (Œª hp, ‚ä•‚Çë (hnp hp))) }
    { assume h hpq; refine ‚à®‚Çë (em P) _ _
      { assume hp; refine ‚àß‚Çë‚ÇÅ h (hpq hp) }
      { assume hnp; refine ‚àß‚Çë‚ÇÇ h hnp } }
end;

// ---- Equivalence (¬ßA.4) ----

// EQV1: ¬¨(P‚áîQ)‚áíR = (P‚áí¬¨Q‚áíR) ‚àß (¬¨P‚áíQ‚áíR)
opaque symbol eqv1_eq [P Q R : Prop]
  : œÄ ((¬¨ (P ‚áî Q) ‚áí R) = ((P ‚áí (¬¨ Q ‚áí R)) ‚àß (¬¨ P ‚áí (Q ‚áí R)))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢
      (Œª hp hnq, h (Œª heqv, hnq (‚àß‚Çë‚ÇÅ heqv hp)))
      (Œª hnp hq, h (Œª heqv, hnp (‚àß‚Çë‚ÇÇ heqv hq))) }
    { assume h hneqv;
      refine ‚à®‚Çë (em P) _ _
      { assume hp; refine ‚à®‚Çë (em Q) _ _
        { assume hq;
          have heqv : œÄ (P ‚áî Q) { refine ‚àß·µ¢ (Œª h0, hq) (Œª h0, hp) };
          refine ‚ä•‚Çë (hneqv heqv) }
        { assume hnq; refine ‚àß‚Çë‚ÇÅ h hp hnq } }
      { assume hnp; refine ‚à®‚Çë (em Q) _ _
        { assume hq; refine ‚àß‚Çë‚ÇÇ h hnp hq }
        { assume hnq;
          have heqv : œÄ (P ‚áî Q)
            { refine ‚àß·µ¢ (Œª hp, ‚ä•‚Çë (hnp hp)) (Œª hq, ‚ä•‚Çë (hnq hq)) };
          refine ‚ä•‚Çë (hneqv heqv) } } }
end;

// EQV3: (P‚áîQ)‚áíR = (P‚áíQ‚áíR) ‚àß (¬¨P‚áí¬¨Q‚áíR)
opaque symbol eqv3_eq [P Q R : Prop]
  : œÄ (((P ‚áî Q) ‚áí R) = ((P ‚áí (Q ‚áí R)) ‚àß (¬¨ P ‚áí (¬¨ Q ‚áí R)))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢
      (Œª hp hq, h (‚àß·µ¢ (Œª h0, hq) (Œª h0, hp)))
      (Œª hnp hnq, h (‚àß·µ¢
        (Œª hp, ‚ä•‚Çë (hnp hp))
        (Œª hq, ‚ä•‚Çë (hnq hq)))) }
    { assume h heqv;
      refine ‚à®‚Çë (em P) _ _
      { assume hp;
        have hq : œÄ Q { refine ‚àß‚Çë‚ÇÅ heqv hp };
        refine ‚àß‚Çë‚ÇÅ h hp hq }
      { assume hnp;
        refine ‚à®‚Çë (em Q) _ _
        { assume hq;
          have hp : œÄ P { refine ‚àß‚Çë‚ÇÇ heqv hq };
          refine ‚ä•‚Çë (hnp hp) }
        { assume hnq; refine ‚àß‚Çë‚ÇÇ h hnp hnq } } }
end;

// ---- Negation (¬ßA.5) ----

// NOT1: ¬¨¬¨P‚áíR = (P‚áíR)
opaque symbol not1_eq [P R : Prop]
  : œÄ ((¬¨ ¬¨ P ‚áí R) = (P ‚áí R)) ‚âî
begin
  assume P R;
  refine propExt _ _ _ _
    { assume h1 hp; refine h1 (Œª hnp, hnp hp) }
    { assume h1 hnnp; refine h1 (¬¨¬¨‚Çë P hnnp) }
end;

// ---- Equality (¬ßA.13) ----

// EVR3: (E=E)‚áíP = P
opaque symbol evr3_eq [E : œÑ Œπ] [P : Prop]
  : œÄ (((E = E) ‚áí P) = P) ‚âî
begin
  assume E P;
  refine propExt _ _ _ _
    { assume h1; refine h1 (eq_refl E) }
    { assume h1 h2; refine h1 }
end;

// ---- _1 equality combinators ----
// Each _1 rule takes child equalities and produces the parent equality.
// These compose as terms: AND3_1 (IMP4_1 (STOP_1)) : œÄ (P = R).

// Transitivity (needed for passthrough _1 rules)
opaque symbol eq_trans [P Q R : Prop]
  : œÄ (P = Q) ‚Üí œÄ (Q = R) ‚Üí œÄ (P = R) ‚âî
begin assume P Q R h1 h2; rewrite h1; refine h2 end;

// STOP_1: leaf ‚Äî identity
opaque symbol STOP_1 [P : Prop] : œÄ (P = P) ‚âî
begin assume P; reflexivity end;

// ---- Structural _1 rules ----

// IMP4_1: congruence of ‚áí on the right (unconditional)
opaque symbol IMP4_1 [P Q R : Prop]
  : œÄ (Q = R) ‚Üí œÄ ((P ‚áí Q) = (P ‚áí R)) ‚âî
begin assume P Q R h; rewrite h; reflexivity end;

// IMP5_1: strip known antecedent (needs proof of P)
opaque symbol IMP5_1 [P Q S : Prop]
  : œÄ P ‚Üí œÄ (Q = S) ‚Üí œÄ ((P ‚áí Q) = S) ‚âî
begin
  assume P Q S hp hqs;
  refine propExt _ _ _ _
  { assume hpq; refine =‚áí hqs (hpq hp) }
  { assume hs hp2; refine =‚áí (eq_sym hqs) hs }
end;

// ALL8_1: congruence under ‚àÄ
opaque symbol ALL8_1 [P R : œÑ Œπ ‚Üí Prop]
  : (ŒÝ x : œÑ Œπ, œÄ (P x = R x))
  ‚Üí œÄ ((`‚àÄ x, P x) = (`‚àÄ x, R x)) ‚âî
begin
  assume P R h;
  refine propExt _ _ _ _
  { assume h1 x; refine =‚áí (h x) (h1 x) }
  { assume h1 x; refine =‚áí (eq_sym (h x)) (h1 x) }
end;

// NRM1_1: strip constant ‚ô¢ under equality.
// (‚ô¢ _, P) ‚áí Q = S  ‚Üí  P ‚áí Q = S  (when P doesn't depend on bound var)
opaque symbol NRM1_1 [P Q S : Prop]
  : œÄ ((P ‚áí Q) = S)
  ‚Üí œÄ (((`‚ô¢ _ : œÑ Œπ, P) ‚áí Q) = S) ‚âî
begin
  assume P Q S h;
  have h1 : œÄ ((`‚ô¢ _ : œÑ Œπ, P) = P)
    { refine ‚àÄ_const Œπ P };
  have h2 : œÄ (((`‚ô¢ _ : œÑ Œπ, P) ‚áí Q) = (P ‚áí Q))
    { rewrite h1; reflexivity };
  refine eq_trans h2 h
end;

// ALL7_1: equality for branching quantifier in _1 chain.
// R is the per-element result; inner chain proves P x = R x for each x.
opaque symbol ALL7_1 [P : œÑ Œπ ‚Üí Prop] (R : œÑ Œπ ‚Üí Prop) [Q S : Prop]
  : (ŒÝ x : œÑ Œπ, œÄ (P x = R x))
  ‚Üí œÄ (((`‚ô¢ x, R x) ‚áí Q) = S)
  ‚Üí œÄ (((`‚àÄ x, P x) ‚áí Q) = S) ‚âî
begin
  assume P R Q S h1 h2;
  have h3 : œÄ ((`‚àÄ x, P x) = (`‚àÄ x, R x))
    { refine ALL8_1 h1 };
  have h4 : œÄ (((`‚àÄ x, P x) ‚áí Q) = ((`‚àÄ x, R x) ‚áí Q))
    { rewrite h3; reflexivity };
  refine eq_trans h4 h2
end;

// ALL7_1_2: Two-variable version.
opaque symbol ALL7_1_2 [P : œÑ Œπ ‚Üí œÑ Œπ ‚Üí Prop] (R : œÑ Œπ ‚Üí œÑ Œπ ‚Üí Prop) [Q S : Prop]
  : (ŒÝ x : œÑ Œπ, ŒÝ y : œÑ Œπ, œÄ (P x y = R x y))
  ‚Üí œÄ (((`‚ô¢ x, `‚ô¢ y, R x y) ‚áí Q) = S)
  ‚Üí œÄ (((`‚àÄ x, `‚àÄ y, P x y) ‚áí Q) = S) ‚âî
begin
  assume P R Q S h1 h2;
  have h3 : œÄ ((`‚àÄ x, `‚àÄ y, P x y) = (`‚àÄ x, `‚àÄ y, R x y))
    { refine ALL8_1 (Œª x, ALL8_1 (h1 x)) };
  have h4 : œÄ (((`‚àÄ x, `‚àÄ y, P x y) ‚áí Q) = ((`‚àÄ x, `‚àÄ y, R x y) ‚áí Q))
    { rewrite h3; reflexivity };
  refine eq_trans h4 h2
end;

// ALL7_1_3: Three-variable version.
opaque symbol ALL7_1_3 [P : œÑ Œπ ‚Üí œÑ Œπ ‚Üí œÑ Œπ ‚Üí Prop] (R : œÑ Œπ ‚Üí œÑ Œπ ‚Üí œÑ Œπ ‚Üí Prop) [Q S : Prop]
  : (ŒÝ x : œÑ Œπ, ŒÝ y : œÑ Œπ, ŒÝ z : œÑ Œπ, œÄ (P x y z = R x y z))
  ‚Üí œÄ (((`‚ô¢ x, `‚ô¢ y, `‚ô¢ z, R x y z) ‚áí Q) = S)
  ‚Üí œÄ (((`‚àÄ x, `‚àÄ y, `‚àÄ z, P x y z) ‚áí Q) = S) ‚âî
begin
  assume P R Q S h1 h2;
  have h3 : œÄ ((`‚àÄ x, `‚àÄ y, `‚àÄ z, P x y z) = (`‚àÄ x, `‚àÄ y, `‚àÄ z, R x y z))
    { refine ALL8_1 (Œª x, ALL8_1 (Œª y, ALL8_1 (h1 x y))) };
  have h4 : œÄ (((`‚àÄ x, `‚àÄ y, `‚àÄ z, P x y z) ‚áí Q) = ((`‚àÄ x, `‚àÄ y, `‚àÄ z, R x y z) ‚áí Q))
    { rewrite h3; reflexivity };
  refine eq_trans h4 h2
end;

// XST7_1: equality for (‚àÉx.P x ‚áí R) normalising to (‚àÄx. P x ‚áí R).
opaque symbol XST7_1 [P : œÑ Œπ ‚Üí Prop] [R S : Prop]
  : œÄ ((`‚àÄ x, P x ‚áí R) = S)
  ‚Üí œÄ (((`‚àÉ x, P x) ‚áí R) = S) ‚âî
begin
  assume P R S h;
  have h1 : œÄ (((`‚àÉ x, P x) ‚áí R) = (`‚àÄ x, P x ‚áí R))
    { refine propExt _ _ _ _
      { assume hir x hpx; refine hir (‚àÉ·µ¢ x hpx) }
      { assume hall hex; refine ‚àÉ‚Çë hex hall } };
  refine eq_trans h1 h
end;

// XST8_1: equality for existential ¬¨¬¨-elimination in _1 chain.
// ‚àÉx.P(x) = ((‚àÄx, ¬¨P(x)) ‚áí ‚ä• = S) ‚Üí (‚àÉx.P(x) = S)
opaque symbol XST8_1 [P : œÑ Œπ ‚Üí Prop] [S : Prop]
  : œÄ (((`‚àÄ x, ¬¨ (P x)) ‚áí ‚ä•) = S)
  ‚Üí œÄ ((`‚àÉ x, P x) = S) ‚âî
begin
  assume P S h;
  have h1 : œÄ ((`‚àÉ x, P x) = ((`‚àÄ x, ¬¨ (P x)) ‚áí ‚ä•))
    { refine propExt _ _ _ _
      { assume hex hall; refine ‚àÉ‚Çë hex (Œª x hpx, hall x hpx) }
      { assume hc; refine ¬¨¬¨‚Çë _ (Œª hne, hc (Œª x hpx, hne (‚àÉ·µ¢ x hpx))) } };
  refine eq_trans h1 h
end;

// XST8_1_2: Two-variable version.
opaque symbol XST8_1_2 [P : œÑ Œπ ‚Üí œÑ Œπ ‚Üí Prop] [S : Prop]
  : œÄ (((`‚àÄ x, `‚àÄ y, ¬¨ (P x y)) ‚áí ‚ä•) = S)
  ‚Üí œÄ ((`‚àÉ x, `‚àÉ y, P x y) = S) ‚âî
begin
  assume P S h;
  have h1 : œÄ ((`‚àÉ x, `‚àÉ y, P x y) = ((`‚àÄ x, `‚àÄ y, ¬¨ (P x y)) ‚áí ‚ä•))
    { refine propExt _ _ _ _
      { assume hex hall; refine ‚àÉ‚Çë hex (Œª x hexy, ‚àÉ‚Çë hexy (Œª y hpxy, hall x y hpxy)) }
      { assume hc; refine ¬¨¬¨‚Çë _ (Œª hne, hc (Œª x y hpxy, hne (‚àÉ·µ¢ x (‚àÉ·µ¢ y hpxy)))) } };
  refine eq_trans h1 h
end;

// XST8_1_3: Three-variable version.
opaque symbol XST8_1_3 [P : œÑ Œπ ‚Üí œÑ Œπ ‚Üí œÑ Œπ ‚Üí Prop] [S : Prop]
  : œÄ (((`‚àÄ x, `‚àÄ y, `‚àÄ z, ¬¨ (P x y z)) ‚áí ‚ä•) = S)
  ‚Üí œÄ ((`‚àÉ x, `‚àÉ y, `‚àÉ z, P x y z) = S) ‚âî
begin
  assume P S h;
  have h1 : œÄ ((`‚àÉ x, `‚àÉ y, `‚àÉ z, P x y z) = ((`‚àÄ x, `‚àÄ y, `‚àÄ z, ¬¨ (P x y z)) ‚áí ‚ä•))
    { refine propExt _ _ _ _
      { assume hex hall;
        refine ‚àÉ‚Çë hex (Œª x hexy, ‚àÉ‚Çë hexy (Œª y hexz, ‚àÉ‚Çë hexz (Œª z hpxyz, hall x y z hpxyz))) }
      { assume hc; refine ¬¨¬¨‚Çë _ (Œª hne, hc (Œª x y z hpxyz, hne (‚àÉ·µ¢ x (‚àÉ·µ¢ y (‚àÉ·µ¢ z hpxyz))))) } };
  refine eq_trans h1 h
end;

// ALL9_1: congruence under hypothesis implication (same as IMP4_1)
opaque symbol ALL9_1 [H Q R : Prop]
  : œÄ (Q = R) ‚Üí œÄ ((H ‚áí Q) = (H ‚áí R)) ‚âî
begin assume H Q R h; rewrite h; reflexivity end;

// ---- Passthrough _1 rules (eq_trans local_eq child_eq) ----

opaque symbol AND2_1 [P Q S : Prop]
  : œÄ ((P ‚áí ¬¨ Q) = S) ‚Üí œÄ (¬¨ (P ‚àß Q) = S) ‚âî
begin assume P Q S h; refine eq_trans (and2_eq) h end;

opaque symbol AND3_1 [P Q R S : Prop]
  : œÄ ((P ‚áí Q ‚áí R) = S) ‚Üí œÄ (((P ‚àß Q) ‚áí R) = S) ‚âî
begin assume P Q R S h; refine eq_trans and3_eq h end;

opaque symbol OR1_1 [P Q R S : Prop]
  : œÄ ((¬¨ P ‚áí ¬¨ Q ‚áí R) = S) ‚Üí œÄ ((¬¨ (P ‚à® Q) ‚áí R) = S) ‚âî
begin assume P Q R S h; refine eq_trans or1_eq h end;

opaque symbol OR4_1 [P Q S : Prop]
  : œÄ ((¬¨ P ‚áí Q) = S) ‚Üí œÄ ((P ‚à® Q) = S) ‚âî
begin assume P Q S h; refine eq_trans (or4_eq P Q) h end;

opaque symbol NOT1_1 [P R S : Prop]
  : œÄ ((P ‚áí R) = S) ‚Üí œÄ ((¬¨ ¬¨ P ‚áí R) = S) ‚âî
begin assume P R S h; refine eq_trans not1_eq h end;

// OPR1_1/OPR2_1: PP's primed one-point-rule. Inside a `_1` chain, the
// step rewrites `(x = E ‚áí P x)` to `(x = E ‚áí P E)` (OPR1) or the
// symmetric `(E = x ‚áí P x)` to `(E = x ‚áí P E)` (OPR2). The bridge
// equality `(x = E ‚áí P x) = (x = E ‚áí P E)` holds pointwise: when
// `x = E` is true, both sides reduce to `P E`; when false, both are
// vacuously `‚ä§`. No surrounding binder is required.
opaque symbol OPR1_1 [E : œÑ Œπ] [S : Prop] (P : œÑ Œπ ‚Üí Prop) (x : œÑ Œπ)
  : œÄ ((x = E ‚áí P E) = S) ‚Üí œÄ ((x = E ‚áí P x) = S) ‚âî
begin
  assume E S P x h;
  have bridge : œÄ ((x = E ‚áí P x) = (x = E ‚áí P E))
    { refine propExt _ _ _ _
        { assume hyp hxe; have px : œÄ (P x) { refine hyp hxe };
          rewrite left hxe; refine px }
        { assume hyp hxe; have pe : œÄ (P E) { refine hyp hxe };
          rewrite hxe; refine pe } };
  refine eq_trans bridge h
end;

opaque symbol OPR2_1 [E : œÑ Œπ] [S : Prop] (P : œÑ Œπ ‚Üí Prop) (x : œÑ Œπ)
  : œÄ ((E = x ‚áí P E) = S) ‚Üí œÄ ((E = x ‚áí P x) = S) ‚âî
begin
  assume E S P x h;
  have bridge : œÄ ((E = x ‚áí P x) = (E = x ‚áí P E))
    { refine propExt _ _ _ _
        { assume hyp hex; have px : œÄ (P x) { refine hyp hex };
          rewrite hex; refine px }
        { assume hyp hex; have pe : œÄ (P E) { refine hyp hex };
          rewrite left hex; refine pe } };
  refine eq_trans bridge h
end;

opaque symbol NOT2_1 [P S : Prop]
  : œÄ (P = S) ‚Üí œÄ (¬¨ ¬¨ P = S) ‚âî
begin assume P S h; refine eq_trans (¬¨¬¨‚Çë_eq P) h end;

opaque symbol IMP1_1 [P Q R S : Prop]
  : œÄ ((P ‚áí ¬¨ Q ‚áí R) = S) ‚Üí œÄ ((¬¨ (P ‚áí Q) ‚áí R) = S) ‚âî
begin assume P Q R S h; refine eq_trans imp1_eq h end;

opaque symbol VR3_1 [P S : Prop]
  : œÄ (P = S) ‚Üí œÄ ((‚ä§ ‚áí P) = S) ‚âî
begin assume P S h; refine eq_trans (‚ä§‚áí P) h end;

opaque symbol EVR2_1 [E : œÑ Œπ] [S : Prop]
  : œÄ (‚ä• = S) ‚Üí œÄ (¬¨ (E = E) = S) ‚âî
begin assume E S h; refine eq_trans (¬¨=_idem Œπ E) h end;

opaque symbol EVR3_1 [E : œÑ Œπ] [P S : Prop]
  : œÄ (P = S) ‚Üí œÄ (((E = E) ‚áí P) = S) ‚âî
begin
  assume E P S h;
  have h1 : œÄ ((E = E) = ‚ä§) { refine =_idem Œπ E };
  have h2 : œÄ (((E = E) ‚áí P) = (‚ä§ ‚áí P))
    { rewrite h1; reflexivity };
  refine eq_trans h2 (eq_trans (‚ä§‚áí P) h)
end;

// ---- Branching _1 rules (eq_trans local_eq (conj_eq child1 child2)) ----

opaque symbol AND1_1 [P Q R S1 S2 : Prop]
  : œÄ ((¬¨ Q ‚áí R) = S1) ‚Üí œÄ ((¬¨ P ‚áí R) = S2)
  ‚Üí œÄ ((¬¨ (P ‚àß Q) ‚áí R) = (S1 ‚àß S2)) ‚âî
begin assume P Q R S1 S2 h1 h2; refine eq_trans and1_eq (conj_eq h1 h2) end;

opaque symbol AND4_1 [P Q S1 S2 : Prop]
  : œÄ (Q = S1) ‚Üí œÄ (P = S2) ‚Üí œÄ ((P ‚àß Q) = (S1 ‚àß S2)) ‚âî
begin
  assume P Q S1 S2 h1 h2;
  refine eq_trans (‚àß_com P Q) (conj_eq h1 h2)
end;

opaque symbol OR2_1 [P Q S1 S2 : Prop]
  : œÄ ((¬¨ Q) = S1) ‚Üí œÄ ((¬¨ P) = S2)
  ‚Üí œÄ (¬¨ (P ‚à® Q) = (S1 ‚àß S2)) ‚âî
begin assume P Q S1 S2 h1 h2; refine eq_trans or2_eq (conj_eq h1 h2) end;

opaque symbol OR3_1 [P Q R S1 S2 : Prop]
  : œÄ ((Q ‚áí R) = S1) ‚Üí œÄ ((P ‚áí R) = S2)
  ‚Üí œÄ (((P ‚à® Q) ‚áí R) = (S1 ‚àß S2)) ‚âî
begin assume P Q R S1 S2 h1 h2; refine eq_trans or3_eq (conj_eq h1 h2) end;

opaque symbol IMP3_1 [P Q R S1 S2 : Prop]
  : œÄ ((Q ‚áí R) = S1) ‚Üí œÄ ((¬¨ P ‚áí R) = S2)
  ‚Üí œÄ (((P ‚áí Q) ‚áí R) = (S1 ‚àß S2)) ‚âî
begin assume P Q R S1 S2 h1 h2; refine eq_trans imp3_eq (conj_eq h1 h2) end;

opaque symbol IMP2_1 [P Q S1 S2 : Prop]
  : œÄ ((¬¨ Q) = S1) ‚Üí œÄ (P = S2)
  ‚Üí œÄ (¬¨ (P ‚áí Q) = (S1 ‚àß S2)) ‚âî
begin assume P Q S1 S2 h1 h2; refine eq_trans imp2_eq (conj_eq h1 h2) end;

opaque symbol EQV1_1 [P Q R S1 S2 : Prop]
  : œÄ ((P ‚áí ¬¨ Q ‚áí R) = S1) ‚Üí œÄ ((¬¨ P ‚áí Q ‚áí R) = S2)
  ‚Üí œÄ ((¬¨ (P ‚áî Q) ‚áí R) = (S1 ‚àß S2)) ‚âî
begin assume P Q R S1 S2 h1 h2; refine eq_trans eqv1_eq (conj_eq h1 h2) end;

opaque symbol EQV3_1 [P Q R S1 S2 : Prop]
  : œÄ ((P ‚áí Q ‚áí R) = S1) ‚Üí œÄ ((¬¨ P ‚áí ¬¨ Q ‚áí R) = S2)
  ‚Üí œÄ (((P ‚áî Q) ‚áí R) = (S1 ‚àß S2)) ‚âî
begin assume P Q R S1 S2 h1 h2; refine eq_trans eqv3_eq (conj_eq h1 h2) end;
