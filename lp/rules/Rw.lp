// Rewrite lemmas for normalisation chains.
// These replace the primed (_1) rule mechanism: instead of equality-chaining
// symbols, the emitter uses `rewrite lemma; ...` sequences.
require open pp2lp.B;

// ---- Structural connectors ----

// Schema 2: lift independent equalities into a conjunction equality.
opaque symbol conj_eq [A B S1 S2 : Prop]
  : œÄ (A = S1) ‚Üí œÄ (B = S2) ‚Üí œÄ ((A ‚àß B) = (S1 ‚àß S2)) ‚âî
begin
  assume A B S1 S2 h1 h2;
  rewrite h1; rewrite h2; reflexivity
end;

// IMP4'/ALL9': lift equality under implication (conditional on hypothesis).
opaque symbol imp_cong [P Q R : Prop]
  : (œÄ P ‚Üí œÄ (Q = R)) ‚Üí œÄ ((P ‚áí Q) = (P ‚áí R)) ‚âî
begin
  assume P Q R h;
  refine propExt _ _ _ _
    { assume h1 hp; refine =‚áí (h hp) (h1 hp) }
    { assume h1 hp; refine =‚áí (eq_sym (h hp)) (h1 hp) }
end;

// ALL8': lift equality under ‚àÄ.
opaque symbol forall_cong [P R : œÑ Œπ ‚Üí Prop]
  : (ŒÝ x : œÑ Œπ, œÄ (P x = R x)) ‚Üí œÄ ((`‚àÄ x : œÑ Œπ, P x) = (`‚àÄ x : œÑ Œπ, R x)) ‚âî
begin
  assume P R h;
  refine propExt _ _ _ _
    { assume h1 x; refine =‚áí (h x) (h1 x) }
    { assume h1 x; refine =‚áí (eq_sym (h x)) (h1 x) }
end;

// AND5': lift antecedent equivalence into implication equality.
opaque symbol ante_cong [C C' R : Prop]
  : (œÄ C ‚Üí œÄ C') ‚Üí (œÄ C' ‚Üí œÄ C) ‚Üí œÄ ((C ‚áí R) = (C' ‚áí R)) ‚âî
begin
  assume C C' R fwd bwd;
  refine propExt _ _ _ _
    { assume h hc'; refine h (bwd hc') }
    { assume h hc; refine h (fwd hc) }
end;

// ---- Conjunction (¬ßA.1) ----

// AND1: ¬¨(P‚àßQ)‚áíR = (¬¨Q‚áíR) ‚àß (¬¨P‚áíR)
opaque symbol and1_eq [P Q R : Prop]
  : œÄ ((¬¨ (P ‚àß Q) ‚áí R) = ((¬¨ Q ‚áí R) ‚àß (¬¨ P ‚áí R))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢
      (Œª hnq, h (Œª hpq, hnq (‚àß‚Çë‚ÇÇ hpq)))
      (Œª hnp, h (Œª hpq, hnp (‚àß‚Çë‚ÇÅ hpq))) }
    { assume h hnpq;
      have hnpnq : œÄ (¬¨ P ‚à® ¬¨ Q) { refine =‚áí (deMorgan_‚àß P Q) hnpq };
      refine ‚à®‚Çë hnpnq _ _
      { assume hnp; refine ‚àß‚Çë‚ÇÇ h hnp }
      { assume hnq; refine ‚àß‚Çë‚ÇÅ h hnq } }
end;

// AND2: ¬¨(P‚àßQ) = (P‚áí¬¨Q)
opaque symbol and2_eq [P Q : Prop]
  : œÄ (¬¨ (P ‚àß Q) = (P ‚áí ¬¨ Q)) ‚âî
begin
  assume P Q;
  refine propExt _ _ _ _
    { assume h1 hp hq; refine h1 (‚àß·µ¢ hp hq) }
    { assume h1 h2; refine h1 (‚àß‚Çë‚ÇÅ h2) (‚àß‚Çë‚ÇÇ h2) }
end;

// AND3: (P‚àßQ)‚áíR = (P‚áíQ‚áíR)
opaque symbol and3_eq [P Q R : Prop]
  : œÄ (((P ‚àß Q) ‚áí R) = (P ‚áí Q ‚áí R)) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h1 hp hq; refine h1 (‚àß·µ¢ hp hq) }
    { assume h1 h2; refine h1 (‚àß‚Çë‚ÇÅ h2) (‚àß‚Çë‚ÇÇ h2) }
end;

// ---- Disjunction (¬ßA.2) ----

// OR1: ¬¨(P‚à®Q)‚áíR = (¬¨P‚áí¬¨Q‚áíR)
opaque symbol or1_eq [P Q R : Prop]
  : œÄ ((¬¨ (P ‚à® Q) ‚áí R) = (¬¨ P ‚áí (¬¨ Q ‚áí R))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h1 hnp hnq;
      have hnpq : œÄ (¬¨ (P ‚à® Q))
        { assume hpq; refine ‚à®‚Çë hpq _ _
          { assume hp; refine hnp hp }
          { assume hq; refine hnq hq } };
      refine h1 hnpq }
    { assume h1 hnpq;
      have hnpnq : œÄ (¬¨ P ‚àß ¬¨ Q) { refine =‚áí (deMorgan_‚à® P Q) hnpq };
      refine h1 (‚àß‚Çë‚ÇÅ hnpnq) (‚àß‚Çë‚ÇÇ hnpnq) }
end;

// OR2: ¬¨(P‚à®Q) = (¬¨Q ‚àß ¬¨P)
opaque symbol or2_eq [P Q : Prop]
  : œÄ (¬¨ (P ‚à® Q) = (¬¨ Q ‚àß ¬¨ P)) ‚âî
begin
  assume P Q;
  rewrite deMorgan_‚à®;
  rewrite ‚àß_com;
  reflexivity
end;

// OR3: (P‚à®Q)‚áíR = (Q‚áíR) ‚àß (P‚áíR)
opaque symbol or3_eq [P Q R : Prop]
  : œÄ (((P ‚à® Q) ‚áí R) = ((Q ‚áí R) ‚àß (P ‚áí R))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢ (Œª hq, h (‚à®·µ¢‚ÇÇ hq)) (Œª hp, h (‚à®·µ¢‚ÇÅ hp)) }
    { assume h hpq; refine ‚à®‚Çë hpq _ _
      { assume hp; refine ‚àß‚Çë‚ÇÇ h hp }
      { assume hq; refine ‚àß‚Çë‚ÇÅ h hq } }
end;

// OR4: P‚à®Q = (¬¨P‚áíQ). P and Q explicit to avoid HO unification issues.
opaque symbol or4_eq (P Q : Prop)
  : œÄ ((P ‚à® Q) = (¬¨ P ‚áí Q)) ‚âî
begin
  assume P Q;
  refine propExt _ _ _ _
    { assume hpq hnp; refine ‚à®‚Çë hpq _ _
      { assume hp; refine ‚ä•‚Çë (hnp hp) }
      { assume hq; refine hq } }
    { assume h1; refine ‚à®‚Çë (em P) _ _
      { assume hp; refine ‚à®·µ¢‚ÇÅ hp }
      { assume hnp; refine ‚à®·µ¢‚ÇÇ (h1 hnp) } }
end;

// AND4: (P ‚àß Q) = (Q ‚àß P) (commutativity ‚Äî no connective transformation)
// No dedicated lemma needed: emit `rewrite ‚àß_com; refine conj_eq ...`

// IMP2: ¬¨(P‚áíQ) = (¬¨Q ‚àß P)
opaque symbol imp2_eq [P Q : Prop]
  : œÄ (¬¨ (P ‚áí Q) = (¬¨ Q ‚àß P)) ‚âî
begin
  assume P Q;
  rewrite ¬¨‚áí=‚àß¬¨;
  rewrite ‚àß_com;
  reflexivity
end;

// ---- Implication (¬ßA.3) ----

// IMP1: ¬¨(P‚áíQ)‚áíR = (P‚áí¬¨Q‚áíR)
opaque symbol imp1_eq [P Q R : Prop]
  : œÄ ((¬¨ (P ‚áí Q) ‚áí R) = (P ‚áí (¬¨ Q ‚áí R))) ‚âî
begin
  assume P Q R;
  rewrite ¬¨‚áí=‚àß¬¨;
  refine propExt _ _ _ _
    { assume h1 hp hnq; refine h1 (‚àß·µ¢ hp hnq) }
    { assume h1 h2; refine h1 (‚àß‚Çë‚ÇÅ h2) (‚àß‚Çë‚ÇÇ h2) }
end;

// IMP3: (P‚áíQ)‚áíR = (Q‚áíR) ‚àß (¬¨P‚áíR)
opaque symbol imp3_eq [P Q R : Prop]
  : œÄ (((P ‚áí Q) ‚áí R) = ((Q ‚áí R) ‚àß (¬¨ P ‚áí R))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢
      (Œª hq, h (Œª h0, hq))
      (Œª hnp, h (Œª hp, ‚ä•‚Çë (hnp hp))) }
    { assume h hpq; refine ‚à®‚Çë (em P) _ _
      { assume hp; refine ‚àß‚Çë‚ÇÅ h (hpq hp) }
      { assume hnp; refine ‚àß‚Çë‚ÇÇ h hnp } }
end;

// ---- Equivalence (¬ßA.4) ----

// EQV1: ¬¨(P‚áîQ)‚áíR = (P‚áí¬¨Q‚áíR) ‚àß (¬¨P‚áíQ‚áíR)
opaque symbol eqv1_eq [P Q R : Prop]
  : œÄ ((¬¨ (P ‚áî Q) ‚áí R) = ((P ‚áí (¬¨ Q ‚áí R)) ‚àß (¬¨ P ‚áí (Q ‚áí R)))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢
      (Œª hp hnq, h (Œª heqv, hnq (‚àß‚Çë‚ÇÅ heqv hp)))
      (Œª hnp hq, h (Œª heqv, hnp (‚àß‚Çë‚ÇÇ heqv hq))) }
    { assume h hneqv;
      refine ‚à®‚Çë (em P) _ _
      { assume hp; refine ‚à®‚Çë (em Q) _ _
        { assume hq;
          have heqv : œÄ (P ‚áî Q) { refine ‚àß·µ¢ (Œª h0, hq) (Œª h0, hp) };
          refine ‚ä•‚Çë (hneqv heqv) }
        { assume hnq; refine ‚àß‚Çë‚ÇÅ h hp hnq } }
      { assume hnp; refine ‚à®‚Çë (em Q) _ _
        { assume hq; refine ‚àß‚Çë‚ÇÇ h hnp hq }
        { assume hnq;
          have heqv : œÄ (P ‚áî Q)
            { refine ‚àß·µ¢ (Œª hp, ‚ä•‚Çë (hnp hp)) (Œª hq, ‚ä•‚Çë (hnq hq)) };
          refine ‚ä•‚Çë (hneqv heqv) } } }
end;

// EQV2: ¬¨(P‚áîQ) = (P‚áí¬¨Q) ‚àß (¬¨Q‚áíP)
opaque symbol eqv2_eq [P Q : Prop]
  : œÄ (¬¨ (P ‚áî Q) = ((P ‚áí ¬¨ Q) ‚àß (¬¨ Q ‚áí P))) ‚âî
begin
  assume P Q;
  refine propExt _ _ _ _
    { assume hneqv; refine ‚àß·µ¢
      (Œª hp hq, hneqv (‚àß·µ¢ (Œª h0, hq) (Œª h0, hp)))
      (Œª hnq, ¬¨¬¨‚Çë P (Œª hnp, hneqv (‚àß·µ¢
        (Œª hp, ‚ä•‚Çë (hnp hp))
        (Œª hq, ‚ä•‚Çë (hnq hq))))) }
    { assume h heqv;
      have hpnq : œÄ (P ‚áí ¬¨ Q) { refine ‚àß‚Çë‚ÇÅ h };
      have hnqp : œÄ (¬¨ Q ‚áí P) { refine ‚àß‚Çë‚ÇÇ h };
      refine ‚à®‚Çë (em Q) _ _
      { assume hq;
        have hp : œÄ P { refine ‚àß‚Çë‚ÇÇ heqv hq };
        refine hpnq hp hq }
      { assume hnq;
        have hp : œÄ P { refine hnqp hnq };
        have hq : œÄ Q { refine ‚àß‚Çë‚ÇÅ heqv hp };
        refine hnq hq } }
end;

// EQV3: (P‚áîQ)‚áíR = (P‚áíQ‚áíR) ‚àß (¬¨P‚áí¬¨Q‚áíR)
opaque symbol eqv3_eq [P Q R : Prop]
  : œÄ (((P ‚áî Q) ‚áí R) = ((P ‚áí (Q ‚áí R)) ‚àß (¬¨ P ‚áí (¬¨ Q ‚áí R)))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢
      (Œª hp hq, h (‚àß·µ¢ (Œª h0, hq) (Œª h0, hp)))
      (Œª hnp hnq, h (‚àß·µ¢
        (Œª hp, ‚ä•‚Çë (hnp hp))
        (Œª hq, ‚ä•‚Çë (hnq hq)))) }
    { assume h heqv;
      refine ‚à®‚Çë (em P) _ _
      { assume hp;
        have hq : œÄ Q { refine ‚àß‚Çë‚ÇÅ heqv hp };
        refine ‚àß‚Çë‚ÇÅ h hp hq }
      { assume hnp;
        refine ‚à®‚Çë (em Q) _ _
        { assume hq;
          have hp : œÄ P { refine ‚àß‚Çë‚ÇÇ heqv hq };
          refine ‚ä•‚Çë (hnp hp) }
        { assume hnq; refine ‚àß‚Çë‚ÇÇ h hnp hnq } } }
end;

// EQV4: (P‚áîQ) = (P‚áíQ) ‚àß (Q‚áíP)
opaque symbol eqv4_eq [P Q : Prop]
  : œÄ ((P ‚áî Q) = ((P ‚áí Q) ‚àß (Q ‚áí P))) ‚âî
begin
  assume P Q;
  refine propExt _ _ _ _
    { assume h; refine h }
    { assume h; refine h }
end;

// ---- Negation (¬ßA.5) ----

// NOT1: ¬¨¬¨P‚áíR = (P‚áíR)
opaque symbol not1_eq [P R : Prop]
  : œÄ ((¬¨ ¬¨ P ‚áí R) = (P ‚áí R)) ‚âî
begin
  assume P R;
  refine propExt _ _ _ _
    { assume h1 hp; refine h1 (Œª hnp, hnp hp) }
    { assume h1 hnnp; refine h1 (¬¨¬¨‚Çë P hnnp) }
end;

// ---- Equality (¬ßA.13) ----

// EVR3: (E=E)‚áíP = P
opaque symbol evr3_eq [E : œÑ Œπ] [P : Prop]
  : œÄ (((E = E) ‚áí P) = P) ‚âî
begin
  assume E P;
  refine propExt _ _ _ _
    { assume h1; refine h1 (eq_refl E) }
    { assume h1 h2; refine h1 }
end;

// OPR1: (x=E)‚áíP(x) = (x=E)‚áíP(E)
opaque symbol opr1_eq [E x : œÑ Œπ] [P : œÑ Œπ ‚Üí Prop]
  : œÄ (((x = E) ‚áí P x) = ((x = E) ‚áí P E)) ‚âî
begin
  assume E x P;
  refine propExt _ _ _ _
    { assume h1 heq; rewrite left heq; refine h1 heq }
    { assume h1 heq; rewrite heq; refine h1 heq }
end;

// OPR2: (E=x)‚áíP(x) = (E=x)‚áíP(E)
opaque symbol opr2_eq [E x : œÑ Œπ] [P : œÑ Œπ ‚Üí Prop]
  : œÄ (((E = x) ‚áí P x) = ((E = x) ‚áí P E)) ‚âî
begin
  assume E x P;
  refine propExt _ _ _ _
    { assume h1 heq;
      have heqs : œÄ (x = E) { symmetry; refine heq };
      rewrite left heqs; refine h1 heq }
    { assume h1 heq;
      have heqs : œÄ (x = E) { symmetry; refine heq };
      rewrite heqs; refine h1 heq }
end;

// EQC1: ¬¨(a‚Ü¶b = c‚Ü¶d)‚áíP = (¬¨(a=c) ‚à® ¬¨(b=d))‚áíP
opaque symbol eqc1_eq [a b c d : œÑ Œπ] [P : Prop]
  : œÄ ((¬¨ ((a ‚Ü¶ b) = (c ‚Ü¶ d)) ‚áí P) = ((¬¨ (a = c) ‚à® ¬¨ (b = d)) ‚áí P)) ‚âî
begin
  assume a b c d P;
  refine propExt _ _ _ _
    { assume h1 h2;
      refine h1 _;
      refine ‚à®‚Çë h2 _ _
      { assume hnac h3;
        refine hnac (‚àß‚Çë‚ÇÅ (pair_inj a b c d h3)) }
      { assume hnbd h3;
        refine hnbd (‚àß‚Çë‚ÇÇ (pair_inj a b c d h3)) } }
    { assume h1 h2;
      refine h1 _;
      refine ‚à®‚Çë (em (a = c)) _ _
      { assume hac; refine ‚à®‚Çë (em (b = d)) _ _
        { assume hbd;
          refine ‚ä•‚Çë (h2 (pair_cong a b c d hac hbd)) }
        { assume hnbd; refine ‚à®·µ¢‚ÇÇ hnbd } }
      { assume hnac; refine ‚à®·µ¢‚ÇÅ hnac } }
end;

// EQC2: (a‚Ü¶b = c‚Ü¶d)‚áíP = (a=c ‚àß b=d)‚áíP
opaque symbol eqc2_eq [a b c d : œÑ Œπ] [P : Prop]
  : œÄ ((((a ‚Ü¶ b) = (c ‚Ü¶ d)) ‚áí P) = (((a = c) ‚àß (b = d)) ‚áí P)) ‚âî
begin
  assume a b c d P;
  refine propExt _ _ _ _
    { assume h1 h2; refine h1 (pair_cong a b c d (‚àß‚Çë‚ÇÅ h2) (‚àß‚Çë‚ÇÇ h2)) }
    { assume h1 h2; refine h1 (pair_inj a b c d h2) }
end;

// EQS1: (‚àÄx. x‚ààE ‚áî x‚ààF)‚áíR = (E=F)‚áíR
opaque symbol eqs1_eq [E F : œÑ Œπ] [R : Prop]
  : œÄ (((`‚àÄ x : œÑ Œπ, (x œµ E) ‚áî (x œµ F)) ‚áí R) = ((E = F) ‚áí R)) ‚âî
begin
  assume E F R;
  refine propExt _ _ _ _
    { assume h1 h2; refine h1 (‚àß‚Çë‚ÇÅ (set_ext E F) h2) }
    { assume h1 h2; refine h1 (‚àß‚Çë‚ÇÇ (set_ext E F) h2) }
end;

// EQS2: ¬¨(‚àÄx. x‚ààE ‚áî x‚ààF)‚áíR = ¬¨(E=F)‚áíR
opaque symbol eqs2_eq [E F : œÑ Œπ] [R : Prop]
  : œÄ ((¬¨ (`‚àÄ x : œÑ Œπ, (x œµ E) ‚áî (x œµ F)) ‚áí R) = (¬¨ (E = F) ‚áí R)) ‚âî
begin
  assume E F R;
  refine propExt _ _ _ _
    { assume h1 h2; refine h1 (Œª heqs, ‚ä•‚Çë (h2 (‚àß‚Çë‚ÇÇ (set_ext E F) heqs))) }
    { assume h1 h2; refine h1 (Œª heq, ‚ä•‚Çë (h2 (‚àß‚Çë‚ÇÅ (set_ext E F) heq))) }
end;

// EIMP51: ¬¨(E=F)‚áíP = P (when ¬¨(F=E) is known)
opaque symbol eimp51_eq [E F : œÑ Œπ] [P : Prop]
  : œÄ (¬¨ (F = E)) ‚Üí œÄ ((¬¨ (E = F) ‚áí P) = P) ‚âî
begin
  assume E F P hneq;
  refine propExt _ _ _ _
    { assume h1; refine h1 (Œª h2, hneq (eq_sym h2)) }
    { assume h1 h2; refine h1 }
end;

// EIMP52: (E=F)‚áíP = P (when F=E is known)
opaque symbol eimp52_eq [E F : œÑ Œπ] [P : Prop]
  : œÄ (F = E) ‚Üí œÄ (((E = F) ‚áí P) = P) ‚âî
begin
  assume E F P heq;
  refine propExt _ _ _ _
    { assume h1; refine h1 (eq_sym heq) }
    { assume h1 h2; refine h1 }
end;

// AR9: (E ‚â§ 0) ‚áí R = (F ‚â§ 0) ‚áí R (from E = F)
opaque symbol ar9_eq [E : œÑ Œπ] (F : œÑ Œπ) [R : Prop]
  : œÄ (E = F)
  ‚Üí œÄ (((E ‚â§ ùüé) ‚áí R) = ((F ‚â§ ùüé) ‚áí R)) ‚âî
begin
  assume E F R heq;
  rewrite heq; reflexivity
end;

// ---- Existential (¬ßA.8) ----

// XST7: (‚àÉx.P x)‚áíR = ‚àÄx.(P x‚áíR)
opaque symbol xst7_eq [P : œÑ Œπ ‚Üí Prop] [R : Prop]
  : œÄ (((`‚àÉ x, P x) ‚áí R) = (`‚àÄ x, P x ‚áí R)) ‚âî
begin
  assume P R;
  refine propExt _ _ _ _
    { assume h1 x hpx; refine h1 (‚àÉ·µ¢ x hpx) }
    { assume h1 hex; refine ‚àÉ‚Çë hex h1 }
end;
