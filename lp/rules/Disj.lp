// Disjunction (┬ДA.2) Рђћ shallow encoding
require open pp2lp.B;

// ---- Base rules ----

// OR1: H Ріб ┬гP РЄњ (┬гQ РЄњ R) Рєњ H Ріб ┬г(P Рѕе Q) РЄњ R
opaque symbol OR1 [P Q R]
  : ¤ђ (┬г P РЄњ (┬г Q РЄњ R))
  Рєњ ¤ђ (┬г (P Рѕе Q) РЄњ R) РЅћ
begin
  assume P Q R h1 h2;
  have h : ¤ђ (┬г P РѕД ┬г Q) {refine =РЄњ (deMorgan_Рѕе P Q) h2};
  refine h1 (РѕДРѓЉРѓЂ h) (РѕДРѓЉРѓѓ h)
end;

// OR2: H Ріб ┬гQ; H Ріб ┬гP Рєњ H Ріб ┬г(P Рѕе Q)
opaque symbol OR2 [P Q]
  : ¤ђ (┬г Q)
  Рєњ ¤ђ (┬г P)
  Рєњ ¤ђ (┬г (P Рѕе Q)) РЅћ
begin
  assume P Q hq hp hpq;
  refine РѕеРѓЉ hpq _ _ {
    assume h; refine hp h
  } {
    assume h; refine hq h
  }
end;

// OR3: H Ріб Q РЄњ R; H Ріб P РЄњ R Рєњ H Ріб (P Рѕе Q) РЄњ R
opaque symbol OR3 [P Q R]
  : ¤ђ (Q РЄњ R)
  Рєњ ¤ђ (P РЄњ R)
  Рєњ ¤ђ ((P Рѕе Q) РЄњ R) РЅћ
begin
  assume P Q R hq hp hpq;
  refine РѕеРѓЉ hpq _ _ {
    assume h; refine hp h
  } {
    assume h; refine hq h
  }
end;

// OR4: H Ріб ┬гP РЄњ Q Рєњ H Ріб P Рѕе Q
opaque symbol OR4 [P Q]
  : ¤ђ (┬г P РЄњ Q)
  Рєњ ¤ђ (P Рѕе Q) РЅћ
begin
  assume P Q h1;
  refine РѕеРѓЉ (em P) _ _ {
    assume hp; refine РѕерхбРѓЂ hp
  } {
    assume hnp; refine РѕерхбРѓѓ (h1 hnp)
  }
end;

// ---- Primed variants (equality-based) ----

// OR1_1: pass-through. ┬г(PРѕеQ)РЄњR = ┬гPРЄњ(┬гQРЄњR).
opaque symbol OR1_1 [P Q R S : Prop]
  : ¤ђ ((┬г P РЄњ (┬г Q РЄњ R)) = S)
  Рєњ ¤ђ ((┬г (P Рѕе Q) РЄњ R) = S) РЅћ
begin
  assume P Q R S h;
  have eq : ¤ђ ((┬г (P Рѕе Q) РЄњ R) = (┬г P РЄњ (┬г Q РЄњ R)))
    { refine propExt _ _ _ _
      { assume h1 hnp hnq;
        have hnpq : ¤ђ (┬г (P Рѕе Q))
          { assume hpq; refine РѕеРѓЉ hpq _ _
            { assume hp; refine hnp hp }
            { assume hq; refine hnq hq } };
        refine h1 hnpq }
      { assume h1 hnpq;
        have hnpnq : ¤ђ (┬г P РѕД ┬г Q) { refine =РЄњ (deMorgan_Рѕе P Q) hnpq };
        refine h1 (РѕДРѓЉРѓЂ hnpnq) (РѕДРѓЉРѓѓ hnpnq) } };
  rewrite eq; refine h
end;

// OR2_1: multi-premise. ┬г(PРѕеQ) = ┬гP РѕД ┬гQ.
opaque symbol OR2_1 [P Q S1 S2 : Prop]
  : ¤ђ (┬г Q = S1)
  Рєњ ¤ђ (┬г P = S2)
  Рєњ ¤ђ (┬г (P Рѕе Q) = (S1 РѕД S2)) РЅћ
begin
  assume P Q S1 S2 h1 h2;
  rewrite deMorgan_Рѕе;
  rewrite РѕД_com;
  rewrite h1; rewrite h2; reflexivity
end;

// OR3_1: multi-premise. (PРѕеQ)РЄњR = (QРЄњR) РѕД (PРЄњR).
opaque symbol OR3_1 [P Q R S1 S2 : Prop]
  : ¤ђ ((Q РЄњ R) = S1)
  Рєњ ¤ђ ((P РЄњ R) = S2)
  Рєњ ¤ђ (((P Рѕе Q) РЄњ R) = (S1 РѕД S2)) РЅћ
begin
  assume P Q R S1 S2 h1 h2;
  have eq : ¤ђ (((P Рѕе Q) РЄњ R) = ((Q РЄњ R) РѕД (P РЄњ R)))
    { refine propExt _ _ _ _
      { assume h; refine РѕДрхб (╬╗ hq, h (РѕерхбРѓѓ hq)) (╬╗ hp, h (РѕерхбРѓЂ hp)) }
      { assume h hpq; refine РѕеРѓЉ hpq _ _
        { assume hp; refine РѕДРѓЉРѓѓ h hp }
        { assume hq; refine РѕДРѓЉРѓЂ h hq } } };
  rewrite eq; rewrite h1; rewrite h2; reflexivity
end;

// OR4_1: pass-through. PРѕеQ = ┬гPРЄњQ.
opaque symbol OR4_1 [P Q S : Prop]
  : ¤ђ ((┬г P РЄњ Q) = S)
  Рєњ ¤ђ ((P Рѕе Q) = S) РЅћ
begin
  assume P Q S h;
  have eq : ¤ђ ((P Рѕе Q) = (┬г P РЄњ Q))
    { refine propExt _ _ _ _
      { assume hpq hnp; refine РѕеРѓЉ hpq _ _
        { assume hp; refine РіЦРѓЉ (hnp hp) }
        { assume hq; refine hq } }
      { assume h1; refine РѕеРѓЉ (em P) _ _
        { assume hp; refine РѕерхбРѓЂ hp }
        { assume hnp; refine РѕерхбРѓѓ (h1 hnp) } } };
  rewrite eq; refine h
end;
