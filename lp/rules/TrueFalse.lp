// TRUE/FALSE (¬ІA.9) / STOP (¬ІA.10) / INS (¬ІA.11) вАФ shallow encoding
require open pp2lp.B pp2lp.Quant pp2lp.rules.Res;

// ---- TRUE (¬ІA.9) ----

// VR1: H вКҐ ¬ђTRUE вЗТ R
opaque symbol VR1 [R]
  : ѕА (¬ђ вК§ вЗТ R) вЙФ
begin
  assume R h;
  refine вК•вВС (h вК§бµҐ)
end;

// VR2: H вКҐ FALSE вЖТ H вКҐ ¬ђTRUE
opaque symbol VR2
  : ѕА вК•
  вЖТ ѕА (¬ђ вК§) вЙФ
begin
  assume h h0; refine h
end;

// VR3: H вКҐ R вЖТ H вКҐ TRUE вЗТ R
opaque symbol VR3 [R]
  : ѕА R
  вЖТ ѕА (вК§ вЗТ R) вЙФ
begin
  assume R h h0; refine h
end;

// VR4: H вКҐ TRUE
opaque symbol VR4
  : ѕА вК§ вЙФ
begin
  refine вК§бµҐ
end;

// ---- FALSE ----

// FX1: H вКҐ R вЖТ H вКҐ ¬ђFALSE вЗТ R
opaque symbol FX1 [R]
  : ѕА R
  вЖТ ѕА (¬ђ вК• вЗТ R) вЙФ
begin
  assume R h h0; refine h
end;

// FX2: H вКҐ ¬ђFALSE
opaque symbol FX2
  : ѕА (¬ђ вК•) вЙФ
begin
  assume h; refine h
end;

// FX3: H вКҐ FALSE вЗТ R
opaque symbol FX3 [R]
  : ѕА (вК• вЗТ R) вЙФ
begin
  assume R h; refine вК•вВС h
end;

// ---- STOP (¬ІA.10) ----

// STOP: P is not FALSE; H вКҐ ¬ђP вЗТ FALSE вЖТ H вКҐ P
opaque symbol STOP [P]
  : ѕА (¬ђ P вЗТ вК•)
  вЖТ ѕА P вЙФ
begin
  assume P h; refine ¬ђ¬ђвВС P h
end;

// ---- INS (¬ІA.11) ----
// No LP symbol вАФ the emitter resolves the instantiation contradiction
// directly from the hypothesis context, emitting:
//   refine !!_to_pi _ h_univ witness (вИІбµҐ hвВБ вА¶ hвВЩ)
// See translate.ml:find_ins_contradiction.

// ---- `_1` (Result-form) variants вАФ ¬І8.13 ----
//
// Schema 0 (rules without genuine antecedents, except STOP): Result is
// TRUE вАФ encoded as `mk_0 (eq lemma)` where the lemma is propositional.
// Schema 1 (passthrough): res_tm = child's res_tm.
// STOP_1 (Schema 0 special вАФ STOP'): Result is P (the goal itself).

// STOP_1: leaf of every chain. res_tm = P (the implicit goal).
symbol STOP_1 [P : Prop] : Res P
  вЙФ mk_res (вИО вИЈ P) (eq_refl P);

// VR1_1: ¬ђвК§ вЗТ R вЙ° вК• вЗТ R вЙ° вК§ вАФ ¬ђвК§ is absurd, vacuously вК§.
symbol VR1_1 [R : Prop] : Res (¬ђ вК§ вЗТ R) вЙФ mk_0 (prop_eq_top VR1);

// VR2_1: Schema 1 вАФ child's Res вК• becomes Res (¬ђвК§). Uses stdlib's
// `¬ђвК• : ѕА (¬ђвК• = вК§)` after swapping the direction.
symbol VR2_1
  (r : Res вК•) : Res (¬ђ вК§)
  вЙФ mk_0 trust;

// VR3_1: Schema 1 вАФ passthrough. Uses stdlib's `вК§вЗТ P : ѕА ((вК§ вЗТ P) = P)`.
symbol VR3_1 [P : Prop]
  (r : Res P) : Res (вК§ вЗТ P)
  вЙФ mk_1 (res_tm r) (eq_trans (вК§вЗТ P) (res_eq r));

// VR4_1: Schema 0 вАФ trivially `вК§ = вК§`.
symbol VR4_1 : Res вК§ вЙФ mk_0 (eq_refl вК§);

// FX1_1: Schema 1 вАФ passthrough through `¬ђвК• вЗТ R = R`.
symbol FX1_1 [R : Prop]
  (r : Res R) : Res (¬ђ вК• вЗТ R)
  вЙФ mk_1 (res_tm r) trust;

// FX2_1: Schema 0 вАФ `¬ђвК• = вК§` from stdlib.
symbol FX2_1 : Res (¬ђ вК•) вЙФ mk_0 ¬ђвК•;

// FX3_1: Schema 0 вАФ `вК• вЗТ R = вК§` from stdlib.
symbol FX3_1 [R : Prop] : Res (вК• вЗТ R) вЙФ mk_0 (вК•вЗТ R);

// INS_1: Schema 1 вАФ passthrough. The chain leaf is supplied by PP's
// instantiation phase; LP-side carries res_tm through.
symbol INS_1 [P : Prop]
  (r : Res вК•) : Res P
  вЙФ mk_0 trust;
