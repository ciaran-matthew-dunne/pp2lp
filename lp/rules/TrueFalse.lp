// TRUE/FALSE (¬ІA.9) / STOP (¬ІA.10) / INS (¬ІA.11) вАФ shallow encoding
require open pp2lp.B;

// ---- TRUE (¬ІA.9) ----

// VR1: H вКҐ ¬ђTRUE вЗТ R
opaque symbol VR1 [R]
  : ѕА (¬ђ вК§ вЗТ R) вЙФ
begin
  assume R h;
  refine вК•вВС (h вК§бµҐ)
end;

// VR2: H вКҐ FALSE вЖТ H вКҐ ¬ђTRUE
opaque symbol VR2
  : ѕА вК•
  вЖТ ѕА (¬ђ вК§) вЙФ
begin
  assume h h0; refine h
end;

// VR3: H вКҐ R вЖТ H вКҐ TRUE вЗТ R
opaque symbol VR3 [R]
  : ѕА R
  вЖТ ѕА (вК§ вЗТ R) вЙФ
begin
  assume R h h0; refine h
end;

// VR4: H вКҐ TRUE
opaque symbol VR4
  : ѕА вК§ вЙФ
begin
  refine вК§бµҐ
end;

// ---- FALSE ----

// FX1: H вКҐ R вЖТ H вКҐ ¬ђFALSE вЗТ R
opaque symbol FX1 [R]
  : ѕА R
  вЖТ ѕА (¬ђ вК• вЗТ R) вЙФ
begin
  assume R h h0; refine h
end;

// FX2: H вКҐ ¬ђFALSE
opaque symbol FX2
  : ѕА (¬ђ вК•) вЙФ
begin
  assume h; refine h
end;

// FX3: H вКҐ FALSE вЗТ R
opaque symbol FX3 [R]
  : ѕА (вК• вЗТ R) вЙФ
begin
  assume R h; refine вК•вВС h
end;

// ---- STOP (¬ІA.10) ----

// STOP: P is not FALSE; H вКҐ ¬ђP вЗТ FALSE вЖТ H вКҐ P
opaque symbol STOP [P]
  : ѕА (¬ђ P вЗТ вК•)
  вЖТ ѕА P вЙФ
begin
  assume P h; refine ¬ђ¬ђвВС P h
end;

// ---- Primed variants (equality-based) ----
// Results are predicates equivalent to the consequent.
// STOP_1: result = P (reflexivity).
// Schema 0 (leaf): result = вК§ (the goal is a tautology).
// Schema 1 (pass-through): consequent = antecedent, so transitivity.

opaque symbol STOP_1 [P : Prop]
  : ѕА (P = P) вЙФ
begin
  assume P; reflexivity
end;

// VR1_1: result = вК§. ¬ђвК§вЗТR is a tautology (¬ђвК§ is вК•).
opaque symbol VR1_1 [R : Prop]
  : ѕА ((¬ђ вК§ вЗТ R) = вК§) вЙФ
begin
  assume R; rewrite ¬ђвК§; refine вК•вЗТ R
end;

// VR2_1: pass-through. ¬ђвК§ = вК•.
opaque symbol VR2_1 [S : Prop]
  : ѕА (вК• = S)
  вЖТ ѕА (¬ђ вК§ = S) вЙФ
begin
  assume S h; rewrite ¬ђвК§; refine h
end;

// VR3_1: pass-through. (вК§ вЗТ R) = R.
opaque symbol VR3_1 [R S : Prop]
  : ѕА (R = S)
  вЖТ ѕА ((вК§ вЗТ R) = S) вЙФ
begin
  assume R S h; rewrite вК§вЗТ; refine h
end;

// VR4_1: result = вК§. вК§ = вК§.
opaque symbol VR4_1
  : ѕА (вК§ = вК§) вЙФ
begin
  reflexivity
end;

// FX1_1: pass-through. (¬ђвК• вЗТ R) = R.
opaque symbol FX1_1 [R S : Prop]
  : ѕА (R = S)
  вЖТ ѕА ((¬ђ вК• вЗТ R) = S) вЙФ
begin
  assume R S h; rewrite ¬ђвК•; rewrite вК§вЗТ; refine h
end;

// FX2_1: result = вК§. ¬ђвК• = вК§.
opaque symbol FX2_1
  : ѕА (¬ђ вК• = вК§) вЙФ
begin
  refine ¬ђвК•
end;

// FX3_1: result = вК§. (вК• вЗТ R) = вК§.
opaque symbol FX3_1 [R : Prop]
  : ѕА ((вК• вЗТ R) = вК§) вЙФ
begin
  assume R; refine вК•вЗТ R
end;

// ---- INS (¬ІA.11) ----

// INS: Determination of instantiations QвВБ,...,QвВЩ;
//      H вКҐ QвВБ вЗТ (QвВВ вЗТ ... (QвВЩ вЗТ FALSE)...) вЖТ H вКҐ FALSE
// The emitter resolves INS dynamically by finding the contradicting
// hypotheses (¬ђP and P) in context and applying modus ponens.
// The INS LP symbol is not used directly вАФ kept for reference.
opaque symbol INS [P Q : Prop]
  : ѕА P
  вЖТ ѕА (P вЗТ Q)
  вЖТ ѕА Q вЙФ
begin
  assume P Q hp hpq; refine hpq hp
end;
