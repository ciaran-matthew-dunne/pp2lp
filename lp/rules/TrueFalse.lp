// TRUE/FALSE (¬ßA.9) / STOP (¬ßA.10) / INS (¬ßA.11) ‚Äî shallow encoding
require open pp2lp.B pp2lp.Quant pp2lp.rules.Res;

// ---- TRUE (¬ßA.9) ----

// VR1: H ‚ä¢ ¬¨TRUE ‚áí R
opaque symbol VR1 [R]
  : œÄ (¬¨ ‚ä§ ‚áí R) ‚âî
begin
  assume R h;
  refine ‚ä•‚Çë (h ‚ä§·µ¢)
end;

// VR2: H ‚ä¢ FALSE ‚Üí H ‚ä¢ ¬¨TRUE
opaque symbol VR2
  : œÄ ‚ä•
  ‚Üí œÄ (¬¨ ‚ä§) ‚âî
begin
  assume h h0; refine h
end;

// VR3: H ‚ä¢ R ‚Üí H ‚ä¢ TRUE ‚áí R
opaque symbol VR3 [R]
  : œÄ R
  ‚Üí œÄ (‚ä§ ‚áí R) ‚âî
begin
  assume R h h0; refine h
end;

// VR4: H ‚ä¢ TRUE
opaque symbol VR4
  : œÄ ‚ä§ ‚âî
begin
  refine ‚ä§·µ¢
end;

// ---- FALSE ----

// FX1: H ‚ä¢ R ‚Üí H ‚ä¢ ¬¨FALSE ‚áí R
opaque symbol FX1 [R]
  : œÄ R
  ‚Üí œÄ (¬¨ ‚ä• ‚áí R) ‚âî
begin
  assume R h h0; refine h
end;

// FX2: H ‚ä¢ ¬¨FALSE
opaque symbol FX2
  : œÄ (¬¨ ‚ä•) ‚âî
begin
  assume h; refine h
end;

// FX3: H ‚ä¢ FALSE ‚áí R
opaque symbol FX3 [R]
  : œÄ (‚ä• ‚áí R) ‚âî
begin
  assume R h; refine ‚ä•‚Çë h
end;

// ---- STOP (¬ßA.10) ----

// STOP: P is not FALSE; H ‚ä¢ ¬¨P ‚áí FALSE ‚Üí H ‚ä¢ P
opaque symbol STOP [P]
  : œÄ (¬¨ P ‚áí ‚ä•)
  ‚Üí œÄ P ‚âî
begin
  assume P h; refine ¬¨¬¨‚Çë P h
end;

// ---- INS (¬ßA.11) ----
// No LP symbol ‚Äî the emitter resolves the instantiation contradiction
// directly from the hypothesis context, emitting:
//   refine !!_to_pi _ h_univ witness (‚àß·µ¢ h‚ÇÅ ‚Ä¶ h‚Çô)
// See translate.ml:find_ins_contradiction.

// ---- `_1` (Result-form) variants ‚Äî ¬ß8.13 ----
//
// Schema 0 (rules without genuine antecedents, except STOP): Result is
// TRUE ‚Äî encoded as `mk_0 (eq lemma)` where the lemma is propositional.
// Schema 1 (passthrough): res_tm = child's res_tm.
// STOP_1 (Schema 0 special ‚Äî STOP'): Result is P (the goal itself).

// STOP_1: leaf of every chain. res_tm = P (the implicit goal).
symbol STOP_1 [P : Prop] : Res P
  ‚âî mk_res (‚àé ‚à∑ P) (eq_refl P);

// VR1_1: ¬¨‚ä§ ‚áí R ‚â° ‚ä• ‚áí R ‚â° ‚ä§ ‚Äî ¬¨‚ä§ is absurd, vacuously ‚ä§.
symbol VR1_1 [R : Prop] : Res (¬¨ ‚ä§ ‚áí R) ‚âî mk_0 (prop_eq_top VR1);

// VR2_1: Schema 1 ‚Äî child's Res ‚ä• becomes Res (¬¨‚ä§) via ¬¨‚ä§ = ‚ä•.
// (The old `mk_0 trust` was wrong: it claimed ¬¨‚ä§ = ‚ä§; this is a Schema-1
// passthrough, so the result is the child's, bridged by `not_top_eq_bot`.)
symbol VR2_1
  (r : Res ‚ä•) : Res (¬¨ ‚ä§)
  ‚âî mk_1 (res_tm r) (eq_trans not_top_eq_bot (res_eq r));

// VR3_1: Schema 1 ‚Äî passthrough. Uses stdlib's `‚ä§‚áí P : œÄ ((‚ä§ ‚áí P) = P)`.
symbol VR3_1 [P : Prop]
  (r : Res P) : Res (‚ä§ ‚áí P)
  ‚âî mk_1 (res_tm r) (eq_trans (‚ä§‚áí P) (res_eq r));

// VR4_1: Schema 0 ‚Äî trivially `‚ä§ = ‚ä§`.
symbol VR4_1 : Res ‚ä§ ‚âî mk_0 (eq_refl ‚ä§);

// FX1_1: Schema 1 ‚Äî passthrough through `¬¨‚ä• ‚áí R = R`.
symbol FX1_1 [R : Prop]
  (r : Res R) : Res (¬¨ ‚ä• ‚áí R)
  ‚âî mk_1 (res_tm r) trust;

// FX2_1: Schema 0 ‚Äî `¬¨‚ä• = ‚ä§` from stdlib.
symbol FX2_1 : Res (¬¨ ‚ä•) ‚âî mk_0 ¬¨‚ä•;

// FX3_1: Schema 0 ‚Äî `‚ä• ‚áí R = ‚ä§` from stdlib.
symbol FX3_1 [R : Prop] : Res (‚ä• ‚áí R) ‚âî mk_0 (‚ä•‚áí R);

// INS_1: Schema 1 ‚Äî passthrough. The chain leaf is supplied by PP's
// instantiation phase; LP-side carries res_tm through.
symbol INS_1 [P : Prop]
  (r : Res ‚ä•) : Res P
  ‚âî mk_0 trust;
