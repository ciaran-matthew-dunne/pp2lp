// Res.lp ‚Äî helpers shared by the per-rule `_1` (Result) variants.
//
// Each `_1` rule lives in its own topic file (Conj.lp, Disj.lp, ‚Ä¶);
// this file collects the cross-cutting infrastructure they share:
//
//   - generic equality combinators (eq_trans, conj_eq, ‚àß_assoc, ‚Ä¶)
//   - per-connective equality lemmas (and1_eq, or1_eq, ‚Ä¶) ‚Äî these are
//     just propositional facts about the connective transformations
//     specified by ¬ßA of the PP rule reference
//   - special bridges (opr1_eq, opr2_eq, xst7_eq, xst8_eq, nrm1_eq)
//
// The `Res`, `mk_1`, `res_tm`, `res_eq` primitives themselves live in
// Quant.lp so that All.lp / Xst.lp can refer to them.

require open pp2lp.B pp2lp.ConjList pp2lp.Quant;

// ============================================================
// Generic equality combinators
// ============================================================

opaque symbol eq_trans [a] [P Q R : œÑ a]
  : œÄ (P = Q) ‚Üí œÄ (Q = R) ‚Üí œÄ (P = R) ‚âî
begin assume a P Q R h1 h2; rewrite h1; refine h2 end;

// A true proposition equals ‚ä§.  This is the Schema-0 result bridge
// (¬ß8.13): a rule "sans ant√©c√©dent v√©ritable" produces the result VRAI,
// which the spec requires to be *equivalent to the consequent P* ‚Äî here
// modulo the hypotheses H that license the rule's side-condition.  Given
// a proof of P (the hyp the rule looked up), `propExt` discharges `P = ‚ä§`.
opaque symbol prop_eq_top [P : Prop] (hp : œÄ P) : œÄ (P = ‚ä§) ‚âî
begin
  assume P hp;
  refine propExt _ _ _ _
  { assume h; refine ‚ä§·µ¢ }
  { assume h; refine hp }
end;

// ¬¨‚ä§ = ‚ä•, as a propositional equality (for VR2_1's Schema-1 passthrough).
opaque symbol not_top_eq_bot : œÄ ((¬¨ ‚ä§) = ‚ä•) ‚âî
begin
  refine propExt _ _ _ _
    { assume h; refine h ‚ä§·µ¢ }
    { assume h; refine ‚ä•‚Çë h }
end;

// Equality is commutative, as a propositional equality (for BOOL21/22_1).
opaque symbol eq_comm_prop [a] (x y : œÑ a) : œÄ ((x = y) = (y = x)) ‚âî
begin
  assume a x y;
  refine propExt _ _ (Œª h, eq_sym h) (Œª h, eq_sym h)
end;

// ¬¨¬¨A = A (classical) ‚Äî for the XST51/61_1 double-negation passthroughs.
opaque symbol not_not_eq [A : Prop] : œÄ ((¬¨ ¬¨ A) = A) ‚âî
begin assume A; refine propExt _ _ (Œª h, ¬¨¬¨‚Çë A h) (Œª h hn, hn h) end;

// (¬¨‚ä• ‚áí R) = R ‚Äî ¬¨‚ä• is provable, so the antecedent drops (FX1_1).
opaque symbol not_bot_imp_eq [R : Prop] : œÄ ((¬¨ ‚ä• ‚áí R) = R) ‚âî
begin assume R; refine propExt _ _ (Œª h, h (Œª b, b)) (Œª hr _, hr) end;

// ‚ãÄ(‚àé ‚à∑ X ‚à∑ Y) = (X ‚àß Y) ‚Äî the 2-element snoc conjunction is binary ‚àß (EQC2_1).
opaque symbol conj2_eq [X Y : Prop] : œÄ ((‚ãÄ (‚àé ‚à∑ X ‚à∑ Y)) = (X ‚àß Y)) ‚âî
begin
  assume X Y;
  refine propExt _ _
    (Œª h, ‚àß·µ¢ (‚ãÄ‚ÇÇ_hd h) (‚ãÄ‚ÇÇ_snd h))
    (Œª h, ‚ãÄ‚ÇÇ_intro (‚àß‚Çë‚ÇÅ h) (‚àß‚Çë‚ÇÇ h))
end;

// (a‚Ü¶b)=(c‚Ü¶d) = (a=c ‚àß b=d) ‚Äî pair injectivity (EQC1/2_1).
opaque symbol pair_eq_decomp [a b c d : œÑ Œπ]
  : œÄ (((a ‚Ü¶ b) = (c ‚Ü¶ d)) = ((a = c) ‚àß (b = d))) ‚âî
begin
  assume a b c d;
  refine propExt _ _
    (Œª h, pair_inj a b c d h)
    (Œª h, pair_cong a b c d (‚àß‚Çë‚ÇÅ h) (‚àß‚Çë‚ÇÇ h))
end;

// Conj congruence: lift independent equalities to their conjunction.
opaque symbol conj_eq [A B S1 S2 : Prop]
  : œÄ (A = S1) ‚Üí œÄ (B = S2) ‚Üí œÄ ((A ‚àß B) = (S1 ‚àß S2)) ‚âî
begin
  assume A B S1 S2 h1 h2;
  rewrite h1; rewrite h2; reflexivity
end;

// Conj associativity (right ‚Üî left), used by ALL7/XST8 continuations
// when the inner _1 chain produced a right-assoc conjunction.
opaque symbol ‚àß_assoc [A B C : Prop]
  : œÄ ((A ‚àß (B ‚àß C)) = ((A ‚àß B) ‚àß C)) ‚âî
begin
  assume A B C;
  refine propExt _ _ _ _
  { assume h; refine ‚àß·µ¢ (‚àß·µ¢ (‚àß‚Çë‚ÇÅ h) (‚àß‚Çë‚ÇÅ (‚àß‚Çë‚ÇÇ h))) (‚àß‚Çë‚ÇÇ (‚àß‚Çë‚ÇÇ h)) }
  { assume h; refine ‚àß·µ¢ (‚àß‚Çë‚ÇÅ (‚àß‚Çë‚ÇÅ h)) (‚àß·µ¢ (‚àß‚Çë‚ÇÇ (‚àß‚Çë‚ÇÅ h)) (‚àß‚Çë‚ÇÇ h)) }
end;

// Antecedent equivalence ‚Üí implication equality (for AND5_1).
opaque symbol ante_cong [C C' R : Prop]
  : (œÄ C ‚Üí œÄ C') ‚Üí (œÄ C' ‚Üí œÄ C) ‚Üí œÄ ((C ‚áí R) = (C' ‚áí R)) ‚âî
begin
  assume C C' R fwd bwd;
  refine propExt _ _ _ _
    { assume h hc'; refine h (bwd hc') }
    { assume h hc; refine h (fwd hc) }
end;

// Implication right congruence.
opaque symbol imp_cong_r [P Q R : Prop]
  : œÄ (Q = R) ‚Üí œÄ ((P ‚áí Q) = (P ‚áí R)) ‚âî
begin assume P Q R h; rewrite h; reflexivity end;

// Implication left congruence.
opaque symbol imp_cong_l [P P' Q : Prop]
  : œÄ (P = P') ‚Üí œÄ ((P ‚áí Q) = (P' ‚áí Q)) ‚âî
begin assume P P' Q h; rewrite h; reflexivity end;

// Negation congruence.
opaque symbol not_cong [A B : Prop]
  : œÄ (A = B) ‚Üí œÄ ((¬¨ A) = (¬¨ B)) ‚âî
begin assume A B h; rewrite h; reflexivity end;

// Snoc-list last-element congruence: rewrite the final conjunct of a `‚ãÄ`.
opaque symbol conj_snoc_last_cong [ps : ùïÉ* o] [P Q : Prop]
  : œÄ (P = Q) ‚Üí œÄ (‚ãÄ (ps ‚à∑ P) = ‚ãÄ (ps ‚à∑ Q)) ‚âî
begin assume ps P Q h; rewrite h; reflexivity end;

// Swap the last two conjuncts.  With [conj_init_cong] below this bubbles a
// conjunct to the end of the list ‚Äî the emitter rotates an NRM20/21 pinning
// equality into tail position before applying the tail-form lemmas.
opaque symbol conj_swap_last2 [ps : ùïÉ* o] [P Q : Prop]
  : œÄ (‚ãÄ (ps ‚à∑ P ‚à∑ Q) = ‚ãÄ (ps ‚à∑ Q ‚à∑ P)) ‚âî
begin
  assume ps P Q;
  refine propExt _ _ _ _
  { assume h;
    refine ‚ãÄ_intro (‚ãÄ_intro (‚ãÄ_init (‚ãÄ_init h)) (‚ãÄ_last h))
                   (‚ãÄ_last (‚ãÄ_init h)) }
  { assume h;
    refine ‚ãÄ_intro (‚ãÄ_intro (‚ãÄ_init (‚ãÄ_init h)) (‚ãÄ_last h))
                   (‚ãÄ_last (‚ãÄ_init h)) }
end;

// Init congruence: rewrite everything *below* the last conjunct.
opaque symbol conj_init_cong [ps qs : ùïÉ* o] [P : Prop]
  : œÄ (‚ãÄ ps = ‚ãÄ qs) ‚Üí œÄ (‚ãÄ (ps ‚à∑ P) = ‚ãÄ (qs ‚à∑ P)) ‚âî
begin
  assume ps qs P h;
  refine propExt _ _ _ _
  { assume hc; refine ‚ãÄ_intro (=‚áí h (‚ãÄ_init hc)) (‚ãÄ_last hc) }
  { assume hc; refine ‚ãÄ_intro (=‚áí (eq_sym h) (‚ãÄ_init hc)) (‚ãÄ_last hc) }
end;

// Strip a known antecedent: œÄ P ‚Üí ((P ‚áí Q) = Q).
opaque symbol imp_known_drop [P Q : Prop]
  : œÄ P ‚Üí œÄ ((P ‚áí Q) = Q) ‚âî
begin
  assume P Q hp;
  refine propExt _ _ _ _
  { assume hpq; refine hpq hp }
  { assume hq hp2; refine hq }
end;

// LHS-of-‚â§-zero congruence (for AR9_1).
opaque symbol leq_zero_eq [E F : œÑ Œπ]
  : œÄ (E = F) ‚Üí œÄ ((E ‚â§ ùüé) = (F ‚â§ ùüé)) ‚âî
begin assume E F h; rewrite h; reflexivity end;

// ============================================================
// Per-connective equality lemmas (¬ßA.1‚ÄìA.5, A.13)
//
// The AND lemmas decompose the snoc conjunction `‚ãÄ (ps ‚à∑ P)` into init
// `‚ãÄ ps` and last `P`.  Proved directly from the ConjList eliminators:
// build the conjunction with `‚ãÄ_intro hps hp` and destruct it with
// `‚ãÄ_init`/`‚ãÄ_last`, in place of the `‚àß·µ¢`/`‚àß‚Çë‚ÇÅ`/`‚àß‚Çë‚ÇÇ` of the OR/IMP lemmas.
// ============================================================

// AND1: (¬¨‚ãÄ(ps‚à∑P)‚áíR) = ((¬¨P‚áíR) ‚àß (¬¨‚ãÄps‚áíR))   [last-first]
opaque symbol and1_eq [ps : ùïÉ* o] [P R : Prop]
  : œÄ ((¬¨ ‚ãÄ (ps ‚à∑ P) ‚áí R) = ((¬¨ P ‚áí R) ‚àß (¬¨ ‚ãÄ ps ‚áí R))) ‚âî
begin
  assume ps P R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢
        (Œª hnp, h (Œª hand, hnp (‚ãÄ_last hand)))
        (Œª hni, h (Œª hand, hni (‚ãÄ_init hand))) }
    { assume h hnand;
      have hnand2 : œÄ (¬¨ (‚ãÄ ps ‚àß P))
        { assume hand; refine hnand (‚ãÄ_intro (‚àß‚Çë‚ÇÅ hand) (‚àß‚Çë‚ÇÇ hand)) };
      have hor : œÄ (¬¨ ‚ãÄ ps ‚à® ¬¨ P)
        { refine =‚áí (deMorgan_‚àß (‚ãÄ ps) P) hnand2 };
      refine ‚à®‚Çë hor _ _
        { assume hni; refine ‚àß‚Çë‚ÇÇ h hni }
        { assume hnp; refine ‚àß‚Çë‚ÇÅ h hnp } }
end;

// AND2: ¬¨‚ãÄ(ps‚à∑P) = (‚ãÄps ‚áí ¬¨P)
opaque symbol and2_eq [ps : ùïÉ* o] [P : Prop]
  : œÄ (¬¨ ‚ãÄ (ps ‚à∑ P) = (‚ãÄ ps ‚áí ¬¨ P)) ‚âî
begin
  assume ps P;
  refine propExt _ _ _ _
    { assume h hps hp; refine h (‚ãÄ_intro hps hp) }
    { assume h hand; refine h (‚ãÄ_init hand) (‚ãÄ_last hand) }
end;

// AND3: (‚ãÄ(ps‚à∑P)‚áíR) = (‚ãÄps ‚áí (P‚áíR))
opaque symbol and3_eq [ps : ùïÉ* o] [P R : Prop]
  : œÄ ((‚ãÄ (ps ‚à∑ P) ‚áí R) = (‚ãÄ ps ‚áí (P ‚áí R))) ‚âî
begin
  assume ps P R;
  refine propExt _ _ _ _
    { assume h hps hp; refine h (‚ãÄ_intro hps hp) }
    { assume h hand; refine h (‚ãÄ_init hand) (‚ãÄ_last hand) }
end;

// AND4: ‚ãÄ(ps‚à∑P) = (P ‚àß ‚ãÄps)   [last-first reordering for AND4_1]
opaque symbol and4_eq [ps : ùïÉ* o] [P : Prop]
  : œÄ (‚ãÄ (ps ‚à∑ P) = (P ‚àß ‚ãÄ ps)) ‚âî
begin
  assume ps P;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢ (‚ãÄ_last h) (‚ãÄ_init h) }
    { assume h; refine ‚ãÄ_intro (‚àß‚Çë‚ÇÇ h) (‚àß‚Çë‚ÇÅ h) }
end;

// OR1: ¬¨(P‚à®Q)‚áíR = (¬¨P‚áí¬¨Q‚áíR)
opaque symbol or1_eq [P Q R : Prop]
  : œÄ ((¬¨ (P ‚à® Q) ‚áí R) = (¬¨ P ‚áí (¬¨ Q ‚áí R))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h1 hnp hnq;
      have hnpq : œÄ (¬¨ (P ‚à® Q))
        { assume hpq; refine ‚à®‚Çë hpq _ _
          { assume hp; refine hnp hp }
          { assume hq; refine hnq hq } };
      refine h1 hnpq }
    { assume h1 hnpq;
      have hnpnq : œÄ (¬¨ P ‚àß ¬¨ Q) { refine =‚áí (deMorgan_‚à® P Q) hnpq };
      refine h1 (‚àß‚Çë‚ÇÅ hnpnq) (‚àß‚Çë‚ÇÇ hnpnq) }
end;

// OR2: ¬¨(P‚à®Q) = (¬¨Q ‚àß ¬¨P)
opaque symbol or2_eq [P Q : Prop]
  : œÄ (¬¨ (P ‚à® Q) = (¬¨ Q ‚àß ¬¨ P)) ‚âî
begin
  assume P Q;
  rewrite deMorgan_‚à®;
  rewrite ‚àß_com;
  reflexivity
end;

// OR3: (P‚à®Q)‚áíR = (Q‚áíR) ‚àß (P‚áíR)
opaque symbol or3_eq [P Q R : Prop]
  : œÄ (((P ‚à® Q) ‚áí R) = ((Q ‚áí R) ‚àß (P ‚áí R))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢ (Œª hq, h (‚à®·µ¢‚ÇÇ hq)) (Œª hp, h (‚à®·µ¢‚ÇÅ hp)) }
    { assume h hpq; refine ‚à®‚Çë hpq _ _
      { assume hp; refine ‚àß‚Çë‚ÇÇ h hp }
      { assume hq; refine ‚àß‚Çë‚ÇÅ h hq } }
end;

// OR4: P‚à®Q = (¬¨P‚áíQ). P, Q explicit to avoid HO-unification issues.
opaque symbol or4_eq (P Q : Prop)
  : œÄ ((P ‚à® Q) = (¬¨ P ‚áí Q)) ‚âî
begin
  assume P Q;
  refine propExt _ _ _ _
    { assume hpq hnp; refine ‚à®‚Çë hpq _ _
      { assume hp; refine ‚ä•‚Çë (hnp hp) }
      { assume hq; refine hq } }
    { assume h1; refine ‚à®‚Çë (em P) _ _
      { assume hp; refine ‚à®·µ¢‚ÇÅ hp }
      { assume hnp; refine ‚à®·µ¢‚ÇÇ (h1 hnp) } }
end;

// IMP1: ¬¨(P‚áíQ)‚áíR = (P‚áí¬¨Q‚áíR)
opaque symbol imp1_eq [P Q R : Prop]
  : œÄ ((¬¨ (P ‚áí Q) ‚áí R) = (P ‚áí (¬¨ Q ‚áí R))) ‚âî
begin
  assume P Q R;
  rewrite ¬¨‚áí=‚àß¬¨;
  refine propExt _ _ _ _
    { assume h1 hp hnq; refine h1 (‚àß·µ¢ hp hnq) }
    { assume h1 h2; refine h1 (‚àß‚Çë‚ÇÅ h2) (‚àß‚Çë‚ÇÇ h2) }
end;

// IMP2: ¬¨(P‚áíQ) = (¬¨Q ‚àß P)
opaque symbol imp2_eq [P Q : Prop]
  : œÄ (¬¨ (P ‚áí Q) = (¬¨ Q ‚àß P)) ‚âî
begin
  assume P Q;
  rewrite ¬¨‚áí=‚àß¬¨;
  rewrite ‚àß_com;
  reflexivity
end;

// IMP3: (P‚áíQ)‚áíR = (Q‚áíR) ‚àß (¬¨P‚áíR)
opaque symbol imp3_eq [P Q R : Prop]
  : œÄ (((P ‚áí Q) ‚áí R) = ((Q ‚áí R) ‚àß (¬¨ P ‚áí R))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢
      (Œª hq, h (Œª h0, hq))
      (Œª hnp, h (Œª hp, ‚ä•‚Çë (hnp hp))) }
    { assume h hpq; refine ‚à®‚Çë (em P) _ _
      { assume hp; refine ‚àß‚Çë‚ÇÅ h (hpq hp) }
      { assume hnp; refine ‚àß‚Çë‚ÇÇ h hnp } }
end;

// EQV1: ¬¨(P‚áîQ)‚áíR = (P‚áí¬¨Q‚áíR) ‚àß (¬¨P‚áíQ‚áíR)
opaque symbol eqv1_eq [P Q R : Prop]
  : œÄ ((¬¨ (P ‚áî Q) ‚áí R) = ((P ‚áí (¬¨ Q ‚áí R)) ‚àß (¬¨ P ‚áí (Q ‚áí R)))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢
      (Œª hp hnq, h (Œª heqv, hnq (‚àß‚Çë‚ÇÅ heqv hp)))
      (Œª hnp hq, h (Œª heqv, hnp (‚àß‚Çë‚ÇÇ heqv hq))) }
    { assume h hneqv;
      refine ‚à®‚Çë (em P) _ _
      { assume hp; refine ‚à®‚Çë (em Q) _ _
        { assume hq;
          have heqv : œÄ (P ‚áî Q) { refine ‚àß·µ¢ (Œª h0, hq) (Œª h0, hp) };
          refine ‚ä•‚Çë (hneqv heqv) }
        { assume hnq; refine ‚àß‚Çë‚ÇÅ h hp hnq } }
      { assume hnp; refine ‚à®‚Çë (em Q) _ _
        { assume hq; refine ‚àß‚Çë‚ÇÇ h hnp hq }
        { assume hnq;
          have heqv : œÄ (P ‚áî Q)
            { refine ‚àß·µ¢ (Œª hp, ‚ä•‚Çë (hnp hp)) (Œª hq, ‚ä•‚Çë (hnq hq)) };
          refine ‚ä•‚Çë (hneqv heqv) } } }
end;

// EQV2: ¬¨(P‚áîQ) = (P‚áí¬¨Q) ‚àß (¬¨Q‚áíP)
opaque symbol eqv2_eq [P Q : Prop]
  : œÄ (¬¨ (P ‚áî Q) = ((P ‚áí ¬¨ Q) ‚àß (¬¨ Q ‚áí P))) ‚âî
begin
  assume P Q;
  refine propExt _ _ _ _
    { assume hneqv;
      refine ‚àß·µ¢
        (Œª hp hq,
          hneqv (‚àß·µ¢ (Œª h0, hq) (Œª h0, hp)))
        (Œª hnq, ¬¨¬¨‚Çë P (Œª hnp,
          hneqv (‚àß·µ¢ (Œª hp, ‚ä•‚Çë (hnp hp)) (Œª hq, ‚ä•‚Çë (hnq hq))))) }
    { assume hand heqv;
      refine ‚à®‚Çë (em Q) _ _
        { assume hq; refine ‚àß‚Çë‚ÇÅ hand (‚àß‚Çë‚ÇÇ heqv hq) hq }
        { assume hnq;
          have hp : œÄ P { refine ‚àß‚Çë‚ÇÇ hand hnq };
          have hq : œÄ Q { refine ‚àß‚Çë‚ÇÅ heqv hp };
          refine hnq hq } }
end;

// EQV3: (P‚áîQ)‚áíR = (P‚áíQ‚áíR) ‚àß (¬¨P‚áí¬¨Q‚áíR)
opaque symbol eqv3_eq [P Q R : Prop]
  : œÄ (((P ‚áî Q) ‚áí R) = ((P ‚áí (Q ‚áí R)) ‚àß (¬¨ P ‚áí (¬¨ Q ‚áí R)))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢
      (Œª hp hq, h (‚àß·µ¢ (Œª h0, hq) (Œª h0, hp)))
      (Œª hnp hnq, h (‚àß·µ¢
        (Œª hp, ‚ä•‚Çë (hnp hp))
        (Œª hq, ‚ä•‚Çë (hnq hq)))) }
    { assume h heqv;
      refine ‚à®‚Çë (em P) _ _
      { assume hp;
        have hq : œÄ Q { refine ‚àß‚Çë‚ÇÅ heqv hp };
        refine ‚àß‚Çë‚ÇÅ h hp hq }
      { assume hnp;
        refine ‚à®‚Çë (em Q) _ _
        { assume hq;
          have hp : œÄ P { refine ‚àß‚Çë‚ÇÇ heqv hq };
          refine ‚ä•‚Çë (hnp hp) }
        { assume hnq; refine ‚àß‚Çë‚ÇÇ h hnp hnq } } }
end;

// EQV4: (P‚áîQ) = (P‚áíQ) ‚àß (Q‚áíP). Definitional in stdlib (‚áî ‚âî Œªp q, ‚Ä¶).
opaque symbol eqv4_eq [P Q : Prop]
  : œÄ ((P ‚áî Q) = ((P ‚áí Q) ‚àß (Q ‚áí P))) ‚âî
begin assume P Q; reflexivity end;

// NOT1: ¬¨¬¨P‚áíR = (P‚áíR)
opaque symbol not1_eq [P R : Prop]
  : œÄ ((¬¨ ¬¨ P ‚áí R) = (P ‚áí R)) ‚âî
begin
  assume P R;
  refine propExt _ _ _ _
    { assume h1 hp; refine h1 (Œª hnp, hnp hp) }
    { assume h1 hnnp; refine h1 (¬¨¬¨‚Çë P hnnp) }
end;

// EVR3: (E=E)‚áíP = P
opaque symbol evr3_eq [E : œÑ Œπ] [P : Prop]
  : œÄ (((E = E) ‚áí P) = P) ‚âî
begin
  assume E P;
  refine propExt _ _ _ _
    { assume h1; refine h1 (eq_refl E) }
    { assume h1 h2; refine h1 }
end;

// ============================================================
// Special bridges (OPR1/OPR2, XST7/XST8, NRM1)
// ============================================================

// OPR1 bridge: (x=E ‚áí P x) = (x=E ‚áí P E). Holds pointwise: when x=E
// is true, both sides reduce to P E; when false, both are vacuously ‚ä§.
opaque symbol opr1_eq [E : œÑ Œπ] (P : œÑ Œπ ‚Üí Prop) (x : œÑ Œπ)
  : œÄ ((x = E ‚áí P x) = (x = E ‚áí P E)) ‚âî
begin
  assume E P x;
  refine propExt _ _ _ _
    { assume hyp hxe; have px : œÄ (P x) { refine hyp hxe };
      rewrite left hxe; refine px }
    { assume hyp hxe; have pe : œÄ (P E) { refine hyp hxe };
      rewrite hxe; refine pe }
end;

// OPR2 bridge: (E=x ‚áí P x) = (E=x ‚áí P E).
opaque symbol opr2_eq [E : œÑ Œπ] (P : œÑ Œπ ‚Üí Prop) (x : œÑ Œπ)
  : œÄ ((E = x ‚áí P x) = (E = x ‚áí P E)) ‚âî
begin
  assume E P x;
  refine propExt _ _ _ _
    { assume hyp hex; have px : œÄ (P x) { refine hyp hex };
      rewrite hex; refine px }
    { assume hyp hex; have pe : œÄ (P E) { refine hyp hex };
      rewrite left hex; refine pe }
end;

// XST7: ((‚àÉ-block, P) ‚áí R) = (‚àÄ-block, P ‚áí R)
opaque symbol xst7_eq [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : œÄ (((`?? v, P v) ‚áí R) = (`!! v, P v ‚áí R)) ‚âî
begin
  assume n P R;
  refine propExt _ _ _ _
    { assume hir; refine pi_to_!! _
        (Œª v hPv, hir (pi_to_??_intro P v hPv)) }
    { assume hall hex; refine pi_to_??_elim P
        (Œª v hpv, !!_to_pi (Œª v, P v ‚áí R) hall v hpv) hex }
end;

// XST6: ¬¨(‚àÉ-block, P) = (‚àÄ-block, ¬¨P)  (quantifier De Morgan).
opaque symbol xst6_eq [n] [P : Tuple n ‚Üí Prop]
  : œÄ ((¬¨ (`?? v, P v)) = (`!! v, ¬¨ (P v))) ‚âî
begin
  assume n P;
  refine propExt _ _ _ _
    { assume hne; refine pi_to_!! (Œª v, ¬¨ (P v))
        (Œª v hpv, hne (pi_to_??_intro P v hpv)) }
    { assume hall hex; refine pi_to_??_elim P
        (Œª v hpv, !!_to_pi (Œª v, ¬¨ (P v)) hall v hpv) hex }
end;

// XST61: ¬¨(‚àÉv¬∑¬¨P v) = (‚àÄv¬∑P v) ‚Äî quantifier De Morgan then double negation.
opaque symbol xst61_eq [n] [P : Tuple n ‚Üí Prop]
  : œÄ ((¬¨ (`?? v, ¬¨ (P v))) = (`!! v, P v)) ‚âî
begin
  assume n P;
  refine eq_trans xst6_eq (!!_cong (Œª v, not_not_eq))
end;

// XST8: (‚àÉ-block, P) = ((‚àÄ-block, ¬¨P) ‚áí ‚ä•)
opaque symbol xst8_eq [n] [P : Tuple n ‚Üí Prop]
  : œÄ ((`?? v, P v) = ((`!! v, ¬¨ (P v)) ‚áí ‚ä•)) ‚âî
begin
  assume n P;
  refine propExt _ _ _ _
    { assume hex hall; refine pi_to_??_elim P
        (Œª v hpv, !!_to_pi (Œª v, ¬¨ (P v)) hall v hpv) hex }
    { assume hc; refine ¬¨¬¨‚Çë _ (Œª hne,
        hc (pi_to_!! (Œª v, ¬¨ (P v))
              (Œª v hpv, hne (pi_to_??_intro P v hpv)))) }
end;

// NRM1 bridge: ((‚ô¢_:Tuple n, P) ‚áí Q) = (P ‚áí Q) when P is x-free.
opaque symbol nrm1_eq [n] [P Q : Prop]
  : œÄ (((`‚ô¢ _ : Tuple n, P) ‚áí Q) = (P ‚áí Q)) ‚âî
begin
  assume n P Q;
  have h1 : œÄ ((`‚ô¢ _ : Tuple n, P) = P)
    { refine eq_trans (‚ô¢_eq_!! (Œª _ : Tuple n, P)) (!!_const [n] P) };
  rewrite h1; reflexivity
end;

// NRM14 bridge: ((‚ô¢v¬∑¬¨P v) ‚áí R) = ((‚ô°v¬∑¬¨(‚ä§ ‚àß P v)) ‚áí R).  ‚ä§ ‚àß X ‚ü∫ X, so the
// ‚ä§-padded ‚ô° body matches the bare ‚ô¢ body; ‚ô¢/‚ô° both reduce to !!, so !!_cong
// lifts the per-v equality.  Used by NRM14_1 (the chain-form NRM14).
opaque symbol nrm14_eq [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : œÄ (((`‚ô¢ v, ¬¨ (P v)) ‚áí R) = ((`‚ô° v, ¬¨ ‚ãÄ_snoc ‚ä§ (P v)) ‚áí R)) ‚âî
begin
  assume n P R;
  have hbody : ŒÝ v, œÄ ((¬¨ (P v)) = (¬¨ ‚ãÄ_snoc ‚ä§ (P v)))
    { assume v;
      refine propExt _ _
        (Œª hnp hcon, hnp (‚ãÄ‚ÇÇ_snd hcon))
        (Œª hncon hp, hncon (‚ãÄ‚ÇÇ_intro ‚ä§·µ¢ hp)) };
  have hpred : œÄ ((`‚ô¢ v, ¬¨ (P v)) = (`‚ô° v, ¬¨ ‚ãÄ_snoc ‚ä§ (P v)))
    { refine eq_trans (‚ô¢_eq_!! (Œª v, ¬¨ (P v)))
        (eq_trans (!!_cong hbody)
                  (eq_sym (‚ô°_eq_!! (Œª v, ¬¨ ‚ãÄ_snoc ‚ä§ (P v))))) };
  rewrite hpred; reflexivity
end;

// NRM13 bridge: ((‚ô¢v¬∑(P v ‚áí Q v)) ‚áí R) = ((‚ô°v¬∑¬¨(P v ‚àß ¬¨Q v)) ‚áí R).  The body
// equivalence (P‚áíQ) ‚ü∫ ¬¨(P ‚àß ¬¨Q) is classical (needs `em` on Q v); ‚ô¢/‚ô° both
// reduce to !!, so !!_cong lifts it.  Used by NRM13_1 (the chain-form NRM13).
opaque symbol nrm13_eq [n] [P Q : Tuple n ‚Üí Prop] [R : Prop]
  : œÄ (((`‚ô¢ v, P v ‚áí Q v) ‚áí R) = ((`‚ô° v, ¬¨ ‚ãÄ_snoc (P v) (¬¨ Q v)) ‚áí R)) ‚âî
begin
  assume n P Q R;
  have hbody : ŒÝ v, œÄ ((P v ‚áí Q v) = (¬¨ ‚ãÄ_snoc (P v) (¬¨ Q v)))
    { assume v;
      refine propExt _ _
        (Œª hpq hcon, (‚ãÄ‚ÇÇ_snd hcon) (hpq (‚ãÄ‚ÇÇ_hd hcon)))
        (Œª hncon hp, ‚à®‚Çë (em (Q v)) (Œª hq, hq)
                       (Œª hnq, ‚ä•‚Çë (hncon (‚ãÄ‚ÇÇ_intro hp hnq)))) };
  have hpred : œÄ ((`‚ô¢ v, P v ‚áí Q v) = (`‚ô° v, ¬¨ ‚ãÄ_snoc (P v) (¬¨ Q v)))
    { refine eq_trans (‚ô¢_eq_!! (Œª v, P v ‚áí Q v))
        (eq_trans (!!_cong hbody)
                  (eq_sym (‚ô°_eq_!! (Œª v, ¬¨ ‚ãÄ_snoc (P v) (¬¨ Q v))))) };
  rewrite hpred; reflexivity
end;

// NRM12 bridge: ((‚ô¢v¬∑(P v ‚áí ¬¨Q v)) ‚áí R) = ((‚ô°v¬∑¬¨(P v ‚àß Q v)) ‚áí R).  The body
// equivalence (P ‚áí ¬¨Q) ‚ü∫ ¬¨(P ‚àß Q) is constructive.  Used by NRM12_1.
opaque symbol nrm12_eq [n] [P Q : Tuple n ‚Üí Prop] [R : Prop]
  : œÄ (((`‚ô¢ v, P v ‚áí ¬¨ (Q v)) ‚áí R) = ((`‚ô° v, ¬¨ ‚ãÄ_snoc (P v) (Q v)) ‚áí R)) ‚âî
begin
  assume n P Q R;
  have hbody : ŒÝ v, œÄ ((P v ‚áí ¬¨ (Q v)) = (¬¨ ‚ãÄ_snoc (P v) (Q v)))
    { assume v;
      refine propExt _ _
        (Œª hpnq hcon, (hpnq (‚ãÄ‚ÇÇ_hd hcon)) (‚ãÄ‚ÇÇ_snd hcon))
        (Œª hncon hp hq, hncon (‚ãÄ‚ÇÇ_intro hp hq)) };
  have hpred : œÄ ((`‚ô¢ v, P v ‚áí ¬¨ (Q v)) = (`‚ô° v, ¬¨ ‚ãÄ_snoc (P v) (Q v)))
    { refine eq_trans (‚ô¢_eq_!! (Œª v, P v ‚áí ¬¨ (Q v)))
        (eq_trans (!!_cong hbody)
                  (eq_sym (‚ô°_eq_!! (Œª v, ¬¨ ‚ãÄ_snoc (P v) (Q v))))) };
  rewrite hpred; reflexivity
end;

// NRM15 bridge: ((‚ô¢v¬∑P v) ‚áí R) = ((‚ô°v¬∑¬¨(‚ä§ ‚àß ¬¨P v)) ‚áí R).  The body
// equivalence P ‚ü∫ ¬¨(‚ä§ ‚àß ¬¨P) is classical (¬¨¬¨‚Çë).  Used by NRM15_1.
opaque symbol nrm15_eq [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : œÄ (((`‚ô¢ v, P v) ‚áí R) = ((`‚ô° v, ¬¨ ‚ãÄ_snoc ‚ä§ (¬¨ (P v))) ‚áí R)) ‚âî
begin
  assume n P R;
  have hbody : ŒÝ v, œÄ ((P v) = (¬¨ ‚ãÄ_snoc ‚ä§ (¬¨ (P v))))
    { assume v;
      refine propExt _ _
        (Œª hp hcon, (‚ãÄ‚ÇÇ_snd hcon) hp)
        (Œª hncon, ¬¨¬¨‚Çë (P v) (Œª hnp, hncon (‚ãÄ‚ÇÇ_intro ‚ä§·µ¢ hnp))) };
  have hpred : œÄ ((`‚ô¢ v, P v) = (`‚ô° v, ¬¨ ‚ãÄ_snoc ‚ä§ (¬¨ (P v))))
    { refine eq_trans (‚ô¢_eq_!! (Œª v, P v))
        (eq_trans (!!_cong hbody)
                  (eq_sym (‚ô°_eq_!! (Œª v, ¬¨ ‚ãÄ_snoc ‚ä§ (¬¨ (P v)))))) };
  rewrite hpred; reflexivity
end;

// NRM23 bridge: ((‚ô°v:Tuple1¬∑¬¨(‚ä§ ‚àß (E = prj 0 v))) ‚áí Q) = (¬¨‚ä§ ‚áí Q).  The ‚ô° body
// is ¬¨(E = prj 0 v); over Tuple 1 the witness v = unit‚®æE makes it absurd, so the
// quantified head collapses to ¬¨‚ä§.  Used by NRM23_1 (the chain-form NRM23).
opaque symbol nrm23_eq [Q : Prop] (E : œÑ Œπ)
  : œÄ (((`‚ô° v : Tuple 1, ¬¨ ‚ãÄ (‚àé ‚à∑ ‚ä§ ‚à∑ (E = prj 0 v))) ‚áí Q) = (¬¨ ‚ä§ ‚áí Q)) ‚âî
begin
  assume Q E;
  have hpred : œÄ ((`‚ô° v : Tuple 1, ¬¨ ‚ãÄ (‚àé ‚à∑ ‚ä§ ‚à∑ (E = prj 0 v))) = ¬¨ ‚ä§)
    { refine propExt _ _
        (Œª h‚ô° ht, ‚ô°_to_pi (Œª v : Tuple 1, ¬¨ ‚ãÄ (‚àé ‚à∑ ‚ä§ ‚à∑ (E = prj 0 v)))
                          h‚ô° (unit ‚®æ E) (‚ãÄ‚ÇÇ_intro ht (eq_refl E)))
        (Œª hn‚ä§, ‚ä•‚Çë (hn‚ä§ ‚ä§·µ¢)) };
  rewrite hpred; reflexivity
end;

// NRM22 bridge, general form: the ‚ô°-body's *tail* equality pins the
// binder (`¬¨(‚ãÄ(ps v) ‚àß (prj 0 v = E))` ‚ü∫ the body refuted at v := E), so
// the quantified head collapses to `¬¨ ‚ãÄ (ps (unit ‚®æ E))`.  The body is a
// *list* `ps v ‚à∑ (prj 0 v = E)` so the cons pattern unifies with any
// conjunct count; the ‚ä§-headed shape is the instance ps := Œª _, (‚àé ‚à∑ ‚ä§).
// The ‚áê direction needs the per-constructor case split, so it goes
// through a helper with a rewrite rule on `(unit ‚®æ a)` (the
// nested_to_compound pattern).
symbol nrm22_pin (ps : Tuple 1 ‚Üí ùïÉ* o) (E : œÑ Œπ)
  (hnp : œÄ (¬¨ ‚ãÄ (ps (unit ‚®æ E))))
  : ŒÝ v : Tuple 1, œÄ (¬¨ ‚ãÄ (ps v ‚à∑ (prj 0 v = E)));
rule nrm22_pin $ps $E $hnp (unit ‚®æ $a) ‚Ü™
  Œª hcon, $hnp (ind_eq (eq_sym (‚ãÄ_last hcon))
                       (Œª z, ‚ãÄ ($ps (unit ‚®æ z)))
                       (‚ãÄ_init hcon));

opaque symbol nrm22_eq [Q : Prop] [ps : Tuple 1 ‚Üí ùïÉ* o] (E : œÑ Œπ)
  : œÄ (((`‚ô° v : Tuple 1, ¬¨ ‚ãÄ (ps v ‚à∑ (prj 0 v = E))) ‚áí Q)
       = ((¬¨ ‚ãÄ (ps (unit ‚®æ E))) ‚áí Q)) ‚âî
begin
  assume Q ps E;
  have hpred : œÄ ((`‚ô° v : Tuple 1, ¬¨ ‚ãÄ (ps v ‚à∑ (prj 0 v = E)))
                  = (¬¨ ‚ãÄ (ps (unit ‚®æ E))))
    { refine propExt _ _
        (Œª h‚ô° hps, ‚ô°_to_pi (Œª v : Tuple 1, ¬¨ ‚ãÄ (ps v ‚à∑ (prj 0 v = E)))
                           h‚ô° (unit ‚®æ E) (‚ãÄ_intro hps (eq_refl E)))
        (Œª hnp, pi_to_‚ô° (Œª v : Tuple 1, ¬¨ ‚ãÄ (ps v ‚à∑ (prj 0 v = E)))
                        (nrm22_pin ps E hnp)) };
  rewrite hpred; reflexivity
end;
