// Res.lp ‚Äî Œ£-type encoding of normalisation chains, self-contained.
//
// `Res t = (t' : œÑ a) √ó œÄ (t = t')` packages a normalised term with a
// proof of equality to the original.  Each `_1` rule consumes child
// Res values and produces a new Res; chains are term-level function
// compositions (e.g. `AND2_1 (VR3_1 STOP_1)`) where `res_tm`
// projects the final normal form and `res_eq` projects the cumulative
// equality witness.  No external `_1` lemmas; every proof is inline.
//
// Helper structure:
//   - generic equality combinators (eq_trans, conj_eq, ‚àß_assoc, ‚Ä¶)
//   - per-connective equality lemmas (and1_eq, and2_eq, ‚Ä¶) ‚Äî these are
//     just propositional facts about the connective transformations
//     specified by ¬ßA of the PP rule reference
//   - the `_1` rules themselves
//   - the `left_‚àß` autoflatten combinator (used by AND4_1 so chained
//     AND4s reduce to a left-associated conjunction without explicit
//     ‚àß_assoc rewrites at the call site)
//   - `ALL7_close` / `XST8_close` chain-exit operators that re-package
//     a per-tuple Res chain into the propositional form expected by
//     All.lp / Xst.lp. Quantifier-related symbols are arity-uniform
//     over `Tuple n`.

require open pp2lp.B pp2lp.Quant pp2lp.rules.All pp2lp.rules.Xst;

// (Res infrastructure ‚Äî Res, mk_1, res_tm, res_eq ‚Äî has moved to
//  Quant.lp so it's available to All.lp/Xst.lp where the result-based
//  ALL7 / XST8 are now defined.)

// ============================================================
// Generic equality combinators
// ============================================================

opaque symbol eq_trans [a] [P Q R : œÑ a]
  : œÄ (P = Q) ‚Üí œÄ (Q = R) ‚Üí œÄ (P = R) ‚âî
begin assume a P Q R h1 h2; rewrite h1; refine h2 end;

// Conj congruence: lift independent equalities to their conjunction.
opaque symbol conj_eq [A B S1 S2 : Prop]
  : œÄ (A = S1) ‚Üí œÄ (B = S2) ‚Üí œÄ ((A ‚àß B) = (S1 ‚àß S2)) ‚âî
begin
  assume A B S1 S2 h1 h2;
  rewrite h1; rewrite h2; reflexivity
end;

// Conj associativity (right ‚Üî left), used by ALL7/XST8 continuations
// when the inner _1 chain produced a right-assoc conjunction.
opaque symbol ‚àß_assoc [A B C : Prop]
  : œÄ ((A ‚àß (B ‚àß C)) = ((A ‚àß B) ‚àß C)) ‚âî
begin
  assume A B C;
  refine propExt _ _ _ _
  { assume h; refine ‚àß·µ¢ (‚àß·µ¢ (‚àß‚Çë‚ÇÅ h) (‚àß‚Çë‚ÇÅ (‚àß‚Çë‚ÇÇ h))) (‚àß‚Çë‚ÇÇ (‚àß‚Çë‚ÇÇ h)) }
  { assume h; refine ‚àß·µ¢ (‚àß‚Çë‚ÇÅ (‚àß‚Çë‚ÇÅ h)) (‚àß·µ¢ (‚àß‚Çë‚ÇÇ (‚àß‚Çë‚ÇÅ h)) (‚àß‚Çë‚ÇÇ h)) }
end;

// Antecedent equivalence ‚Üí implication equality (for AND5_1).
opaque symbol ante_cong [C C' R : Prop]
  : (œÄ C ‚Üí œÄ C') ‚Üí (œÄ C' ‚Üí œÄ C) ‚Üí œÄ ((C ‚áí R) = (C' ‚áí R)) ‚âî
begin
  assume C C' R fwd bwd;
  refine propExt _ _ _ _
    { assume h hc'; refine h (bwd hc') }
    { assume h hc; refine h (fwd hc) }
end;

// (`!!_cong` ‚Äî pointwise equality lifts to `!!` equality ‚Äî
//  is provided by Quant.lp.)

// Implication right congruence.
opaque symbol imp_cong_r [P Q R : Prop]
  : œÄ (Q = R) ‚Üí œÄ ((P ‚áí Q) = (P ‚áí R)) ‚âî
begin assume P Q R h; rewrite h; reflexivity end;

// Strip a known antecedent: œÄ P ‚Üí ((P ‚áí Q) = Q).
opaque symbol imp_known_drop [P Q : Prop]
  : œÄ P ‚Üí œÄ ((P ‚áí Q) = Q) ‚âî
begin
  assume P Q hp;
  refine propExt _ _ _ _
  { assume hpq; refine hpq hp }
  { assume hq hp2; refine hq }
end;

// ============================================================
// Per-connective equality lemmas (¬ßA.1‚ÄìA.5, A.13)
// ============================================================

// AND1: ¬¨(P‚àßQ)‚áíR = (¬¨Q‚áíR) ‚àß (¬¨P‚áíR)
opaque symbol and1_eq [P Q R : Prop]
  : œÄ ((¬¨ (P ‚àß Q) ‚áí R) = ((¬¨ Q ‚áí R) ‚àß (¬¨ P ‚áí R))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢
      (Œª hnq, h (Œª hpq, hnq (‚àß‚Çë‚ÇÇ hpq)))
      (Œª hnp, h (Œª hpq, hnp (‚àß‚Çë‚ÇÅ hpq))) }
    { assume h hnpq;
      have hnpnq : œÄ (¬¨ P ‚à® ¬¨ Q) { refine =‚áí (deMorgan_‚àß P Q) hnpq };
      refine ‚à®‚Çë hnpnq _ _
      { assume hnp; refine ‚àß‚Çë‚ÇÇ h hnp }
      { assume hnq; refine ‚àß‚Çë‚ÇÅ h hnq } }
end;

// AND2: ¬¨(P‚àßQ) = (P‚áí¬¨Q)
opaque symbol and2_eq [P Q : Prop]
  : œÄ (¬¨ (P ‚àß Q) = (P ‚áí ¬¨ Q)) ‚âî
begin
  assume P Q;
  refine propExt _ _ _ _
    { assume h1 hp hq; refine h1 (‚àß·µ¢ hp hq) }
    { assume h1 h2; refine h1 (‚àß‚Çë‚ÇÅ h2) (‚àß‚Çë‚ÇÇ h2) }
end;

// AND3: (P‚àßQ)‚áíR = (P‚áíQ‚áíR)
opaque symbol and3_eq [P Q R : Prop]
  : œÄ (((P ‚àß Q) ‚áí R) = (P ‚áí Q ‚áí R)) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h1 hp hq; refine h1 (‚àß·µ¢ hp hq) }
    { assume h1 h2; refine h1 (‚àß‚Çë‚ÇÅ h2) (‚àß‚Çë‚ÇÇ h2) }
end;

// OR1: ¬¨(P‚à®Q)‚áíR = (¬¨P‚áí¬¨Q‚áíR)
opaque symbol or1_eq [P Q R : Prop]
  : œÄ ((¬¨ (P ‚à® Q) ‚áí R) = (¬¨ P ‚áí (¬¨ Q ‚áí R))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h1 hnp hnq;
      have hnpq : œÄ (¬¨ (P ‚à® Q))
        { assume hpq; refine ‚à®‚Çë hpq _ _
          { assume hp; refine hnp hp }
          { assume hq; refine hnq hq } };
      refine h1 hnpq }
    { assume h1 hnpq;
      have hnpnq : œÄ (¬¨ P ‚àß ¬¨ Q) { refine =‚áí (deMorgan_‚à® P Q) hnpq };
      refine h1 (‚àß‚Çë‚ÇÅ hnpnq) (‚àß‚Çë‚ÇÇ hnpnq) }
end;

// OR2: ¬¨(P‚à®Q) = (¬¨Q ‚àß ¬¨P)
opaque symbol or2_eq [P Q : Prop]
  : œÄ (¬¨ (P ‚à® Q) = (¬¨ Q ‚àß ¬¨ P)) ‚âî
begin
  assume P Q;
  rewrite deMorgan_‚à®;
  rewrite ‚àß_com;
  reflexivity
end;

// OR3: (P‚à®Q)‚áíR = (Q‚áíR) ‚àß (P‚áíR)
opaque symbol or3_eq [P Q R : Prop]
  : œÄ (((P ‚à® Q) ‚áí R) = ((Q ‚áí R) ‚àß (P ‚áí R))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢ (Œª hq, h (‚à®·µ¢‚ÇÇ hq)) (Œª hp, h (‚à®·µ¢‚ÇÅ hp)) }
    { assume h hpq; refine ‚à®‚Çë hpq _ _
      { assume hp; refine ‚àß‚Çë‚ÇÇ h hp }
      { assume hq; refine ‚àß‚Çë‚ÇÅ h hq } }
end;

// OR4: P‚à®Q = (¬¨P‚áíQ). P, Q explicit to avoid HO-unification issues.
opaque symbol or4_eq (P Q : Prop)
  : œÄ ((P ‚à® Q) = (¬¨ P ‚áí Q)) ‚âî
begin
  assume P Q;
  refine propExt _ _ _ _
    { assume hpq hnp; refine ‚à®‚Çë hpq _ _
      { assume hp; refine ‚ä•‚Çë (hnp hp) }
      { assume hq; refine hq } }
    { assume h1; refine ‚à®‚Çë (em P) _ _
      { assume hp; refine ‚à®·µ¢‚ÇÅ hp }
      { assume hnp; refine ‚à®·µ¢‚ÇÇ (h1 hnp) } }
end;

// IMP1: ¬¨(P‚áíQ)‚áíR = (P‚áí¬¨Q‚áíR)
opaque symbol imp1_eq [P Q R : Prop]
  : œÄ ((¬¨ (P ‚áí Q) ‚áí R) = (P ‚áí (¬¨ Q ‚áí R))) ‚âî
begin
  assume P Q R;
  rewrite ¬¨‚áí=‚àß¬¨;
  refine propExt _ _ _ _
    { assume h1 hp hnq; refine h1 (‚àß·µ¢ hp hnq) }
    { assume h1 h2; refine h1 (‚àß‚Çë‚ÇÅ h2) (‚àß‚Çë‚ÇÇ h2) }
end;

// IMP2: ¬¨(P‚áíQ) = (¬¨Q ‚àß P)
opaque symbol imp2_eq [P Q : Prop]
  : œÄ (¬¨ (P ‚áí Q) = (¬¨ Q ‚àß P)) ‚âî
begin
  assume P Q;
  rewrite ¬¨‚áí=‚àß¬¨;
  rewrite ‚àß_com;
  reflexivity
end;

// IMP3: (P‚áíQ)‚áíR = (Q‚áíR) ‚àß (¬¨P‚áíR)
opaque symbol imp3_eq [P Q R : Prop]
  : œÄ (((P ‚áí Q) ‚áí R) = ((Q ‚áí R) ‚àß (¬¨ P ‚áí R))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢
      (Œª hq, h (Œª h0, hq))
      (Œª hnp, h (Œª hp, ‚ä•‚Çë (hnp hp))) }
    { assume h hpq; refine ‚à®‚Çë (em P) _ _
      { assume hp; refine ‚àß‚Çë‚ÇÅ h (hpq hp) }
      { assume hnp; refine ‚àß‚Çë‚ÇÇ h hnp } }
end;

// EQV1: ¬¨(P‚áîQ)‚áíR = (P‚áí¬¨Q‚áíR) ‚àß (¬¨P‚áíQ‚áíR)
opaque symbol eqv1_eq [P Q R : Prop]
  : œÄ ((¬¨ (P ‚áî Q) ‚áí R) = ((P ‚áí (¬¨ Q ‚áí R)) ‚àß (¬¨ P ‚áí (Q ‚áí R)))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢
      (Œª hp hnq, h (Œª heqv, hnq (‚àß‚Çë‚ÇÅ heqv hp)))
      (Œª hnp hq, h (Œª heqv, hnp (‚àß‚Çë‚ÇÇ heqv hq))) }
    { assume h hneqv;
      refine ‚à®‚Çë (em P) _ _
      { assume hp; refine ‚à®‚Çë (em Q) _ _
        { assume hq;
          have heqv : œÄ (P ‚áî Q) { refine ‚àß·µ¢ (Œª h0, hq) (Œª h0, hp) };
          refine ‚ä•‚Çë (hneqv heqv) }
        { assume hnq; refine ‚àß‚Çë‚ÇÅ h hp hnq } }
      { assume hnp; refine ‚à®‚Çë (em Q) _ _
        { assume hq; refine ‚àß‚Çë‚ÇÇ h hnp hq }
        { assume hnq;
          have heqv : œÄ (P ‚áî Q)
            { refine ‚àß·µ¢ (Œª hp, ‚ä•‚Çë (hnp hp)) (Œª hq, ‚ä•‚Çë (hnq hq)) };
          refine ‚ä•‚Çë (hneqv heqv) } } }
end;

// EQV3: (P‚áîQ)‚áíR = (P‚áíQ‚áíR) ‚àß (¬¨P‚áí¬¨Q‚áíR)
opaque symbol eqv3_eq [P Q R : Prop]
  : œÄ (((P ‚áî Q) ‚áí R) = ((P ‚áí (Q ‚áí R)) ‚àß (¬¨ P ‚áí (¬¨ Q ‚áí R)))) ‚âî
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚àß·µ¢
      (Œª hp hq, h (‚àß·µ¢ (Œª h0, hq) (Œª h0, hp)))
      (Œª hnp hnq, h (‚àß·µ¢
        (Œª hp, ‚ä•‚Çë (hnp hp))
        (Œª hq, ‚ä•‚Çë (hnq hq)))) }
    { assume h heqv;
      refine ‚à®‚Çë (em P) _ _
      { assume hp;
        have hq : œÄ Q { refine ‚àß‚Çë‚ÇÅ heqv hp };
        refine ‚àß‚Çë‚ÇÅ h hp hq }
      { assume hnp;
        refine ‚à®‚Çë (em Q) _ _
        { assume hq;
          have hp : œÄ P { refine ‚àß‚Çë‚ÇÇ heqv hq };
          refine ‚ä•‚Çë (hnp hp) }
        { assume hnq; refine ‚àß‚Çë‚ÇÇ h hnp hnq } } }
end;

// NOT1: ¬¨¬¨P‚áíR = (P‚áíR)
opaque symbol not1_eq [P R : Prop]
  : œÄ ((¬¨ ¬¨ P ‚áí R) = (P ‚áí R)) ‚âî
begin
  assume P R;
  refine propExt _ _ _ _
    { assume h1 hp; refine h1 (Œª hnp, hnp hp) }
    { assume h1 hnnp; refine h1 (¬¨¬¨‚Çë P hnnp) }
end;

// EVR3: (E=E)‚áíP = P
opaque symbol evr3_eq [E : œÑ Œπ] [P : Prop]
  : œÄ (((E = E) ‚áí P) = P) ‚âî
begin
  assume E P;
  refine propExt _ _ _ _
    { assume h1; refine h1 (eq_refl E) }
    { assume h1 h2; refine h1 }
end;

// ============================================================
// Special bridges (OPR1/OPR2, XST7/XST8, NRM1)
// ============================================================

// OPR1 bridge: (x=E ‚áí P x) = (x=E ‚áí P E). Holds pointwise: when x=E
// is true, both sides reduce to P E; when false, both are vacuously ‚ä§.
opaque symbol opr1_eq [E : œÑ Œπ] (P : œÑ Œπ ‚Üí Prop) (x : œÑ Œπ)
  : œÄ ((x = E ‚áí P x) = (x = E ‚áí P E)) ‚âî
begin
  assume E P x;
  refine propExt _ _ _ _
    { assume hyp hxe; have px : œÄ (P x) { refine hyp hxe };
      rewrite left hxe; refine px }
    { assume hyp hxe; have pe : œÄ (P E) { refine hyp hxe };
      rewrite hxe; refine pe }
end;

// OPR2 bridge: (E=x ‚áí P x) = (E=x ‚áí P E).
opaque symbol opr2_eq [E : œÑ Œπ] (P : œÑ Œπ ‚Üí Prop) (x : œÑ Œπ)
  : œÄ ((E = x ‚áí P x) = (E = x ‚áí P E)) ‚âî
begin
  assume E P x;
  refine propExt _ _ _ _
    { assume hyp hex; have px : œÄ (P x) { refine hyp hex };
      rewrite hex; refine px }
    { assume hyp hex; have pe : œÄ (P E) { refine hyp hex };
      rewrite left hex; refine pe }
end;

// XST7: ((‚àÉ-block, P) ‚áí R) = (‚àÄ-block, P ‚áí R)
opaque symbol xst7_eq [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : œÄ (((`?? v, P v) ‚áí R) = (`!! v, P v ‚áí R)) ‚âî
begin
  assume n P R;
  refine propExt _ _ _ _
    { assume hir; refine pi_to_!! _
        (Œª v hPv, hir (pi_to_??_intro P v hPv)) }
    { assume hall hex; refine pi_to_??_elim P
        (Œª v hpv, !!_to_pi (Œª v, P v ‚áí R) hall v hpv) hex }
end;

// XST8: (‚àÉ-block, P) = ((‚àÄ-block, ¬¨P) ‚áí ‚ä•)
opaque symbol xst8_eq [n] [P : Tuple n ‚Üí Prop]
  : œÄ ((`?? v, P v) = ((`!! v, ¬¨ (P v)) ‚áí ‚ä•)) ‚âî
begin
  assume n P;
  refine propExt _ _ _ _
    { assume hex hall; refine pi_to_??_elim P
        (Œª v hpv, !!_to_pi (Œª v, ¬¨ (P v)) hall v hpv) hex }
    { assume hc; refine ¬¨¬¨‚Çë _ (Œª hne,
        hc (pi_to_!! (Œª v, ¬¨ (P v))
              (Œª v hpv, hne (pi_to_??_intro P v hpv)))) }
end;

// NRM1 bridge: ((‚ô¢_:œÑŒπ, P) ‚áí Q) = (P ‚áí Q) when P is x-free.
opaque symbol nrm1_eq [P Q : Prop]
  : œÄ (((`‚ô¢ _ : œÑ Œπ, P) ‚áí Q) = (P ‚áí Q)) ‚âî
begin
  assume P Q;
  have h1 : œÄ ((`‚ô¢ _ : œÑ Œπ, P) = P) { refine ‚àÄ_const Œπ P };
  rewrite h1; reflexivity
end;

// ============================================================
// left_‚àß: left-fold combinator for AND4 chains
// ============================================================
// `left_‚àß x y` left-folds x into the binary ‚àß-tree y, accumulating on
// the left.  Fires automatically and correctly at any chain depth:
//   left_‚àß r (q ‚àß p)       ‚Ü™ left_‚àß (left_‚àß r q) p ‚Ü™ (r ‚àß q) ‚àß p
//   left_‚àß d ((c ‚àß b) ‚àß a) ‚Ü™ left_‚àß (left_‚àß d (c ‚àß b)) a ‚Ü™ ((d ‚àß c) ‚àß b) ‚àß a
sequential symbol left_‚àß : œÑ o ‚Üí œÑ o ‚Üí œÑ o;
rule left_‚àß $x ($a ‚àß $b) ‚Ü™ left_‚àß (left_‚àß $x $a) $b
with left_‚àß $x $y ‚Ü™ $x ‚àß $y;

// ============================================================
// Res leaf
// ============================================================

symbol STOP_1 [P : Prop] : Res P
  ‚âî mk_1 P (eq_refl P);

// ============================================================
// Res passthrough rules
// ============================================================

symbol AND2_1 [P Q : Prop]
  (r : Res (P ‚áí ¬¨ Q)) : Res (¬¨ (P ‚àß Q))
  ‚âî mk_1 (res_tm r) (eq_trans and2_eq (res_eq r));

symbol AND3_1 [P Q R : Prop]
  (r : Res (P ‚áí Q ‚áí R)) : Res ((P ‚àß Q) ‚áí R)
  ‚âî mk_1 (res_tm r) (eq_trans and3_eq (res_eq r));

symbol OR1_1 [P Q R : Prop]
  (r : Res (¬¨ P ‚áí ¬¨ Q ‚áí R)) : Res (¬¨ (P ‚à® Q) ‚áí R)
  ‚âî mk_1 (res_tm r) (eq_trans or1_eq (res_eq r));

symbol OR4_1 [P Q : Prop]
  (r : Res (¬¨ P ‚áí Q)) : Res (P ‚à® Q)
  ‚âî mk_1 (res_tm r) (eq_trans (or4_eq P Q) (res_eq r));

symbol NOT1_1 [P R : Prop]
  (r : Res (P ‚áí R)) : Res (¬¨ ¬¨ P ‚áí R)
  ‚âî mk_1 (res_tm r) (eq_trans not1_eq (res_eq r));

symbol NOT2_1 [P : Prop]
  (r : Res P) : Res (¬¨ ¬¨ P)
  ‚âî mk_1 (res_tm r) (eq_trans (¬¨¬¨‚Çë_eq P) (res_eq r));

symbol IMP1_1 [P Q R : Prop]
  (r : Res (P ‚áí ¬¨ Q ‚áí R)) : Res (¬¨ (P ‚áí Q) ‚áí R)
  ‚âî mk_1 (res_tm r) (eq_trans imp1_eq (res_eq r));

symbol VR3_1 [P : Prop]
  (r : Res P) : Res (‚ä§ ‚áí P)
  ‚âî mk_1 (res_tm r) (eq_trans (‚ä§‚áí P) (res_eq r));

symbol EVR2_1 [E : œÑ Œπ]
  (r : Res ‚ä•) : Res (¬¨ (E = E))
  ‚âî mk_1 (res_tm r) (eq_trans (¬¨=_idem Œπ E) (res_eq r));

symbol EVR3_1 [E : œÑ Œπ] [P : Prop]
  (r : Res P) : Res ((E = E) ‚áí P)
  ‚âî mk_1 (res_tm r) (eq_trans evr3_eq (res_eq r));

symbol OPR1_1 [E : œÑ Œπ] (P : œÑ Œπ ‚Üí Prop) (x : œÑ Œπ)
  (r : Res (x = E ‚áí P E)) : Res (x = E ‚áí P x)
  ‚âî mk_1 (res_tm r) (eq_trans (opr1_eq P x) (res_eq r));

symbol OPR2_1 [E : œÑ Œπ] (P : œÑ Œπ ‚Üí Prop) (x : œÑ Œπ)
  (r : Res (E = x ‚áí P E)) : Res (E = x ‚áí P x)
  ‚âî mk_1 (res_tm r) (eq_trans (opr2_eq P x) (res_eq r));

// ============================================================
// Res structural rules
// ============================================================

// IMP4_1: congruence of ‚áí on the right (P doesn't depend on context).
symbol IMP4_1 [P Q : Prop]
  (r : Res Q) : Res (P ‚áí Q)
  ‚âî mk_1 (P ‚áí res_tm r) (imp_cong_r (res_eq r));

// IMP5_1: strip a known antecedent (hp : œÄ P) ‚Äî collapses the ‚áí.
symbol IMP5_1 [P Q : Prop]
  (hp : œÄ P) (r : Res Q) : Res (P ‚áí Q)
  ‚âî mk_1 (res_tm r) (eq_trans (imp_known_drop hp) (res_eq r));

// ALL9_1: same shape as IMP4_1 ‚Äî H ‚áí continuation.
symbol ALL9_1 [H Q : Prop]
  (r : Res Q) : Res (H ‚áí Q)
  ‚âî mk_1 (H ‚áí res_tm r) (imp_cong_r (res_eq r));

// NRM1_1: strip constant ‚ô¢-binder.
symbol NRM1_1 [P Q : Prop]
  (r : Res (P ‚áí Q)) : Res ((`‚ô¢ _ : œÑ Œπ, P) ‚áí Q)
  ‚âî mk_1 (res_tm r) (eq_trans nrm1_eq (res_eq r));

// ALL8_1: congruence under ‚àÄ-block.
symbol ALL8_1 [n] [P : Tuple n ‚Üí Prop]
  (œÅ : ŒÝ v : Tuple n, Res (P v)) : Res (`!! v, P v)
  ‚âî mk_1 (`!! v, res_tm (œÅ v))
           (!!_cong (Œª v, res_eq (œÅ v)));

// XST7_1: (‚àÉ-block, P) ‚áí R via (‚àÄ-block, P ‚áí R).
symbol XST7_1 [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  (r : Res (`!! v, P v ‚áí R)) : Res ((`?? v, P v) ‚áí R)
  ‚âî mk_1 (res_tm r) (eq_trans xst7_eq (res_eq r));

// XST8_1: ‚àÉ-block, P via ((‚àÄ-block, ¬¨P) ‚áí ‚ä•).
symbol XST8_1 [n] [P : Tuple n ‚Üí Prop]
  (r : Res ((`!! v, ¬¨ (P v)) ‚áí ‚ä•)) : Res (`?? v, P v)
  ‚âî mk_1 (res_tm r) (eq_trans xst8_eq (res_eq r));

// ALL7_1: branching quantifier ‚Äî per-tuple Res chain œÅ + continuation r.
opaque symbol ALL7_1 [n] [P : Tuple n ‚Üí Prop] [Q : Prop]
  (œÅ : ŒÝ v : Tuple n, Res (P v))
  (r : Res ((`!! v, res_tm (œÅ v)) ‚áí Q))
  : Res ((`!! v, P v) ‚áí Q) ‚âî
begin
  assume n P Q œÅ r;
  refine mk_1 (res_tm r) _;
  have h1 : œÄ ((`!! v, P v) = (`!! v, res_tm (œÅ v)))
    { refine !!_cong (Œª v, res_eq (œÅ v)) };
  have h2 : œÄ (((`!! v, P v) ‚áí Q) = ((`!! v, res_tm (œÅ v)) ‚áí Q))
    { rewrite h1; reflexivity };
  refine eq_trans h2 (res_eq r)
end;

// ============================================================
// Res branching rules (two children ‚Üí conjunction normal form)
// ============================================================

symbol AND1_1 [P Q R : Prop]
  (r1 : Res (¬¨ Q ‚áí R)) (r2 : Res (¬¨ P ‚áí R))
  : Res (¬¨ (P ‚àß Q) ‚áí R)
  ‚âî mk_1 (res_tm r1 ‚àß res_tm r2)
      (eq_trans and1_eq (conj_eq (res_eq r1) (res_eq r2)));

// AND4_1: (P ‚àß Q) ‚Üí (Q ‚àß P) via ‚àß_com, then per-arg Res children.
// `left_‚àß` reduces (S1 ‚àß S2) to its left-assoc tree definitionally.
symbol AND4_1 [P Q : Prop]
  (r1 : Res Q) (r2 : Res P) : Res (P ‚àß Q)
  ‚âî mk_1 (left_‚àß (res_tm r1) (res_tm r2))
           (eq_trans (‚àß_com P Q) (conj_eq (res_eq r1) (res_eq r2)));

symbol OR2_1 [P Q : Prop]
  (r1 : Res (¬¨ Q)) (r2 : Res (¬¨ P)) : Res (¬¨ (P ‚à® Q))
  ‚âî mk_1 (res_tm r1 ‚àß res_tm r2)
      (eq_trans or2_eq (conj_eq (res_eq r1) (res_eq r2)));

symbol OR3_1 [P Q R : Prop]
  (r1 : Res (Q ‚áí R)) (r2 : Res (P ‚áí R))
  : Res ((P ‚à® Q) ‚áí R)
  ‚âî mk_1 (res_tm r1 ‚àß res_tm r2)
      (eq_trans or3_eq (conj_eq (res_eq r1) (res_eq r2)));

symbol IMP3_1 [P Q R : Prop]
  (r1 : Res (Q ‚áí R)) (r2 : Res (¬¨ P ‚áí R))
  : Res ((P ‚áí Q) ‚áí R)
  ‚âî mk_1 (res_tm r1 ‚àß res_tm r2)
      (eq_trans imp3_eq (conj_eq (res_eq r1) (res_eq r2)));

symbol IMP2_1 [P Q : Prop]
  (r1 : Res (¬¨ Q)) (r2 : Res P) : Res (¬¨ (P ‚áí Q))
  ‚âî mk_1 (res_tm r1 ‚àß res_tm r2)
      (eq_trans imp2_eq (conj_eq (res_eq r1) (res_eq r2)));

symbol EQV1_1 [P Q R : Prop]
  (r1 : Res (P ‚áí ¬¨ Q ‚áí R)) (r2 : Res (¬¨ P ‚áí Q ‚áí R))
  : Res (¬¨ (P ‚áî Q) ‚áí R)
  ‚âî mk_1 (res_tm r1 ‚àß res_tm r2)
      (eq_trans eqv1_eq (conj_eq (res_eq r1) (res_eq r2)));

symbol EQV3_1 [P Q R : Prop]
  (r1 : Res (P ‚áí Q ‚áí R)) (r2 : Res (¬¨ P ‚áí ¬¨ Q ‚áí R))
  : Res ((P ‚áî Q) ‚áí R)
  ‚âî mk_1 (res_tm r1 ‚àß res_tm r2)
      (eq_trans eqv3_eq (conj_eq (res_eq r1) (res_eq r2)));

// (Chain-exit operators ALL7_close / XST8_close have been folded
//  into the canonical ALL7 / XST8 in All.lp / Xst.lp respectively.)
