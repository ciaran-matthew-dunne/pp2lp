// Res.lp ‚ÄĒ helpers shared by the per-rule `_1` (Result) variants.
//
// Each `_1` rule lives in its own topic file (Conj.lp, Disj.lp, ‚Ä¶);
// this file collects the cross-cutting infrastructure they share:
//
//   - generic equality combinators (eq_trans, conj_eq, ‚ąß_assoc, ‚Ä¶)
//   - per-connective equality lemmas (and1_eq, or1_eq, ‚Ä¶) ‚ÄĒ these are
//     just propositional facts about the connective transformations
//     specified by ¬ßA of the PP rule reference
//   - special bridges (opr1_eq, opr2_eq, xst7_eq, xst8_eq, nrm1_eq)
//
// The `Res`, `mk_1`, `res_tm`, `res_eq` primitives themselves live in
// Quant.lp so that All.lp / Xst.lp can refer to them.

require open pp2lp.B pp2lp.ConjList pp2lp.Quant;

// ============================================================
// Generic equality combinators
// ============================================================

opaque symbol eq_trans [a] [P Q R : ŌĄ a]
  : ŌÄ (P = Q) ‚Üí ŌÄ (Q = R) ‚Üí ŌÄ (P = R) ‚ČĒ
begin assume a P Q R h1 h2; rewrite h1; refine h2 end;

// A true proposition equals ‚ä§.  This is the Schema-0 result bridge
// (¬ß8.13): a rule "sans ant√©c√©dent v√©ritable" produces the result VRAI,
// which the spec requires to be *equivalent to the consequent P* ‚ÄĒ here
// modulo the hypotheses H that license the rule's side-condition.  Given
// a proof of P (the hyp the rule looked up), `propExt` discharges `P = ‚ä§`.
opaque symbol prop_eq_top [P : Prop] (hp : ŌÄ P) : ŌÄ (P = ‚ä§) ‚ČĒ
begin
  assume P hp;
  refine propExt _ _ _ _
  { assume h; refine ‚ä§ŠĶĘ }
  { assume h; refine hp }
end;

// Conj congruence: lift independent equalities to their conjunction.
opaque symbol conj_eq [A B S1 S2 : Prop]
  : ŌÄ (A = S1) ‚Üí ŌÄ (B = S2) ‚Üí ŌÄ ((A ‚ąß B) = (S1 ‚ąß S2)) ‚ČĒ
begin
  assume A B S1 S2 h1 h2;
  rewrite h1; rewrite h2; reflexivity
end;

// Conj associativity (right ‚ÜĒ left), used by ALL7/XST8 continuations
// when the inner _1 chain produced a right-assoc conjunction.
opaque symbol ‚ąß_assoc [A B C : Prop]
  : ŌÄ ((A ‚ąß (B ‚ąß C)) = ((A ‚ąß B) ‚ąß C)) ‚ČĒ
begin
  assume A B C;
  refine propExt _ _ _ _
  { assume h; refine ‚ąßŠĶĘ (‚ąßŠĶĘ (‚ąß‚āĎ‚āĀ h) (‚ąß‚āĎ‚āĀ (‚ąß‚āĎ‚āā h))) (‚ąß‚āĎ‚āā (‚ąß‚āĎ‚āā h)) }
  { assume h; refine ‚ąßŠĶĘ (‚ąß‚āĎ‚āĀ (‚ąß‚āĎ‚āĀ h)) (‚ąßŠĶĘ (‚ąß‚āĎ‚āā (‚ąß‚āĎ‚āĀ h)) (‚ąß‚āĎ‚āā h)) }
end;

// Antecedent equivalence ‚Üí implication equality (for AND5_1).
opaque symbol ante_cong [C C' R : Prop]
  : (ŌÄ C ‚Üí ŌÄ C') ‚Üí (ŌÄ C' ‚Üí ŌÄ C) ‚Üí ŌÄ ((C ‚áí R) = (C' ‚áí R)) ‚ČĒ
begin
  assume C C' R fwd bwd;
  refine propExt _ _ _ _
    { assume h hc'; refine h (bwd hc') }
    { assume h hc; refine h (fwd hc) }
end;

// Implication right congruence.
opaque symbol imp_cong_r [P Q R : Prop]
  : ŌÄ (Q = R) ‚Üí ŌÄ ((P ‚áí Q) = (P ‚áí R)) ‚ČĒ
begin assume P Q R h; rewrite h; reflexivity end;

// Implication left congruence.
opaque symbol imp_cong_l [P P' Q : Prop]
  : ŌÄ (P = P') ‚Üí ŌÄ ((P ‚áí Q) = (P' ‚áí Q)) ‚ČĒ
begin assume P P' Q h; rewrite h; reflexivity end;

// Negation congruence.
opaque symbol not_cong [A B : Prop]
  : ŌÄ (A = B) ‚Üí ŌÄ ((¬¨ A) = (¬¨ B)) ‚ČĒ
begin assume A B h; rewrite h; reflexivity end;

// Snoc-list last-element congruence: rewrite the final conjunct of a `‚čÄ`.
opaque symbol conj_snoc_last_cong [ps : ūĚēÉ* o] [P Q : Prop]
  : ŌÄ (P = Q) ‚Üí ŌÄ (‚čÄ (ps ‚ą∑ P) = ‚čÄ (ps ‚ą∑ Q)) ‚ČĒ
begin assume ps P Q h; rewrite h; reflexivity end;

// Swap the last two conjuncts.  With [conj_init_cong] below this bubbles a
// conjunct to the end of the list ‚ÄĒ the emitter rotates an NRM20/21 pinning
// equality into tail position before applying the tail-form lemmas.
opaque symbol conj_swap_last2 [ps : ūĚēÉ* o] [P Q : Prop]
  : ŌÄ (‚čÄ (ps ‚ą∑ P ‚ą∑ Q) = ‚čÄ (ps ‚ą∑ Q ‚ą∑ P)) ‚ČĒ
begin
  assume ps P Q;
  refine propExt _ _ _ _
  { assume h;
    refine ‚čÄ_intro (‚čÄ_intro (‚čÄ_init (‚čÄ_init h)) (‚čÄ_last h))
                   (‚čÄ_last (‚čÄ_init h)) }
  { assume h;
    refine ‚čÄ_intro (‚čÄ_intro (‚čÄ_init (‚čÄ_init h)) (‚čÄ_last h))
                   (‚čÄ_last (‚čÄ_init h)) }
end;

// Init congruence: rewrite everything *below* the last conjunct.
opaque symbol conj_init_cong [ps qs : ūĚēÉ* o] [P : Prop]
  : ŌÄ (‚čÄ ps = ‚čÄ qs) ‚Üí ŌÄ (‚čÄ (ps ‚ą∑ P) = ‚čÄ (qs ‚ą∑ P)) ‚ČĒ
begin
  assume ps qs P h;
  refine propExt _ _ _ _
  { assume hc; refine ‚čÄ_intro (=‚áí h (‚čÄ_init hc)) (‚čÄ_last hc) }
  { assume hc; refine ‚čÄ_intro (=‚áí (eq_sym h) (‚čÄ_init hc)) (‚čÄ_last hc) }
end;

// Strip a known antecedent: ŌÄ P ‚Üí ((P ‚áí Q) = Q).
opaque symbol imp_known_drop [P Q : Prop]
  : ŌÄ P ‚Üí ŌÄ ((P ‚áí Q) = Q) ‚ČĒ
begin
  assume P Q hp;
  refine propExt _ _ _ _
  { assume hpq; refine hpq hp }
  { assume hq hp2; refine hq }
end;

// LHS-of-‚Č§-zero congruence (for AR9_1).
opaque symbol leq_zero_eq [E F : ŌĄ őĻ]
  : ŌÄ (E = F) ‚Üí ŌÄ ((E ‚Č§ ūĚüé) = (F ‚Č§ ūĚüé)) ‚ČĒ
begin assume E F h; rewrite h; reflexivity end;

// ============================================================
// Per-connective equality lemmas (¬ßA.1‚ÄďA.5, A.13)
//
// The AND lemmas decompose the snoc conjunction `‚čÄ (ps ‚ą∑ P)` into init
// `‚čÄ ps` and last `P`.  Proved directly from the ConjList eliminators:
// build the conjunction with `‚čÄ_intro hps hp` and destruct it with
// `‚čÄ_init`/`‚čÄ_last`, in place of the `‚ąßŠĶĘ`/`‚ąß‚āĎ‚āĀ`/`‚ąß‚āĎ‚āā` of the OR/IMP lemmas.
// ============================================================

// AND1: (¬¨‚čÄ(ps‚ą∑P)‚áíR) = ((¬¨P‚áíR) ‚ąß (¬¨‚čÄps‚áíR))   [last-first]
opaque symbol and1_eq [ps : ūĚēÉ* o] [P R : Prop]
  : ŌÄ ((¬¨ ‚čÄ (ps ‚ą∑ P) ‚áí R) = ((¬¨ P ‚áí R) ‚ąß (¬¨ ‚čÄ ps ‚áí R))) ‚ČĒ
begin
  assume ps P R;
  refine propExt _ _ _ _
    { assume h; refine ‚ąßŠĶĘ
        (őĽ hnp, h (őĽ hand, hnp (‚čÄ_last hand)))
        (őĽ hni, h (őĽ hand, hni (‚čÄ_init hand))) }
    { assume h hnand;
      have hnand2 : ŌÄ (¬¨ (‚čÄ ps ‚ąß P))
        { assume hand; refine hnand (‚čÄ_intro (‚ąß‚āĎ‚āĀ hand) (‚ąß‚āĎ‚āā hand)) };
      have hor : ŌÄ (¬¨ ‚čÄ ps ‚ą® ¬¨ P)
        { refine =‚áí (deMorgan_‚ąß (‚čÄ ps) P) hnand2 };
      refine ‚ą®‚āĎ hor _ _
        { assume hni; refine ‚ąß‚āĎ‚āā h hni }
        { assume hnp; refine ‚ąß‚āĎ‚āĀ h hnp } }
end;

// AND2: ¬¨‚čÄ(ps‚ą∑P) = (‚čÄps ‚áí ¬¨P)
opaque symbol and2_eq [ps : ūĚēÉ* o] [P : Prop]
  : ŌÄ (¬¨ ‚čÄ (ps ‚ą∑ P) = (‚čÄ ps ‚áí ¬¨ P)) ‚ČĒ
begin
  assume ps P;
  refine propExt _ _ _ _
    { assume h hps hp; refine h (‚čÄ_intro hps hp) }
    { assume h hand; refine h (‚čÄ_init hand) (‚čÄ_last hand) }
end;

// AND3: (‚čÄ(ps‚ą∑P)‚áíR) = (‚čÄps ‚áí (P‚áíR))
opaque symbol and3_eq [ps : ūĚēÉ* o] [P R : Prop]
  : ŌÄ ((‚čÄ (ps ‚ą∑ P) ‚áí R) = (‚čÄ ps ‚áí (P ‚áí R))) ‚ČĒ
begin
  assume ps P R;
  refine propExt _ _ _ _
    { assume h hps hp; refine h (‚čÄ_intro hps hp) }
    { assume h hand; refine h (‚čÄ_init hand) (‚čÄ_last hand) }
end;

// AND4: ‚čÄ(ps‚ą∑P) = (P ‚ąß ‚čÄps)   [last-first reordering for AND4_1]
opaque symbol and4_eq [ps : ūĚēÉ* o] [P : Prop]
  : ŌÄ (‚čÄ (ps ‚ą∑ P) = (P ‚ąß ‚čÄ ps)) ‚ČĒ
begin
  assume ps P;
  refine propExt _ _ _ _
    { assume h; refine ‚ąßŠĶĘ (‚čÄ_last h) (‚čÄ_init h) }
    { assume h; refine ‚čÄ_intro (‚ąß‚āĎ‚āā h) (‚ąß‚āĎ‚āĀ h) }
end;

// OR1: ¬¨(P‚ą®Q)‚áíR = (¬¨P‚áí¬¨Q‚áíR)
opaque symbol or1_eq [P Q R : Prop]
  : ŌÄ ((¬¨ (P ‚ą® Q) ‚áí R) = (¬¨ P ‚áí (¬¨ Q ‚áí R))) ‚ČĒ
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h1 hnp hnq;
      have hnpq : ŌÄ (¬¨ (P ‚ą® Q))
        { assume hpq; refine ‚ą®‚āĎ hpq _ _
          { assume hp; refine hnp hp }
          { assume hq; refine hnq hq } };
      refine h1 hnpq }
    { assume h1 hnpq;
      have hnpnq : ŌÄ (¬¨ P ‚ąß ¬¨ Q) { refine =‚áí (deMorgan_‚ą® P Q) hnpq };
      refine h1 (‚ąß‚āĎ‚āĀ hnpnq) (‚ąß‚āĎ‚āā hnpnq) }
end;

// OR2: ¬¨(P‚ą®Q) = (¬¨Q ‚ąß ¬¨P)
opaque symbol or2_eq [P Q : Prop]
  : ŌÄ (¬¨ (P ‚ą® Q) = (¬¨ Q ‚ąß ¬¨ P)) ‚ČĒ
begin
  assume P Q;
  rewrite deMorgan_‚ą®;
  rewrite ‚ąß_com;
  reflexivity
end;

// OR3: (P‚ą®Q)‚áíR = (Q‚áíR) ‚ąß (P‚áíR)
opaque symbol or3_eq [P Q R : Prop]
  : ŌÄ (((P ‚ą® Q) ‚áí R) = ((Q ‚áí R) ‚ąß (P ‚áí R))) ‚ČĒ
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚ąßŠĶĘ (őĽ hq, h (‚ą®ŠĶĘ‚āā hq)) (őĽ hp, h (‚ą®ŠĶĘ‚āĀ hp)) }
    { assume h hpq; refine ‚ą®‚āĎ hpq _ _
      { assume hp; refine ‚ąß‚āĎ‚āā h hp }
      { assume hq; refine ‚ąß‚āĎ‚āĀ h hq } }
end;

// OR4: P‚ą®Q = (¬¨P‚áíQ). P, Q explicit to avoid HO-unification issues.
opaque symbol or4_eq (P Q : Prop)
  : ŌÄ ((P ‚ą® Q) = (¬¨ P ‚áí Q)) ‚ČĒ
begin
  assume P Q;
  refine propExt _ _ _ _
    { assume hpq hnp; refine ‚ą®‚āĎ hpq _ _
      { assume hp; refine ‚ä•‚āĎ (hnp hp) }
      { assume hq; refine hq } }
    { assume h1; refine ‚ą®‚āĎ (em P) _ _
      { assume hp; refine ‚ą®ŠĶĘ‚āĀ hp }
      { assume hnp; refine ‚ą®ŠĶĘ‚āā (h1 hnp) } }
end;

// IMP1: ¬¨(P‚áíQ)‚áíR = (P‚áí¬¨Q‚áíR)
opaque symbol imp1_eq [P Q R : Prop]
  : ŌÄ ((¬¨ (P ‚áí Q) ‚áí R) = (P ‚áí (¬¨ Q ‚áí R))) ‚ČĒ
begin
  assume P Q R;
  rewrite ¬¨‚áí=‚ąß¬¨;
  refine propExt _ _ _ _
    { assume h1 hp hnq; refine h1 (‚ąßŠĶĘ hp hnq) }
    { assume h1 h2; refine h1 (‚ąß‚āĎ‚āĀ h2) (‚ąß‚āĎ‚āā h2) }
end;

// IMP2: ¬¨(P‚áíQ) = (¬¨Q ‚ąß P)
opaque symbol imp2_eq [P Q : Prop]
  : ŌÄ (¬¨ (P ‚áí Q) = (¬¨ Q ‚ąß P)) ‚ČĒ
begin
  assume P Q;
  rewrite ¬¨‚áí=‚ąß¬¨;
  rewrite ‚ąß_com;
  reflexivity
end;

// IMP3: (P‚áíQ)‚áíR = (Q‚áíR) ‚ąß (¬¨P‚áíR)
opaque symbol imp3_eq [P Q R : Prop]
  : ŌÄ (((P ‚áí Q) ‚áí R) = ((Q ‚áí R) ‚ąß (¬¨ P ‚áí R))) ‚ČĒ
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚ąßŠĶĘ
      (őĽ hq, h (őĽ h0, hq))
      (őĽ hnp, h (őĽ hp, ‚ä•‚āĎ (hnp hp))) }
    { assume h hpq; refine ‚ą®‚āĎ (em P) _ _
      { assume hp; refine ‚ąß‚āĎ‚āĀ h (hpq hp) }
      { assume hnp; refine ‚ąß‚āĎ‚āā h hnp } }
end;

// EQV1: ¬¨(P‚áĒQ)‚áíR = (P‚áí¬¨Q‚áíR) ‚ąß (¬¨P‚áíQ‚áíR)
opaque symbol eqv1_eq [P Q R : Prop]
  : ŌÄ ((¬¨ (P ‚áĒ Q) ‚áí R) = ((P ‚áí (¬¨ Q ‚áí R)) ‚ąß (¬¨ P ‚áí (Q ‚áí R)))) ‚ČĒ
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚ąßŠĶĘ
      (őĽ hp hnq, h (őĽ heqv, hnq (‚ąß‚āĎ‚āĀ heqv hp)))
      (őĽ hnp hq, h (őĽ heqv, hnp (‚ąß‚āĎ‚āā heqv hq))) }
    { assume h hneqv;
      refine ‚ą®‚āĎ (em P) _ _
      { assume hp; refine ‚ą®‚āĎ (em Q) _ _
        { assume hq;
          have heqv : ŌÄ (P ‚áĒ Q) { refine ‚ąßŠĶĘ (őĽ h0, hq) (őĽ h0, hp) };
          refine ‚ä•‚āĎ (hneqv heqv) }
        { assume hnq; refine ‚ąß‚āĎ‚āĀ h hp hnq } }
      { assume hnp; refine ‚ą®‚āĎ (em Q) _ _
        { assume hq; refine ‚ąß‚āĎ‚āā h hnp hq }
        { assume hnq;
          have heqv : ŌÄ (P ‚áĒ Q)
            { refine ‚ąßŠĶĘ (őĽ hp, ‚ä•‚āĎ (hnp hp)) (őĽ hq, ‚ä•‚āĎ (hnq hq)) };
          refine ‚ä•‚āĎ (hneqv heqv) } } }
end;

// EQV2: ¬¨(P‚áĒQ) = (P‚áí¬¨Q) ‚ąß (¬¨Q‚áíP)
opaque symbol eqv2_eq [P Q : Prop]
  : ŌÄ (¬¨ (P ‚áĒ Q) = ((P ‚áí ¬¨ Q) ‚ąß (¬¨ Q ‚áí P))) ‚ČĒ
begin
  assume P Q;
  refine propExt _ _ _ _
    { assume hneqv;
      refine ‚ąßŠĶĘ
        (őĽ hp hq,
          hneqv (‚ąßŠĶĘ (őĽ h0, hq) (őĽ h0, hp)))
        (őĽ hnq, ¬¨¬¨‚āĎ P (őĽ hnp,
          hneqv (‚ąßŠĶĘ (őĽ hp, ‚ä•‚āĎ (hnp hp)) (őĽ hq, ‚ä•‚āĎ (hnq hq))))) }
    { assume hand heqv;
      refine ‚ą®‚āĎ (em Q) _ _
        { assume hq; refine ‚ąß‚āĎ‚āĀ hand (‚ąß‚āĎ‚āā heqv hq) hq }
        { assume hnq;
          have hp : ŌÄ P { refine ‚ąß‚āĎ‚āā hand hnq };
          have hq : ŌÄ Q { refine ‚ąß‚āĎ‚āĀ heqv hp };
          refine hnq hq } }
end;

// EQV3: (P‚áĒQ)‚áíR = (P‚áíQ‚áíR) ‚ąß (¬¨P‚áí¬¨Q‚áíR)
opaque symbol eqv3_eq [P Q R : Prop]
  : ŌÄ (((P ‚áĒ Q) ‚áí R) = ((P ‚áí (Q ‚áí R)) ‚ąß (¬¨ P ‚áí (¬¨ Q ‚áí R)))) ‚ČĒ
begin
  assume P Q R;
  refine propExt _ _ _ _
    { assume h; refine ‚ąßŠĶĘ
      (őĽ hp hq, h (‚ąßŠĶĘ (őĽ h0, hq) (őĽ h0, hp)))
      (őĽ hnp hnq, h (‚ąßŠĶĘ
        (őĽ hp, ‚ä•‚āĎ (hnp hp))
        (őĽ hq, ‚ä•‚āĎ (hnq hq)))) }
    { assume h heqv;
      refine ‚ą®‚āĎ (em P) _ _
      { assume hp;
        have hq : ŌÄ Q { refine ‚ąß‚āĎ‚āĀ heqv hp };
        refine ‚ąß‚āĎ‚āĀ h hp hq }
      { assume hnp;
        refine ‚ą®‚āĎ (em Q) _ _
        { assume hq;
          have hp : ŌÄ P { refine ‚ąß‚āĎ‚āā heqv hq };
          refine ‚ä•‚āĎ (hnp hp) }
        { assume hnq; refine ‚ąß‚āĎ‚āā h hnp hnq } } }
end;

// EQV4: (P‚áĒQ) = (P‚áíQ) ‚ąß (Q‚áíP). Definitional in stdlib (‚áĒ ‚ČĒ őĽp q, ‚Ä¶).
opaque symbol eqv4_eq [P Q : Prop]
  : ŌÄ ((P ‚áĒ Q) = ((P ‚áí Q) ‚ąß (Q ‚áí P))) ‚ČĒ
begin assume P Q; reflexivity end;

// NOT1: ¬¨¬¨P‚áíR = (P‚áíR)
opaque symbol not1_eq [P R : Prop]
  : ŌÄ ((¬¨ ¬¨ P ‚áí R) = (P ‚áí R)) ‚ČĒ
begin
  assume P R;
  refine propExt _ _ _ _
    { assume h1 hp; refine h1 (őĽ hnp, hnp hp) }
    { assume h1 hnnp; refine h1 (¬¨¬¨‚āĎ P hnnp) }
end;

// EVR3: (E=E)‚áíP = P
opaque symbol evr3_eq [E : ŌĄ őĻ] [P : Prop]
  : ŌÄ (((E = E) ‚áí P) = P) ‚ČĒ
begin
  assume E P;
  refine propExt _ _ _ _
    { assume h1; refine h1 (eq_refl E) }
    { assume h1 h2; refine h1 }
end;

// ============================================================
// Special bridges (OPR1/OPR2, XST7/XST8, NRM1)
// ============================================================

// OPR1 bridge: (x=E ‚áí P x) = (x=E ‚áí P E). Holds pointwise: when x=E
// is true, both sides reduce to P E; when false, both are vacuously ‚ä§.
opaque symbol opr1_eq [E : ŌĄ őĻ] (P : ŌĄ őĻ ‚Üí Prop) (x : ŌĄ őĻ)
  : ŌÄ ((x = E ‚áí P x) = (x = E ‚áí P E)) ‚ČĒ
begin
  assume E P x;
  refine propExt _ _ _ _
    { assume hyp hxe; have px : ŌÄ (P x) { refine hyp hxe };
      rewrite left hxe; refine px }
    { assume hyp hxe; have pe : ŌÄ (P E) { refine hyp hxe };
      rewrite hxe; refine pe }
end;

// OPR2 bridge: (E=x ‚áí P x) = (E=x ‚áí P E).
opaque symbol opr2_eq [E : ŌĄ őĻ] (P : ŌĄ őĻ ‚Üí Prop) (x : ŌĄ őĻ)
  : ŌÄ ((E = x ‚áí P x) = (E = x ‚áí P E)) ‚ČĒ
begin
  assume E P x;
  refine propExt _ _ _ _
    { assume hyp hex; have px : ŌÄ (P x) { refine hyp hex };
      rewrite hex; refine px }
    { assume hyp hex; have pe : ŌÄ (P E) { refine hyp hex };
      rewrite left hex; refine pe }
end;

// XST7: ((‚ąÉ-block, P) ‚áí R) = (‚ąÄ-block, P ‚áí R)
opaque symbol xst7_eq [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ (((`?? v, P v) ‚áí R) = (`!! v, P v ‚áí R)) ‚ČĒ
begin
  assume n P R;
  refine propExt _ _ _ _
    { assume hir; refine pi_to_!! _
        (őĽ v hPv, hir (pi_to_??_intro P v hPv)) }
    { assume hall hex; refine pi_to_??_elim P
        (őĽ v hpv, !!_to_pi (őĽ v, P v ‚áí R) hall v hpv) hex }
end;

// XST6: ¬¨(‚ąÉ-block, P) = (‚ąÄ-block, ¬¨P)  (quantifier De Morgan).
opaque symbol xst6_eq [n] [P : Tuple n ‚Üí Prop]
  : ŌÄ ((¬¨ (`?? v, P v)) = (`!! v, ¬¨ (P v))) ‚ČĒ
begin
  assume n P;
  refine propExt _ _ _ _
    { assume hne; refine pi_to_!! (őĽ v, ¬¨ (P v))
        (őĽ v hpv, hne (pi_to_??_intro P v hpv)) }
    { assume hall hex; refine pi_to_??_elim P
        (őĽ v hpv, !!_to_pi (őĽ v, ¬¨ (P v)) hall v hpv) hex }
end;

// XST8: (‚ąÉ-block, P) = ((‚ąÄ-block, ¬¨P) ‚áí ‚ä•)
opaque symbol xst8_eq [n] [P : Tuple n ‚Üí Prop]
  : ŌÄ ((`?? v, P v) = ((`!! v, ¬¨ (P v)) ‚áí ‚ä•)) ‚ČĒ
begin
  assume n P;
  refine propExt _ _ _ _
    { assume hex hall; refine pi_to_??_elim P
        (őĽ v hpv, !!_to_pi (őĽ v, ¬¨ (P v)) hall v hpv) hex }
    { assume hc; refine ¬¨¬¨‚āĎ _ (őĽ hne,
        hc (pi_to_!! (őĽ v, ¬¨ (P v))
              (őĽ v hpv, hne (pi_to_??_intro P v hpv)))) }
end;

// NRM1 bridge: ((‚ôĘ_:Tuple n, P) ‚áí Q) = (P ‚áí Q) when P is x-free.
opaque symbol nrm1_eq [n] [P Q : Prop]
  : ŌÄ (((`‚ôĘ _ : Tuple n, P) ‚áí Q) = (P ‚áí Q)) ‚ČĒ
begin
  assume n P Q;
  have h1 : ŌÄ ((`‚ôĘ _ : Tuple n, P) = P)
    { refine eq_trans (‚ôĘ_eq_!! (őĽ _ : Tuple n, P)) (!!_const [n] P) };
  rewrite h1; reflexivity
end;

// NRM14 bridge: ((‚ôĘv¬∑¬¨P v) ‚áí R) = ((‚ô°v¬∑¬¨(‚ä§ ‚ąß P v)) ‚áí R).  ‚ä§ ‚ąß X ‚üļ X, so the
// ‚ä§-padded ‚ô° body matches the bare ‚ôĘ body; ‚ôĘ/‚ô° both reduce to !!, so !!_cong
// lifts the per-v equality.  Used by NRM14_1 (the chain-form NRM14).
opaque symbol nrm14_eq [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ (((`‚ôĘ v, ¬¨ (P v)) ‚áí R) = ((`‚ô° v, ¬¨ ‚čÄ_snoc ‚ä§ (P v)) ‚áí R)) ‚ČĒ
begin
  assume n P R;
  have hbody : ő† v, ŌÄ ((¬¨ (P v)) = (¬¨ ‚čÄ_snoc ‚ä§ (P v)))
    { assume v;
      refine propExt _ _
        (őĽ hnp hcon, hnp (‚čÄ‚āā_snd hcon))
        (őĽ hncon hp, hncon (‚čÄ‚āā_intro ‚ä§ŠĶĘ hp)) };
  have hpred : ŌÄ ((`‚ôĘ v, ¬¨ (P v)) = (`‚ô° v, ¬¨ ‚čÄ_snoc ‚ä§ (P v)))
    { refine eq_trans (‚ôĘ_eq_!! (őĽ v, ¬¨ (P v)))
        (eq_trans (!!_cong hbody)
                  (eq_sym (‚ô°_eq_!! (őĽ v, ¬¨ ‚čÄ_snoc ‚ä§ (P v))))) };
  rewrite hpred; reflexivity
end;

// NRM13 bridge: ((‚ôĘv¬∑(P v ‚áí Q v)) ‚áí R) = ((‚ô°v¬∑¬¨(P v ‚ąß ¬¨Q v)) ‚áí R).  The body
// equivalence (P‚áíQ) ‚üļ ¬¨(P ‚ąß ¬¨Q) is classical (needs `em` on Q v); ‚ôĘ/‚ô° both
// reduce to !!, so !!_cong lifts it.  Used by NRM13_1 (the chain-form NRM13).
opaque symbol nrm13_eq [n] [P Q : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ (((`‚ôĘ v, P v ‚áí Q v) ‚áí R) = ((`‚ô° v, ¬¨ ‚čÄ_snoc (P v) (¬¨ Q v)) ‚áí R)) ‚ČĒ
begin
  assume n P Q R;
  have hbody : ő† v, ŌÄ ((P v ‚áí Q v) = (¬¨ ‚čÄ_snoc (P v) (¬¨ Q v)))
    { assume v;
      refine propExt _ _
        (őĽ hpq hcon, (‚čÄ‚āā_snd hcon) (hpq (‚čÄ‚āā_hd hcon)))
        (őĽ hncon hp, ‚ą®‚āĎ (em (Q v)) (őĽ hq, hq)
                       (őĽ hnq, ‚ä•‚āĎ (hncon (‚čÄ‚āā_intro hp hnq)))) };
  have hpred : ŌÄ ((`‚ôĘ v, P v ‚áí Q v) = (`‚ô° v, ¬¨ ‚čÄ_snoc (P v) (¬¨ Q v)))
    { refine eq_trans (‚ôĘ_eq_!! (őĽ v, P v ‚áí Q v))
        (eq_trans (!!_cong hbody)
                  (eq_sym (‚ô°_eq_!! (őĽ v, ¬¨ ‚čÄ_snoc (P v) (¬¨ Q v))))) };
  rewrite hpred; reflexivity
end;

// NRM12 bridge: ((‚ôĘv¬∑(P v ‚áí ¬¨Q v)) ‚áí R) = ((‚ô°v¬∑¬¨(P v ‚ąß Q v)) ‚áí R).  The body
// equivalence (P ‚áí ¬¨Q) ‚üļ ¬¨(P ‚ąß Q) is constructive.  Used by NRM12_1.
opaque symbol nrm12_eq [n] [P Q : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ (((`‚ôĘ v, P v ‚áí ¬¨ (Q v)) ‚áí R) = ((`‚ô° v, ¬¨ ‚čÄ_snoc (P v) (Q v)) ‚áí R)) ‚ČĒ
begin
  assume n P Q R;
  have hbody : ő† v, ŌÄ ((P v ‚áí ¬¨ (Q v)) = (¬¨ ‚čÄ_snoc (P v) (Q v)))
    { assume v;
      refine propExt _ _
        (őĽ hpnq hcon, (hpnq (‚čÄ‚āā_hd hcon)) (‚čÄ‚āā_snd hcon))
        (őĽ hncon hp hq, hncon (‚čÄ‚āā_intro hp hq)) };
  have hpred : ŌÄ ((`‚ôĘ v, P v ‚áí ¬¨ (Q v)) = (`‚ô° v, ¬¨ ‚čÄ_snoc (P v) (Q v)))
    { refine eq_trans (‚ôĘ_eq_!! (őĽ v, P v ‚áí ¬¨ (Q v)))
        (eq_trans (!!_cong hbody)
                  (eq_sym (‚ô°_eq_!! (őĽ v, ¬¨ ‚čÄ_snoc (P v) (Q v))))) };
  rewrite hpred; reflexivity
end;

// NRM15 bridge: ((‚ôĘv¬∑P v) ‚áí R) = ((‚ô°v¬∑¬¨(‚ä§ ‚ąß ¬¨P v)) ‚áí R).  The body
// equivalence P ‚üļ ¬¨(‚ä§ ‚ąß ¬¨P) is classical (¬¨¬¨‚āĎ).  Used by NRM15_1.
opaque symbol nrm15_eq [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ (((`‚ôĘ v, P v) ‚áí R) = ((`‚ô° v, ¬¨ ‚čÄ_snoc ‚ä§ (¬¨ (P v))) ‚áí R)) ‚ČĒ
begin
  assume n P R;
  have hbody : ő† v, ŌÄ ((P v) = (¬¨ ‚čÄ_snoc ‚ä§ (¬¨ (P v))))
    { assume v;
      refine propExt _ _
        (őĽ hp hcon, (‚čÄ‚āā_snd hcon) hp)
        (őĽ hncon, ¬¨¬¨‚āĎ (P v) (őĽ hnp, hncon (‚čÄ‚āā_intro ‚ä§ŠĶĘ hnp))) };
  have hpred : ŌÄ ((`‚ôĘ v, P v) = (`‚ô° v, ¬¨ ‚čÄ_snoc ‚ä§ (¬¨ (P v))))
    { refine eq_trans (‚ôĘ_eq_!! (őĽ v, P v))
        (eq_trans (!!_cong hbody)
                  (eq_sym (‚ô°_eq_!! (őĽ v, ¬¨ ‚čÄ_snoc ‚ä§ (¬¨ (P v)))))) };
  rewrite hpred; reflexivity
end;

// NRM23 bridge: ((‚ô°v:Tuple1¬∑¬¨(‚ä§ ‚ąß (E = prj 0 v))) ‚áí Q) = (¬¨‚ä§ ‚áí Q).  The ‚ô° body
// is ¬¨(E = prj 0 v); over Tuple 1 the witness v = unit‚®ĺE makes it absurd, so the
// quantified head collapses to ¬¨‚ä§.  Used by NRM23_1 (the chain-form NRM23).
opaque symbol nrm23_eq [Q : Prop] (E : ŌĄ őĻ)
  : ŌÄ (((`‚ô° v : Tuple 1, ¬¨ ‚čÄ (‚ąé ‚ą∑ ‚ä§ ‚ą∑ (E = prj 0 v))) ‚áí Q) = (¬¨ ‚ä§ ‚áí Q)) ‚ČĒ
begin
  assume Q E;
  have hpred : ŌÄ ((`‚ô° v : Tuple 1, ¬¨ ‚čÄ (‚ąé ‚ą∑ ‚ä§ ‚ą∑ (E = prj 0 v))) = ¬¨ ‚ä§)
    { refine propExt _ _
        (őĽ h‚ô° ht, ‚ô°_to_pi (őĽ v : Tuple 1, ¬¨ ‚čÄ (‚ąé ‚ą∑ ‚ä§ ‚ą∑ (E = prj 0 v)))
                          h‚ô° (unit ‚®ĺ E) (‚čÄ‚āā_intro ht (eq_refl E)))
        (őĽ hn‚ä§, ‚ä•‚āĎ (hn‚ä§ ‚ä§ŠĶĘ)) };
  rewrite hpred; reflexivity
end;

// NRM22 bridge, general form: the ‚ô°-body's *tail* equality pins the
// binder (`¬¨(‚čÄ(ps v) ‚ąß (prj 0 v = E))` ‚üļ the body refuted at v := E), so
// the quantified head collapses to `¬¨ ‚čÄ (ps (unit ‚®ĺ E))`.  The body is a
// *list* `ps v ‚ą∑ (prj 0 v = E)` so the cons pattern unifies with any
// conjunct count; the ‚ä§-headed shape is the instance ps := őĽ _, (‚ąé ‚ą∑ ‚ä§).
// The ‚áź direction needs the per-constructor case split, so it goes
// through a helper with a rewrite rule on `(unit ‚®ĺ a)` (the
// nested_to_compound pattern).
symbol nrm22_pin (ps : Tuple 1 ‚Üí ūĚēÉ* o) (E : ŌĄ őĻ)
  (hnp : ŌÄ (¬¨ ‚čÄ (ps (unit ‚®ĺ E))))
  : ő† v : Tuple 1, ŌÄ (¬¨ ‚čÄ (ps v ‚ą∑ (prj 0 v = E)));
rule nrm22_pin $ps $E $hnp (unit ‚®ĺ $a) ‚Ü™
  őĽ hcon, $hnp (ind_eq (eq_sym (‚čÄ_last hcon))
                       (őĽ z, ‚čÄ ($ps (unit ‚®ĺ z)))
                       (‚čÄ_init hcon));

opaque symbol nrm22_eq [Q : Prop] [ps : Tuple 1 ‚Üí ūĚēÉ* o] (E : ŌĄ őĻ)
  : ŌÄ (((`‚ô° v : Tuple 1, ¬¨ ‚čÄ (ps v ‚ą∑ (prj 0 v = E))) ‚áí Q)
       = ((¬¨ ‚čÄ (ps (unit ‚®ĺ E))) ‚áí Q)) ‚ČĒ
begin
  assume Q ps E;
  have hpred : ŌÄ ((`‚ô° v : Tuple 1, ¬¨ ‚čÄ (ps v ‚ą∑ (prj 0 v = E)))
                  = (¬¨ ‚čÄ (ps (unit ‚®ĺ E))))
    { refine propExt _ _
        (őĽ h‚ô° hps, ‚ô°_to_pi (őĽ v : Tuple 1, ¬¨ ‚čÄ (ps v ‚ą∑ (prj 0 v = E)))
                           h‚ô° (unit ‚®ĺ E) (‚čÄ_intro hps (eq_refl E)))
        (őĽ hnp, pi_to_‚ô° (őĽ v : Tuple 1, ¬¨ ‚čÄ (ps v ‚ą∑ (prj 0 v = E)))
                        (nrm22_pin ps E hnp)) };
  rewrite hpred; reflexivity
end;
