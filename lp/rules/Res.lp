// Res P: proof-with-result for normalisation chains.
// result is computed from constructors via rewrite rules.
// All constructor args are implicit ‚Äî inferred by lambdapi from context.
require open pp2lp.B pp2lp.rules.Rw;

constant symbol Res : Prop ‚Üí TYPE;
injective symbol result [P : Prop] : Res P ‚Üí Prop;
symbol to_eq [P : Prop] (r : Res P) : œÄ (P = result r);

// ---- STOP ----
constant symbol stop_r [P : Prop] : Res P;
rule result (@stop_r $P) ‚Ü™ $P;

// ---- Schema 1: passthrough ----

constant symbol and2_r [P Q : Prop] : Res (P ‚áí ¬¨ Q) ‚Üí Res (¬¨ (P ‚àß Q));
rule result (and2_r $h) ‚Ü™ result $h;

constant symbol and3_r [P Q R : Prop] : Res (P ‚áí Q ‚áí R) ‚Üí Res ((P ‚àß Q) ‚áí R);
rule result (and3_r $h) ‚Ü™ result $h;

constant symbol or4_r [P Q : Prop] : Res (¬¨ P ‚áí Q) ‚Üí Res (P ‚à® Q);
rule result (or4_r $h) ‚Ü™ result $h;

constant symbol vr3_r [P : Prop] : Res P ‚Üí Res (‚ä§ ‚áí P);
rule result (vr3_r $h) ‚Ü™ result $h;

constant symbol evr2_r [E : œÑ Œπ] : Res ‚ä• ‚Üí Res (¬¨ (E = E));
rule result (evr2_r $h) ‚Ü™ result $h;

constant symbol not1_r [P R : Prop] : Res (P ‚áí R) ‚Üí Res (¬¨ ¬¨ P ‚áí R);
rule result (not1_r $h) ‚Ü™ result $h;

constant symbol xst7_r [P : œÑ Œπ ‚Üí Prop] [R : Prop]
  : Res (`‚àÄ x, P x ‚áí R) ‚Üí Res ((`‚àÉ x, P x) ‚áí R);
rule result (xst7_r $h) ‚Ü™ result $h;

constant symbol evr3_r [E : œÑ Œπ] [P : Prop] : Res P ‚Üí Res ((E = E) ‚áí P);
rule result (evr3_r $h) ‚Ü™ result $h;

constant symbol or1_r [P Q R : Prop]
  : Res (¬¨ P ‚áí ¬¨ Q ‚áí R) ‚Üí Res (¬¨ (P ‚à® Q) ‚áí R);
rule result (or1_r $h) ‚Ü™ result $h;

constant symbol imp1_r [P Q R : Prop]
  : Res (P ‚áí ¬¨ Q ‚áí R) ‚Üí Res (¬¨ (P ‚áí Q) ‚áí R);
rule result (imp1_r $h) ‚Ü™ result $h;

constant symbol imp5_r [P Q : Prop] : Res Q ‚Üí Res (P ‚áí Q);
rule result (imp5_r $h) ‚Ü™ result $h;

constant symbol not2_r [P : Prop] : Res P ‚Üí Res (¬¨ ¬¨ P);
rule result (not2_r $h) ‚Ü™ result $h;

constant symbol vr2_r : Res ‚ä• ‚Üí Res (¬¨ ‚ä§);
rule result (vr2_r $h) ‚Ü™ result $h;

constant symbol fx1_r [P : Prop] : Res P ‚Üí Res (¬¨ ‚ä• ‚áí P);
rule result (fx1_r $h) ‚Ü™ result $h;

// EQV: schema 2 (branching)
constant symbol eqv1_r [P Q R : Prop]
  : Res (P ‚áí ¬¨ Q ‚áí R) ‚Üí Res (¬¨ P ‚áí Q ‚áí R) ‚Üí Res (¬¨ (P ‚áî Q) ‚áí R);
rule result (eqv1_r $h1 $h2) ‚Ü™ result $h1 ‚àß result $h2;

constant symbol eqv2_r [P Q : Prop]
  : Res (¬¨ Q) ‚Üí Res P ‚Üí Res (¬¨ (P ‚áî Q));
rule result (eqv2_r $h1 $h2) ‚Ü™ result $h1 ‚àß result $h2;

constant symbol eqv3_r [P Q R : Prop]
  : Res (Q ‚áí R) ‚Üí Res (P ‚áí R) ‚Üí Res ((P ‚áî Q) ‚áí R);
rule result (eqv3_r $h1 $h2) ‚Ü™ result $h1 ‚àß result $h2;

constant symbol eqv4_r [P Q : Prop]
  : Res (Q ‚áí P) ‚Üí Res (P ‚áí Q) ‚Üí Res (P ‚áî Q);
rule result (eqv4_r $h1 $h2) ‚Ü™ result $h1 ‚àß result $h2;

// OPR1/OPR2: substitution under equality
// PE (child consequent) is explicit; Px (goal consequent) inferred from context.
constant symbol opr1_r [x E : œÑ Œπ] (PE : Prop) [Px : Prop]
  : Res ((x = E) ‚áí PE) ‚Üí Res ((x = E) ‚áí Px);
rule result (opr1_r _ $h) ‚Ü™ result $h;

constant symbol opr2_r [E x : œÑ Œπ] (PE : Prop) [Px : Prop]
  : Res ((E = x) ‚áí PE) ‚Üí Res ((E = x) ‚áí Px);
rule result (opr2_r _ $h) ‚Ü™ result $h;

// AR9: solver equality E=F
constant symbol ar9_r [E F : œÑ Œπ] [R : Prop]
  : œÄ (E = F) ‚Üí Res ((F ‚â§ ùüé) ‚áí R) ‚Üí Res ((E ‚â§ ùüé) ‚áí R);
rule result (ar9_r _ $h) ‚Ü™ result $h;

// ---- Schema 2: branching (result = S1 ‚àß S2) ----

constant symbol and1_r [P Q R : Prop]
  : Res (¬¨ Q ‚áí R) ‚Üí Res (¬¨ P ‚áí R) ‚Üí Res (¬¨ (P ‚àß Q) ‚áí R);
rule result (and1_r $h1 $h2) ‚Ü™ result $h1 ‚àß result $h2;

constant symbol or3_r [P Q R : Prop]
  : Res (Q ‚áí R) ‚Üí Res (P ‚áí R) ‚Üí Res ((P ‚à® Q) ‚áí R);
rule result (or3_r $h1 $h2) ‚Ü™ result $h1 ‚àß result $h2;

constant symbol and4_r [P Q : Prop]
  : Res Q ‚Üí Res P ‚Üí Res (P ‚àß Q);
rule result (and4_r $h1 $h2) ‚Ü™ result $h1 ‚àß result $h2;

constant symbol imp3_r [P Q R : Prop]
  : Res (Q ‚áí R) ‚Üí Res (¬¨ P ‚áí R) ‚Üí Res ((P ‚áí Q) ‚áí R);
rule result (imp3_r $h1 $h2) ‚Ü™ result $h1 ‚àß result $h2;

constant symbol or2_r [P Q : Prop]
  : Res (¬¨ Q) ‚Üí Res (¬¨ P) ‚Üí Res (¬¨ (P ‚à® Q));
rule result (or2_r $h1 $h2) ‚Ü™ result $h1 ‚àß result $h2;

constant symbol imp2_r [P Q : Prop]
  : Res (¬¨ Q) ‚Üí Res P ‚Üí Res (¬¨ (P ‚áí Q));
rule result (imp2_r $h1 $h2) ‚Ü™ result $h1 ‚àß result $h2;

// ---- Structural ----

constant symbol imp4_r [P Q : Prop] : Res Q ‚Üí Res (P ‚áí Q);
rule result (@imp4_r $P _ $h) ‚Ü™ $P ‚áí result $h;

constant symbol all8_r [P : œÑ Œπ ‚Üí Prop]
  : (ŒÝ x : œÑ Œπ, Res (P x)) ‚Üí Res (`‚àÄ x, P x);
rule result (all8_r $f) ‚Ü™ `‚àÄ x, result ($f x);

constant symbol all9_r [H Q : Prop] : Res Q ‚Üí Res (H ‚áí Q);
rule result (@all9_r $H _ $h) ‚Ü™ $H ‚áí result $h;

constant symbol and5_r [C C' R : Prop]
  : (œÄ C ‚Üí œÄ C') ‚Üí (œÄ C' ‚Üí œÄ C) ‚Üí Res (C' ‚áí R) ‚Üí Res (C ‚áí R);
rule result (and5_r _ _ $h) ‚Ü™ result $h;

// ---- ALL7 with dependent type ----

symbol ALL7r [P : œÑ Œπ ‚Üí Prop] [Q : Prop]
  (h1 : ŒÝ x : œÑ Œπ, Res (P x))
  (h2 : œÄ ((`‚ô¢ x, result (h1 x)) ‚áí Q))
  : œÄ ((`‚àÄ x, P x) ‚áí Q) ‚âî
  Œª hP, h2 (Œª x, =‚áí (to_eq (h1 x)) (hP x));

symbol ALL7_2r [P : œÑ Œπ ‚Üí œÑ Œπ ‚Üí Prop] [Q : Prop]
  (h1 : ŒÝ x : œÑ Œπ, ŒÝ y : œÑ Œπ, Res (P x y))
  (h2 : œÄ ((`‚ô¢ x, `‚ô¢ y, result (h1 x y)) ‚áí Q))
  : œÄ ((`‚àÄ x, `‚àÄ y, P x y) ‚áí Q) ‚âî
  Œª hP, h2 (Œª x y, =‚áí (to_eq (h1 x y)) (hP x y));

// ---- XST8 with Res: existential via ¬¨¬¨ elimination ----
// XST8: (H ‚ä¢ ¬¨P) ‚áù R; H ‚ä¢ (‚àÄx¬∑R) ‚áí ‚ä• ‚Üí H ‚ä¢ ‚àÉx¬∑P
// The result chain computes R from ¬¨P. We need ¬¨(P x) = result(h1 x),
// then the continuation proves (‚àÄx, result(h1 x)) ‚áí ‚ä•.

symbol XST8r [P : œÑ Œπ ‚Üí Prop]
  (h1 : ŒÝ x : œÑ Œπ, Res (¬¨ (P x)))
  (h2 : œÄ ((`‚àÄ x, result (h1 x)) ‚áí ‚ä•))
  : œÄ (`‚àÉ x, P x) ‚âî
  ¬¨¬¨‚Çë _ (Œª hne, h2 (Œª x, =‚áí (to_eq (h1 x)) (Œª hpx, hne (‚àÉ·µ¢ x hpx))));

symbol XST8_2r [P : œÑ Œπ ‚Üí œÑ Œπ ‚Üí Prop]
  (h1 : ŒÝ x : œÑ Œπ, ŒÝ y : œÑ Œπ, Res (¬¨ (P x y)))
  (h2 : œÄ ((`‚àÄ x, `‚àÄ y, result (h1 x y)) ‚áí ‚ä•))
  : œÄ (`‚àÉ x, `‚àÉ y, P x y) ‚âî
  ¬¨¬¨‚Çë _ (Œª hne, h2 (Œª x y, =‚áí (to_eq (h1 x y)) (Œª hpxy, hne (‚àÉ·µ¢ x (‚àÉ·µ¢ y hpxy)))));
