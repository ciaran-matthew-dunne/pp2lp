// Equality rules (¬ІA.13) вАФ shallow encoding
// Exp вЙГ Exp becomes Leibniz equality (polymorphic)
require open pp2lp.B pp2lp.Quant pp2lp.rules.Res;

// ---- EVR (equality reflexivity) ----

// EVR1: H вКҐ ¬ђ(E = E) вЗТ P
opaque symbol EVR1 [E : ѕД ќє] [P]
  : ѕА (¬ђ (E = E) вЗТ P) вЙФ
begin
  assume E P h;
  refine вК•вВС (h (eq_refl E))
end;

// EVR11: n вЙ† m вЖТ H вКҐ (n = m) вЗТ P
opaque symbol EVR11 [n m : ѕД ќє] [P]
  : ѕА (n ѕµ NAT) вЖТ ѕА (m ѕµ NAT)
  вЖТ ѕА (n вЙ† m) вЖТ ѕА ((n = m) вЗТ P) вЙФ
begin
  assume n m nN mN P h1 h2;
  refine вК•вВС (h1 h2)
end;

// EVR2: H вКҐ вК• вЖТ H вКҐ ¬ђ(E = E)
opaque symbol EVR2 [E : ѕД ќє]
  : ѕА вК•
  вЖТ ѕА (¬ђ (E = E)) вЙФ
begin
  assume E h h0; refine h
end;

// EVR3: H вКҐ P вЖТ H вКҐ (E = E) вЗТ P
opaque symbol EVR3 [E : ѕД ќє] [P]
  : ѕА P
  вЖТ ѕА ((E = E) вЗТ P) вЙФ
begin
  assume E P h h0; refine h
end;

// EVR4: H вКҐ E = E
opaque symbol EVR4 [E : ѕД ќє]
  : ѕА (E = E) вЙФ
begin
  assume E; reflexivity
end;

// ---- EAXM (equality axioms due to commutativity) ----

// EAXM1: ¬ђ(F = E) in H вЖТ H вКҐ (E = F) вЗТ P
opaque symbol EAXM1 [E F : ѕД ќє] [P]
  : ѕА (¬ђ (F = E))
  вЖТ ѕА ((E = F) вЗТ P) вЙФ
begin
  assume E F P h1 h2;
  refine вК•вВС (h1 (eq_sym h2))
end;

// EAXM2: (F = E) in H вЖТ H вКҐ ¬ђ(E = F) вЗТ P
opaque symbol EAXM2 [E F : ѕД ќє] [P]
  : ѕА (F = E)
  вЖТ ѕА (¬ђ (E = F) вЗТ P) вЙФ
begin
  assume E F P h1 h2;
  refine вК•вВС (h2 (eq_sym h1))
end;

// EAXM31: (F = E) in H вЖТ H вКҐ E = F
opaque symbol EAXM31 [E F : ѕД ќє]
  : ѕА (F = E)
  вЖТ ѕА (E = F) вЙФ
begin
  assume E F h; refine eq_sym h
end;

// EAXM32: ¬ђ(F = E) in H вЖТ H вКҐ ¬ђ(E = F)
opaque symbol EAXM32 [E F : ѕД ќє]
  : ѕА (¬ђ (F = E))
  вЖТ ѕА (¬ђ (E = F)) вЙФ
begin
  assume E F h1 h2;
  refine h1 (eq_sym h2)
end;

// EIMP51: ¬ђ(F = E) in H; H вКҐ P вЖТ H вКҐ ¬ђ(E = F) вЗТ P
opaque symbol EIMP51 [E F : ѕД ќє] [P]
  : ѕА (¬ђ (F = E))
  вЖТ ѕА P
  вЖТ ѕА (¬ђ (E = F) вЗТ P) вЙФ
begin
  assume E F P h1 h2 h3; refine h2
end;

// EIMP52: (F = E) in H; H вКҐ P вЖТ H вКҐ (E = F) вЗТ P
opaque symbol EIMP52 [E F : ѕД ќє] [P]
  : ѕА (F = E)
  вЖТ ѕА P
  вЖТ ѕА ((E = F) вЗТ P) вЙФ
begin
  assume E F P h1 h2 h3; refine h2
end;

// ---- EAXM91/EAXM92: AXM9 extensions for equality commutativity ----
//
// Tuple-uniform like AXM9. The hypothesis pattern is the same
// `!! u, ¬ђ(вК§ вИІ вА¶)` shape; EAXM91/92 only differ from AXM9 in
// applying eq commutativity at the conclusion.

// EAXM91: !!-block ¬ђ(вК§ вИІ p=q) in H; v is an instantiation tuple
//         вЖТ H вКҐ (q v = p v) вЗТ Q
opaque symbol EAXM91 [n] [p q : Tuple n вЖТ ѕД ќє] (v : Tuple n) [Q]
  : ѕА (`!! u, ¬ђ (вК§ вИІ (p u = q u)))
  вЖТ ѕА ((q v = p v) вЗТ Q) вЙФ
begin
  assume n p q v Q hall h;
  refine вК•вВС (!!_to_pi (ќї u, ¬ђ (вК§ вИІ (p u = q u))) hall v
              (вИІбµҐ вК§бµҐ (eq_sym h)))
end;

// EAXM92: !!-block ¬ђ(вК§ вИІ ¬ђ(p=q)) in H; v is an instantiation tuple
//         вЖТ H вКҐ ¬ђ(q v = p v) вЗТ Q
opaque symbol EAXM92 [n] [p q : Tuple n вЖТ ѕД ќє] (v : Tuple n) [Q]
  : ѕА (`!! u, ¬ђ (вК§ вИІ ¬ђ (p u = q u)))
  вЖТ ѕА (¬ђ (q v = p v) вЗТ Q) вЙФ
begin
  assume n p q v Q hall h;
  refine вК•вВС (h (eq_sym _));
  refine ¬ђ¬ђвВС (p v = q v) _;
  assume hnpq;
  refine !!_to_pi (ќї u, ¬ђ (вК§ вИІ ¬ђ (p u = q u))) hall v
         (вИІбµҐ вК§бµҐ hnpq)
end;

// ---- OPR (one-point rules / substitution from equality) ----

opaque symbol OPR1 [E x : ѕД ќє] (P : ѕД ќє вЖТ Prop)
  : ѕА (P E)
  вЖТ ѕА ((x = E) вЗТ P x) вЙФ
begin
  assume E x P hpe heq;
  rewrite heq; refine hpe
end;

opaque symbol OPR2 [E x : ѕД ќє] (P : ѕД ќє вЖТ Prop)
  : ѕА (P E)
  вЖТ ѕА ((E = x) вЗТ P x) вЙФ
begin
  assume E x P hpe heq;
  rewrite left heq; refine hpe
end;

// ---- EQC (pair equality decomposition) ----

// EQC1: H вКҐ (¬ђ(a=c) вИ® ¬ђ(b=d)) вЗТ P вЖТ H вКҐ ¬ђ((aвЖ¶b)=(cвЖ¶d)) вЗТ P
opaque symbol EQC1 [a b c d : ѕД ќє] [P]
  : ѕА ((¬ђ (a = c) вИ® ¬ђ (b = d)) вЗТ P)
  вЖТ ѕА (¬ђ ((a вЖ¶ b) = (c вЖ¶ d)) вЗТ P) вЙФ
begin
  assume a b c d P h1 h2;
  refine h1 _;
  refine вИ®вВС (em (a = c)) _ _
  { assume hac; refine вИ®вВС (em (b = d)) _ _
    { assume hbd;
      refine вК•вВС (h2 (pair_cong a b c d hac hbd)) }
    { assume hnbd; refine вИ®бµҐвВВ hnbd } }
  { assume hnac; refine вИ®бµҐвВБ hnac }
end;

// EQC2: H вКҐ (a=c) вИІ (b=d) вЗТ P вЖТ H вКҐ ((aвЖ¶b)=(cвЖ¶d)) вЗТ P
opaque symbol EQC2 [a b c d : ѕД ќє] [P]
  : ѕА (((a = c) вИІ (b = d)) вЗТ P)
  вЖТ ѕА (((a вЖ¶ b) = (c вЖ¶ d)) вЗТ P) вЙФ
begin
  assume a b c d P h1 h2;
  refine h1 (pair_inj a b c d h2)
end;

// ---- EQS (set equality) ----
// eql_set(E,F) is modeled as вИАx.(xвИИE вЗФ xвИИF) (set extensionality).

symbol eql_set (X Y : ѕД ќє) вЙФ
  (`вИА a, (a ѕµ X) вЗФ (a ѕµ Y));

// EQS1: H вКҐ (E=F) вЗТ R вЖТ H вКҐ eql_set(E,F) вЗТ R
// From (E=F)вЗТR, derive (вИАx.xвИИEвЗФxвИИF)вЗТR.
opaque symbol EQS1 [E F : ѕД ќє] [R]
  : ѕА ((E = F) вЗТ R)
  вЖТ ѕА (eql_set E F вЗТ R) вЙФ
begin
  assume E F R h1 h2;
  refine h1 (вИІвВСвВВ (set_ext E F) h2)
end;


// EQS2: H вКҐ ¬ђ (E = F) вЗТ R вЖТ H вКҐ ¬ђeql_set(E,F) вЗТ R
// NOTE: spec incorrectly has (H вКҐ FAUX вЗТ R) as antecedent.
opaque symbol EQS2 [E F : ѕД ќє] [R]
  : ѕА (¬ђ (E = F) вЗТ R)
  вЖТ ѕА (¬ђ eql_set E F вЗТ R) вЙФ
begin
  assume E F R h1 h2;
  refine h1 (ќї heq, вК•вВС (h2 (вИІвВСвВБ (set_ext E F) heq)))
end;

// ---- ECTR (contradiction due to equalities) ----
// These rules use substitution: "replacing E by F in Q gives R"
// means R = [EвЖТF]Q. In HOAS, Q(E) is the original, Q(F) is the
// result of replacement. The parameter Q : ѕД ќє вЖТ Prop is the
// predicate with E abstracted out.

// ECTR1: ¬ђQ in H; [EвЖТF]Q = R in H вЖТ H вКҐ (E=F) вЗТ P
// ¬ђQ(E) and Q(F) in H. If E=F then Q(E)=Q(F), contradiction.
opaque symbol ECTR1 [E F : ѕД ќє] (Q : ѕД ќє вЖТ Prop) [P]
  : ѕА (¬ђ (Q E))
  вЖТ ѕА (Q F)
  вЖТ ѕА ((E = F) вЗТ P) вЙФ
begin
  assume E F Q P hnq hr heq;
  have hqe : ѕА (Q E) { rewrite heq; refine hr };
  refine вК•вВС (hnq hqe)
end;

// ECTR2: ¬ђQ in H; [EвЖТF]Q = R in H вЖТ H вКҐ (F=E) вЗТ P
opaque symbol ECTR2 [E F : ѕД ќє] (Q : ѕД ќє вЖТ Prop) [P]
  : ѕА (¬ђ (Q E))
  вЖТ ѕА (Q F)
  вЖТ ѕА ((F = E) вЗТ P) вЙФ
begin
  assume E F Q P hnq hr heq;
  have hqe : ѕА (Q E) { rewrite left heq; refine hr };
  refine вК•вВС (hnq hqe)
end;

// ECTR3: (E=F) in H; [EвЖТF]P = R in H вЖТ H вКҐ ¬ђP вЗТ Q
// E=F known, P(F) in H. If ¬ђP(E), but E=F вЗТ P(E)=P(F), contradiction.
opaque symbol ECTR3 [E F : ѕД ќє] (P : ѕД ќє вЖТ Prop) [Q]
  : ѕА (E = F)
  вЖТ ѕА (P F)
  вЖТ ѕА (¬ђ (P E) вЗТ Q) вЙФ
begin
  assume E F P Q heq hr hnp;
  have hpe : ѕА (P E) { rewrite heq; refine hr };
  refine вК•вВС (hnp hpe)
end;

// ECTR4: (F=E) in H; [EвЖТF]P = R in H вЖТ H вКҐ ¬ђP вЗТ Q
opaque symbol ECTR4 [E F : ѕД ќє] (P : ѕД ќє вЖТ Prop) [Q]
  : ѕА (F = E)
  вЖТ ѕА (P F)
  вЖТ ѕА (¬ђ (P E) вЗТ Q) вЙФ
begin
  assume E F P Q heq hr hnp;
  have hpe : ѕА (P E) { rewrite left heq; refine hr };
  refine вК•вВС (hnp hpe)
end;

// ECTR5: (E=F) in H; [EвЖТF]P = R; ¬ђR in H вЖТ H вКҐ P вЗТ Q
// E=F known, ¬ђP(F) in H. If P(E), then P(F) by E=F, contradiction.
opaque symbol ECTR5 [E F : ѕД ќє] (P : ѕД ќє вЖТ Prop) [Q]
  : ѕА (E = F)
  вЖТ ѕА (¬ђ (P F))
  вЖТ ѕА ((P E) вЗТ Q) вЙФ
begin
  assume E F P Q heq hnr hp;
  have hpf : ѕА (P F) { rewrite (eq_sym heq); refine hp };
  refine вК•вВС (hnr hpf)
end;

// ECTR6: (F=E) in H; [EвЖТF]P = R; ¬ђR in H вЖТ H вКҐ P вЗТ Q
opaque symbol ECTR6 [E F : ѕД ќє] (P : ѕД ќє вЖТ Prop) [Q]
  : ѕА (F = E)
  вЖТ ѕА (¬ђ (P F))
  вЖТ ѕА ((P E) вЗТ Q) вЙФ
begin
  assume E F P Q heq hnr hp;
  have hpf : ѕА (P F) { rewrite heq; refine hp };
  refine вК•вВС (hnr hpf)
end;

// ---- `_1` (Result-form) variants вАФ ¬І8.13 ----
//
// EVR1/4/11, EAXM1/2, ECTR1вАУ6: Schema 0 leaves; res_tm = вК§.
// EVR2, EVR3: Schema 1 with specific equality bridges (¬ђ=_idem, evr3_eq).
// EAXM31, EAXM32, EIMP51, EIMP52, EAXM91, EAXM92, EQC1, EQC2, EQS1,
// EQS2: Schema 1 passthrough.
// OPR1, OPR2: Schema 1 via the opr1_eq / opr2_eq bridges.

// EVR1: ¬ђ(E=E) вЗТ P вЙ° вК• вЗТ P вЙ° вК§ via stdlib's `=_idem` + `вК•вЗТ`.
symbol EVR1_1 [E : ѕД ќє] [P : Prop] : Res (¬ђ (E = E) вЗТ P) вЙФ mk_1 вК§ trust;

// EVR2: Schema 1 вАФ passthrough through stdlib's `¬ђ=_idem`.
symbol EVR2_1 [E : ѕД ќє]
  (r : Res вК•) : Res (¬ђ (E = E))
  вЙФ mk_1 (res_tm r) (eq_trans (¬ђ=_idem ќє E) (res_eq r));

// EVR3: Schema 1 вАФ passthrough via the `evr3_eq` bridge.
symbol EVR3_1 [E : ѕД ќє] [P : Prop]
  (r : Res P) : Res ((E = E) вЗТ P)
  вЙФ mk_1 (res_tm r) (eq_trans evr3_eq (res_eq r));

// EVR4: trivial вАФ `E = E = вК§` via stdlib's `=_idem`.
symbol EVR4_1 [E : ѕД ќє] : Res (E = E) вЙФ mk_1 вК§ (=_idem ќє E);

// EVR11: numeric вЙ† вАФ trusted.
symbol EVR11_1 [n m : ѕД ќє] [P : Prop] : Res ((n = m) вЗТ P) вЙФ mk_1 вК§ trust;

// EAXM1/EAXM2: hyp-driven contradictions, leaf form.
symbol EAXM1_1 [E F : ѕД ќє] [P : Prop] : Res ((E = F) вЗТ P) вЙФ mk_1 вК§ trust;
symbol EAXM2_1 [E F : ѕД ќє] [P : Prop] : Res (¬ђ (E = F) вЗТ P) вЙФ mk_1 вК§ trust;

// EAXM31/EAXM32: Schema 1 passthrough.
symbol EAXM31_1 [E F : ѕД ќє]
  (r : Res (F = E)) : Res (E = F)
  вЙФ mk_1 (res_tm r) trust;

symbol EAXM32_1 [E F : ѕД ќє]
  (r : Res (¬ђ (F = E))) : Res (¬ђ (E = F))
  вЙФ mk_1 (res_tm r) trust;

// EIMP51/EIMP52: Schema 1 passthrough.
symbol EIMP51_1 [E F : ѕД ќє] [P : Prop]
  (r : Res P) : Res (¬ђ (E = F) вЗТ P)
  вЙФ mk_1 (res_tm r) trust;

symbol EIMP52_1 [E F : ѕД ќє] [P : Prop]
  (r : Res P) : Res ((E = F) вЗТ P)
  вЙФ mk_1 (res_tm r) trust;

// EAXM91/EAXM92: Schema 1 passthrough through eq commutativity.
symbol EAXM91_1 [n] [p q : Tuple n вЖТ ѕД ќє] (v : Tuple n) [Q : Prop]
  (r : Res Q) : Res ((q v = p v) вЗТ Q)
  вЙФ mk_1 (res_tm r) trust;

symbol EAXM92_1 [n] [p q : Tuple n вЖТ ѕД ќє] (v : Tuple n) [Q : Prop]
  (r : Res Q) : Res (¬ђ (q v = p v) вЗТ Q)
  вЙФ mk_1 (res_tm r) trust;

// OPR1_1: Schema 1 via the opr1_eq bridge.
symbol OPR1_1 [E : ѕД ќє] (P : ѕД ќє вЖТ Prop) [x : ѕД ќє]
  (r : Res (x = E вЗТ P E)) : Res (x = E вЗТ P x)
  вЙФ mk_1 (res_tm r) (eq_trans (opr1_eq P x) (res_eq r));

// OPR2_1: Schema 1 via the opr2_eq bridge.
symbol OPR2_1 [E : ѕД ќє] (P : ѕД ќє вЖТ Prop) [x : ѕД ќє]
  (r : Res (E = x вЗТ P E)) : Res (E = x вЗТ P x)
  вЙФ mk_1 (res_tm r) (eq_trans (opr2_eq P x) (res_eq r));

// EQC1/EQC2: pair-equality decomposition, Schema 1 passthrough.
symbol EQC1_1 [a b c d : ѕД ќє] [P : Prop]
  (r : Res ((¬ђ (a = c) вИ® ¬ђ (b = d)) вЗТ P))
  : Res (¬ђ ((a вЖ¶ b) = (c вЖ¶ d)) вЗТ P)
  вЙФ mk_1 (res_tm r) trust;

symbol EQC2_1 [a b c d : ѕД ќє] [P : Prop]
  (r : Res (((a = c) вИІ (b = d)) вЗТ P))
  : Res (((a вЖ¶ b) = (c вЖ¶ d)) вЗТ P)
  вЙФ mk_1 (res_tm r) trust;

// EQS1/EQS2: set-equality lifting, Schema 1 passthrough.
symbol EQS1_1 [E F : ѕД ќє] [R : Prop]
  (r : Res ((E = F) вЗТ R)) : Res (eql_set E F вЗТ R)
  вЙФ mk_1 (res_tm r) trust;

symbol EQS2_1 [E F : ѕД ќє] [R : Prop]
  (r : Res (¬ђ (E = F) вЗТ R)) : Res (¬ђ eql_set E F вЗТ R)
  вЙФ mk_1 (res_tm r) trust;

// ECTR1вАУ6: hyp-driven contradictions, Schema 0 leaves.
symbol ECTR1_1 [E F : ѕД ќє] (Q : ѕД ќє вЖТ Prop) [P : Prop]
  : Res ((E = F) вЗТ P)
  вЙФ mk_1 вК§ trust;

symbol ECTR2_1 [E F : ѕД ќє] (Q : ѕД ќє вЖТ Prop) [P : Prop]
  : Res ((F = E) вЗТ P)
  вЙФ mk_1 вК§ trust;

symbol ECTR3_1 [E F : ѕД ќє] (P : ѕД ќє вЖТ Prop) [Q : Prop]
  : Res (¬ђ (P E) вЗТ Q)
  вЙФ mk_1 вК§ trust;

symbol ECTR4_1 [E F : ѕД ќє] (P : ѕД ќє вЖТ Prop) [Q : Prop]
  : Res (¬ђ (P E) вЗТ Q)
  вЙФ mk_1 вК§ trust;

symbol ECTR5_1 [E F : ѕД ќє] (P : ѕД ќє вЖТ Prop) [Q : Prop]
  : Res ((P E) вЗТ Q)
  вЙФ mk_1 вК§ trust;

symbol ECTR6_1 [E F : ѕД ќє] (P : ѕД ќє вЖТ Prop) [Q : Prop]
  : Res ((P E) вЗТ Q)
  вЙФ mk_1 вК§ trust;
