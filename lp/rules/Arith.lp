// Arithmetic (¬ІA.14) вАФ shallow encoding
// Uses вЙ§ and leq_refl from B.lp.
require open pp2lp.B;

// ---- AR1-3: Reflexivity of вЙ§ ----

// AR1: H вКҐ R вЖТ H вКҐ E вЙ§ E вЗТ R
opaque symbol AR1 [E : ѕД ќє] [R : Prop]
  : ѕА R
  вЖТ ѕА ((E вЙ§ E) вЗТ R) вЙФ
begin
  assume E R h h0; refine h
end;

// AR2: a numeric, b numeric, a > b вЖТ H вКҐ a вЙ§ b вЗТ R
opaque symbol AR2 [a b : ѕД ќє] [R : Prop]
  : ѕА (¬ђ (a вЙ§ b))
  вЖТ ѕА ((a вЙ§ b) вЗТ R) вЙФ
begin
  admit
end;

opaque symbol AR3 [a : ѕД ќє] [R : Prop]
  : ѕА (((рЭЯП - a) вЙ§ рЭЯО) вЗТ R)
  вЖТ ѕА (¬ђ (a вЙ§ рЭЯО) вЗТ R) вЙФ
begin
  admit
end;

opaque symbol AR4 [E : ѕД ќє] [R : Prop] (F : ѕД ќє)
  : ѕА (F вЙ§ рЭЯО)
  вЖТ ѕА (¬ђ ((E + F) вЙ§ рЭЯО))
  вЖТ ѕА ((E вЙ§ рЭЯО) вЗТ R) вЙФ
begin
  admit
end;

// ---- AR5/AR6: Antisymmetry decomposition ----

opaque symbol AR5 [a : ѕД ќє] [R : Prop]
  : ѕА (a вЙ™ рЭЯО)
  вЖТ ѕА (a = рЭЯО вЗТ ((вАФ a вЙ§ рЭЯО) вЗТ R))
  вЖТ ѕА ((вАФ a вЙ§ рЭЯО) вЗТ R) вЙФ
begin
  admit
end;

opaque symbol AR6 [a : ѕД ќє] [R : Prop]
  : ѕА ((вАФ a) вЙ™ рЭЯО)
  вЖТ ѕА ((a = рЭЯО) вЗТ ((a вЙ§ рЭЯО) вЗТ R))
  вЖТ ѕА ((a вЙ§ рЭЯО) вЗТ R) вЙФ
begin
  admit
end;

// ---- AR7/AR8: Antisymmetry with offset ----

opaque symbol AR7 [a b c : ѕД ќє] [R : Prop]
  : ѕА ((c + b) вЙ™ рЭЯО)
  вЖТ ѕА ((a + c) = рЭЯО)
  вЖТ ѕА ((a = b) вЗТ (((a - b) вЙ™ рЭЯО) вЗТ R))
  вЖТ ѕА (((a - b) вЙ§ рЭЯО) вЗТ R) вЙФ
begin
  admit
end;

opaque symbol AR8 [a b c : ѕД ќє] [R : Prop]
  : ѕА ((a - b) вЙ™ рЭЯО)
  вЖТ ѕА ((a + c) = рЭЯО)
  вЖТ ѕА ((a = b) вЗТ (((c + b) вЙ§ рЭЯО) вЗТ R))
  вЖТ ѕА (((c + b) вЙ§ рЭЯО) вЗТ R) вЙФ
begin
  admit
end;

opaque symbol AR9 [E : ѕД ќє] (F : ѕД ќє) [R : Prop]
  : ѕА (E = F)
  вЖТ ѕА ((F вЙ§ рЭЯО) вЗТ R)
  вЖТ ѕА ((E вЙ§ рЭЯО) вЗТ R) вЙФ
begin
  admit
end;

opaque symbol AR9_1 [E : ѕД ќє] (F : ѕД ќє) [R : Prop] [S : Prop]
  : ѕА вК§
  вЖТ ѕА (((F вЙ§ рЭЯО) вЗТ R) = S)
  вЖТ ѕА (((E вЙ§ рЭЯО) вЗТ R) = S) вЙФ
begin
  admit
end;

// AR10: solver(P) = Q; H вКҐ Q вЗТ R вЖТ H вКҐ P вЗТ R
opaque symbol AR10 [P Q R : Prop]
  : ѕА (P = Q)
  вЖТ ѕА (Q вЗТ R)
  вЖТ ѕА (P вЗТ R) вЙФ
begin
  assume P Q R heq h1 h2;
  refine h1 (=вЗТ heq h2)
end;

// AR11: H вКҐ ¬ђ(x вЙ§ x) вЗТ P
opaque symbol AR11 [E : ѕД ќє] [P : Prop]
  : ѕА (¬ђ (E вЙ§ E) вЗТ P) вЙФ
begin
  assume E P h; refine вК•вВС (h (leq_refl E))
end;

// AR12: H, (a вЙ§ b) вКҐ P вЖТ H вКҐ (a вЙ™ b) вЗТ P
opaque symbol AR12 [a b : ѕД ќє] [P : Prop]
  : (ѕА (a вЙ§ b) вЖТ ѕА P)
  вЖТ ѕА ((a вЙ™ b) вЗТ P) вЙФ
begin
  assume a b P h1 h2;
  refine h1 (strict_to_leq a b h2)
end;

// AR13: solver(1вИТa) = b; b вЙ§ 0 вЖТ ¬ђ(a вЙ™ 0)
opaque symbol AR13 [a b : ѕД ќє]
  : ѕА ((рЭЯП - a) = b)
  вЖТ ѕА (b вЙ§ рЭЯО)
  вЖТ ѕА (¬ђ (a вЙ™ рЭЯО)) вЙФ
begin
  admit
end;
