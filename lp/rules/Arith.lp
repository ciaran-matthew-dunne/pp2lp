// Arithmetic (¬ІA.14) вАФ shallow encoding
// Uses вЙ§ and leq_refl from B.lp.
require open pp2lp.B pp2lp.Quant pp2lp.rules.Res;

// ---- AR1-3: Reflexivity of вЙ§ ----

opaque symbol AR1 [E : ѕД ќє] [R : Prop]
  : ѕА R
  вЖТ ѕА ((E вЙ§ E) вЗТ R) вЙФ
begin
  assume E R h h0; refine h
end;

opaque symbol AR2 [a b : ѕД ќє] [R : Prop]
  : ѕА (a > b)
  вЖТ ѕА ((a вЙ§ b) вЗТ R) вЙФ
begin
  assume a b R hgt h;
  refine вК•вВС (hgt h)
end;

opaque symbol AR3 (a : ѕД ќє) [R : Prop]
  : ѕА ((рЭЯП - a вЙ§ рЭЯО) вЗТ R)
  вЖТ ѕА (¬ђ (a вЙ§ рЭЯО) вЗТ R) вЙФ
begin
  assume a R h hna;
  refine h (sub_leq рЭЯП a (discrete a hna))
end;

// AR3' вАФ bridged variant for the case where PP's solver normalises the
// AR3 sub-premise `(рЭЯП - a) вЙ§ рЭЯО` to `r вЙ§ рЭЯО` for some r вЙ† (рЭЯП - a). The
// emitter passes (a, r, eq) where eq : (рЭЯП - a) = r, and the inner proof
// works directly with (r вЙ§ рЭЯО) вЗТ R.
opaque symbol AR3' (a r : ѕД ќє) [R : Prop]
  : ѕА (рЭЯП - a = r)
  вЖТ ѕА ((r вЙ§ рЭЯО) вЗТ R)
  вЖТ ѕА (¬ђ (a вЙ§ рЭЯО) вЗТ R) вЙФ
begin
  assume a r R eq h;
  refine AR3 a _;
  assume h0;
  refine h _;
  rewrite left eq;
  refine h0
end;

// Bridge lemma: `рЭЯП - (вАФ x)` reduces to `рЭЯП + x` after `neg_neg`.
opaque symbol ar3_bridge_neg (x : ѕД ќє) : ѕА (рЭЯП - (вАФ x) = рЭЯП + x) вЙФ
begin
  assume x; simplify; rewrite neg_neg x; reflexivity
end;

// ---- AR3_F: PP's forward normalisation `¬ђ(a вЙ§ рЭЯО) вЯњ r вЙ§ рЭЯО` (r = рЭЯПвИТa) ----
//
// PP's solver rewrites `¬ђ(a вЙ§ рЭЯО)` to `r вЙ§ рЭЯО` in place (the AR3_F replay
// step), where `r` is its arithmetic-normalised form of `рЭЯП вИТ a`.  LP keeps
// the literal `¬ђ(a вЙ§ рЭЯО)`, so the two views diverge at the consuming leaf.
// These bridge the gap *ground* (after the binder is introduced вАФ an
// under-binder rewrite crashes Lambdapi's inference): `not_leq_of_sub1`
// transports a hypothesis `рЭЯП вИТ a вЙ§ рЭЯО` back to `¬ђ(a вЙ§ рЭЯО)` for an INS
// witness; `ar3f_eq` is the propositional equality the goal-side consumer
// (AXM7) transports along.  Both `1 вИТ a вЯЇ a > рЭЯО вЯЇ ¬ђ(a вЙ§ рЭЯО)`, no `trust`.
opaque symbol not_leq_of_sub1 (a : ѕД ќє) : ѕА (рЭЯП - a вЙ§ рЭЯО) вЖТ ѕА (¬ђ (a вЙ§ рЭЯО)) вЙФ
begin
  assume a h ha;
  refine one_not_leq_zero (leq_trans рЭЯП a рЭЯО (leq_of_sub рЭЯП a h) ha)
end;

opaque symbol ar3f_eq (a r : ѕД ќє) : ѕА (рЭЯП - a = r) вЖТ ѕА ((¬ђ (a вЙ§ рЭЯО)) = (r вЙ§ рЭЯО)) вЙФ
begin
  assume a r eq;
  rewrite left eq;
  refine propExt _ _ _ _
  { assume hna; refine sub_leq рЭЯП a (discrete a hna) }
  { assume hsub; refine not_leq_of_sub1 a hsub }
end;

// AR3_F is *not* a single symbol: PP's forward normalisation rewrites a
// `¬ђ(a вЙ§ рЭЯО)` occurrence in place, at an arbitrary binder-nested position.
// The emitter (translate.ml `ar3f_cong`) builds the congruence proof for
// that exact position by composing `imp_cong_l/r`, `not_cong`,
// `conj_snoc_last_cong`, and `!!_cong` (recursing under the binder) down to
// an `ar3f_eq` leaf, then transports the goal with `=вЗТ`.

// AR4: F вЙ§ 0 in H; E + F > 0 (solver-confirmed) вЖТ H вКҐ E вЙ§ 0 вЗТ R
// If E вЙ§ 0 and F вЙ§ 0 then E + F вЙ§ 0, contradicting E + F > 0.
opaque symbol AR4 [E : ѕД ќє] [R : Prop] (F : ѕД ќє)
  : ѕА (F вЙ§ рЭЯО)
  вЖТ ѕА ((E + F) > рЭЯО)
  вЖТ ѕА ((E вЙ§ рЭЯО) вЗТ R) вЙФ
begin
  assume E R F hF hEF hE;
  refine вК•вВС (hEF (add_leq_zero E F hE hF))
end;

// AR5: a вЙ§ 0 in H, вАФa вЙ§ 0 antecedent вЗТ a = 0 (antisymmetry of вЙ§).
//
// The B-book premise is `(a = рЭЯО) вЗТ ((вАФa вЙ§ рЭЯО) вЗТ R)`, but PP commutes
// the antecedents (presumably via classical equivalence inside its
// solver) before chaining into AR12. We use the commuted form here so
// the LP rule matches PP's emission shape directly.
opaque symbol AR5 [a : ѕД ќє] [R : Prop]
  : ѕА (a вЙ™ рЭЯО)
  вЖТ ѕА ((вАФ a вЙ§ рЭЯО) вЗТ ((a = рЭЯО) вЗТ R))
  вЖТ ѕА ((вАФ a вЙ§ рЭЯО) вЗТ R) вЙФ
begin
  assume a R ha hR hna;
  refine hR hna (leq_antisym a рЭЯО ha (neg_leq_zero a hna))
end;

// AR6: вАФa вЙ§ 0 in H, a вЙ§ 0 antecedent вЗТ a = 0 (dual to AR5).
opaque symbol AR6 [a : ѕД ќє] [R : Prop]
  : ѕА ((вАФ a) вЙ§ рЭЯО)
  вЖТ ѕА ((a вЙ§ рЭЯО) вЗТ ((a = рЭЯО) вЗТ R))
  вЖТ ѕА ((a вЙ§ рЭЯО) вЗТ R) вЙФ
begin
  assume a R hna hR ha;
  refine hR ha (leq_antisym a рЭЯО ha (neg_leq_zero a hna))
end;

// AR7: c+b вЙ§ 0 in H, a+c = 0, aвИТb вЙ§ 0 antecedent вЗТ a = b.
// From a+c = 0: c = вАФa. So c+b вЙ§ 0 becomes вАФa+b = bвИТa вЙ§ 0, i.e. b вЙ§ a.
// Combined with aвИТb вЙ§ 0 (i.e. a вЙ§ b), antisymmetry gives a = b.
// hR's equality is stated `b = a` (not `a = b`): PP records the antisymmetry
// equality bare-variable-first (e.g. `b = -1+a`), and the emitter feeds that
// child directly into the `hR` slot, so the lemma must match that orientation.
opaque symbol AR7 [a b : ѕД ќє] (c : ѕД ќє) [R : Prop]
  : ѕА ((c + b) вЙ™ рЭЯО)
  вЖТ ѕА ((a + c) = рЭЯО)
  вЖТ ѕА ((b = a) вЗТ (((a - b) вЙ§ рЭЯО) вЗТ R))
  вЖТ ѕА (((a - b) вЙ§ рЭЯО) вЗТ R) вЙФ
begin
  assume a b c R hcb hac hR hab;
  have heq_c : ѕА (c = вАФ a) {
    rewrite left zero_add c;
    rewrite left neg_add a;
    rewrite add_assoc (вАФ a) a c;
    rewrite hac;
    refine add_zero (вАФ a)
  };
  have ba_leq : ѕА (b - a вЙ§ рЭЯО) {
    simplify;
    rewrite left heq_c;
    rewrite add_comm b c;
    refine hcb
  };
  refine hR (eq_sym (leq_antisym a b (leq_of_sub a b hab) (leq_of_sub b a ba_leq))) hab
end;

// AR8: dual to AR7 вАФ aвИТb вЙ§ 0 in H, a+c = 0, c+b вЙ§ 0 antecedent вЗТ a = b.
// `b = a` orientation, as for AR7 above.
opaque symbol AR8 (a : ѕД ќє) [b c : ѕД ќє] [R : Prop]
  : ѕА ((a - b) вЙ™ рЭЯО)
  вЖТ ѕА ((a + c) = рЭЯО)
  вЖТ ѕА ((b = a) вЗТ (((c + b) вЙ§ рЭЯО) вЗТ R))
  вЖТ ѕА (((c + b) вЙ§ рЭЯО) вЗТ R) вЙФ
begin
  assume a b c R hab hac hR hcb;
  have heq_c : ѕА (c = вАФ a) {
    rewrite left zero_add c;
    rewrite left neg_add a;
    rewrite add_assoc (вАФ a) a c;
    rewrite hac;
    refine add_zero (вАФ a)
  };
  have ba_leq : ѕА (b - a вЙ§ рЭЯО) {
    simplify;
    rewrite left heq_c;
    rewrite add_comm b c;
    refine hcb
  };
  refine hR (eq_sym (leq_antisym a b (leq_of_sub a b hab) (leq_of_sub b a ba_leq))) hcb
end;

opaque symbol AR9 [E : ѕД ќє] (F : ѕД ќє) [R : Prop]
  : ѕА (E = F)
  вЖТ ѕА ((F вЙ§ рЭЯО) вЗТ R)
  вЖТ ѕА ((E вЙ§ рЭЯО) вЗТ R) вЙФ
begin
  assume E F R heq hf h;
  have h2 : ѕА (F вЙ§ рЭЯО) { rewrite left heq; refine h };
  refine hf h2
end;


// AR10: solver(P) = Q; H вКҐ Q вЗТ R вЖТ H вКҐ P вЗТ R
opaque symbol AR10 [P Q R : Prop]
  : ѕА (P = Q)
  вЖТ ѕА (Q вЗТ R)
  вЖТ ѕА (P вЗТ R) вЙФ
begin
  assume P Q R heq h1 h2;
  refine h1 (=вЗТ heq h2)
end;

// AR11: H вКҐ ¬ђ(x вЙ§ x) вЗТ P
opaque symbol AR11 [E : ѕД ќє] [P : Prop]
  : ѕА (¬ђ (E вЙ§ E) вЗТ P) вЙФ
begin
  assume E P h; refine вК•вВС (h (leq_refl E))
end;

// AR12: H, (a вЙ§ b) вКҐ P вЖТ H вКҐ (a вЙ™ b) вЗТ P in the B-book; PP never emits вЙ™
// on the wire, so we type the antecedent with вЙ§ directly. (B.lp also aliases
// вЙ™ вЙФ вЙ§ for AR5вАУAR8, AR13 whose signatures still mention вЙ™.)
opaque symbol AR12 [a b : ѕД ќє] [P : Prop]
  : (ѕА (a вЙ§ b) вЖТ ѕА P)
  вЖТ ѕА ((a вЙ§ b) вЗТ P) вЙФ
begin
  assume a b P h1 h2; refine h1 h2
end;

// AR13: solver(1вИТa) = b; b вЙ§ 0 вЖТ ¬ђ(a вЙ™ 0)
// Substitute b вЖТ 1вИТa, then 1вИТa вЙ§ 0 вЗТ 1 вЙ§ a; combined with a вЙ§ 0
// (the assumed antecedent of ¬ђ), 1 вЙ§ 0 вАФ contradicting one_not_leq_zero.
opaque symbol AR13 [a b : ѕД ќє]
  : ѕА ((рЭЯП - a) = b)
  вЖТ ѕА (b вЙ§ рЭЯО)
  вЖТ ѕА (¬ђ (a вЙ§ рЭЯО)) вЙФ
begin
  assume a b heq hb ha;
  have h1 : ѕА (рЭЯП - a вЙ§ рЭЯО) { rewrite heq; refine hb };
  refine one_not_leq_zero (leq_trans рЭЯП a рЭЯО (leq_of_sub рЭЯП a h1) ha)
end;

// ---- `_1` (Result-form) variants вАФ ¬І8.13 ----
//
// AR9_1 below uses leq_zero_eq to bridge the solver-supplied
// equality. Other AR rules use `trust` for the propositional equality
// since the chain emit doesn't thread the solver side-conditions.

// (E вЙ§ E) вЗТ R вЙ° R вАФ the antecedent is always true (leq_refl).  Mirrors evr3_eq.
opaque symbol ar1_eq [E : ѕД ќє] [R : Prop] : ѕА (((E вЙ§ E) вЗТ R) = R) вЙФ
begin
  assume E R;
  refine propExt _ _ _ _
    { assume h; refine h (leq_refl E) }
    { assume h h0; refine h }
end;

symbol AR1_1 [E : ѕД ќє] [R : Prop]
  (r : Res R) : Res ((E вЙ§ E) вЗТ R)
  вЙФ mk_1 (res_tm r) (eq_trans ar1_eq (res_eq r));

symbol AR2_1 [a b : ѕД ќє] [R : Prop] : Res ((a вЙ§ b) вЗТ R) вЙФ mk_0 trust;

symbol AR3_1 (a : ѕД ќє) [R : Prop]
  (r : Res ((рЭЯП - a вЙ§ рЭЯО) вЗТ R)) : Res (¬ђ (a вЙ§ рЭЯО) вЗТ R)
  вЙФ mk_1 (res_tm r)
       (eq_trans (imp_cong_l (ar3f_eq a (рЭЯП - a) (eq_refl (рЭЯП - a)))) (res_eq r));

// AR3'_1: bridged Res-chain AR3, for when PP's solver records the sub-premise
// `рЭЯП - a` in a different (neg-normalised) term order `r`.  The `¬ђ(aвЙ§рЭЯО) =
// (рЭЯП-aвЙ§рЭЯО)` step is the AR3 logical bridge (trusted, as in AR3_1); the
// `(рЭЯП-aвЙ§рЭЯО) = (rвЙ§рЭЯО)` step is the real, emitter-supplied equality `eq : рЭЯП-a=r`.
symbol AR3'_1 (a r : ѕД ќє) [R : Prop]
  (eq : ѕА (рЭЯП - a = r))
  (cont : Res ((r вЙ§ рЭЯО) вЗТ R)) : Res (¬ђ (a вЙ§ рЭЯО) вЗТ R)
  вЙФ mk_1 (res_tm cont)
       (eq_trans (imp_cong_l (ar3f_eq a r eq)) (res_eq cont));

symbol AR4_1 [E : ѕД ќє] [R : Prop] (F : ѕД ќє) : Res ((E вЙ§ рЭЯО) вЗТ R)
  вЙФ mk_0 trust;

symbol AR5_1 [a : ѕД ќє] [R : Prop]
  (r : Res ((вАФ a вЙ§ рЭЯО) вЗТ ((a = рЭЯО) вЗТ R))) : Res ((вАФ a вЙ§ рЭЯО) вЗТ R)
  вЙФ mk_1 (res_tm r) trust;

symbol AR6_1 [a : ѕД ќє] [R : Prop]
  (r : Res ((a вЙ§ рЭЯО) вЗТ ((a = рЭЯО) вЗТ R))) : Res ((a вЙ§ рЭЯО) вЗТ R)
  вЙФ mk_1 (res_tm r) trust;

symbol AR7_1 [a b : ѕД ќє] (c : ѕД ќє) [R : Prop]
  (r : Res ((a = b) вЗТ (((a - b) вЙ§ рЭЯО) вЗТ R)))
  : Res (((a - b) вЙ§ рЭЯО) вЗТ R)
  вЙФ mk_1 (res_tm r) trust;

symbol AR8_1 (a : ѕД ќє) [b c : ѕД ќє] [R : Prop]
  (r : Res ((a = b) вЗТ (((c + b) вЙ§ рЭЯО) вЗТ R)))
  : Res (((c + b) вЙ§ рЭЯО) вЗТ R)
  вЙФ mk_1 (res_tm r) trust;

// AR9_1: solver-confirmed equality on the antecedent of a Res chain.
// Mirrors the spec AR9 but in Res form: given a bridge proof E = F, a
// chain proving (F вЙ§ 0 вЗТ R) lifts to one for (E вЙ§ 0 вЗТ R). F is
// explicit so emit sites can pin it via the PP-supplied solver result.
// Transparent вАФ `res_tm (AR9_1 F he r)` reduces to `res_tm r` so the
// outer chain can decompose the resulting Prop.
symbol AR9_1 [E : ѕД ќє] (F : ѕД ќє) [R : Prop]
  (he : ѕА (E = F))
  (r : Res ((F вЙ§ рЭЯО) вЗТ R)) : Res ((E вЙ§ рЭЯО) вЗТ R)
  вЙФ mk_1 (res_tm r) (eq_trans (imp_cong_l (leq_zero_eq he)) (res_eq r));

symbol AR10_1 [P Q R : Prop]
  (heq : ѕА (P = Q)) (r : Res (Q вЗТ R)) : Res (P вЗТ R)
  вЙФ mk_1 (res_tm r) (eq_trans (imp_cong_l heq) (res_eq r));

symbol AR11_1 [E : ѕД ќє] [P : Prop] : Res (¬ђ (E вЙ§ E) вЗТ P)
  вЙФ mk_0 (prop_eq_top AR11);  // ¬ђ(EвЙ§E) absurd (leq_refl) вЗТ vacuously вК§

symbol AR12_1 [a b : ѕД ќє] [P : Prop]
  (r : Res P) : Res ((a вЙ§ b) вЗТ P)
  вЙФ mk_1 (res_tm r) trust;

symbol AR13_1 [a b : ѕД ќє] : Res (¬ђ (a вЙ§ рЭЯО)) вЙФ mk_0 trust;
