// Arithmetic (В§A.14) вЂ” shallow encoding
// Uses в‰¤ and leq_refl from B.lp.
require open pp2lp.B pp2lp.Int pp2lp.Quant pp2lp.rules.Res;

// ---- AR1-3: Reflexivity of в‰¤ ----

opaque symbol AR1 [E : П„ О№] [R : Prop]
  : ПЂ R
  в†’ ПЂ ((E в‰¤ E) в‡’ R) в‰”
begin
  assume E R h h0; refine h
end;

opaque symbol AR2 [a b : П„ О№] [R : Prop]
  : ПЂ (a > b)
  в†’ ПЂ ((a в‰¤ b) в‡’ R) в‰”
begin
  assume a b R hgt h;
  refine вЉҐв‚‘ (hgt h)
end;

opaque symbol AR3 (a : П„ О№) [R : Prop]
  : ПЂ ((рќџЏ - a в‰¤ рќџЋ) в‡’ R)
  в†’ ПЂ (В¬ (a в‰¤ рќџЋ) в‡’ R) в‰”
begin
  assume a R h hna;
  refine h (sub_leq рќџЏ a (discrete a hna))
end;

// AR3' вЂ” bridged variant for the case where PP's solver normalises the
// AR3 sub-premise `(рќџЏ - a) в‰¤ рќџЋ` to `r в‰¤ рќџЋ` for some r в‰  (рќџЏ - a). The
// emitter passes (a, r, eq) where eq : (рќџЏ - a) = r, and the inner proof
// works directly with (r в‰¤ рќџЋ) в‡’ R.
opaque symbol AR3' (a r : П„ О№) [R : Prop]
  : ПЂ (рќџЏ - a = r)
  в†’ ПЂ ((r в‰¤ рќџЋ) в‡’ R)
  в†’ ПЂ (В¬ (a в‰¤ рќџЋ) в‡’ R) в‰”
begin
  assume a r R eq h;
  refine AR3 a _;
  assume h0;
  refine h _;
  rewrite left eq;
  refine h0
end;

// Bridge lemma: `рќџЏ - (вЂ” x) = рќџЏ + x` (Z.вЂ”_idem on the projection; unconditional).
opaque symbol ar3_bridge_neg (x : П„ О№) : ПЂ (рќџЏ - (вЂ” x) = рќџЏ + x) в‰”
begin
  assume x;
  have e : ПЂ (Stdlib.Z.+ (to_int рќџЏ) (Stdlib.Z.вЂ” (Stdlib.Z.вЂ” (to_int x)))
             = Stdlib.Z.+ (to_int рќџЏ) (to_int x))
    { rewrite Stdlib.Z.вЂ”_idem (to_int x); reflexivity };
  refine feq from_int e
end;

// ---- AR3_F: PP's forward normalisation `В¬(a в‰¤ рќџЋ) вџї r в‰¤ рќџЋ` (r = рќџЏв€’a) ----
//
// PP's solver rewrites `В¬(a в‰¤ рќџЋ)` to `r в‰¤ рќџЋ` in place (the AR3_F replay
// step), where `r` is its arithmetic-normalised form of `рќџЏ в€’ a`.  LP keeps
// the literal `В¬(a в‰¤ рќџЋ)`, so the two views diverge at the consuming leaf.
// These bridge the gap *ground* (after the binder is introduced вЂ” an
// under-binder rewrite crashes Lambdapi's inference): `not_leq_of_sub1`
// transports a hypothesis `рќџЏ в€’ a в‰¤ рќџЋ` back to `В¬(a в‰¤ рќџЋ)` for an INS
// witness; `ar3f_eq` is the propositional equality the goal-side consumer
// (AXM7) transports along.  Both `1 в€’ a вџє a > рќџЋ вџє В¬(a в‰¤ рќџЋ)`, no `trust`.
opaque symbol not_leq_of_sub1 (a : П„ О№) : ПЂ (рќџЏ - a в‰¤ рќџЋ) в†’ ПЂ (В¬ (a в‰¤ рќџЋ)) в‰”
begin
  assume a h ha;
  refine one_not_leq_zero (leq_trans рќџЏ a рќџЋ (leq_of_sub рќџЏ a h) ha)
end;

opaque symbol ar3f_eq (a r : П„ О№) : ПЂ (рќџЏ - a = r) в†’ ПЂ ((В¬ (a в‰¤ рќџЋ)) = (r в‰¤ рќџЋ)) в‰”
begin
  assume a r eq;
  rewrite left eq;
  refine propExt _ _ _ _
  { assume hna; refine sub_leq рќџЏ a (discrete a hna) }
  { assume hsub; refine not_leq_of_sub1 a hsub }
end;

// (a в‰¤ b) = (a в€’ b в‰¤ рќџЋ), as a propositional equality (AR2's `a > b`, the
// emitter transports `prove_gt_zero (aв€’b)` back along its negation).
opaque symbol sub_leq_eq (a b : П„ О№) : ПЂ ((a в‰¤ b) = (a - b в‰¤ рќџЋ)) в‰”
begin assume a b; refine propExt _ _ (sub_leq a b) (leq_of_sub a b) end;

// AR3_F is *not* a single symbol: PP's forward normalisation rewrites a
// `В¬(a в‰¤ рќџЋ)` occurrence in place, at an arbitrary binder-nested position.
// The emitter (translate.ml `ar3f_cong`) builds the congruence proof for
// that exact position by composing `imp_cong_l/r`, `not_cong`,
// `conj_snoc_last_cong`, and `!!_cong` (recursing under the binder) down to
// an `ar3f_eq` leaf, then transports the goal with `=в‡’`.

// AR4: F в‰¤ 0 in H; E + F > 0 (solver-confirmed) в†’ H вЉў E в‰¤ 0 в‡’ R
// If E в‰¤ 0 and F в‰¤ 0 then E + F в‰¤ 0, contradicting E + F > 0.
// E, F implicit: E inferred from the `(E в‰¤ рќџЋ)` goal, F from the `F в‰¤ рќџЋ` premise вЂ”
// both via the Int.lp `to_int`/`isGt` unification rules (a defined `в‰¤` would
// otherwise hide them behind `to_int (from_int вЂ¦)`).
opaque symbol AR4 [E : П„ О№] [R : Prop] [F : П„ О№]
  : ПЂ (F в‰¤ рќџЋ)
  в†’ ПЂ ((E + F) > рќџЋ)
  в†’ ПЂ ((E в‰¤ рќџЋ) в‡’ R) в‰”
begin
  assume E R F hF hEF hE;
  refine вЉҐв‚‘ (hEF (add_leq_zero E F hE hF))
end;

// AR5: a в‰¤ 0 in H, вЂ”a в‰¤ 0 antecedent в‡’ a = 0 (antisymmetry of в‰¤).
//
// The B-book premise is `(a = рќџЋ) в‡’ ((вЂ”a в‰¤ рќџЋ) в‡’ R)`, but PP commutes
// the antecedents (presumably via classical equivalence inside its
// solver) before chaining into AR12. We use the commuted form here so
// the LP rule matches PP's emission shape directly.
opaque symbol AR5 [a : П„ О№] [R : Prop] (hai : ПЂ (a Пµ INT))
  : ПЂ (a в‰Є рќџЋ)
  в†’ ПЂ ((вЂ” a в‰¤ рќџЋ) в‡’ ((a = рќџЋ) в‡’ R))
  в†’ ПЂ ((вЂ” a в‰¤ рќџЋ) в‡’ R) в‰”
begin
  assume a R hai ha hR hna;
  refine hR hna (leq_antisym a рќџЋ hai zero_in_int ha (neg_leq_zero a hna))
end;

// AR6: вЂ”a в‰¤ 0 in H, a в‰¤ 0 antecedent в‡’ a = 0 (dual to AR5).
opaque symbol AR6 [a : П„ О№] [R : Prop] (hai : ПЂ (a Пµ INT))
  : ПЂ ((вЂ” a) в‰¤ рќџЋ)
  в†’ ПЂ ((a в‰¤ рќџЋ) в‡’ ((a = рќџЋ) в‡’ R))
  в†’ ПЂ ((a в‰¤ рќџЋ) в‡’ R) в‰”
begin
  assume a R hai hna hR ha;
  refine hR ha (leq_antisym a рќџЋ hai zero_in_int ha (neg_leq_zero a hna))
end;

// AR7: c+b в‰¤ 0 in H, a+c = 0, aв€’b в‰¤ 0 antecedent в‡’ a = b.
// From a+c = 0: c = вЂ”a. So c+b в‰¤ 0 becomes вЂ”a+b = bв€’a в‰¤ 0, i.e. b в‰¤ a.
// Combined with aв€’b в‰¤ 0 (i.e. a в‰¤ b), antisymmetry gives a = b.
// hR's equality is stated `b = a` (not `a = b`): PP records the antisymmetry
// equality bare-variable-first (e.g. `b = -1+a`), and the emitter feeds that
// child directly into the `hR` slot, so the lemma must match that orientation.
opaque symbol AR7 [a b : П„ О№] (c : П„ О№) [R : Prop]
  (hai : ПЂ (a Пµ INT)) (hbi : ПЂ (b Пµ INT)) (hci : ПЂ (c Пµ INT))
  : ПЂ ((c + b) в‰Є рќџЋ)
  в†’ ПЂ ((a + c) = рќџЋ)
  в†’ ПЂ ((b = a) в‡’ (((a - b) в‰¤ рќџЋ) в‡’ R))
  в†’ ПЂ (((a - b) в‰¤ рќџЋ) в‡’ R) в‰”
begin
  assume a b c R hai hbi hci hcb hac hR hab;
  have heq_c : ПЂ (c = вЂ” a) {
    rewrite left (zero_add c hci);
    rewrite left neg_add a;
    rewrite add_assoc (вЂ” a) a c;
    rewrite hac;
    refine add_zero (вЂ” a) (neg_in_int a)
  };
  have ba_leq : ПЂ (b - a в‰¤ рќџЋ) {
    refine leq_subst_l (eq_trans (add_congR b (eq_sym heq_c)) (add_comm b c)) hcb
  };
  refine hR (eq_sym (leq_antisym a b hai hbi (leq_of_sub a b hab) (leq_of_sub b a ba_leq))) hab
end;

// AR8: dual to AR7 вЂ” aв€’b в‰¤ 0 in H, a+c = 0, c+b в‰¤ 0 antecedent в‡’ a = b.
// `b = a` orientation, as for AR7 above.
opaque symbol AR8 (a : П„ О№) [b c : П„ О№] [R : Prop]
  (hai : ПЂ (a Пµ INT)) (hbi : ПЂ (b Пµ INT)) (hci : ПЂ (c Пµ INT))
  : ПЂ ((a - b) в‰Є рќџЋ)
  в†’ ПЂ ((a + c) = рќџЋ)
  в†’ ПЂ ((b = a) в‡’ (((c + b) в‰¤ рќџЋ) в‡’ R))
  в†’ ПЂ (((c + b) в‰¤ рќџЋ) в‡’ R) в‰”
begin
  assume a b c R hai hbi hci hab hac hR hcb;
  have heq_c : ПЂ (c = вЂ” a) {
    rewrite left (zero_add c hci);
    rewrite left neg_add a;
    rewrite add_assoc (вЂ” a) a c;
    rewrite hac;
    refine add_zero (вЂ” a) (neg_in_int a)
  };
  have ba_leq : ПЂ (b - a в‰¤ рќџЋ) {
    refine leq_subst_l (eq_trans (add_congR b (eq_sym heq_c)) (add_comm b c)) hcb
  };
  refine hR (eq_sym (leq_antisym a b hai hbi (leq_of_sub a b hab) (leq_of_sub b a ba_leq))) hcb
end;

opaque symbol AR9 [E : П„ О№] (F : П„ О№) [R : Prop]
  : ПЂ (E = F)
  в†’ ПЂ ((F в‰¤ рќџЋ) в‡’ R)
  в†’ ПЂ ((E в‰¤ рќџЋ) в‡’ R) в‰”
begin
  assume E F R heq hf h;
  have h2 : ПЂ (F в‰¤ рќџЋ) { rewrite left heq; refine h };
  refine hf h2
end;


// AR10: solver(P) = Q; H вЉў Q в‡’ R в†’ H вЉў P в‡’ R
opaque symbol AR10 [P Q R : Prop]
  : ПЂ (P = Q)
  в†’ ПЂ (Q в‡’ R)
  в†’ ПЂ (P в‡’ R) в‰”
begin
  assume P Q R heq h1 h2;
  refine h1 (=в‡’ heq h2)
end;

// AR11: H вЉў В¬(x в‰¤ x) в‡’ P
opaque symbol AR11 [E : П„ О№] [P : Prop]
  : ПЂ (В¬ (E в‰¤ E) в‡’ P) в‰”
begin
  assume E P h; refine вЉҐв‚‘ (h (leq_refl E))
end;

// AR12: H, (a в‰¤ b) вЉў P в†’ H вЉў (a в‰Є b) в‡’ P in the B-book; PP never emits в‰Є
// on the wire, so we type the antecedent with в‰¤ directly. (B.lp also aliases
// в‰Є в‰” в‰¤ for AR5вЂ“AR8, AR13 whose signatures still mention в‰Є.)
// a, b explicit: a defined `в‰¤` can't infer them from `(a в‰¤ b)` (emitter supplies).
opaque symbol AR12 [a b : П„ О№] [P : Prop]
  : (ПЂ (a в‰¤ b) в†’ ПЂ P)
  в†’ ПЂ ((a в‰¤ b) в‡’ P) в‰”
begin
  assume a b P h1 h2; refine h1 h2
end;

// AR13: solver(1в€’a) = b; b в‰¤ 0 в†’ В¬(a в‰Є 0)
// Substitute b в†’ 1в€’a, then 1в€’a в‰¤ 0 в‡’ 1 в‰¤ a; combined with a в‰¤ 0
// (the assumed antecedent of В¬), 1 в‰¤ 0 вЂ” contradicting one_not_leq_zero.
opaque symbol AR13 [a b : П„ О№]
  : ПЂ ((рќџЏ - a) = b)
  в†’ ПЂ (b в‰¤ рќџЋ)
  в†’ ПЂ (В¬ (a в‰¤ рќџЋ)) в‰”
begin
  assume a b heq hb ha;
  have h1 : ПЂ (рќџЏ - a в‰¤ рќџЋ) { rewrite heq; refine hb };
  refine one_not_leq_zero (leq_trans рќџЏ a рќџЋ (leq_of_sub рќџЏ a h1) ha)
end;

// ---- `_1` (Result-form) variants вЂ” В§8.13 ----
//
// AR9_1 below uses leq_zero_eq to bridge the solver-supplied
// equality. Other AR_1 forms are proven outright or bridge the equality with
// a generated proof (AR3'_1); shapes the chain emit can't thread fail loud вЂ”
// none emit `trust`.

// (E в‰¤ E) в‡’ R в‰Ў R вЂ” the antecedent is always true (leq_refl).  Mirrors evr3_eq.
opaque symbol ar1_eq [E : П„ О№] [R : Prop] : ПЂ (((E в‰¤ E) в‡’ R) = R) в‰”
begin
  assume E R;
  refine propExt _ _ _ _
    { assume h; refine h (leq_refl E) }
    { assume h h0; refine h }
end;

symbol AR1_1 [E : П„ О№] [R : Prop]
  (r : Res R) : Res ((E в‰¤ E) в‡’ R)
  в‰” mk_1 (res_tm r) (eq_trans (@ar1_eq E R) (res_eq r));

symbol AR2_1 [a b : П„ О№] [R : Prop] (h : ПЂ (a > b))
  : Res ((a в‰¤ b) в‡’ R) в‰” mk_0 (prop_eq_top (@AR2 a b R h));

symbol AR3_1 (a : П„ О№) [R : Prop]
  (r : Res ((рќџЏ - a в‰¤ рќџЋ) в‡’ R)) : Res (В¬ (a в‰¤ рќџЋ) в‡’ R)
  в‰” mk_1 (res_tm r)
       (eq_trans (imp_cong_l (ar3f_eq a (рќџЏ - a) (eq_refl (рќџЏ - a)))) (res_eq r));

// AR3'_1: bridged Res-chain AR3, for when PP's solver records the sub-premise
// `рќџЏ - a` in a different (neg-normalised) term order `r`.  Both steps are now
// real: `В¬(aв‰¤рќџЋ) = (rв‰¤рќџЋ)` is `ar3f_eq a r eq` and `eq : рќџЏ-a=r` is the
// emitter-supplied equality (cf. AR3_1, which is the special case r = рќџЏ-a).
symbol AR3'_1 (a r : П„ О№) [R : Prop]
  (eq : ПЂ (рќџЏ - a = r))
  (cont : Res ((r в‰¤ рќџЋ) в‡’ R)) : Res (В¬ (a в‰¤ рќџЋ) в‡’ R)
  в‰” mk_1 (res_tm cont)
       (eq_trans (imp_cong_l (ar3f_eq a r eq)) (res_eq cont));

// AR4_1: reuse the base rule (Fв‰¤рќџЋ, (E+F)>рќџЋ solver facts as evidence).
symbol AR4_1 [E : П„ О№] [R : Prop] (F : П„ О№)
  (hf : ПЂ (F в‰¤ рќџЋ)) (hef : ПЂ ((E + F) > рќџЋ)) : Res ((E в‰¤ рќџЋ) в‡’ R)
  в‰” mk_0 (prop_eq_top (@AR4 E R F hf hef));

// AR5/AR6: antisymmetry-to-zero вЂ” `a = рќџЋ` (from the two bounds) lets the inner
// `(a=рќџЋ) в‡’` be stripped (imp_known_drop under imp_cong_r).
symbol AR5_1 [a : П„ О№] [R : Prop] (h0 : ПЂ (a = рќџЋ))
  (r : Res ((вЂ” a в‰¤ рќџЋ) в‡’ ((a = рќџЋ) в‡’ R))) : Res ((вЂ” a в‰¤ рќџЋ) в‡’ R)
  в‰” mk_1 (res_tm r)
       (eq_trans (eq_sym (imp_cong_r (imp_known_drop h0))) (res_eq r));

symbol AR6_1 [a : П„ О№] [R : Prop] (h0 : ПЂ (a = рќџЋ))
  (r : Res ((a в‰¤ рќџЋ) в‡’ ((a = рќџЋ) в‡’ R))) : Res ((a в‰¤ рќџЋ) в‡’ R)
  в‰” mk_1 (res_tm r)
       (eq_trans (eq_sym (imp_cong_r (imp_known_drop h0))) (res_eq r));

// AR7/AR8: the antisymmetry `a = b` strips the leading `(a=b) в‡’`.
symbol AR7_1 [a b : П„ О№] (c : П„ О№) [R : Prop] (hab : ПЂ (a = b))
  (r : Res ((a = b) в‡’ (((a - b) в‰¤ рќџЋ) в‡’ R)))
  : Res (((a - b) в‰¤ рќџЋ) в‡’ R)
  в‰” mk_1 (res_tm r) (eq_trans (eq_sym (imp_known_drop hab)) (res_eq r));

symbol AR8_1 (a : П„ О№) [b c : П„ О№] [R : Prop] (hab : ПЂ (a = b))
  (r : Res ((a = b) в‡’ (((c + b) в‰¤ рќџЋ) в‡’ R)))
  : Res (((c + b) в‰¤ рќџЋ) в‡’ R)
  в‰” mk_1 (res_tm r) (eq_trans (eq_sym (imp_known_drop hab)) (res_eq r));

// AR9_1: solver-confirmed equality on the antecedent of a Res chain.
// Mirrors the spec AR9 but in Res form: given a bridge proof E = F, a
// chain proving (F в‰¤ 0 в‡’ R) lifts to one for (E в‰¤ 0 в‡’ R). F is
// explicit so emit sites can pin it via the PP-supplied solver result.
// Transparent вЂ” `res_tm (AR9_1 F he r)` reduces to `res_tm r` so the
// outer chain can decompose the resulting Prop.
symbol AR9_1 [E : П„ О№] (F : П„ О№) [R : Prop]
  (he : ПЂ (E = F))
  (r : Res ((F в‰¤ рќџЋ) в‡’ R)) : Res ((E в‰¤ рќџЋ) в‡’ R)
  в‰” mk_1 (res_tm r) (eq_trans (imp_cong_l (leq_zero_eq he)) (res_eq r));

symbol AR10_1 [P Q R : Prop]
  (heq : ПЂ (P = Q)) (r : Res (Q в‡’ R)) : Res (P в‡’ R)
  в‰” mk_1 (res_tm r) (eq_trans (imp_cong_l heq) (res_eq r));

symbol AR11_1 [E : П„ О№] [P : Prop] : Res (В¬ (E в‰¤ E) в‡’ P)
  в‰” mk_0 (prop_eq_top (@AR11 E P));  // В¬(Eв‰¤E) absurd (leq_refl) в‡’ vacuously вЉ¤

symbol AR12_1 [a b : П„ О№] [P : Prop] (h : ПЂ (a в‰¤ b))
  (r : Res P) : Res ((a в‰¤ b) в‡’ P)
  в‰” mk_1 (res_tm r) (eq_trans (imp_known_drop h) (res_eq r));

// AR13: `В¬(a в‰¤ рќџЋ)` is the result; supply it as evidence (a > рќџЋ from the solver).
symbol AR13_1 [a b : П„ О№] (h : ПЂ (В¬ (a в‰¤ рќџЋ))) : Res (В¬ (a в‰¤ рќџЋ))
  в‰” mk_0 (prop_eq_top h);
