// Normalisation (┬πA.12) έΑΦ tuple-based encoding.
//
// Spec uses `έβλ` (= goal-side n-ary universal) and `έβκ` (= hypothesis-
// side n-ary universal). Both reduce propositionally to `!!` via the
// `έβλ_eq_!!` / `έβκ_eq_!!` axioms in Quant.lp; bodies use the dedicated
// `pi_to_έβλ` / `έβλ_to_pi` (and έβκ analogues) bridges.

require open pp2lp.B pp2lp.Quant pp2lp.rules.Res;

// ---- NRM1-7: Logical transformations under `έβλ` ----

// NRM1: x not free in P; H έΛλ P έΘΤ S έΗΤ H έΛλ (έβλx ┬╖ P) έΘΤ S
opaque symbol NRM1 [n] [P S : Prop]
  : ╧Α (P έΘΤ S)
  έΗΤ ╧Α ((`έβλ _ : Tuple n, P) έΘΤ S) έΚΦ
begin
  assume n P S h1 h2;
  refine h1 (έβλ_to_pi (╬╗ _ : Tuple n, P) h2 (inh_tuple [n]))
end;

// NRM2: x not free in P; H έΛλ (P έΘΤ έβλx ┬╖ Q) έΘΤ S έΗΤ H έΛλ έβλx ┬╖ (P έΘΤ Q) έΘΤ S
opaque symbol NRM2 [n] [P : Prop] [Q : Tuple n έΗΤ Prop] [S : Prop]
  : ╧Α ((P έΘΤ (`έβλ v, Q v)) έΘΤ S)
  έΗΤ ╧Α ((`έβλ v, P έΘΤ Q v) έΘΤ S) έΚΦ
begin
  assume n P Q S h1 h2;
  refine h1 (╬╗ p,
    pi_to_έβλ Q (╬╗ v, έβλ_to_pi (╬╗ v', P έΘΤ Q v') h2 v p))
end;

// NRM3: x not free in Q; H έΛλ (Q έΘΤ S) έΙπ ((έΙΑx ┬╖ ┬υP) έΘΤ S) έΗΤ H έΛλ έβλx ┬╖ (P έΘΤ Q) έΘΤ S
opaque symbol NRM3 [n] [P : Tuple n έΗΤ Prop] [Q S : Prop]
  : ╧Α (έΜΑ_snoc (Q έΘΤ S) ((`!! v, ┬υ (P v)) έΘΤ S))
  έΗΤ ╧Α ((`έβλ v, P v έΘΤ Q) έΘΤ S) έΚΦ
begin
  assume n P Q S h1 h2;
  refine έΙρέΓΣ (em (`?? v, P v)) _ _
  { assume hex;
    refine pi_to_??_elim P
      (╬╗ v hpv, (έΜΑέΓΓ_hd h1) (έβλ_to_pi (╬╗ v', P v' έΘΤ Q) h2 v hpv)) hex }
  { assume hnex;
    refine (έΜΑέΓΓ_snd h1) (pi_to_!! (╬╗ v, ┬υ (P v))
      (╬╗ v hpv, hnex (pi_to_??_intro P v hpv))) }
end;

// NRM4: x not free in Q; H έΛλ (Q έΘΤ έβλx ┬╖ (P έΘΤ R)) έΘΤ S έΗΤ H έΛλ έβλx ┬╖ (P έΘΤ Q έΘΤ R) έΘΤ S
opaque symbol NRM4 [n] [P R : Tuple n έΗΤ Prop] [Q S : Prop]
  : ╧Α ((Q έΘΤ (`έβλ v, P v έΘΤ R v)) έΘΤ S)
  έΗΤ ╧Α ((`έβλ v, P v έΘΤ Q έΘΤ R v) έΘΤ S) έΚΦ
begin
  assume n P R Q S h1 h2;
  refine h1 (╬╗ hq,
    pi_to_έβλ (╬╗ v, P v έΘΤ R v)
      (╬╗ v hpv, έβλ_to_pi (╬╗ v', P v' έΘΤ Q έΘΤ R v') h2 v hpv hq))
end;

// NRM5: H έΛλ έβλx ┬╖ (P έΙπ Q έΘΤ R) έΘΤ S έΗΤ H έΛλ έβλx ┬╖ (P έΘΤ Q έΘΤ R) έΘΤ S
// Uncurry: `έΜΑ_snoc (P v) (Q v)` reduces to `έΜΑ (έΙΟ έΙ╖ P v έΙ╖ Q v)`, so the
// hypothesis splits with `έΜΑέΓΓ_hd`/`έΜΑέΓΓ_snd` to feed the curried body.
opaque symbol NRM5 [n] [P Q R : Tuple n έΗΤ Prop] [S : Prop]
  : ╧Α ((`έβλ v, έΜΑ_snoc (P v) (Q v) έΘΤ R v) έΘΤ S)
  έΗΤ ╧Α ((`έβλ v, P v έΘΤ Q v έΘΤ R v) έΘΤ S) έΚΦ
begin
  assume n P Q R S h1 h2;
  refine h1 (pi_to_έβλ (╬╗ v, έΜΑ_snoc (P v) (Q v) έΘΤ R v)
    (╬╗ v hpq, έβλ_to_pi (╬╗ v', P v' έΘΤ Q v' έΘΤ R v') h2 v
                (έΜΑέΓΓ_hd hpq) (έΜΑέΓΓ_snd hpq)))
end;

// NRM6: H έΛλ έβλx ┬╖ (R έΘΤ P) έΘΤ (έβλx ┬╖ (R έΘΤ Q) έΘΤ S) έΗΤ H έΛλ έβλx ┬╖ (R έΘΤ P έΙπ Q) έΘΤ S
// Generalised over a snoc list: the consequent `έΜΑ (qs v έΙ╖ P v)` splits into
// init `έΜΑ (qs v)` and last `P v`.  init-first lets the emitter chain
// `refine NRM6 _;` for n-conjunct goals, since `έΜΑ (qs v)` is itself a
// `έΜΑ (qs' v έΙ╖ P' v)` when |qs v| έΚξ 2.
opaque symbol NRM6 [n] [Qs : Tuple n έΗΤ ΏζΧΔ* o] [P R : Tuple n έΗΤ Prop] [S : Prop]
  : ╧Α ((`έβλ v, R v έΘΤ έΜΑ (Qs v)) έΘΤ ((`έβλ v, R v έΘΤ P v) έΘΤ S))
  έΗΤ ╧Α ((`έβλ v, R v έΘΤ έΜΑ (Qs v έΙ╖ P v)) έΘΤ S) έΚΦ
begin
  assume n qs P R S h1 h2;
  refine h1
    (pi_to_έβλ (╬╗ v, R v έΘΤ έΜΑ (qs v))
      (╬╗ v hr, έΜΑ_init (έβλ_to_pi (╬╗ v', R v' έΘΤ έΜΑ (qs v' έΙ╖ P v')) h2 v hr)))
    (pi_to_έβλ (╬╗ v, R v έΘΤ P v)
      (╬╗ v hr, έΜΑ_last (έβλ_to_pi (╬╗ v', R v' έΘΤ έΜΑ (qs v' έΙ╖ P v')) h2 v hr)))
end;

// NRM7: H έΛλ (έβλx ┬╖ P) έΘΤ ((έβλx ┬╖ Q) έΘΤ S) έΗΤ H έΛλ έβλx ┬╖ (P έΙπ Q) έΘΤ S
// Generalised: same shape as NRM6 but without the R έΘΤ antecedent.
opaque symbol NRM7 [n] [Qs : Tuple n έΗΤ ΏζΧΔ* o] [P : Tuple n έΗΤ Prop] [S : Prop]
  : ╧Α ((`έβλ v, έΜΑ (Qs v))
        έΘΤ ((`έβλ v, P v) έΘΤ S))
  έΗΤ ╧Α ((`έβλ v : Tuple n, έΜΑ (Qs v έΙ╖ P v)) έΘΤ S) έΚΦ
begin
  assume n qs P S h1 h2;
  refine h1
    (pi_to_έβλ (╬╗ v, έΜΑ (qs v))
      (╬╗ v, έΜΑ_init (έβλ_to_pi (╬╗ v', έΜΑ (qs v' έΙ╖ P v')) h2 v)))
    (pi_to_έβλ (╬╗ v, P v)
      (╬╗ v, έΜΑ_last (έβλ_to_pi (╬╗ v', έΜΑ (qs v' έΙ╖ P v')) h2 v)))
end;

// ---- NRM8-9: compoundέΗΦmixed binders (split with `take`/`drop`) ----
//
// NRM8: spec is `(έβλ(x,y) ┬╖ Q) έΘΤ S` έΗΡ `(έβλx ┬╖ έΙΑy ┬╖ Q) έΘΤ S`.
// Encoded with the n,m-indexed split helpers from Quant.lp:
//   the conclusion's `Q x y` (clean HO pattern) gets unified back
//   from the premise's `Q (take v) (drop v)` after Lambdapi infers Q.
opaque symbol NRM8 [n m] [Q : Tuple n έΗΤ Tuple m έΗΤ Prop] [S : Prop]
  : ╧Α ((`έβλ v : Tuple (n ++ m), Q (take [n] [m] v) (drop [n] [m] v)) έΘΤ S)
  έΗΤ ╧Α ((`έβλ x : Tuple n, `!! y : Tuple m, Q x y) έΘΤ S) έΚΦ
begin
  assume n m Q S h hnested;
  // hnested : ╧Α (`έβλ x : Tuple n, `!! y : Tuple m, Q x y)
  // Need:    ╧Α (`έβλ v : Tuple (n ++ m), Q (take v) (drop v))
  // Witness: ╬╗ v, !!_to_pi (Q x) (έβλ_to_pi (╬╗ x, `!! y, Q x y) hnested x') y'
  //          where x' = take v, y' = drop v.
  refine h (pi_to_έβλ (╬╗ v : Tuple (n ++ m),
                       Q (take [n] [m] v) (drop [n] [m] v))
    (╬╗ v : Tuple (n ++ m),
       !!_to_pi (╬╗ y, Q (take [n] [m] v) y)
                (έβλ_to_pi (╬╗ x, `!! y : Tuple m, Q x y)
                         hnested
                         (take [n] [m] v))
                (drop [n] [m] v)))
end;

// NRM9: spec is `(έβλ(x,y) ┬╖ (P έΘΤ Q)) έΘΤ S` έΗΡ `(έβλx ┬╖ (P έΘΤ έΙΑy ┬╖ Q)) έΘΤ S`,
// with y not free in P. Same split: premise body is `P (take v) έΘΤ Q (take v) (drop v)`.
opaque symbol NRM9 [n m]
  [P : Tuple n έΗΤ Prop]
  [Q : Tuple n έΗΤ Tuple m έΗΤ Prop]
  [S : Prop]
  : ╧Α ((`έβλ v : Tuple (n ++ m),
         P (take [n] [m] v) έΘΤ Q (take [n] [m] v) (drop [n] [m] v)) έΘΤ S)
  έΗΤ ╧Α ((`έβλ x : Tuple n, P x έΘΤ (`!! y : Tuple m, Q x y)) έΘΤ S) έΚΦ
begin
  assume n m P Q S h hnested;
  refine h (pi_to_έβλ
    (╬╗ v, P (take [n] [m] v) έΘΤ Q (take [n] [m] v) (drop [n] [m] v))
    (╬╗ v hp,
       !!_to_pi (╬╗ y, Q (take [n] [m] v) y)
                (έβλ_to_pi (╬╗ x, P x έΘΤ (`!! y : Tuple m, Q x y))
                         hnested
                         (take [n] [m] v)
                         hp)
                (drop [n] [m] v)))
end;

// ---- NRM10-15: Implication / negation under `έβλ` and `έβκ` ----

// NRM10: H έΛλ έβκx ┬╖ ┬υ(P έΙπ Q) έΘΤ R έΗΤ H έΛλ έβλx ┬╖ (P έΙπ Q έΘΤ έΛξ) έΘΤ R
opaque symbol NRM10 [n] [Ps : Tuple n έΗΤ ΏζΧΔ* o] [Q : Tuple n έΗΤ Prop] [R : Prop]
  : ╧Α ((`έβκ v, ┬υ έΜΑ (Ps v έΙ╖ Q v)) έΘΤ R)
  έΗΤ ╧Α ((`έβλ v, έΜΑ (Ps v έΙ╖ Q v) έΘΤ έΛξ) έΘΤ R) έΚΦ
begin
  assume n Ps Q R h1 h2;
  refine h1 (pi_to_έβκ (╬╗ v, ┬υ έΜΑ (Ps v έΙ╖ Q v))
    (╬╗ v hpq, έβλ_to_pi (╬╗ v', έΜΑ (Ps v' έΙ╖ Q v') έΘΤ έΛξ) h2 v hpq))
end;

// NRM11: H έΛλ έβκx ┬╖ ┬υ(έΛν έΙπ P) έΘΤ R έΗΤ H έΛλ έβλx ┬╖ (P έΘΤ έΛξ) έΘΤ R
opaque symbol NRM11 [n] [P : Tuple n έΗΤ Prop] [R : Prop]
  : ╧Α ((`έβκ v, ┬υ (έΜΑ_snoc έΛν (P v))) έΘΤ R)
  έΗΤ ╧Α ((`έβλ v, P v έΘΤ έΛξ) έΘΤ R) έΚΦ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_έβκ (╬╗ v, ┬υ έΜΑ (έΙΟ έΙ╖ έΛν έΙ╖ P v))
    (╬╗ v htpv, έβλ_to_pi (╬╗ v', P v' έΘΤ έΛξ) h2 v (έΜΑέΓΓ_snd htpv)))
end;

// NRM12: H έΛλ έβκx ┬╖ ┬υ(P έΙπ Q) έΘΤ R έΗΤ H έΛλ έβλx ┬╖ (P έΘΤ ┬υQ) έΘΤ R
opaque symbol NRM12 [n] [P Q : Tuple n έΗΤ Prop] [R : Prop]
  : ╧Α ((`έβκ v, ┬υ έΜΑ_snoc (P v) (Q v)) έΘΤ R)
  έΗΤ ╧Α ((`έβλ v, P v έΘΤ ┬υ (Q v)) έΘΤ R) έΚΦ
begin
  assume n P Q R h1 h2;
  refine h1 (pi_to_έβκ (╬╗ v, ┬υ έΜΑ (έΙΟ έΙ╖ P v έΙ╖ Q v))
    (╬╗ v hpq, έβλ_to_pi (╬╗ v', P v' έΘΤ ┬υ (Q v')) h2 v
                (έΜΑέΓΓ_hd hpq) (έΜΑέΓΓ_snd hpq)))
end;

// NRM13: H έΛλ έβκx ┬╖ ┬υ(P έΙπ ┬υQ) έΘΤ R έΗΤ H έΛλ έβλx ┬╖ (P έΘΤ Q) έΘΤ R
opaque symbol NRM13 [n] [P Q : Tuple n έΗΤ Prop] [R : Prop]
  : ╧Α ((`έβκ v, ┬υ έΜΑ_snoc (P v) (┬υ Q v)) έΘΤ R)
  έΗΤ ╧Α ((`έβλ v, P v έΘΤ Q v) έΘΤ R) έΚΦ
begin
  assume n P Q R h1 h2;
  refine h1 (pi_to_έβκ (╬╗ v, ┬υ έΜΑ (έΙΟ έΙ╖ P v έΙ╖ ┬υ (Q v)))
    (╬╗ v hc, (έΜΑέΓΓ_snd hc) (έβλ_to_pi (╬╗ v', P v' έΘΤ Q v') h2 v (έΜΑέΓΓ_hd hc))))
end;

// NRM14: H έΛλ έβκx ┬╖ ┬υ(έΛν έΙπ P) έΘΤ R έΗΤ H έΛλ (έβλx ┬╖ ┬υP) έΘΤ R
opaque symbol NRM14 [n] [P : Tuple n έΗΤ Prop] [R : Prop]
  : ╧Α ((`έβκ v, ┬υ έΜΑ_snoc έΛν (P v)) έΘΤ R)
  έΗΤ ╧Α ((`έβλ v, ┬υ (P v)) έΘΤ R) έΚΦ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_έβκ (╬╗ v, ┬υ έΜΑ (έΙΟ έΙ╖ έΛν έΙ╖ P v))
    (╬╗ v htpv, έβλ_to_pi (╬╗ v', ┬υ (P v')) h2 v (έΜΑέΓΓ_snd htpv)))
end;

// NRM15: H έΛλ έβκx ┬╖ ┬υ(έΛν έΙπ ┬υP) έΘΤ R έΗΤ H έΛλ (έβλx ┬╖ P) έΘΤ R
opaque symbol NRM15 [n] [P : Tuple n έΗΤ Prop] [R : Prop]
  : ╧Α ((`έβκ v, ┬υ έΜΑ_snoc έΛν (┬υ P v)) έΘΤ R)
  έΗΤ ╧Α ((`έβλ v, P v) έΘΤ R) έΚΦ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_έβκ (╬╗ v, ┬υ έΜΑ (έΙΟ έΙ╖ έΛν έΙ╖ ┬υ (P v)))
    (╬╗ v htnpv, (έΜΑέΓΓ_snd htnpv) (έβλ_to_pi P h2 v)))
end;

// ---- NRM16-19: Universal-instantiation patterns ----

// NRM16: έΙΑx.P in H; Q έΗΤ H έΛλ (έβκx ┬╖ P) έΘΤ Q
opaque symbol NRM16 [n] [P : Tuple n έΗΤ Prop] [Q : Prop]
  : ╧Α (`!! v, P v)
  έΗΤ ╧Α Q
  έΗΤ ╧Α ((`έβκ v, P v) έΘΤ Q) έΚΦ
begin
  assume n P Q hp hq ht; refine hq
end;

// NRM17: NRM16 with extra spec-level equality side-conditions.
// At the LP level the proof obligation collapses to NRM16's shape.
opaque symbol NRM17 [n] [P : Tuple n έΗΤ Prop] [Q : Prop]
  : ╧Α (`!! v, P v)
  έΗΤ ╧Α Q
  έΗΤ ╧Α ((`έβκ v, P v) έΘΤ Q) έΚΦ
begin
  assume n P Q hp hq ht; refine hq
end;

// NRM18: έΙΑx ┬╖ ┬υ(έΛν έΙπ ┬υP) in H; έΙΔE. [x:=E]P = R έΗΤ H έΛλ έβκy ┬╖ ┬υ(έΛν έΙπ R) έΘΤ Q
opaque symbol NRM18 [n] [P : Tuple n έΗΤ Prop] [R Q : Prop] (v : Tuple n)
  : ╧Α (`!! u, ┬υ έΜΑ_snoc έΛν (┬υ P u))
  έΗΤ ╧Α (P v = R)
  έΗΤ ╧Α ((`έβκ _ : Tuple n, ┬υ έΜΑ_snoc έΛν R) έΘΤ Q) έΚΦ
begin
  assume n P R Q v hp heq h;
  // Derive ╧Α (P v) classically.
  have hpv : ╧Α (P v)
    { refine ┬υ┬υέΓΣ (P v) _;
      assume hnpv;
      refine !!_to_pi (╬╗ u, ┬υ έΜΑ (έΙΟ έΙ╖ έΛν έΙ╖ ┬υ (P u))) hp v (έΜΑέΓΓ_intro έΛνά╡λ hnpv) };
  // Transport along heq.
  have hr : ╧Α R { rewrite left heq; refine hpv };
  refine έΛξέΓΣ (έβκ_to_pi (╬╗ _ : Tuple n, ┬υ έΜΑ (έΙΟ έΙ╖ έΛν έΙ╖ R)) h (inh_tuple [n])
              (έΜΑέΓΓ_intro έΛνά╡λ hr))
end;

// NRM19: P in H; έΙΔE. [x:=E]R = P έΗΤ H έΛλ έβκx ┬╖ ┬υ(έΛν έΙπ R) έΘΤ Q
opaque symbol NRM19 [n] [Q : Prop] [R : Tuple n έΗΤ Prop] (v : Tuple n)
  : ╧Α (R v)
  έΗΤ ╧Α ((`έβκ u, ┬υ έΜΑ_snoc έΛν (R u)) έΘΤ Q) έΚΦ
begin
  assume n Q R v hr hf;
  refine έΛξέΓΣ (έβκ_to_pi (╬╗ u, ┬υ έΜΑ (έΙΟ έΙ╖ έΛν έΙ╖ R u)) hf v (έΜΑέΓΓ_intro έΛνά╡λ hr))
end;

// ---- NRM20-23: Substitution ----

// NRM20: x not free in E; H έΛλ έβκy ┬╖ ┬υ[x:=E]P έΘΤ Q
//        έΗΤ H έΛλ έβκ(x,y) ┬╖ ┬υ(x = E έΙπ P) έΘΤ Q
//
//   έΙΑ (x2,..,xn), ┬υ (P2(E,..,xn) έΙπ .. έΙπ Pn(E,...,xn))
//   ----------------------------------------------------------
//   έΙΑ (x1,..,xn), ┬υ ((x1 = E) έΙπ P2(x1..xn) έΙπ .. έΙπ Pn(x1...xn))
//
// `ps v` is the *full* conjunct list.  Its head `popl (ps v)` is the leading
// equality `x1 = E` (έΚκ `prj 0 v = E`, pinned by the first premise); its tail
// `dropl (ps v)` is the body `P2 έΙπ .. έΙπ Pn`.  Instantiating the goal's
// universal at `v' έρ╛ E` performs the substitution x1 := E: the head becomes
// `E = E` (true by `eq_refl`) and the tail matches the hypothesis's body, so
// `έΜΑ_pop_intro` rebuilds `έΜΑ (ps (v' έρ╛ E))` to discharge the negation.
opaque symbol NRM20 [n] [ps : Tuple (+1 n) έΗΤ ΏζΧΔ* o] [Q : Prop] (E : ╧Ε ╬╣)
  : (╬ι v', ╧Α (popl (ps v') = (prj 0 v' = E)))
  έΗΤ ╧Α ((`έβκ v' : Tuple n, ┬υ έΜΑ dropl (ps (v' έρ╛ E))) έΘΤ Q)
  έΗΤ ╧Α ((`έβκ v : Tuple (+1 n), ┬υ έΜΑ (ps v)) έΘΤ Q) έΚΦ
begin
  assume n ps Q E heq hsmall hbig;
  refine hsmall (pi_to_έβκ (╬╗ v' : Tuple n, ┬υ έΜΑ dropl (ps (v' έρ╛ E)))
    (╬╗ v' hp,
      έβκ_to_pi (╬╗ v, ┬υ έΜΑ (ps v)) hbig (v' έρ╛ E)
        (έΜΑ_pop_intro (ps (v' έρ╛ E))
          (=έΘΤ (eq_sym (heq (v' έρ╛ E))) (eq_refl E))
          hp)))
end;

// NRM21 / NRM23 έΑΦ reversed-equality (`E = x`) duals of NRM20 / NRM22.
//
// UNVERIFIED: no replay in the corpus exercises these, so their signatures
// below are spec-derived and have NOT been checked against PP's actual output.
// NRM20 and NRM22 both needed rewriting once a real replay showed the spec was
// wrong (NRM20's head-equality `ps` list; NRM22's literal-έΛν head) έΑΦ expect the
// same here.  Before relying on NRM21/23, obtain a triggering trace and re-derive
// the shape from it; the emitter still emits a bare `refine NRM2{1,3} _` (no E),
// which will fail loudly rather than silently mis-prove.
opaque symbol NRM21 [n] [ps : Tuple (+1 n) έΗΤ ΏζΧΔ* o] [Q : Prop] (E : ╧Ε ╬╣)
  (heq : ╬ι v', ╧Α (popl (ps v') = (E = prj 0 v')))
  : ╧Α ((`έβκ v' : Tuple n, ┬υ έΜΑ dropl (ps (v' έρ╛ E))) έΘΤ Q)
  έΗΤ ╧Α ((`έβκ v : Tuple (+1 n), ┬υ έΜΑ (ps v)) έΘΤ Q) έΚΦ
begin
  assume n ps Q E heq hsmall hbig;
  refine hsmall (pi_to_έβκ (╬╗ v' : Tuple n, ┬υ έΜΑ dropl (ps (v' έρ╛ E)))
    (╬╗ v' hp,
      έβκ_to_pi (╬╗ v, ┬υ έΜΑ (ps v)) hbig (v' έρ╛ E)
        (έΜΑ_pop_intro (ps (v' έρ╛ E))
          (=έΘΤ (eq_sym (heq (v' έρ╛ E))) (eq_refl E))
          hp)))
end;

// ---- Tail-equality substitution forms (NRM20/21 over an end-of-list pin) ----
//
// PP's NRM20/21 pin *whichever* binder an equality conjunct determines, and
// the equality may sit at the END of the conjunct list (NRM14 prepends έΛν, so
// a 2-conjunct body reads `έΛν έΙπ (x = E)`).  The head-equality forms above
// (popl/dropl) cover the head position; these cover the tail position, with
// the witness E a *function of the remaining tuple* έΑΦ PP may pin x at another
// still-bound variable (`#x.#y.(x = y)` pins x at y = prj 0 of what remains).
//
// Slot discipline (position i in PP's binder list έΗο prj i): the S forms pin
// slot 0 (PP's first listed binder, the rightmost έρ╛-slot), the P forms pin
// slot 1 (the second).  The emitter picks by the pinned var's position, read
// off the rule annotation against its child's binder list.

// NRM20S: pin slot 0 by a tail equality `prj 0 v = E (init v)`.
opaque symbol NRM20S [n] [qs : Tuple (+1 n) έΗΤ ΏζΧΔ* o] [Q : Prop]
  (E : Tuple n έΗΤ ╧Ε ╬╣)
  : ╧Α ((`έβκ v' : Tuple n, ┬υ έΜΑ (qs (v' έρ╛ E v'))) έΘΤ Q)
  έΗΤ ╧Α ((`έβκ v : Tuple (+1 n), ┬υ έΜΑ (qs v έΙ╖ (prj 0 v = E (init v)))) έΘΤ Q) έΚΦ
begin
  assume n qs Q E hsmall hbig;
  refine hsmall (pi_to_έβκ (╬╗ v' : Tuple n, ┬υ έΜΑ (qs (v' έρ╛ E v')))
    (╬╗ v' hq,
      έβκ_to_pi (╬╗ v, ┬υ έΜΑ (qs v έΙ╖ (prj 0 v = E (init v)))) hbig (v' έρ╛ E v')
        (έΜΑ_intro hq (eq_refl (E v')))))
end;

// NRM21S: NRM20S with reversed equality (`E έΑο = prj 0 v`).
opaque symbol NRM21S [n] [qs : Tuple (+1 n) έΗΤ ΏζΧΔ* o] [Q : Prop]
  (E : Tuple n έΗΤ ╧Ε ╬╣)
  : ╧Α ((`έβκ v' : Tuple n, ┬υ έΜΑ (qs (v' έρ╛ E v'))) έΘΤ Q)
  έΗΤ ╧Α ((`έβκ v : Tuple (+1 n), ┬υ έΜΑ (qs v έΙ╖ (E (init v) = prj 0 v))) έΘΤ Q) έΚΦ
begin
  assume n qs Q E hsmall hbig;
  refine hsmall (pi_to_έβκ (╬╗ v' : Tuple n, ┬υ έΜΑ (qs (v' έρ╛ E v')))
    (╬╗ v' hq,
      έβκ_to_pi (╬╗ v, ┬υ έΜΑ (qs v έΙ╖ (E (init v) = prj 0 v))) hbig (v' έρ╛ E v')
        (έΜΑ_intro hq (eq_refl (E v')))))
end;

// NRM20P: pin slot 1 by a tail equality `prj 1 v = E (rm1 v)`.
opaque symbol NRM20P [n] [qs : Tuple (+1 (+1 n)) έΗΤ ΏζΧΔ* o] [Q : Prop]
  (E : Tuple (+1 n) έΗΤ ╧Ε ╬╣)
  : ╧Α ((`έβκ v' : Tuple (+1 n), ┬υ έΜΑ (qs (tuple_insert1 (E v') v'))) έΘΤ Q)
  έΗΤ ╧Α ((`έβκ v : Tuple (+1 (+1 n)), ┬υ έΜΑ (qs v έΙ╖ (prj 1 v = E (rm1 v)))) έΘΤ Q) έΚΦ
begin
  assume n qs Q E hsmall hbig;
  refine hsmall
    (pi_to_έβκ (╬╗ v' : Tuple (+1 n), ┬υ έΜΑ (qs (tuple_insert1 (E v') v')))
      (╬╗ v' hq,
        έβκ_to_pi (╬╗ v, ┬υ έΜΑ (qs v έΙ╖ (prj 1 v = E (rm1 v)))) hbig
          (tuple_insert1 (E v') v')
          (έΜΑ_intro hq (eq_refl (E v')))))
end;

// NRM21P: NRM20P with reversed equality.
opaque symbol NRM21P [n] [qs : Tuple (+1 (+1 n)) έΗΤ ΏζΧΔ* o] [Q : Prop]
  (E : Tuple (+1 n) έΗΤ ╧Ε ╬╣)
  : ╧Α ((`έβκ v' : Tuple (+1 n), ┬υ έΜΑ (qs (tuple_insert1 (E v') v'))) έΘΤ Q)
  έΗΤ ╧Α ((`έβκ v : Tuple (+1 (+1 n)), ┬υ έΜΑ (qs v έΙ╖ (E (rm1 v) = prj 1 v))) έΘΤ Q) έΚΦ
begin
  assume n qs Q E hsmall hbig;
  refine hsmall
    (pi_to_έβκ (╬╗ v' : Tuple (+1 n), ┬υ έΜΑ (qs (tuple_insert1 (E v') v')))
      (╬╗ v' hq,
        έβκ_to_pi (╬╗ v, ┬υ έΜΑ (qs v έΙ╖ (E (rm1 v) = prj 1 v))) hbig
          (tuple_insert1 (E v') v')
          (έΜΑ_intro hq (eq_refl (E v')))))
end;

// NRM22: the έβκ-body's tail equality pins the binder at E (general list
// form; the έΛν-headed NRM14-fed shape is the instance ps := ╬╗ _, (έΙΟ έΙ╖ έΛν)).
opaque symbol NRM22 [Q : Prop] [ps : Tuple 1 έΗΤ ΏζΧΔ* o] (E : ╧Ε ╬╣)
  : ╧Α (┬υ έΜΑ (ps (unit έρ╛ E)) έΘΤ Q)
  έΗΤ ╧Α ((`έβκ v : Tuple 1, ┬υ έΜΑ (ps v έΙ╖ (prj 0 v = E))) έΘΤ Q) έΚΦ
begin
  assume Q ps E h1 h2;
  refine h1 (╬╗ hps,
    έβκ_to_pi (╬╗ v : Tuple 1, ┬υ έΜΑ (ps v έΙ╖ (prj 0 v = E)))
            h2 (unit έρ╛ E)
            (έΜΑ_intro hps (eq_refl E)))
end;

// NRM23: NRM22 with reversed equality.
opaque symbol NRM23 [Q : Prop] (E : ╧Ε ╬╣)
  : ╧Α (┬υ έΛν έΘΤ Q)
  έΗΤ ╧Α ((`έβκ v : Tuple 1,
         ┬υ έΜΑ (έΙΟ έΙ╖ έΛν έΙ╖ (E = prj 0 v))) έΘΤ Q) έΚΦ
begin
  assume Q E h1 h2;
  refine h1 (╬╗ ht,
    έβκ_to_pi (╬╗ v : Tuple 1, ┬υ έΜΑ (έΙΟ έΙ╖ έΛν έΙ╖ (E = prj 0 v)))
            h2 (unit έρ╛ E)
            (έΜΑέΓΓ_intro ht (eq_refl E)))
end;

// ---- NRM24-26: Trivial structural rules ----

// NRM24: P not of form A έΙπ B; H έΛλ έβκx ┬╖ ┬υ(έΛν έΙπ P) έΘΤ Q έΗΤ H έΛλ έβκx ┬╖ ┬υP έΘΤ Q
opaque symbol NRM24 [n] [P : Tuple n έΗΤ Prop] [Q : Prop]
  : ╧Α ((`έβκ v, ┬υ έΜΑ (έΙΟ έΙ╖ έΛν έΙ╖ P v)) έΘΤ Q)
  έΗΤ ╧Α ((`έβκ v, ┬υ (P v)) έΘΤ Q) έΚΦ
begin
  assume n P Q h1 h2;
  refine h1 (pi_to_έβκ (╬╗ v, ┬υ έΜΑ (έΙΟ έΙ╖ έΛν έΙ╖ P v))
    (╬╗ v htpv, έβκ_to_pi (╬╗ v', ┬υ (P v')) h2 v (έΜΑέΓΓ_snd htpv)))
end;

// NRM25: x not free in P; H έΛλ P έΗΤ H έΛλ έβκ(x) ┬╖ P
//   = forall2(x).P in PP notation. `pi_to_έβκ` with constant predicate
//   (the body doesn't depend on the bound tuple).
opaque symbol NRM25 [n] [P : Prop] [Q : Prop]
  : ╧Α (P έΘΤ Q)
  έΗΤ ╧Α ((`έβκ _ : Tuple n, P) έΘΤ Q) έΚΦ
begin
  assume n P Q hp hέβκ;
  refine hp (έβκ_to_pi (╬╗ _, P) hέβκ (inh_tuple [n]))
end;

// NRM26: y not free in P; H έΛλ έβκ(x,...) ┬╖ P έΗΤ H έΛλ έβκ(x,y,...) ┬╖ P
// Helper: prepend an element to a Tuple n.
symbol tuple_prepend [n] : ╧Ε ╬╣ έΗΤ Tuple n έΗΤ Tuple (+1 n);
rule tuple_prepend [0] $x unit έΗς unit έρ╛ $x
with tuple_prepend [+1 $n] $x ($w έρ╛ $y) έΗς tuple_prepend [$n] $x $w έρ╛ $y;

opaque symbol NRM26 [n] [P : Tuple (+1 n) έΗΤ Prop] [Q : Prop]
  : ╧Α ((`έβκ v' : Tuple n, P (tuple_prepend ΏζθΟ v')) έΘΤ Q)
  έΗΤ ╧Α ((`έβκ v : Tuple (+1 n), P v) έΘΤ Q) έΚΦ
begin
  assume n P Q hp hέβκ;
  refine hp (pi_to_έβκ (╬╗ v', P (tuple_prepend ΏζθΟ v'))
    (╬╗ v', έβκ_to_pi (╬╗ v, P v) hέβκ (tuple_prepend ΏζθΟ v')))
end;

// PP's NRM26 drops the unused binder *wherever it sits* in the binder list,
// not only last-listed.  `tuple_prepend` above dummy-fills the leftmost slot
// (= the last-listed binder); the variants below fill slot 0 (NRM26S έΑΦ PP's
// first listed binder) and slot 1 (NRM26M).  With the wrong variant the
// remaining binders' projections shift onto the dummy slot, so the emitter
// picks by the dropped var's position (annotation diff against the child).
opaque symbol NRM26S [n] [P : Tuple (+1 n) έΗΤ Prop] [Q : Prop]
  : ╧Α ((`έβκ v' : Tuple n, P (v' έρ╛ ΏζθΟ)) έΘΤ Q)
  έΗΤ ╧Α ((`έβκ v : Tuple (+1 n), P v) έΘΤ Q) έΚΦ
begin
  assume n P Q hp hέβκ;
  refine hp (pi_to_έβκ (╬╗ v', P (v' έρ╛ ΏζθΟ))
    (╬╗ v', έβκ_to_pi (╬╗ v, P v) hέβκ (v' έρ╛ ΏζθΟ)))
end;

opaque symbol NRM26M [n] [P : Tuple (+1 (+1 n)) έΗΤ Prop] [Q : Prop]
  : ╧Α ((`έβκ v' : Tuple (+1 n), P (tuple_insert1 ΏζθΟ v')) έΘΤ Q)
  έΗΤ ╧Α ((`έβκ v : Tuple (+1 (+1 n)), P v) έΘΤ Q) έΚΦ
begin
  assume n P Q hp hέβκ;
  refine hp (pi_to_έβκ (╬╗ v', P (tuple_insert1 ΏζθΟ v'))
    (╬╗ v', έβκ_to_pi (╬╗ v, P v) hέβκ (tuple_insert1 ΏζθΟ v')))
end;

// ---- NRM27-30: Arithmetic solver dispatch (trust-free) ----
//
// PP's solver closes a universal hypothesis `έβκ(xέΓΒ,έΑο,xέΓβ)┬╖┬υ(P έΙπ έΑο έΙπ Q)`
// when the conjunction holds two bounding inequalities `a + xά╡λ έΚν ΏζθΟ` and
// `b έΙΤ xά╡λ έΚν ΏζθΟ` with `solveur(a + b) = ΏζθΟ`: those force `xά╡λ = b`, and the
// substituted conjunction `[xά╡λ := b](P έΙπ έΑο έΙπ Q)` is satisfiable, so the
// universal-of-negation is *false* and discharges the sequent.
//
// Trust-free realisation: peel the pinned binder by *instantiating* the
// `έβκ`-hypothesis at the solver witness `b` (the membership premises the
// spec carries are solver bookkeeping έΑΦ unused here).  This leaves the
// continuation premise `έβλv'┬╖┬υέΜΑ(ps (v' έρ╛ b v')) έΘΤ R`; the emitter bridges
// the literal substituted conjunction `έΜΑ (ps (v' έρ╛ b v'))` to έΛν with a
// generated congruence proof (each cancelling bound = έΛν via `eq_true` +
// `leq_zero_of_sum_zero` + `prove_sum_eq`), matching PP's έΛν-normalisation.
//
//   NRM27 / NRM29 έΑΦ multi-binder (έβκ-block) forms, drop one binder.
//   NRM28 / NRM30 έΑΦ unary (έβκx) forms, drop the binder entirely.
//   27/28 are the `xά╡λ = ΏζθΟ` specialisation (a = b = ΏζθΟ) of 29/30.

// ---- helper lemmas for the trust-free solver dispatch ----

// `P` provably true έθ╣ `P = έΛν`, so a έΜΑ-conjunct the solver discharges can
// be rewritten to έΛν and absorbed by `έΜΑ (_ έΙ╖ έΛν) έΗς έΜΑ _`.
opaque symbol eq_true (P : Prop) : ╧Α P έΗΤ ╧Α (P = έΛν) έΚΦ
begin
  assume P h;
  refine propExt _ _ _ _
  { assume hp; refine έΛνά╡λ }
  { assume ht; refine h }
end;

// A sum that arithmetic-normalises to ΏζθΟ is έΚν ΏζθΟ.  The emitter builds the
// `E = ΏζθΟ` proof with `prove_sum_eq` (add_comm/assoc/opp cancellation).
opaque symbol leq_zero_of_sum_zero (E : ╧Ε ╬╣) : ╧Α (E = ΏζθΟ) έΗΤ ╧Α (E έΚν ΏζθΟ) έΚΦ
begin
  assume E h;
  rewrite h;
  refine leq_refl ΏζθΟ
end;

// `mem P ps` : `P` occurs (up to propositional equality) in the conjunct
// list `ps`.  The solver's "(x έΚν ΏζθΟ) est dans (P έΙπ έΑο έΙπ Q)" side-conditions.
symbol mem : Prop έΗΤ ΏζΧΔ* o έΗΤ Prop;
rule mem _  έΙΟ          έΗς έΛξ
with mem $P ($ps έΙ╖ $Q) έΗς (mem $P $ps) έΙρ ($P = $Q);

// If `P έΙΙ ps` and `έΜΑ ps` holds, then `P` holds έΑΦ the membership premises
// are sound, so NRM27 needs no `trust` to use them.
opaque symbol mem_sound (P : Prop)
  : ╬ι ps : ΏζΧΔ* o, ╧Α (mem P ps) έΗΤ ╧Α (έΜΑ ps) έΗΤ ╧Α P έΚΦ
begin
  assume P;
  induction
  { assume hmem hconj; refine έΛξέΓΣ hmem }
  { assume ps ih Q hmem hconj;
    refine έΙρέΓΣ hmem _ _
    { assume hin; refine ih hin (έΜΑ_init hconj) }
    { assume heq; refine =έΘΤ (eq_sym heq) (έΜΑ_last hconj) } }
end;

// NRM27: bare goal (no `έΘΤR`), the `xά╡λ = ΏζθΟ` case.  The bounds `prj 0 v έΚν ΏζθΟ`
// and `έΑΦ prj 0 v έΚν ΏζθΟ` (members of the conjunction) pin `prj 0 v = ΏζθΟ` by
// antisymmetry; tuple-╬╖ (`(init v) έρ╛ ΏζθΟ = v`, via Quant.lp) then transports
// `έΜΑ (ps v)` to `έΜΑ (ps ((init v) έρ╛ ΏζθΟ))`, contradicting the premise.  Fully
// trust-free; untriggered in the corpus (the only NRM2x trace is NRM29).
opaque symbol NRM27 [n] [ps : Tuple (+1 n) έΗΤ ΏζΧΔ* o]
  (hpos : ╬ι v, ╧Α (mem (prj 0 v έΚν ΏζθΟ) (ps v)))
  (hneg : ╬ι v, ╧Α (mem (έΑΦ prj 0 v έΚν ΏζθΟ) (ps v)))
  : ╧Α (`έβλ v' : Tuple n, ┬υ έΜΑ (ps (v' έρ╛ ΏζθΟ)))
  έΗΤ ╧Α (`έβκ v : Tuple (+1 n), ┬υ έΜΑ (ps v)) έΚΦ
begin
  assume n ps hpos hneg h_prem;
  refine pi_to_έβκ (╬╗ v, ┬υ έΜΑ (ps v)) (╬╗ v hpv, _);
  have hle : ╧Α (prj 0 v έΚν ΏζθΟ)
    { refine mem_sound _ (ps v) (hpos v) hpv };
  have hge : ╧Α (ΏζθΟ έΚν prj 0 v)
    { refine neg_leq_zero (prj 0 v) (mem_sound _ (ps v) (hneg v) hpv) };
  have hz : ╧Α (prj 0 v = ΏζθΟ)
    { refine leq_antisym (prj 0 v) ΏζθΟ hle hge };
  have heq : ╧Α (((init v) έρ╛ ΏζθΟ) = v)
    { rewrite left hz; refine tuple_eta v };
  have hcontra : ╧Α (┬υ έΜΑ (ps ((init v) έρ╛ ΏζθΟ)))
    { refine έβλ_to_pi (╬╗ v' : Tuple n, ┬υ έΜΑ (ps (v' έρ╛ ΏζθΟ))) h_prem (init v) };
  have hgood : ╧Α (έΜΑ (ps ((init v) έρ╛ ΏζθΟ)))
    { rewrite heq; refine hpv };
  refine hcontra hgood
end;

// NRM30: unary έβκx, general witness b.  Instantiate at b, feed the premise.
opaque symbol NRM30 [ps : ╧Ε ╬╣ έΗΤ ΏζΧΔ* o] [R : Prop] (b : ╧Ε ╬╣)
  : ╧Α (┬υ έΜΑ (ps b) έΘΤ R)
  έΗΤ ╧Α ((`έβκ v : Tuple 1, ┬υ έΜΑ (ps (prj 0 v))) έΘΤ R) έΚΦ
begin
  assume ps R b h_prem hέβκ;
  refine h_prem (έβκ_to_pi (╬╗ v : Tuple 1, ┬υ έΜΑ (ps (prj 0 v))) hέβκ (unit έρ╛ b))
end;

// NRM28: x := ΏζθΟ specialisation of NRM30.
opaque symbol NRM28 [ps : ╧Ε ╬╣ έΗΤ ΏζΧΔ* o] [R : Prop]
  : ╧Α (┬υ έΜΑ (ps ΏζθΟ) έΘΤ R)
  έΗΤ ╧Α ((`έβκ v : Tuple 1, ┬υ έΜΑ (ps (prj 0 v))) έΘΤ R) έΚΦ
begin
  assume ps R h_prem hέβκ;
  refine h_prem (έβκ_to_pi (╬╗ v : Tuple 1, ┬υ έΜΑ (ps (prj 0 v))) hέβκ (unit έρ╛ ΏζθΟ))
end;

// NRM29: multi-binder, pin the prj0 slot to `b v'` (witness a function of
// the remaining binders έΑΦ e.g. b v' = έΑΦ prj 0 v' for the sum-zero /
// cancelling case).  The emitter supplies `b` and the έΛν-normalisation
// bridge for the substituted conjunction `έΜΑ (ps (v' έρ╛ b v'))`.
opaque symbol NRM29 [n] [ps : Tuple (+1 n) έΗΤ ΏζΧΔ* o] [R : Prop] (b : Tuple n έΗΤ ╧Ε ╬╣)
  : ╧Α ((`έβλ v' : Tuple n, ┬υ έΜΑ (ps (v' έρ╛ b v'))) έΘΤ R)
  έΗΤ ╧Α ((`έβκ v : Tuple (+1 n), ┬υ έΜΑ (ps v)) έΘΤ R) έΚΦ
begin
  assume n ps R b h_prem hέβκ;
  refine h_prem (pi_to_έβλ (╬╗ v', ┬υ έΜΑ (ps (v' έρ╛ b v')))
    (╬╗ v', έβκ_to_pi (╬╗ v, ┬υ έΜΑ (ps v)) hέβκ (v' έρ╛ b v')))
end;

// ---- `_1` (Result-form) variants έΑΦ ┬π8.13 ----
//
// Per discussion, no NRM_1 rules are emitted in the current corpus.
// NRM1_1 is the lone exception έΑΦ it strips a constant έβλ-binder via
// `nrm1_eq`, mirroring NRM1's role at the chain level.

symbol NRM1_1 [n] [P Q : Prop]
  (r : Res (P έΘΤ Q)) : Res ((`έβλ _ : Tuple n, P) έΘΤ Q)
  έΚΦ mk_1 (res_tm r) (eq_trans (@nrm1_eq n P Q) (res_eq r));

// NRM14_1 έΑΦ chain (Res) form of NRM14.  PP leaves NRM rules *unprimed* in the
// first-normalisation chain (unlike ALL7/ALL9/STOP/IMP), so the emitter maps a
// chain-context `NRM14` to this; `nrm14_eq` (Res.lp) is the bridge equality.
symbol NRM14_1 [n] [P : Tuple n έΗΤ Prop] [R : Prop]
  (r : Res ((`έβκ v, ┬υ έΜΑ_snoc έΛν (P v)) έΘΤ R)) : Res ((`έβλ v, ┬υ (P v)) έΘΤ R)
  έΚΦ mk_1 (res_tm r) (eq_trans (@nrm14_eq n P R) (res_eq r));

// NRM13_1 έΑΦ chain (Res) form of NRM13, via the `nrm13_eq` bridge (Res.lp).
symbol NRM13_1 [n] [P Q : Tuple n έΗΤ Prop] [R : Prop]
  (r : Res ((`έβκ v, ┬υ έΜΑ_snoc (P v) (┬υ Q v)) έΘΤ R)) : Res ((`έβλ v, P v έΘΤ Q v) έΘΤ R)
  έΚΦ mk_1 (res_tm r) (eq_trans (@nrm13_eq n P Q R) (res_eq r));

// NRM12_1 έΑΦ chain (Res) form of NRM12, via the `nrm12_eq` bridge (Res.lp).
symbol NRM12_1 [n] [P Q : Tuple n έΗΤ Prop] [R : Prop]
  (r : Res ((`έβκ v, ┬υ έΜΑ_snoc (P v) (Q v)) έΘΤ R)) : Res ((`έβλ v, P v έΘΤ ┬υ (Q v)) έΘΤ R)
  έΚΦ mk_1 (res_tm r) (eq_trans (@nrm12_eq n P Q R) (res_eq r));

// NRM15_1 έΑΦ chain (Res) form of NRM15, via the `nrm15_eq` bridge (Res.lp).
symbol NRM15_1 [n] [P : Tuple n έΗΤ Prop] [R : Prop]
  (r : Res ((`έβκ v, ┬υ έΜΑ_snoc έΛν (┬υ (P v))) έΘΤ R)) : Res ((`έβλ v, P v) έΘΤ R)
  έΚΦ mk_1 (res_tm r) (eq_trans (@nrm15_eq n P R) (res_eq r));

// NRM3 bridge: ((έβλv┬╖(P v έΘΤ Q)) έΘΤ S) = ((Q έΘΤ S) έΙπ ((έΙΑv┬╖┬υP v) έΘΤ S)), Q is v-free.
// (Lives here, not Res.lp, because the έΘΡ direction reuses NRM3 itself; the έΘΤ
// direction builds the έβλ witness from Q, or vacuously from ┬υP v.)
opaque symbol nrm3_eq [n] [P : Tuple n έΗΤ Prop] [Q S : Prop]
  : ╧Α (((`έβλ v, P v έΘΤ Q) έΘΤ S) = έΜΑ_snoc (Q έΘΤ S) ((`!! v, ┬υ (P v)) έΘΤ S)) έΚΦ
begin
  assume n P Q S;
  refine propExt _ _
    (╬╗ hres, έΜΑέΓΓ_intro
       (╬╗ hq, hres (pi_to_έβλ (╬╗ v, P v έΘΤ Q) (╬╗ v hpv, hq)))
       (╬╗ hnp, hres (pi_to_έβλ (╬╗ v, P v έΘΤ Q)
                       (╬╗ v hpv, έΛξέΓΣ (!!_to_pi (╬╗ v, ┬υ (P v)) hnp v hpv)))))
    (╬╗ hprem, @NRM3 n P Q S hprem)
end;

// NRM3_1 έΑΦ chain (Res) form of NRM3, via the `nrm3_eq` bridge above.  The
// premise is the snoc-conjunction the emitter discharges with AND4_1.
symbol NRM3_1 [n] [P : Tuple n έΗΤ Prop] [Q S : Prop]
  (r : Res (έΜΑ_snoc (Q έΘΤ S) ((`!! v, ┬υ (P v)) έΘΤ S))) : Res ((`έβλ v, P v έΘΤ Q) έΘΤ S)
  έΚΦ mk_1 (res_tm r) (eq_trans (@nrm3_eq n P Q S) (res_eq r));

// NRM23_1 έΑΦ chain (Res) form of NRM23, via the `nrm23_eq` bridge (Res.lp).  E is
// implicit here (the emitter emits `NRM23_1 _`, inferring E from the Res target).
symbol NRM23_1 [Q : Prop] [E : ╧Ε ╬╣]
  (r : Res (┬υ έΛν έΘΤ Q))
  : Res ((`έβκ v : Tuple 1, ┬υ έΜΑ (έΙΟ έΙ╖ έΛν έΙ╖ (E = prj 0 v))) έΘΤ Q)
  έΚΦ mk_1 (res_tm r) (eq_trans (@nrm23_eq Q E) (res_eq r));

// NRM22_1 έΑΦ chain (Res) form of NRM22, via the general `nrm22_eq` bridge
// (Res.lp): the body's tail equality pins the binder at E.
symbol NRM22_1 [Q : Prop] [ps : Tuple 1 έΗΤ ΏζΧΔ* o] [E : ╧Ε ╬╣]
  (r : Res (┬υ έΜΑ (ps (unit έρ╛ E)) έΘΤ Q))
  : Res ((`έβκ v : Tuple 1, ┬υ έΜΑ (ps v έΙ╖ (prj 0 v = E))) έΘΤ Q)
  έΚΦ mk_1 (res_tm r) (eq_trans (@nrm22_eq Q ps E) (res_eq r));
