// Normalisation (┬ДA.12) Рђћ tuple-based encoding.
//
// Spec uses `РЎб` (= goal-side n-ary universal) and `РЎА` (= hypothesis-
// side n-ary universal). Both reduce propositionally to `!!` via the
// `РЎб_eq_!!` / `РЎА_eq_!!` axioms in Quant.lp; bodies use the dedicated
// `pi_to_РЎб` / `РЎб_to_pi` (and РЎА analogues) bridges.

require open pp2lp.B pp2lp.Int pp2lp.Quant pp2lp.rules.Res;

// ---- NRM1-7: Logical transformations under `РЎб` ----

// NRM1: x not free in P; H Ріб P РЄњ S Рєњ H Ріб (РЎбx ┬и P) РЄњ S
opaque symbol NRM1 [n] [P S : Prop]
  : ¤ђ (P РЄњ S)
  Рєњ ¤ђ ((`РЎб _ : Tuple n, P) РЄњ S) РЅћ
begin
  assume n P S h1 h2;
  refine h1 (РЎб_to_pi (╬╗ _ : Tuple n, P) h2 (inh_tuple [n]))
end;

// NRM2: x not free in P; H Ріб (P РЄњ РЎбx ┬и Q) РЄњ S Рєњ H Ріб РЎбx ┬и (P РЄњ Q) РЄњ S
opaque symbol NRM2 [n] [P : Prop] [Q : Tuple n Рєњ Prop] [S : Prop]
  : ¤ђ ((P РЄњ (`РЎб v, Q v)) РЄњ S)
  Рєњ ¤ђ ((`РЎб v, P РЄњ Q v) РЄњ S) РЅћ
begin
  assume n P Q S h1 h2;
  refine h1 (╬╗ p,
    pi_to_РЎб Q (╬╗ v, РЎб_to_pi (╬╗ v', P РЄњ Q v') h2 v p))
end;

// NRM3: x not free in Q; H Ріб (Q РЄњ S) РѕД ((Рѕђx ┬и ┬гP) РЄњ S) Рєњ H Ріб РЎбx ┬и (P РЄњ Q) РЄњ S
opaque symbol NRM3 [n] [P : Tuple n Рєњ Prop] [Q S : Prop]
  : ¤ђ (РІђ_snoc (Q РЄњ S) ((`!! v, ┬г (P v)) РЄњ S))
  Рєњ ¤ђ ((`РЎб v, P v РЄњ Q) РЄњ S) РЅћ
begin
  assume n P Q S h1 h2;
  refine РѕеРѓЉ (em (`?? v, P v)) _ _
  { assume hex;
    refine pi_to_??_elim P
      (╬╗ v hpv, (РІђРѓѓ_hd h1) (РЎб_to_pi (╬╗ v', P v' РЄњ Q) h2 v hpv)) hex }
  { assume hnex;
    refine (РІђРѓѓ_snd h1) (pi_to_!! (╬╗ v, ┬г (P v))
      (╬╗ v hpv, hnex (pi_to_??_intro P v hpv))) }
end;

// NRM4: x not free in Q; H Ріб (Q РЄњ РЎбx ┬и (P РЄњ R)) РЄњ S Рєњ H Ріб РЎбx ┬и (P РЄњ Q РЄњ R) РЄњ S
opaque symbol NRM4 [n] [P R : Tuple n Рєњ Prop] [Q S : Prop]
  : ¤ђ ((Q РЄњ (`РЎб v, P v РЄњ R v)) РЄњ S)
  Рєњ ¤ђ ((`РЎб v, P v РЄњ Q РЄњ R v) РЄњ S) РЅћ
begin
  assume n P R Q S h1 h2;
  refine h1 (╬╗ hq,
    pi_to_РЎб (╬╗ v, P v РЄњ R v)
      (╬╗ v hpv, РЎб_to_pi (╬╗ v', P v' РЄњ Q РЄњ R v') h2 v hpv hq))
end;

// NRM5: H Ріб РЎбx ┬и (P РѕД Q РЄњ R) РЄњ S Рєњ H Ріб РЎбx ┬и (P РЄњ Q РЄњ R) РЄњ S
// Uncurry: `РІђ_snoc (P v) (Q v)` reduces to `РІђ (Рѕј Рѕи P v Рѕи Q v)`, so the
// hypothesis splits with `РІђРѓѓ_hd`/`РІђРѓѓ_snd` to feed the curried body.
opaque symbol NRM5 [n] [P Q R : Tuple n Рєњ Prop] [S : Prop]
  : ¤ђ ((`РЎб v, РІђ_snoc (P v) (Q v) РЄњ R v) РЄњ S)
  Рєњ ¤ђ ((`РЎб v, P v РЄњ Q v РЄњ R v) РЄњ S) РЅћ
begin
  assume n P Q R S h1 h2;
  refine h1 (pi_to_РЎб (╬╗ v, РІђ_snoc (P v) (Q v) РЄњ R v)
    (╬╗ v hpq, РЎб_to_pi (╬╗ v', P v' РЄњ Q v' РЄњ R v') h2 v
                (РІђРѓѓ_hd hpq) (РІђРѓѓ_snd hpq)))
end;

// NRM6: H Ріб РЎбx ┬и (R РЄњ P) РЄњ (РЎбx ┬и (R РЄњ Q) РЄњ S) Рєњ H Ріб РЎбx ┬и (R РЄњ P РѕД Q) РЄњ S
// Generalised over a snoc list: the consequent `РІђ (qs v Рѕи P v)` splits into
// init `РІђ (qs v)` and last `P v`.  init-first lets the emitter chain
// `refine NRM6 _;` for n-conjunct goals, since `РІђ (qs v)` is itself a
// `РІђ (qs' v Рѕи P' v)` when |qs v| РЅЦ 2.
opaque symbol NRM6 [n] [Qs : Tuple n Рєњ ­ЮЋЃ* o] [P R : Tuple n Рєњ Prop] [S : Prop]
  : ¤ђ ((`РЎб v, R v РЄњ РІђ (Qs v)) РЄњ ((`РЎб v, R v РЄњ P v) РЄњ S))
  Рєњ ¤ђ ((`РЎб v, R v РЄњ РІђ (Qs v Рѕи P v)) РЄњ S) РЅћ
begin
  assume n qs P R S h1 h2;
  refine h1
    (pi_to_РЎб (╬╗ v, R v РЄњ РІђ (qs v))
      (╬╗ v hr, РІђ_init (РЎб_to_pi (╬╗ v', R v' РЄњ РІђ (qs v' Рѕи P v')) h2 v hr)))
    (pi_to_РЎб (╬╗ v, R v РЄњ P v)
      (╬╗ v hr, РІђ_last (РЎб_to_pi (╬╗ v', R v' РЄњ РІђ (qs v' Рѕи P v')) h2 v hr)))
end;

// NRM7: H Ріб (РЎбx ┬и P) РЄњ ((РЎбx ┬и Q) РЄњ S) Рєњ H Ріб РЎбx ┬и (P РѕД Q) РЄњ S
// Generalised: same shape as NRM6 but without the R РЄњ antecedent.
opaque symbol NRM7 [n] [Qs : Tuple n Рєњ ­ЮЋЃ* o] [P : Tuple n Рєњ Prop] [S : Prop]
  : ¤ђ ((`РЎб v, РІђ (Qs v))
        РЄњ ((`РЎб v, P v) РЄњ S))
  Рєњ ¤ђ ((`РЎб v : Tuple n, РІђ (Qs v Рѕи P v)) РЄњ S) РЅћ
begin
  assume n qs P S h1 h2;
  refine h1
    (pi_to_РЎб (╬╗ v, РІђ (qs v))
      (╬╗ v, РІђ_init (РЎб_to_pi (╬╗ v', РІђ (qs v' Рѕи P v')) h2 v)))
    (pi_to_РЎб (╬╗ v, P v)
      (╬╗ v, РІђ_last (РЎб_to_pi (╬╗ v', РІђ (qs v' Рѕи P v')) h2 v)))
end;

// ---- NRM8-9: compoundРєћmixed binders (split with `take`/`drop`) ----
//
// NRM8: spec is `(РЎб(x,y) ┬и Q) РЄњ S` Рєљ `(РЎбx ┬и Рѕђy ┬и Q) РЄњ S`.
// Encoded with the n,m-indexed split helpers from Quant.lp:
//   the conclusion's `Q x y` (clean HO pattern) gets unified back
//   from the premise's `Q (take v) (drop v)` after Lambdapi infers Q.
opaque symbol NRM8 [n m] [Q : Tuple n Рєњ Tuple m Рєњ Prop] [S : Prop]
  : ¤ђ ((`РЎб v : Tuple (n ++ m), Q (take [n] [m] v) (drop [n] [m] v)) РЄњ S)
  Рєњ ¤ђ ((`РЎб x : Tuple n, `!! y : Tuple m, Q x y) РЄњ S) РЅћ
begin
  assume n m Q S h hnested;
  // hnested : ¤ђ (`РЎб x : Tuple n, `!! y : Tuple m, Q x y)
  // Need:    ¤ђ (`РЎб v : Tuple (n ++ m), Q (take v) (drop v))
  // Witness: ╬╗ v, !!_to_pi (Q x) (РЎб_to_pi (╬╗ x, `!! y, Q x y) hnested x') y'
  //          where x' = take v, y' = drop v.
  refine h (pi_to_РЎб (╬╗ v : Tuple (n ++ m),
                       Q (take [n] [m] v) (drop [n] [m] v))
    (╬╗ v : Tuple (n ++ m),
       !!_to_pi (╬╗ y, Q (take [n] [m] v) y)
                (РЎб_to_pi (╬╗ x, `!! y : Tuple m, Q x y)
                         hnested
                         (take [n] [m] v))
                (drop [n] [m] v)))
end;

// NRM9: spec is `(РЎб(x,y) ┬и (P РЄњ Q)) РЄњ S` Рєљ `(РЎбx ┬и (P РЄњ Рѕђy ┬и Q)) РЄњ S`,
// with y not free in P. Same split: premise body is `P (take v) РЄњ Q (take v) (drop v)`.
opaque symbol NRM9 [n m]
  [P : Tuple n Рєњ Prop]
  [Q : Tuple n Рєњ Tuple m Рєњ Prop]
  [S : Prop]
  : ¤ђ ((`РЎб v : Tuple (n ++ m),
         P (take [n] [m] v) РЄњ Q (take [n] [m] v) (drop [n] [m] v)) РЄњ S)
  Рєњ ¤ђ ((`РЎб x : Tuple n, P x РЄњ (`!! y : Tuple m, Q x y)) РЄњ S) РЅћ
begin
  assume n m P Q S h hnested;
  refine h (pi_to_РЎб
    (╬╗ v, P (take [n] [m] v) РЄњ Q (take [n] [m] v) (drop [n] [m] v))
    (╬╗ v hp,
       !!_to_pi (╬╗ y, Q (take [n] [m] v) y)
                (РЎб_to_pi (╬╗ x, P x РЄњ (`!! y : Tuple m, Q x y))
                         hnested
                         (take [n] [m] v)
                         hp)
                (drop [n] [m] v)))
end;

// ---- NRM10-15: Implication / negation under `РЎб` and `РЎА` ----

// NRM10: H Ріб РЎАx ┬и ┬г(P РѕД Q) РЄњ R Рєњ H Ріб РЎбx ┬и (P РѕД Q РЄњ РіЦ) РЄњ R
opaque symbol NRM10 [n] [Ps : Tuple n Рєњ ­ЮЋЃ* o] [Q : Tuple n Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА v, ┬г РІђ (Ps v Рѕи Q v)) РЄњ R)
  Рєњ ¤ђ ((`РЎб v, РІђ (Ps v Рѕи Q v) РЄњ РіЦ) РЄњ R) РЅћ
begin
  assume n Ps Q R h1 h2;
  refine h1 (pi_to_РЎА (╬╗ v, ┬г РІђ (Ps v Рѕи Q v))
    (╬╗ v hpq, РЎб_to_pi (╬╗ v', РІђ (Ps v' Рѕи Q v') РЄњ РіЦ) h2 v hpq))
end;

// NRM11: H Ріб РЎАx ┬и ┬г(Ріц РѕД P) РЄњ R Рєњ H Ріб РЎбx ┬и (P РЄњ РіЦ) РЄњ R
opaque symbol NRM11 [n] [P : Tuple n Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА v, ┬г (РІђ_snoc Ріц (P v))) РЄњ R)
  Рєњ ¤ђ ((`РЎб v, P v РЄњ РіЦ) РЄњ R) РЅћ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_РЎА (╬╗ v, ┬г РІђ (Рѕј Рѕи Ріц Рѕи P v))
    (╬╗ v htpv, РЎб_to_pi (╬╗ v', P v' РЄњ РіЦ) h2 v (РІђРѓѓ_snd htpv)))
end;

// NRM12: H Ріб РЎАx ┬и ┬г(P РѕД Q) РЄњ R Рєњ H Ріб РЎбx ┬и (P РЄњ ┬гQ) РЄњ R
opaque symbol NRM12 [n] [P Q : Tuple n Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА v, ┬г РІђ_snoc (P v) (Q v)) РЄњ R)
  Рєњ ¤ђ ((`РЎб v, P v РЄњ ┬г (Q v)) РЄњ R) РЅћ
begin
  assume n P Q R h1 h2;
  refine h1 (pi_to_РЎА (╬╗ v, ┬г РІђ (Рѕј Рѕи P v Рѕи Q v))
    (╬╗ v hpq, РЎб_to_pi (╬╗ v', P v' РЄњ ┬г (Q v')) h2 v
                (РІђРѓѓ_hd hpq) (РІђРѓѓ_snd hpq)))
end;

// NRM13: H Ріб РЎАx ┬и ┬г(P РѕД ┬гQ) РЄњ R Рєњ H Ріб РЎбx ┬и (P РЄњ Q) РЄњ R
opaque symbol NRM13 [n] [P Q : Tuple n Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА v, ┬г РІђ_snoc (P v) (┬г Q v)) РЄњ R)
  Рєњ ¤ђ ((`РЎб v, P v РЄњ Q v) РЄњ R) РЅћ
begin
  assume n P Q R h1 h2;
  refine h1 (pi_to_РЎА (╬╗ v, ┬г РІђ (Рѕј Рѕи P v Рѕи ┬г (Q v)))
    (╬╗ v hc, (РІђРѓѓ_snd hc) (РЎб_to_pi (╬╗ v', P v' РЄњ Q v') h2 v (РІђРѓѓ_hd hc))))
end;

// NRM14: H Ріб РЎАx ┬и ┬г(Ріц РѕД P) РЄњ R Рєњ H Ріб (РЎбx ┬и ┬гP) РЄњ R
opaque symbol NRM14 [n] [P : Tuple n Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА v, ┬г РІђ_snoc Ріц (P v)) РЄњ R)
  Рєњ ¤ђ ((`РЎб v, ┬г (P v)) РЄњ R) РЅћ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_РЎА (╬╗ v, ┬г РІђ (Рѕј Рѕи Ріц Рѕи P v))
    (╬╗ v htpv, РЎб_to_pi (╬╗ v', ┬г (P v')) h2 v (РІђРѓѓ_snd htpv)))
end;

// NRM15: H Ріб РЎАx ┬и ┬г(Ріц РѕД ┬гP) РЄњ R Рєњ H Ріб (РЎбx ┬и P) РЄњ R
opaque symbol NRM15 [n] [P : Tuple n Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА v, ┬г РІђ_snoc Ріц (┬г P v)) РЄњ R)
  Рєњ ¤ђ ((`РЎб v, P v) РЄњ R) РЅћ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_РЎА (╬╗ v, ┬г РІђ (Рѕј Рѕи Ріц Рѕи ┬г (P v)))
    (╬╗ v htnpv, (РІђРѓѓ_snd htnpv) (РЎб_to_pi P h2 v)))
end;

// ---- NRM16-19: Universal-instantiation patterns ----

// NRM16: Рѕђx.P in H; Q Рєњ H Ріб (РЎАx ┬и P) РЄњ Q
opaque symbol NRM16 [n] [P : Tuple n Рєњ Prop] [Q : Prop]
  : ¤ђ (`!! v, P v)
  Рєњ ¤ђ Q
  Рєњ ¤ђ ((`РЎА v, P v) РЄњ Q) РЅћ
begin
  assume n P Q hp hq ht; refine hq
end;

// NRM17: NRM16 with extra spec-level equality side-conditions.
// At the LP level the proof obligation collapses to NRM16's shape.
opaque symbol NRM17 [n] [P : Tuple n Рєњ Prop] [Q : Prop]
  : ¤ђ (`!! v, P v)
  Рєњ ¤ђ Q
  Рєњ ¤ђ ((`РЎА v, P v) РЄњ Q) РЅћ
begin
  assume n P Q hp hq ht; refine hq
end;

// NRM18: Рѕђx ┬и ┬г(Ріц РѕД ┬гP) in H; РѕЃE. [x:=E]P = R Рєњ H Ріб РЎАy ┬и ┬г(Ріц РѕД R) РЄњ Q
opaque symbol NRM18 [n] [P : Tuple n Рєњ Prop] [R Q : Prop] (v : Tuple n)
  : ¤ђ (`!! u, ┬г РІђ_snoc Ріц (┬г P u))
  Рєњ ¤ђ (P v = R)
  Рєњ ¤ђ ((`РЎА _ : Tuple n, ┬г РІђ_snoc Ріц R) РЄњ Q) РЅћ
begin
  assume n P R Q v hp heq h;
  // Derive ¤ђ (P v) classically.
  have hpv : ¤ђ (P v)
    { refine ┬г┬гРѓЉ (P v) _;
      assume hnpv;
      refine !!_to_pi (╬╗ u, ┬г РІђ (Рѕј Рѕи Ріц Рѕи ┬г (P u))) hp v (РІђРѓѓ_intro Ріцрхб hnpv) };
  // Transport along heq.
  have hr : ¤ђ R { rewrite left heq; refine hpv };
  refine РіЦРѓЉ (РЎА_to_pi (╬╗ _ : Tuple n, ┬г РІђ (Рѕј Рѕи Ріц Рѕи R)) h (inh_tuple [n])
              (РІђРѓѓ_intro Ріцрхб hr))
end;

// NRM19: P in H; РѕЃE. [x:=E]R = P Рєњ H Ріб РЎАx ┬и ┬г(Ріц РѕД R) РЄњ Q
opaque symbol NRM19 [n] [Q : Prop] [R : Tuple n Рєњ Prop] (v : Tuple n)
  : ¤ђ (R v)
  Рєњ ¤ђ ((`РЎА u, ┬г РІђ_snoc Ріц (R u)) РЄњ Q) РЅћ
begin
  assume n Q R v hr hf;
  refine РіЦРѓЉ (РЎА_to_pi (╬╗ u, ┬г РІђ (Рѕј Рѕи Ріц Рѕи R u)) hf v (РІђРѓѓ_intro Ріцрхб hr))
end;

// ---- NRM20-23: Substitution ----

// NRM20: x not free in E; H Ріб РЎАy ┬и ┬г[x:=E]P РЄњ Q
//        Рєњ H Ріб РЎА(x,y) ┬и ┬г(x = E РѕД P) РЄњ Q
//
//   Рѕђ (x2,..,xn), ┬г (P2(E,..,xn) РѕД .. РѕД Pn(E,...,xn))
//   ----------------------------------------------------------
//   Рѕђ (x1,..,xn), ┬г ((x1 = E) РѕД P2(x1..xn) РѕД .. РѕД Pn(x1...xn))
//
// `ps v` is the *full* conjunct list.  Its head `popl (ps v)` is the leading
// equality `x1 = E` (РЅА `prj 0 v = E`, pinned by the first premise); its tail
// `dropl (ps v)` is the body `P2 РѕД .. РѕД Pn`.  Instantiating the goal's
// universal at `v' РеЙ E` performs the substitution x1 := E: the head becomes
// `E = E` (true by `eq_refl`) and the tail matches the hypothesis's body, so
// `РІђ_pop_intro` rebuilds `РІђ (ps (v' РеЙ E))` to discharge the negation.
opaque symbol NRM20 [n] [ps : Tuple (+1 n) Рєњ ­ЮЋЃ* o] [Q : Prop] (E : ¤ё ╬╣)
  : (╬а v', ¤ђ (popl (ps v') = (prj 0 v' = E)))
  Рєњ ¤ђ ((`РЎА v' : Tuple n, ┬г РІђ dropl (ps (v' РеЙ E))) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple (+1 n), ┬г РІђ (ps v)) РЄњ Q) РЅћ
begin
  assume n ps Q E heq hsmall hbig;
  refine hsmall (pi_to_РЎА (╬╗ v' : Tuple n, ┬г РІђ dropl (ps (v' РеЙ E)))
    (╬╗ v' hp,
      РЎА_to_pi (╬╗ v, ┬г РІђ (ps v)) hbig (v' РеЙ E)
        (РІђ_pop_intro (ps (v' РеЙ E))
          (=РЄњ (eq_sym (heq (v' РеЙ E))) (eq_refl E))
          hp)))
end;

// NRM21 / NRM23 Рђћ reversed-equality (`E = x`) duals of NRM20 / NRM22.
//
// UNVERIFIED: no replay in the corpus exercises these, so their signatures
// below are spec-derived and have NOT been checked against PP's actual output.
// NRM20 and NRM22 both needed rewriting once a real replay showed the spec was
// wrong (NRM20's head-equality `ps` list; NRM22's literal-Ріц head) Рђћ expect the
// same here.  Before relying on NRM21/23, obtain a triggering trace and re-derive
// the shape from it; the emitter still emits a bare `refine NRM2{1,3} _` (no E),
// which will fail loudly rather than silently mis-prove.
opaque symbol NRM21 [n] [ps : Tuple (+1 n) Рєњ ­ЮЋЃ* o] [Q : Prop] (E : ¤ё ╬╣)
  (heq : ╬а v', ¤ђ (popl (ps v') = (E = prj 0 v')))
  : ¤ђ ((`РЎА v' : Tuple n, ┬г РІђ dropl (ps (v' РеЙ E))) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple (+1 n), ┬г РІђ (ps v)) РЄњ Q) РЅћ
begin
  assume n ps Q E heq hsmall hbig;
  refine hsmall (pi_to_РЎА (╬╗ v' : Tuple n, ┬г РІђ dropl (ps (v' РеЙ E)))
    (╬╗ v' hp,
      РЎА_to_pi (╬╗ v, ┬г РІђ (ps v)) hbig (v' РеЙ E)
        (РІђ_pop_intro (ps (v' РеЙ E))
          (=РЄњ (eq_sym (heq (v' РеЙ E))) (eq_refl E))
          hp)))
end;

// ---- Tail-equality substitution forms (NRM20/21 over an end-of-list pin) ----
//
// PP's NRM20/21 pin *whichever* binder an equality conjunct determines, and
// the equality may sit at the END of the conjunct list (NRM14 prepends Ріц, so
// a 2-conjunct body reads `Ріц РѕД (x = E)`).  The head-equality forms above
// (popl/dropl) cover the head position; these cover the tail position, with
// the witness E a *function of the remaining tuple* Рђћ PP may pin x at another
// still-bound variable (`#x.#y.(x = y)` pins x at y = prj 0 of what remains).
//
// Slot discipline (position i in PP's binder list Рєд prj i): the S forms pin
// slot 0 (PP's first listed binder, the rightmost РеЙ-slot), the P forms pin
// slot 1 (the second).  The emitter picks by the pinned var's position, read
// off the rule annotation against its child's binder list.

// NRM20S: pin slot 0 by a tail equality `prj 0 v = E (init v)`.
opaque symbol NRM20S [n] [qs : Tuple (+1 n) Рєњ ­ЮЋЃ* o] [Q : Prop]
  (E : Tuple n Рєњ ¤ё ╬╣)
  : ¤ђ ((`РЎА v' : Tuple n, ┬г РІђ (qs (v' РеЙ E v'))) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple (+1 n), ┬г РІђ (qs v Рѕи (prj 0 v = E (init v)))) РЄњ Q) РЅћ
begin
  assume n qs Q E hsmall hbig;
  refine hsmall (pi_to_РЎА (╬╗ v' : Tuple n, ┬г РІђ (qs (v' РеЙ E v')))
    (╬╗ v' hq,
      РЎА_to_pi (╬╗ v, ┬г РІђ (qs v Рѕи (prj 0 v = E (init v)))) hbig (v' РеЙ E v')
        (РІђ_intro hq (eq_refl (E v')))))
end;

// NRM21S: NRM20S with reversed equality (`E Рђд = prj 0 v`).
opaque symbol NRM21S [n] [qs : Tuple (+1 n) Рєњ ­ЮЋЃ* o] [Q : Prop]
  (E : Tuple n Рєњ ¤ё ╬╣)
  : ¤ђ ((`РЎА v' : Tuple n, ┬г РІђ (qs (v' РеЙ E v'))) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple (+1 n), ┬г РІђ (qs v Рѕи (E (init v) = prj 0 v))) РЄњ Q) РЅћ
begin
  assume n qs Q E hsmall hbig;
  refine hsmall (pi_to_РЎА (╬╗ v' : Tuple n, ┬г РІђ (qs (v' РеЙ E v')))
    (╬╗ v' hq,
      РЎА_to_pi (╬╗ v, ┬г РІђ (qs v Рѕи (E (init v) = prj 0 v))) hbig (v' РеЙ E v')
        (РІђ_intro hq (eq_refl (E v')))))
end;

// NRM20P: pin slot 1 by a tail equality `prj 1 v = E (rm1 v)`.
opaque symbol NRM20P [n] [qs : Tuple (+1 (+1 n)) Рєњ ­ЮЋЃ* o] [Q : Prop]
  (E : Tuple (+1 n) Рєњ ¤ё ╬╣)
  : ¤ђ ((`РЎА v' : Tuple (+1 n), ┬г РІђ (qs (tuple_insert1 (E v') v'))) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple (+1 (+1 n)), ┬г РІђ (qs v Рѕи (prj 1 v = E (rm1 v)))) РЄњ Q) РЅћ
begin
  assume n qs Q E hsmall hbig;
  refine hsmall
    (pi_to_РЎА (╬╗ v' : Tuple (+1 n), ┬г РІђ (qs (tuple_insert1 (E v') v')))
      (╬╗ v' hq,
        РЎА_to_pi (╬╗ v, ┬г РІђ (qs v Рѕи (prj 1 v = E (rm1 v)))) hbig
          (tuple_insert1 (E v') v')
          (РІђ_intro hq (eq_refl (E v')))))
end;

// NRM21P: NRM20P with reversed equality.
opaque symbol NRM21P [n] [qs : Tuple (+1 (+1 n)) Рєњ ­ЮЋЃ* o] [Q : Prop]
  (E : Tuple (+1 n) Рєњ ¤ё ╬╣)
  : ¤ђ ((`РЎА v' : Tuple (+1 n), ┬г РІђ (qs (tuple_insert1 (E v') v'))) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple (+1 (+1 n)), ┬г РІђ (qs v Рѕи (E (rm1 v) = prj 1 v))) РЄњ Q) РЅћ
begin
  assume n qs Q E hsmall hbig;
  refine hsmall
    (pi_to_РЎА (╬╗ v' : Tuple (+1 n), ┬г РІђ (qs (tuple_insert1 (E v') v')))
      (╬╗ v' hq,
        РЎА_to_pi (╬╗ v, ┬г РІђ (qs v Рѕи (E (rm1 v) = prj 1 v))) hbig
          (tuple_insert1 (E v') v')
          (РІђ_intro hq (eq_refl (E v')))))
end;

// NRM20P2 / NRM21P2: pin slot 2 (tuple_insert2 / rm2).
opaque symbol NRM20P2 [n] [qs : Tuple (+1 (+1 (+1 n))) Рєњ ­ЮЋЃ* o] [Q : Prop]
  (E : Tuple (+1 (+1 n)) Рєњ ¤ё ╬╣)
  : ¤ђ ((`РЎА v' : Tuple (+1 (+1 n)), ┬г РІђ (qs (tuple_insert2 (E v') v'))) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple (+1 (+1 (+1 n))), ┬г РІђ (qs v Рѕи (prj 2 v = E (rm2 v)))) РЄњ Q) РЅћ
begin
  assume n qs Q E hsmall hbig;
  refine hsmall
    (pi_to_РЎА (╬╗ v' : Tuple (+1 (+1 n)), ┬г РІђ (qs (tuple_insert2 (E v') v')))
      (╬╗ v' hq,
        РЎА_to_pi (╬╗ v, ┬г РІђ (qs v Рѕи (prj 2 v = E (rm2 v)))) hbig
          (tuple_insert2 (E v') v')
          (РІђ_intro hq (eq_refl (E v')))))
end;

opaque symbol NRM21P2 [n] [qs : Tuple (+1 (+1 (+1 n))) Рєњ ­ЮЋЃ* o] [Q : Prop]
  (E : Tuple (+1 (+1 n)) Рєњ ¤ё ╬╣)
  : ¤ђ ((`РЎА v' : Tuple (+1 (+1 n)), ┬г РІђ (qs (tuple_insert2 (E v') v'))) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple (+1 (+1 (+1 n))), ┬г РІђ (qs v Рѕи (E (rm2 v) = prj 2 v))) РЄњ Q) РЅћ
begin
  assume n qs Q E hsmall hbig;
  refine hsmall
    (pi_to_РЎА (╬╗ v' : Tuple (+1 (+1 n)), ┬г РІђ (qs (tuple_insert2 (E v') v')))
      (╬╗ v' hq,
        РЎА_to_pi (╬╗ v, ┬г РІђ (qs v Рѕи (E (rm2 v) = prj 2 v))) hbig
          (tuple_insert2 (E v') v')
          (РІђ_intro hq (eq_refl (E v')))))
end;

// NRM22: the РЎА-body's tail equality pins the binder at E (general list
// form; the Ріц-headed NRM14-fed shape is the instance ps := ╬╗ _, (Рѕј Рѕи Ріц)).
opaque symbol NRM22 [Q : Prop] [ps : Tuple 1 Рєњ ­ЮЋЃ* o] (E : ¤ё ╬╣)
  : ¤ђ (┬г РІђ (ps (unit РеЙ E)) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple 1, ┬г РІђ (ps v Рѕи (prj 0 v = E))) РЄњ Q) РЅћ
begin
  assume Q ps E h1 h2;
  refine h1 (╬╗ hps,
    РЎА_to_pi (╬╗ v : Tuple 1, ┬г РІђ (ps v Рѕи (prj 0 v = E)))
            h2 (unit РеЙ E)
            (РІђ_intro hps (eq_refl E)))
end;

// NRM23: NRM22 with reversed equality (Ріц-headed special case; kept for the
// chain-form nrm23_eq bridge).
opaque symbol NRM23 [Q : Prop] (E : ¤ё ╬╣)
  : ¤ђ (┬г Ріц РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple 1,
         ┬г РІђ (Рѕј Рѕи Ріц Рѕи (E = prj 0 v))) РЄњ Q) РЅћ
begin
  assume Q E h1 h2;
  refine h1 (╬╗ ht,
    РЎА_to_pi (╬╗ v : Tuple 1, ┬г РІђ (Рѕј Рѕи Ріц Рѕи (E = prj 0 v)))
            h2 (unit РеЙ E)
            (РІђРѓѓ_intro ht (eq_refl E)))
end;

// NRM23G: the general-list reversed form (NRM22's exact mirror) Рђћ the
// main-tree emitter uses this one uniformly.
opaque symbol NRM23G [Q : Prop] [ps : Tuple 1 Рєњ ­ЮЋЃ* o] (E : ¤ё ╬╣)
  : ¤ђ (┬г РІђ (ps (unit РеЙ E)) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple 1, ┬г РІђ (ps v Рѕи (E = prj 0 v))) РЄњ Q) РЅћ
begin
  assume Q ps E h1 h2;
  refine h1 (╬╗ hps,
    РЎА_to_pi (╬╗ v : Tuple 1, ┬г РІђ (ps v Рѕи (E = prj 0 v)))
            h2 (unit РеЙ E)
            (РІђ_intro hps (eq_refl E)))
end;

// ---- NRM24-26: Trivial structural rules ----

// NRM24: P not of form A РѕД B; H Ріб РЎАx ┬и ┬г(Ріц РѕД P) РЄњ Q Рєњ H Ріб РЎАx ┬и ┬гP РЄњ Q
opaque symbol NRM24 [n] [P : Tuple n Рєњ Prop] [Q : Prop]
  : ¤ђ ((`РЎА v, ┬г РІђ (Рѕј Рѕи Ріц Рѕи P v)) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v, ┬г (P v)) РЄњ Q) РЅћ
begin
  assume n P Q h1 h2;
  refine h1 (pi_to_РЎА (╬╗ v, ┬г РІђ (Рѕј Рѕи Ріц Рѕи P v))
    (╬╗ v htpv, РЎА_to_pi (╬╗ v', ┬г (P v')) h2 v (РІђРѓѓ_snd htpv)))
end;

// NRM25: x not free in P; H Ріб P Рєњ H Ріб РЎА(x) ┬и P
//   = forall2(x).P in PP notation. `pi_to_РЎА` with constant predicate
//   (the body doesn't depend on the bound tuple).
opaque symbol NRM25 [n] [P : Prop] [Q : Prop]
  : ¤ђ (P РЄњ Q)
  Рєњ ¤ђ ((`РЎА _ : Tuple n, P) РЄњ Q) РЅћ
begin
  assume n P Q hp hРЎА;
  refine hp (РЎА_to_pi (╬╗ _, P) hРЎА (inh_tuple [n]))
end;

// NRM26: y not free in P; H Ріб РЎА(x,...) ┬и P Рєњ H Ріб РЎА(x,y,...) ┬и P
// (`tuple_prepend` and the rest of the slot surgery live in Quant.lp.)
opaque symbol NRM26 [n] [P : Tuple (+1 n) Рєњ Prop] [Q : Prop]
  : ¤ђ ((`РЎА v' : Tuple n, P (tuple_prepend ­ЮЪј v')) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple (+1 n), P v) РЄњ Q) РЅћ
begin
  assume n P Q hp hРЎА;
  refine hp (pi_to_РЎА (╬╗ v', P (tuple_prepend ­ЮЪј v'))
    (╬╗ v', РЎА_to_pi (╬╗ v, P v) hРЎА (tuple_prepend ­ЮЪј v')))
end;

// PP's NRM26 drops the unused binder *wherever it sits* in the binder list,
// not only last-listed.  `tuple_prepend` above dummy-fills the leftmost slot
// (= the last-listed binder); the variants below fill slot 0 (NRM26S Рђћ PP's
// first listed binder) and slot 1 (NRM26M).  With the wrong variant the
// remaining binders' projections shift onto the dummy slot, so the emitter
// picks by the dropped var's position (annotation diff against the child).
opaque symbol NRM26S [n] [P : Tuple (+1 n) Рєњ Prop] [Q : Prop]
  : ¤ђ ((`РЎА v' : Tuple n, P (v' РеЙ ­ЮЪј)) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple (+1 n), P v) РЄњ Q) РЅћ
begin
  assume n P Q hp hРЎА;
  refine hp (pi_to_РЎА (╬╗ v', P (v' РеЙ ­ЮЪј))
    (╬╗ v', РЎА_to_pi (╬╗ v, P v) hРЎА (v' РеЙ ­ЮЪј)))
end;

opaque symbol NRM26M [n] [P : Tuple (+1 (+1 n)) Рєњ Prop] [Q : Prop]
  : ¤ђ ((`РЎА v' : Tuple (+1 n), P (tuple_insert1 ­ЮЪј v')) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple (+1 (+1 n)), P v) РЄњ Q) РЅћ
begin
  assume n P Q hp hРЎА;
  refine hp (pi_to_РЎА (╬╗ v', P (tuple_insert1 ­ЮЪј v'))
    (╬╗ v', РЎА_to_pi (╬╗ v, P v) hРЎА (tuple_insert1 ­ЮЪј v')))
end;

opaque symbol NRM26M2 [n] [P : Tuple (+1 (+1 (+1 n))) Рєњ Prop] [Q : Prop]
  : ¤ђ ((`РЎА v' : Tuple (+1 (+1 n)), P (tuple_insert2 ­ЮЪј v')) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple (+1 (+1 (+1 n))), P v) РЄњ Q) РЅћ
begin
  assume n P Q hp hРЎА;
  refine hp (pi_to_РЎА (╬╗ v', P (tuple_insert2 ­ЮЪј v'))
    (╬╗ v', РЎА_to_pi (╬╗ v, P v) hРЎА (tuple_insert2 ­ЮЪј v')))
end;

// ---- NRM27-30: Arithmetic solver dispatch (trust-free) ----
//
// PP's solver closes a universal hypothesis `РЎА(xРѓЂ,Рђд,xРѓЎ)┬и┬г(P РѕД Рђд РѕД Q)`
// when the conjunction holds two bounding inequalities `a + xрхб РЅц ­ЮЪј` and
// `b Рѕњ xрхб РЅц ­ЮЪј` with `solveur(a + b) = ­ЮЪј`: those force `xрхб = b`, and the
// substituted conjunction `[xрхб := b](P РѕД Рђд РѕД Q)` is satisfiable, so the
// universal-of-negation is *false* and discharges the sequent.
//
// Trust-free realisation: peel the pinned binder by *instantiating* the
// `РЎА`-hypothesis at the solver witness `b` (the membership premises the
// spec carries are solver bookkeeping Рђћ unused here).  This leaves the
// continuation premise `РЎбv'┬и┬гРІђ(ps (v' РеЙ b v')) РЄњ R`; the emitter bridges
// the literal substituted conjunction `РІђ (ps (v' РеЙ b v'))` to Ріц with a
// generated congruence proof (each cancelling bound = Ріц via `eq_true` +
// `leq_zero_of_sum_zero` + `prove_sum_eq`), matching PP's Ріц-normalisation.
//
//   NRM27 / NRM29 Рђћ multi-binder (РЎА-block) forms, drop one binder.
//   NRM28 / NRM30 Рђћ unary (РЎАx) forms, drop the binder entirely.
//   27/28 are the `xрхб = ­ЮЪј` specialisation (a = b = ­ЮЪј) of 29/30.

// ---- helper lemmas for the trust-free solver dispatch ----

// `P` provably true РЪ╣ `P = Ріц`, so a РІђ-conjunct the solver discharges can
// be rewritten to Ріц and absorbed by `РІђ (_ Рѕи Ріц) Рєф РІђ _`.
opaque symbol eq_true (P : Prop) : ¤ђ P Рєњ ¤ђ (P = Ріц) РЅћ
begin
  assume P h;
  refine propExt _ _ _ _
  { assume hp; refine Ріцрхб }
  { assume ht; refine h }
end;

// A sum that arithmetic-normalises to ­ЮЪј is РЅц ­ЮЪј.  The emitter builds the
// `E = ­ЮЪј` proof with `prove_sum_eq` (add_comm/assoc/opp cancellation).
opaque symbol leq_zero_of_sum_zero (E : ¤ё ╬╣) : ¤ђ (E = ­ЮЪј) Рєњ ¤ђ (E РЅц ­ЮЪј) РЅћ
begin
  assume E h;
  rewrite h;
  refine leq_refl ­ЮЪј
end;

// `mem P ps` : `P` occurs (up to propositional equality) in the conjunct
// list `ps`.  The solver's "(x РЅц ­ЮЪј) est dans (P РѕД Рђд РѕД Q)" side-conditions.
symbol mem : Prop Рєњ ­ЮЋЃ* o Рєњ Prop;
rule mem _  Рѕј          Рєф РіЦ
with mem $P ($ps Рѕи $Q) Рєф (mem $P $ps) Рѕе ($P = $Q);

// If `P Рѕѕ ps` and `РІђ ps` holds, then `P` holds Рђћ the membership premises
// are sound, so NRM27 needs no `trust` to use them.
opaque symbol mem_sound (P : Prop)
  : ╬а ps : ­ЮЋЃ* o, ¤ђ (mem P ps) Рєњ ¤ђ (РІђ ps) Рєњ ¤ђ P РЅћ
begin
  assume P;
  induction
  { assume hmem hconj; refine РіЦРѓЉ hmem }
  { assume ps ih Q hmem hconj;
    refine РѕеРѓЉ hmem _ _
    { assume hin; refine ih hin (РІђ_init hconj) }
    { assume heq; refine =РЄњ (eq_sym heq) (РІђ_last hconj) } }
end;

// NRM27: bare goal (no `РЄњR`), the `xрхб = ­ЮЪј` case.  The bounds `prj 0 v РЅц ­ЮЪј`
// and `Рђћ prj 0 v РЅц ­ЮЪј` (members of the conjunction) pin `prj 0 v = ­ЮЪј` by
// antisymmetry; tuple-╬и (`(init v) РеЙ ­ЮЪј = v`, via Quant.lp) then transports
// `РІђ (ps v)` to `РІђ (ps ((init v) РеЙ ­ЮЪј))`, contradicting the premise.  Fully
// trust-free; untriggered in the corpus (the only NRM2x trace is NRM29).
opaque symbol NRM27 [n] [ps : Tuple (+1 n) Рєњ ­ЮЋЃ* o]
  (hint : ╬а v, ¤ђ (prj 0 v ¤х INT))
  (hpos : ╬а v, ¤ђ (mem (prj 0 v РЅц ­ЮЪј) (ps v)))
  (hneg : ╬а v, ¤ђ (mem (Рђћ prj 0 v РЅц ­ЮЪј) (ps v)))
  : ¤ђ (`РЎб v' : Tuple n, ┬г РІђ (ps (v' РеЙ ­ЮЪј)))
  Рєњ ¤ђ (`РЎА v : Tuple (+1 n), ┬г РІђ (ps v)) РЅћ
begin
  assume n ps hint hpos hneg h_prem;
  refine pi_to_РЎА (╬╗ v, ┬г РІђ (ps v)) (╬╗ v hpv, _);
  have hle : ¤ђ (prj 0 v РЅц ­ЮЪј)
    { refine mem_sound _ (ps v) (hpos v) hpv };
  have hge : ¤ђ (­ЮЪј РЅц prj 0 v)
    { refine neg_leq_zero (prj 0 v) (mem_sound _ (ps v) (hneg v) hpv) };
  have hz : ¤ђ (prj 0 v = ­ЮЪј)
    { refine leq_antisym (prj 0 v) ­ЮЪј (hint v) zero_in_int hle hge };
  have heq : ¤ђ (((init v) РеЙ ­ЮЪј) = v)
    { rewrite left hz; refine tuple_eta v };
  have hcontra : ¤ђ (┬г РІђ (ps ((init v) РеЙ ­ЮЪј)))
    { refine РЎб_to_pi (╬╗ v' : Tuple n, ┬г РІђ (ps (v' РеЙ ­ЮЪј))) h_prem (init v) };
  have hgood : ¤ђ (РІђ (ps ((init v) РеЙ ­ЮЪј)))
    { rewrite heq; refine hpv };
  refine hcontra hgood
end;

// NRM30: unary РЎАx, general witness b.  Instantiate at b, feed the premise.
opaque symbol NRM30 [ps : ¤ё ╬╣ Рєњ ­ЮЋЃ* o] [R : Prop] (b : ¤ё ╬╣)
  : ¤ђ (┬г РІђ (ps b) РЄњ R)
  Рєњ ¤ђ ((`РЎА v : Tuple 1, ┬г РІђ (ps (prj 0 v))) РЄњ R) РЅћ
begin
  assume ps R b h_prem hРЎА;
  refine h_prem (РЎА_to_pi (╬╗ v : Tuple 1, ┬г РІђ (ps (prj 0 v))) hРЎА (unit РеЙ b))
end;

// NRM28: x := ­ЮЪј specialisation of NRM30.
opaque symbol NRM28 [ps : ¤ё ╬╣ Рєњ ­ЮЋЃ* o] [R : Prop]
  : ¤ђ (┬г РІђ (ps ­ЮЪј) РЄњ R)
  Рєњ ¤ђ ((`РЎА v : Tuple 1, ┬г РІђ (ps (prj 0 v))) РЄњ R) РЅћ
begin
  assume ps R h_prem hРЎА;
  refine h_prem (РЎА_to_pi (╬╗ v : Tuple 1, ┬г РІђ (ps (prj 0 v))) hРЎА (unit РеЙ ­ЮЪј))
end;

// NRM29: multi-binder, pin the prj0 slot to `b v'` (witness a function of
// the remaining binders Рђћ e.g. b v' = Рђћ prj 0 v' for the sum-zero /
// cancelling case).  The emitter supplies `b` and the Ріц-normalisation
// bridge for the substituted conjunction `РІђ (ps (v' РеЙ b v'))`.
opaque symbol NRM29 [n] [ps : Tuple (+1 n) Рєњ ­ЮЋЃ* o] [R : Prop] (b : Tuple n Рєњ ¤ё ╬╣)
  : ¤ђ ((`РЎб v' : Tuple n, ┬г РІђ (ps (v' РеЙ b v'))) РЄњ R)
  Рєњ ¤ђ ((`РЎА v : Tuple (+1 n), ┬г РІђ (ps v)) РЄњ R) РЅћ
begin
  assume n ps R b h_prem hРЎА;
  refine h_prem (pi_to_РЎб (╬╗ v', ┬г РІђ (ps (v' РеЙ b v')))
    (╬╗ v', РЎА_to_pi (╬╗ v, ┬г РІђ (ps v)) hРЎА (v' РеЙ b v')))
end;

// ---- `_1` (Result-form) variants Рђћ ┬Д8.13 ----
//
// PP leaves NRM rules *unprimed* in the first-normalisation chain (unlike
// ALL7/ALL9/STOP/IMP), so the emitter primes a chain-context `NRM<k>` to
// `NRM<k>_1` (`Emit_ctx.chain_emit_name`).  Each chain form lifts the base
// rule's premiseРєњconclusion implication to a `Res`-to-`Res` map through a
// bridge equality `nrm<k>_eq : conclusion = premise`; the body is the uniform
// `mk_1 (res_tm r) (eq_trans (@nrm<k>_eq Рђд) (res_eq r))`.  Every NRM rule that
// can appear in a Res chain needs one (see CLAUDE.md: emitting an undefined
// `NRM<k>_1` shows up as a lambdapi "Unknown symbol", not a fail-loud emit).

symbol NRM1_1 [n] [P Q : Prop]
  (r : Res (P РЄњ Q)) : Res ((`РЎб _ : Tuple n, P) РЄњ Q)
  РЅћ mk_1 (res_tm r) (eq_trans (@nrm1_eq n P Q) (res_eq r));

// NRM2 bridge (evidence form).  PP's chain NRM2 weakens the РЎб-body by a v-free
// hypothesis P (`(РЎбv┬иQ v) РЄњ S  Рєд  (РЎбv┬и(PРЄњQ v)) РЄњ S`), sound only given a proof
// of P: under `hp : ¤ђ P` the body equivalence `(PРЄњQ v) РЪ║ Q v` holds, lifted
// under the РЎб by `!!_cong`.  Unlike the unconditional nrmK_eq bridges this
// takes `hp`, so the emitter must supply it (translate.ml NRM2 chain dispatch).
opaque symbol nrm2_eq [n] [P : Prop] [Q : Tuple n Рєњ Prop] [S : Prop] (hp : ¤ђ P)
  : ¤ђ (((`РЎб v, P РЄњ Q v) РЄњ S) = ((`РЎб v, Q v) РЄњ S)) РЅћ
begin
  assume n P Q S hp;
  have hbody : ╬а v, ¤ђ ((P РЄњ Q v) = (Q v))
    { assume v; refine propExt _ _ (╬╗ hpq, hpq hp) (╬╗ hq _, hq) };
  have hpred : ¤ђ ((`РЎб v, P РЄњ Q v) = (`РЎб v, Q v))
    { refine eq_trans (РЎб_eq_!! (╬╗ v, P РЄњ Q v))
        (eq_trans (!!_cong hbody) (eq_sym (РЎб_eq_!! (╬╗ v, Q v)))) };
  rewrite hpred; reflexivity
end;

// NRM2_1 Рђћ chain (Res) form of NRM2, via the evidence-form `nrm2_eq` above.
symbol NRM2_1 [n] [P : Prop] [Q : Tuple n Рєњ Prop] [S : Prop] (hp : ¤ђ P)
  (r : Res ((`РЎб v, Q v) РЄњ S)) : Res ((`РЎб v, P РЄњ Q v) РЄњ S)
  РЅћ mk_1 (res_tm r) (eq_trans (@nrm2_eq n P Q S hp) (res_eq r));

// NRM14_1 Рђћ chain (Res) form of NRM14.  PP leaves NRM rules *unprimed* in the
// first-normalisation chain (unlike ALL7/ALL9/STOP/IMP), so the emitter maps a
// chain-context `NRM14` to this; `nrm14_eq` (Res.lp) is the bridge equality.
symbol NRM14_1 [n] [P : Tuple n Рєњ Prop] [R : Prop]
  (r : Res ((`РЎА v, ┬г РІђ_snoc Ріц (P v)) РЄњ R)) : Res ((`РЎб v, ┬г (P v)) РЄњ R)
  РЅћ mk_1 (res_tm r) (eq_trans (@nrm14_eq n P R) (res_eq r));

// NRM13_1 Рђћ chain (Res) form of NRM13, via the `nrm13_eq` bridge (Res.lp).
symbol NRM13_1 [n] [P Q : Tuple n Рєњ Prop] [R : Prop]
  (r : Res ((`РЎА v, ┬г РІђ_snoc (P v) (┬г Q v)) РЄњ R)) : Res ((`РЎб v, P v РЄњ Q v) РЄњ R)
  РЅћ mk_1 (res_tm r) (eq_trans (@nrm13_eq n P Q R) (res_eq r));

// NRM12_1 Рђћ chain (Res) form of NRM12, via the `nrm12_eq` bridge (Res.lp).
symbol NRM12_1 [n] [P Q : Tuple n Рєњ Prop] [R : Prop]
  (r : Res ((`РЎА v, ┬г РІђ_snoc (P v) (Q v)) РЄњ R)) : Res ((`РЎб v, P v РЄњ ┬г (Q v)) РЄњ R)
  РЅћ mk_1 (res_tm r) (eq_trans (@nrm12_eq n P Q R) (res_eq r));

// NRM15_1 Рђћ chain (Res) form of NRM15, via the `nrm15_eq` bridge (Res.lp).
symbol NRM15_1 [n] [P : Tuple n Рєњ Prop] [R : Prop]
  (r : Res ((`РЎА v, ┬г РІђ_snoc Ріц (┬г (P v))) РЄњ R)) : Res ((`РЎб v, P v) РЄњ R)
  РЅћ mk_1 (res_tm r) (eq_trans (@nrm15_eq n P R) (res_eq r));

// NRM3 bridge: ((РЎбv┬и(P v РЄњ Q)) РЄњ S) = ((Q РЄњ S) РѕД ((Рѕђv┬и┬гP v) РЄњ S)), Q is v-free.
// (Lives here, not Res.lp, because the РЄљ direction reuses NRM3 itself; the РЄњ
// direction builds the РЎб witness from Q, or vacuously from ┬гP v.)
opaque symbol nrm3_eq [n] [P : Tuple n Рєњ Prop] [Q S : Prop]
  : ¤ђ (((`РЎб v, P v РЄњ Q) РЄњ S) = РІђ_snoc (Q РЄњ S) ((`!! v, ┬г (P v)) РЄњ S)) РЅћ
begin
  assume n P Q S;
  refine propExt _ _
    (╬╗ hres, РІђРѓѓ_intro
       (╬╗ hq, hres (pi_to_РЎб (╬╗ v, P v РЄњ Q) (╬╗ v hpv, hq)))
       (╬╗ hnp, hres (pi_to_РЎб (╬╗ v, P v РЄњ Q)
                       (╬╗ v hpv, РіЦРѓЉ (!!_to_pi (╬╗ v, ┬г (P v)) hnp v hpv)))))
    (╬╗ hprem, @NRM3 n P Q S hprem)
end;

// NRM3_1 Рђћ chain (Res) form of NRM3, via the `nrm3_eq` bridge above.  The
// premise is the snoc-conjunction the emitter discharges with AND4_1.
symbol NRM3_1 [n] [P : Tuple n Рєњ Prop] [Q S : Prop]
  (r : Res (РІђ_snoc (Q РЄњ S) ((`!! v, ┬г (P v)) РЄњ S))) : Res ((`РЎб v, P v РЄњ Q) РЄњ S)
  РЅћ mk_1 (res_tm r) (eq_trans (@nrm3_eq n P Q S) (res_eq r));

// NRM23_1 Рђћ chain (Res) form of NRM23, via the `nrm23_eq` bridge (Res.lp).  E is
// implicit here (the emitter emits `NRM23_1 _`, inferring E from the Res target).
symbol NRM23_1 [Q : Prop] [E : ¤ё ╬╣]
  (r : Res (┬г Ріц РЄњ Q))
  : Res ((`РЎА v : Tuple 1, ┬г РІђ (Рѕј Рѕи Ріц Рѕи (E = prj 0 v))) РЄњ Q)
  РЅћ mk_1 (res_tm r) (eq_trans (@nrm23_eq Q E) (res_eq r));

// NRM22_1 Рђћ chain (Res) form of NRM22, via the general `nrm22_eq` bridge
// (Res.lp): the body's tail equality pins the binder at E.
symbol NRM22_1 [Q : Prop] [ps : Tuple 1 Рєњ ­ЮЋЃ* o] [E : ¤ё ╬╣]
  (r : Res (┬г РІђ (ps (unit РеЙ E)) РЄњ Q))
  : Res ((`РЎА v : Tuple 1, ┬г РІђ (ps v Рѕи (prj 0 v = E))) РЄњ Q)
  РЅћ mk_1 (res_tm r) (eq_trans (@nrm22_eq Q ps E) (res_eq r));
