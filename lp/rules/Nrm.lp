// Normalisation (┬ДA.12) Рђћ tuple-based encoding.
//
// Spec uses `РЎб` (= goal-side n-ary universal) and `РЎА` (= hypothesis-
// side n-ary universal). Both reduce propositionally to `!!` via the
// `РЎб_eq_!!` / `РЎА_eq_!!` axioms in Quant.lp; bodies use the dedicated
// `pi_to_РЎб` / `РЎб_to_pi` (and РЎА analogues) bridges.

require open pp2lp.B pp2lp.Quant pp2lp.rules.Res;

// ---- NRM1-7: Logical transformations under `РЎб` ----

// NRM1: x not free in P; H Ріб P РЄњ S Рєњ H Ріб (РЎбx ┬и P) РЄњ S
opaque symbol NRM1 [n] [P S : Prop]
  : ¤ђ (P РЄњ S)
  Рєњ ¤ђ ((`РЎб _ : Tuple n, P) РЄњ S) РЅћ
begin
  assume n P S h1 h2;
  refine h1 (РЎб_to_pi (╬╗ _ : Tuple n, P) h2 (inh_tuple [n]))
end;

// NRM2: x not free in P; H Ріб (P РЄњ РЎбx ┬и Q) РЄњ S Рєњ H Ріб РЎбx ┬и (P РЄњ Q) РЄњ S
opaque symbol NRM2 [n] [P : Prop] [Q : Tuple n Рєњ Prop] [S : Prop]
  : ¤ђ ((P РЄњ (`РЎб v, Q v)) РЄњ S)
  Рєњ ¤ђ ((`РЎб v, P РЄњ Q v) РЄњ S) РЅћ
begin
  assume n P Q S h1 h2;
  refine h1 (╬╗ p,
    pi_to_РЎб Q (╬╗ v, РЎб_to_pi (╬╗ v', P РЄњ Q v') h2 v p))
end;

// NRM3: x not free in Q; H Ріб (Q РЄњ S) РѕД ((Рѕђx ┬и ┬гP) РЄњ S) Рєњ H Ріб РЎбx ┬и (P РЄњ Q) РЄњ S
opaque symbol NRM3 [n] [P : Tuple n Рєњ Prop] [Q S : Prop]
  : ¤ђ (РІђ_snoc (Q РЄњ S) ((`!! v, ┬г (P v)) РЄњ S))
  Рєњ ¤ђ ((`РЎб v, P v РЄњ Q) РЄњ S) РЅћ
begin
  assume n P Q S h1 h2;
  refine РѕеРѓЉ (em (`?? v, P v)) _ _
  { assume hex;
    refine pi_to_??_elim P
      (╬╗ v hpv, (РІђРѓѓ_hd h1) (РЎб_to_pi (╬╗ v', P v' РЄњ Q) h2 v hpv)) hex }
  { assume hnex;
    refine (РІђРѓѓ_snd h1) (pi_to_!! (╬╗ v, ┬г (P v))
      (╬╗ v hpv, hnex (pi_to_??_intro P v hpv))) }
end;

// NRM4: x not free in Q; H Ріб (Q РЄњ РЎбx ┬и (P РЄњ R)) РЄњ S Рєњ H Ріб РЎбx ┬и (P РЄњ Q РЄњ R) РЄњ S
opaque symbol NRM4 [n] [P R : Tuple n Рєњ Prop] [Q S : Prop]
  : ¤ђ ((Q РЄњ (`РЎб v, P v РЄњ R v)) РЄњ S)
  Рєњ ¤ђ ((`РЎб v, P v РЄњ Q РЄњ R v) РЄњ S) РЅћ
begin
  assume n P R Q S h1 h2;
  refine h1 (╬╗ hq,
    pi_to_РЎб (╬╗ v, P v РЄњ R v)
      (╬╗ v hpv, РЎб_to_pi (╬╗ v', P v' РЄњ Q РЄњ R v') h2 v hpv hq))
end;

// NRM5: H Ріб РЎбx ┬и (P РѕД Q РЄњ R) РЄњ S Рєњ H Ріб РЎбx ┬и (P РЄњ Q РЄњ R) РЄњ S
symbol NRM5 [n] [P Q R : Tuple n Рєњ Prop] [S : Prop]
  : ¤ђ ((`РЎб v, РІђ_snoc (P v) (Q v) РЄњ R v) РЄњ S)
  Рєњ ¤ђ ((`РЎб v, P v РЄњ Q v РЄњ R v) РЄњ S);

// NRM6: H Ріб РЎбx ┬и (R РЄњ P) РЄњ (РЎбx ┬и (R РЄњ Q) РЄњ S) Рєњ H Ріб РЎбx ┬и (R РЄњ P РѕД Q) РЄњ S
// Generalised over a snoc list: the consequent `РІђ (qs v Рѕи P v)` splits into
// init `РІђ (qs v)` and last `P v`.  init-first lets the emitter chain
// `refine NRM6 _;` for n-conjunct goals, since `РІђ (qs v)` is itself a
// `РІђ (qs' v Рѕи P' v)` when |qs v| РЅЦ 2.
opaque symbol NRM6 [n] [Qs : Tuple n Рєњ ­ЮЋЃ* o] [P R : Tuple n Рєњ Prop] [S : Prop]
  : ¤ђ ((`РЎб v, R v РЄњ РІђ (Qs v)) РЄњ ((`РЎб v, R v РЄњ P v) РЄњ S))
  Рєњ ¤ђ ((`РЎб v, R v РЄњ РІђ (Qs v Рѕи P v)) РЄњ S) РЅћ
begin
  assume n qs P R S h1 h2;
  refine h1
    (pi_to_РЎб (╬╗ v, R v РЄњ РІђ (qs v))
      (╬╗ v hr, РІђ_init (РЎб_to_pi (╬╗ v', R v' РЄњ РІђ (qs v' Рѕи P v')) h2 v hr)))
    (pi_to_РЎб (╬╗ v, R v РЄњ P v)
      (╬╗ v hr, РІђ_last (РЎб_to_pi (╬╗ v', R v' РЄњ РІђ (qs v' Рѕи P v')) h2 v hr)))
end;

// NRM7: H Ріб (РЎбx ┬и P) РЄњ ((РЎбx ┬и Q) РЄњ S) Рєњ H Ріб РЎбx ┬и (P РѕД Q) РЄњ S
// Generalised: same shape as NRM6 but without the R РЄњ antecedent.
opaque symbol NRM7 [n] [Qs : Tuple n Рєњ ­ЮЋЃ* o] [P : Tuple n Рєњ Prop] [S : Prop]
  : ¤ђ ((`РЎб v, РІђ (Qs v))
        РЄњ ((`РЎб v, P v) РЄњ S))
  Рєњ ¤ђ ((`РЎб v : Tuple n, РІђ (Qs v Рѕи P v)) РЄњ S) РЅћ
begin
  assume n qs P S h1 h2;
  refine h1
    (pi_to_РЎб (╬╗ v, РІђ (qs v))
      (╬╗ v, РІђ_init (РЎб_to_pi (╬╗ v', РІђ (qs v' Рѕи P v')) h2 v)))
    (pi_to_РЎб (╬╗ v, P v)
      (╬╗ v, РІђ_last (РЎб_to_pi (╬╗ v', РІђ (qs v' Рѕи P v')) h2 v)))
end;

// ---- NRM8-9: compoundРєћmixed binders (split with `take`/`drop`) ----
//
// NRM8: spec is `(РЎб(x,y) ┬и Q) РЄњ S` Рєљ `(РЎбx ┬и Рѕђy ┬и Q) РЄњ S`.
// Encoded with the n,m-indexed split helpers from Quant.lp:
//   the conclusion's `Q x y` (clean HO pattern) gets unified back
//   from the premise's `Q (take v) (drop v)` after Lambdapi infers Q.
opaque symbol NRM8 [n m] [Q : Tuple n Рєњ Tuple m Рєњ Prop] [S : Prop]
  : ¤ђ ((`РЎб v : Tuple (n ++ m), Q (take [n] [m] v) (drop [n] [m] v)) РЄњ S)
  Рєњ ¤ђ ((`РЎб x : Tuple n, `!! y : Tuple m, Q x y) РЄњ S) РЅћ
begin
  assume n m Q S h hnested;
  // hnested : ¤ђ (`РЎб x : Tuple n, `!! y : Tuple m, Q x y)
  // Need:    ¤ђ (`РЎб v : Tuple (n ++ m), Q (take v) (drop v))
  // Witness: ╬╗ v, !!_to_pi (Q x) (РЎб_to_pi (╬╗ x, `!! y, Q x y) hnested x') y'
  //          where x' = take v, y' = drop v.
  refine h (pi_to_РЎб (╬╗ v : Tuple (n ++ m),
                       Q (take [n] [m] v) (drop [n] [m] v))
    (╬╗ v : Tuple (n ++ m),
       !!_to_pi (╬╗ y, Q (take [n] [m] v) y)
                (РЎб_to_pi (╬╗ x, `!! y : Tuple m, Q x y)
                         hnested
                         (take [n] [m] v))
                (drop [n] [m] v)))
end;

// NRM9: spec is `(РЎб(x,y) ┬и (P РЄњ Q)) РЄњ S` Рєљ `(РЎбx ┬и (P РЄњ Рѕђy ┬и Q)) РЄњ S`,
// with y not free in P. Same split: premise body is `P (take v) РЄњ Q (take v) (drop v)`.
opaque symbol NRM9 [n m]
  [P : Tuple n Рєњ Prop]
  [Q : Tuple n Рєњ Tuple m Рєњ Prop]
  [S : Prop]
  : ¤ђ ((`РЎб v : Tuple (n ++ m),
         P (take [n] [m] v) РЄњ Q (take [n] [m] v) (drop [n] [m] v)) РЄњ S)
  Рєњ ¤ђ ((`РЎб x : Tuple n, P x РЄњ (`!! y : Tuple m, Q x y)) РЄњ S) РЅћ
begin
  assume n m P Q S h hnested;
  refine h (pi_to_РЎб
    (╬╗ v, P (take [n] [m] v) РЄњ Q (take [n] [m] v) (drop [n] [m] v))
    (╬╗ v hp,
       !!_to_pi (╬╗ y, Q (take [n] [m] v) y)
                (РЎб_to_pi (╬╗ x, P x РЄњ (`!! y : Tuple m, Q x y))
                         hnested
                         (take [n] [m] v)
                         hp)
                (drop [n] [m] v)))
end;

// ---- NRM10-15: Implication / negation under `РЎб` and `РЎА` ----

// NRM10: H Ріб РЎАx ┬и ┬г(P РѕД Q) РЄњ R Рєњ H Ріб РЎбx ┬и (P РѕД Q РЄњ РіЦ) РЄњ R
opaque symbol NRM10 [n] [Ps : Tuple n Рєњ ­ЮЋЃ* o] [Q : Tuple n Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА v, ┬г РІђ (Ps v Рѕи Q v)) РЄњ R)
  Рєњ ¤ђ ((`РЎб v, РІђ (Ps v Рѕи Q v) РЄњ РіЦ) РЄњ R) РЅћ
begin
  admit;
  //assume n P Q R h1 h2;
  //refine h1 (pi_to_РЎА (╬╗ v, ┬г РІђ (Рѕј Рѕи P v Рѕи Q v))
  //  (╬╗ v hpq, РЎб_to_pi (╬╗ v', РІђ (Рѕј Рѕи P v' Рѕи Q v') РЄњ РіЦ) h2 v hpq))
end;

// NRM11: H Ріб РЎАx ┬и ┬г(Ріц РѕД P) РЄњ R Рєњ H Ріб РЎбx ┬и (P РЄњ РіЦ) РЄњ R
opaque symbol NRM11 [n] [P : Tuple n Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА v, ┬г (РІђ_snoc Ріц (P v))) РЄњ R)
  Рєњ ¤ђ ((`РЎб v, P v РЄњ РіЦ) РЄњ R) РЅћ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_РЎА (╬╗ v, ┬г РІђ (Рѕј Рѕи Ріц Рѕи P v))
    (╬╗ v htpv, РЎб_to_pi (╬╗ v', P v' РЄњ РіЦ) h2 v (РІђРѓѓ_snd htpv)))
end;

// NRM12: H Ріб РЎАx ┬и ┬г(P РѕД Q) РЄњ R Рєњ H Ріб РЎбx ┬и (P РЄњ ┬гQ) РЄњ R
opaque symbol NRM12 [n] [P Q : Tuple n Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА v, ┬г РІђ_snoc (P v) (Q v)) РЄњ R)
  Рєњ ¤ђ ((`РЎб v, P v РЄњ ┬г (Q v)) РЄњ R) РЅћ
begin
  assume n P Q R h1 h2;
  refine h1 (pi_to_РЎА (╬╗ v, ┬г РІђ (Рѕј Рѕи P v Рѕи Q v))
    (╬╗ v hpq, РЎб_to_pi (╬╗ v', P v' РЄњ ┬г (Q v')) h2 v
                (РІђРѓѓ_hd hpq) (РІђРѓѓ_snd hpq)))
end;

// NRM13: H Ріб РЎАx ┬и ┬г(P РѕД ┬гQ) РЄњ R Рєњ H Ріб РЎбx ┬и (P РЄњ Q) РЄњ R
opaque symbol NRM13 [n] [P Q : Tuple n Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА v, ┬г РІђ_snoc (P v) (┬г Q v)) РЄњ R)
  Рєњ ¤ђ ((`РЎб v, P v РЄњ Q v) РЄњ R) РЅћ
begin
  assume n P Q R h1 h2;
  refine h1 (pi_to_РЎА (╬╗ v, ┬г РІђ (Рѕј Рѕи P v Рѕи ┬г (Q v)))
    (╬╗ v hc, (РІђРѓѓ_snd hc) (РЎб_to_pi (╬╗ v', P v' РЄњ Q v') h2 v (РІђРѓѓ_hd hc))))
end;

// NRM14: H Ріб РЎАx ┬и ┬г(Ріц РѕД P) РЄњ R Рєњ H Ріб (РЎбx ┬и ┬гP) РЄњ R
opaque symbol NRM14 [n] [P : Tuple n Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА v, ┬г РІђ_snoc Ріц (P v)) РЄњ R)
  Рєњ ¤ђ ((`РЎб v, ┬г (P v)) РЄњ R) РЅћ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_РЎА (╬╗ v, ┬г РІђ (Рѕј Рѕи Ріц Рѕи P v))
    (╬╗ v htpv, РЎб_to_pi (╬╗ v', ┬г (P v')) h2 v (РІђРѓѓ_snd htpv)))
end;

// NRM15: H Ріб РЎАx ┬и ┬г(Ріц РѕД ┬гP) РЄњ R Рєњ H Ріб (РЎбx ┬и P) РЄњ R
opaque symbol NRM15 [n] [P : Tuple n Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА v, ┬г РІђ_snoc Ріц (┬г P v)) РЄњ R)
  Рєњ ¤ђ ((`РЎб v, P v) РЄњ R) РЅћ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_РЎА (╬╗ v, ┬г РІђ (Рѕј Рѕи Ріц Рѕи ┬г (P v)))
    (╬╗ v htnpv, (РІђРѓѓ_snd htnpv) (РЎб_to_pi P h2 v)))
end;

// ---- NRM16-19: Universal-instantiation patterns ----

// NRM16: Рѕђx.P in H; Q Рєњ H Ріб (РЎАx ┬и P) РЄњ Q
opaque symbol NRM16 [n] [P : Tuple n Рєњ Prop] [Q : Prop]
  : ¤ђ (`!! v, P v)
  Рєњ ¤ђ Q
  Рєњ ¤ђ ((`РЎА v, P v) РЄњ Q) РЅћ
begin
  assume n P Q hp hq ht; refine hq
end;

// NRM17: NRM16 with extra spec-level equality side-conditions.
// At the LP level the proof obligation collapses to NRM16's shape.
opaque symbol NRM17 [n] [P : Tuple n Рєњ Prop] [Q : Prop]
  : ¤ђ (`!! v, P v)
  Рєњ ¤ђ Q
  Рєњ ¤ђ ((`РЎА v, P v) РЄњ Q) РЅћ
begin
  assume n P Q hp hq ht; refine hq
end;

// NRM18: Рѕђx ┬и ┬г(Ріц РѕД ┬гP) in H; РѕЃE. [x:=E]P = R Рєњ H Ріб РЎАy ┬и ┬г(Ріц РѕД R) РЄњ Q
opaque symbol NRM18 [n] [P : Tuple n Рєњ Prop] [R Q : Prop] (v : Tuple n)
  : ¤ђ (`!! u, ┬г РІђ_snoc Ріц (┬г P u))
  Рєњ ¤ђ (P v = R)
  Рєњ ¤ђ ((`РЎА _ : Tuple n, ┬г РІђ_snoc Ріц R) РЄњ Q) РЅћ
begin
  assume n P R Q v hp heq h;
  // Derive ¤ђ (P v) classically.
  have hpv : ¤ђ (P v)
    { refine ┬г┬гРѓЉ (P v) _;
      assume hnpv;
      refine !!_to_pi (╬╗ u, ┬г РІђ (Рѕј Рѕи Ріц Рѕи ┬г (P u))) hp v (РІђРѓѓ_intro Ріцрхб hnpv) };
  // Transport along heq.
  have hr : ¤ђ R { rewrite left heq; refine hpv };
  refine РіЦРѓЉ (РЎА_to_pi (╬╗ _ : Tuple n, ┬г РІђ (Рѕј Рѕи Ріц Рѕи R)) h (inh_tuple [n])
              (РІђРѓѓ_intro Ріцрхб hr))
end;

// NRM19: P in H; РѕЃE. [x:=E]R = P Рєњ H Ріб РЎАx ┬и ┬г(Ріц РѕД R) РЄњ Q
opaque symbol NRM19 [n] [Q : Prop] [R : Tuple n Рєњ Prop] (v : Tuple n)
  : ¤ђ (R v)
  Рєњ ¤ђ ((`РЎА u, ┬г РІђ_snoc Ріц (R u)) РЄњ Q) РЅћ
begin
  assume n Q R v hr hf;
  refine РіЦРѓЉ (РЎА_to_pi (╬╗ u, ┬г РІђ (Рѕј Рѕи Ріц Рѕи R u)) hf v (РІђРѓѓ_intro Ріцрхб hr))
end;

// ---- NRM20-23: Substitution ----

// NRM20: x not free in E; H Ріб РЎАy ┬и ┬г[x:=E]P РЄњ Q
//        Рєњ H Ріб РЎА(x,y) ┬и ┬г(x = E РѕД P) РЄњ Q
//
// PP's left-associative РѕД puts the equality `x = E` *first* Рђћ at the head of
// the snoc list Рђћ so the conclusion pushes it onto the front of the rest `ps`
// with `pushl`.  The premise drops it and substitutes x := E (`ps (v' РеЙ E)`).
// `РІђ_push_front` re-adds the head conjunct to recover the full goal; after the
// substitution `prj 0 (v' РеЙ E) Рєф E`, so it discharges as `eq_refl E`.
opaque symbol NRM20 [n] [ps : Tuple (+1 n) Рєњ ­ЮЋЃ* o] [Q : Prop] (E : ¤ё ╬╣)
  : ¤ђ ((`РЎА v' : Tuple n, ┬г РІђ ps (v' РеЙ E)) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple (+1 n), ┬г РІђ pushl (prj 0 v = E) (ps v)) РЄњ Q) РЅћ
begin
  assume n ps Q E h1 h2;
  refine h1 (pi_to_РЎА _
    (╬╗ v' hp,
      РЎА_to_pi (╬╗ v, ┬г РІђ pushl (prj 0 v = E) (ps v)) h2 (v' РеЙ E)
        (РІђ_push_front (prj 0 (v' РеЙ E) = E) (ps (v' РеЙ E)) (eq_refl E) hp)))
end;

// NRM21: dual to NRM20 Рђћ equality reversed.
opaque symbol NRM21 [n] [P : Tuple (+1 n) Рєњ Prop] [Q : Prop] (E : ¤ё ╬╣)
  : ¤ђ ((`РЎА y : Tuple n, ┬г (P (y РеЙ E))) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple (+1 n),
         ┬г РІђ (Рѕј Рѕи P v Рѕи (E = prj 0 v))) РЄњ Q) РЅћ
begin
  assume n P Q E h1 h2;
  refine h1 (pi_to_РЎА (╬╗ y, ┬г (P (y РеЙ E)))
    (╬╗ y hpy,
      РЎА_to_pi (╬╗ v, ┬г РІђ (Рѕј Рѕи P v Рѕи (E = prj 0 v))) h2 (y РеЙ E)
        (РІђРѓѓ_intro hpy (eq_refl E))))
end;

// NRM22: simpler unary version of NRM20 (no extra y-binder).
opaque symbol NRM22 [P : ¤ё ╬╣ Рєњ Prop] [Q : Prop] (E : ¤ё ╬╣)
  : ¤ђ (┬г (P E) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple 1,
         ┬г РІђ (Рѕј Рѕи P (prj 0 v) Рѕи (prj 0 v = E))) РЄњ Q) РЅћ
begin
  assume P Q E h1 h2;
  refine h1 (╬╗ hpe,
    РЎА_to_pi (╬╗ v : Tuple 1, ┬г РІђ (Рѕј Рѕи P (prj 0 v) Рѕи (prj 0 v = E)))
            h2 (unit РеЙ E)
            (РІђРѓѓ_intro hpe (eq_refl E)))
end;

// NRM23: NRM22 with reversed equality.
opaque symbol NRM23 [P : ¤ё ╬╣ Рєњ Prop] [Q : Prop] (E : ¤ё ╬╣)
  : ¤ђ (┬г (P E) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v : Tuple 1,
         ┬г РІђ (Рѕј Рѕи P (prj 0 v) Рѕи (E = prj 0 v))) РЄњ Q) РЅћ
begin
  assume P Q E h1 h2;
  refine h1 (╬╗ hpe,
    РЎА_to_pi (╬╗ v : Tuple 1, ┬г РІђ (Рѕј Рѕи P (prj 0 v) Рѕи (E = prj 0 v)))
            h2 (unit РеЙ E)
            (РІђРѓѓ_intro hpe (eq_refl E)))
end;

// ---- NRM24-26: Trivial structural rules ----

// NRM24: P not of form A РѕД B; H Ріб РЎАx ┬и ┬г(Ріц РѕД P) РЄњ Q Рєњ H Ріб РЎАx ┬и ┬гP РЄњ Q
opaque symbol NRM24 [n] [P : Tuple n Рєњ Prop] [Q : Prop]
  : ¤ђ ((`РЎА v, ┬г РІђ (Рѕј Рѕи Ріц Рѕи P v)) РЄњ Q)
  Рєњ ¤ђ ((`РЎА v, ┬г (P v)) РЄњ Q) РЅћ
begin
  assume n P Q h1 h2;
  refine h1 (pi_to_РЎА (╬╗ v, ┬г РІђ (Рѕј Рѕи Ріц Рѕи P v))
    (╬╗ v htpv, РЎА_to_pi (╬╗ v', ┬г (P v')) h2 v (РІђРѓѓ_snd htpv)))
end;

// NRM25: x not free in P; H Ріб P Рєњ H Ріб РЎА(x) ┬и P
//   = forall2(x).P in PP notation. `pi_to_РЎА` with constant predicate
//   (the body doesn't depend on the bound tuple).
opaque symbol NRM25 [n] [P : Prop]
  : ¤ђ P Рєњ ¤ђ (`РЎА _ : Tuple n, P) РЅћ
begin
  assume n P hp;
  refine pi_to_РЎА (╬╗ _ : Tuple n, P) (╬╗ _, hp)
end;

// NRM26: y not free in P; H Ріб РЎА(x,...) ┬и P Рєњ H Ріб РЎА(x,y,...) ┬и P
//   = extend the binder with a y not appearing in P. The body
//   ignores the new variable.

// Helper: drop the last element of a Tuple (+1 n).
symbol nrm26_drop_last [n] : Tuple (+1 n) Рєњ Tuple n;
rule nrm26_drop_last [$n] ($w РеЙ _) Рєф $w;

// Helper: produce P (drop_last v) from a per-tuple-n proof of P.
//   Stays !!-typed so the rewrite rule fires; rule body transports
//   from РЎА via `РЎА_eq_!!`.
symbol nrm26_drop_proof [n] (P : Tuple n Рєњ Prop)
  : ¤ђ (`!! w, P w)
  Рєњ ╬а v : Tuple (+1 n), ¤ђ (P (nrm26_drop_last v));
rule nrm26_drop_proof [$n] $P $h ($w РеЙ _) Рєф !!_to_pi $P $h $w;

opaque symbol NRM26 [n] [P : Tuple n Рєњ Prop]
  : ¤ђ (`РЎА v, P v)
  Рєњ ¤ђ (`РЎА v : Tuple (+1 n), P (nrm26_drop_last v)) РЅћ
begin
  assume n P h;
  refine pi_to_РЎА (╬╗ v : Tuple (+1 n), P (nrm26_drop_last v))
    (nrm26_drop_proof P (=РЄњ (РЎА_eq_!! P) h))
end;

// ---- NRM27-30: Arithmetic solver dispatch ----
//
// These rules encode arithmetic solver outputs. Their full encoding
// requires arithmetic-solver infrastructure (see Arith.lp's solver
// rules). Stubs for now.
//
// NRM27: (xрхб РЅц 0) and (Рѕњxрхб РЅц 0) in conjunction; R = [xрхб := 0]Рђд
//   Рєњ РЎбРђд ┬и ┬гR  Ріб  РЎА(xРѓЂ,...,xРѓЎ) ┬и ┬г(P РѕД РІ» РѕД Q)
// NRM28-30: variants with solver dispatch.
// TODO: implement once Arith.lp solver rules are wired.

// ---- `_1` (Result-form) variants Рђћ ┬Д8.13 ----
//
// Per discussion, no NRM_1 rules are emitted in the current corpus.
// NRM1_1 is the lone exception Рђћ it strips a constant РЎб-binder via
// `nrm1_eq`, mirroring NRM1's role at the chain level.

symbol NRM1_1 [n] [P Q : Prop]
  (r : Res (P РЄњ Q)) : Res ((`РЎб _ : Tuple n, P) РЄњ Q)
  РЅћ mk_1 (res_tm r) (eq_trans (@nrm1_eq n P Q) (res_eq r));
