// Normalisation (¬ßA.12) ‚ÄĒ shallow encoding
//
// With HOAS and ‚ôĘ/‚ô° defined as ‚ąÄ in B.lp:
// - Compound variables (‚®ĺ) become nested ‚ąÄ
// - Substitution is HOAS application
// - Non-freeness is implicit (Prop vs ŌĄ őĻ ‚Üí Prop)
require open pp2lp.B;

// ---- NRM1-7: Logical transformations under ‚ôĘ ----

// NRM1: x not free in P; H ‚äĘ P ‚áí S ‚Üí H ‚äĘ (‚ôĘx ¬∑ P) ‚áí S
opaque symbol NRM1 [P S : Prop]
  : ŌÄ (P ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ _ : ŌĄ őĻ, P) ‚áí S) ‚ČĒ
begin
  assume P S h1 h2;
  refine h1 (h2 inh)
end;

// NRM2: x not free in P; H ‚äĘ (P ‚áí ‚ôĘx ¬∑ Q) ‚áí S ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí Q) ‚áí S
opaque symbol NRM2 [P : Prop] [Q : ŌĄ őĻ ‚Üí Prop] [S : Prop]
  : ŌÄ ((P ‚áí (`‚ôĘ x, Q x)) ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ x, P ‚áí Q x) ‚áí S) ‚ČĒ
begin
  assume P Q S h1 h2;
  refine h1 (őĽ hp x, h2 x hp)
end;

// NRM3: x not free in Q; Q is not FALSE; H ‚äĘ (Q ‚áí S) ‚ąß ((‚ąÄx ¬∑ ¬¨P) ‚áí S) ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí Q) ‚áí S
opaque symbol NRM3 [P : ŌĄ őĻ ‚Üí Prop] [Q S : Prop]
  : ŌÄ ((Q ‚áí S) ‚ąß ((`‚ąÄ x, ¬¨ (P x)) ‚áí S))
  ‚Üí ŌÄ ((`‚ôĘ x, P x ‚áí Q) ‚áí S) ‚ČĒ
begin
  assume P Q S h1 h2;
  refine ‚ą®‚āĎ (em (`‚ąÉ x, P x)) _ _ {
    assume hex;
    refine ‚ąÉ‚āĎ hex (őĽ x hpx, (‚ąß‚āĎ‚āĀ h1) (h2 x hpx))
  } {
    assume hnex;
    refine (‚ąß‚āĎ‚āā h1) (őĽ x hpx, hnex (‚ąÉŠĶĘ x hpx))
  }
end;

// NRM4: x not free in Q; H ‚äĘ (Q ‚áí ‚ôĘx ¬∑ (P ‚áí R)) ‚áí S ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí (Q ‚áí R)) ‚áí S
opaque symbol NRM4 [P R : ŌĄ őĻ ‚Üí Prop] [Q S : Prop]
  : ŌÄ ((Q ‚áí (`‚ôĘ x, P x ‚áí R x)) ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ x, P x ‚áí Q ‚áí R x) ‚áí S) ‚ČĒ
begin
  assume P R Q S h1 h2;
  refine h1 (őĽ hq x hpx, h2 x hpx hq)
end;

// NRM5: H ‚äĘ ‚ôĘx ¬∑ (P ‚ąß Q ‚áí R) ‚áí S ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí (Q ‚áí R)) ‚áí S
opaque symbol NRM5 [P Q R : ŌĄ őĻ ‚Üí Prop] [S : Prop]
  : ŌÄ ((`‚ôĘ x, P x ‚ąß Q x ‚áí R x) ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ x, P x ‚áí Q x ‚áí R x) ‚áí S) ‚ČĒ
begin
  assume P Q R S h1 h2;
  refine h1 (őĽ x hpq, h2 x (‚ąß‚āĎ‚āĀ hpq) (‚ąß‚āĎ‚āā hpq))
end;

// NRM5_2: Two-variable version.
opaque symbol NRM5_2 [P Q R : ŌĄ őĻ ‚Üí ŌĄ őĻ ‚Üí Prop] [S : Prop]
  : ŌÄ ((`‚ôĘ x, `‚ôĘ y, P x y ‚ąß Q x y ‚áí R x y) ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ x, `‚ôĘ y, P x y ‚áí Q x y ‚áí R x y) ‚áí S) ‚ČĒ
begin
  assume P Q R S h1 h2;
  refine h1 (őĽ x y hpq, h2 x y (‚ąß‚āĎ‚āĀ hpq) (‚ąß‚āĎ‚āā hpq))
end;

// NRM6: H ‚äĘ ‚ôĘx ¬∑ (R ‚áí P) ‚áí (‚ôĘx ¬∑ (R ‚áí Q) ‚áí S) ‚Üí H ‚äĘ ‚ôĘx ¬∑ (R ‚áí P ‚ąß Q) ‚áí S
opaque symbol NRM6 [P Q R : ŌĄ őĻ ‚Üí Prop] [S : Prop]
  : ŌÄ ((`‚ôĘ x, R x ‚áí P x) ‚áí ((`‚ôĘ x, R x ‚áí Q x) ‚áí S))
  ‚Üí ŌÄ ((`‚ôĘ x, R x ‚áí P x ‚ąß Q x) ‚áí S) ‚ČĒ
begin
  assume P Q R S h1 h2;
  refine h1 (őĽ x hr, ‚ąß‚āĎ‚āĀ (h2 x hr)) (őĽ x hr, ‚ąß‚āĎ‚āā (h2 x hr))
end;

// NRM7: H ‚äĘ (‚ôĘx ¬∑ P) ‚áí ((‚ôĘx ¬∑ Q) ‚áí S) ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚ąß Q) ‚áí S
opaque symbol NRM7 [P Q : ŌĄ őĻ ‚Üí Prop] [S : Prop]
  : ŌÄ ((`‚ôĘ x, P x) ‚áí ((`‚ôĘ x, Q x) ‚áí S))
  ‚Üí ŌÄ ((`‚ôĘ x, P x ‚ąß Q x) ‚áí S) ‚ČĒ
begin
  assume P Q S h1 h2;
  refine h1 (őĽ x, ‚ąß‚āĎ‚āĀ (h2 x)) (őĽ x, ‚ąß‚āĎ‚āā (h2 x))
end;

// NRM7_2: Two-variable version.
opaque symbol NRM7_2 [P Q : ŌĄ őĻ ‚Üí ŌĄ őĻ ‚Üí Prop] [S : Prop]
  : ŌÄ ((`‚ôĘ x, `‚ôĘ y, P x y) ‚áí ((`‚ôĘ x, `‚ôĘ y, Q x y) ‚áí S))
  ‚Üí ŌÄ ((`‚ôĘ x, `‚ôĘ y, P x y ‚ąß Q x y) ‚áí S) ‚ČĒ
begin
  assume P Q S h1 h2;
  refine h1 (őĽ x y, ‚ąß‚āĎ‚āĀ (h2 x y)) (őĽ x y, ‚ąß‚āĎ‚āā (h2 x y))
end;

// ---- NRM8-9: Quantifier flattening ----

opaque symbol NRM8 [Q : ŌĄ őĻ ‚Üí ŌĄ őĻ ‚Üí Prop] [S : Prop]
  : ŌÄ ((`‚ôĘ x, `‚ôĘ y, Q x y) ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ x, `‚ąÄ y, Q x y) ‚áí S) ‚ČĒ
begin
  assume Q S h; refine h
end;

// NRM8_13: Combined NRM8 + NRM13 for two-variable compound.
// Converts ‚ôĘx.‚ąÄy.(P x y ‚áí Q x y) to ‚ô°x.‚ô°y.¬¨(P x y ‚ąß ¬¨(Q x y)).
// In HOAS (‚ôĘ=‚ô°=‚ąÄ): (‚ąÄx y, P x y ‚áí Q x y) ‚áí R ‚Üí (‚ąÄx y, ¬¨(P x y ‚ąß ¬¨(Q x y))) ‚áí R.
opaque symbol NRM8_13 [P Q : ŌĄ őĻ ‚Üí ŌĄ őĻ ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° x, `‚ô° y, ¬¨ (P x y ‚ąß ¬¨ (Q x y))) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ x, `‚ąÄ y, P x y ‚áí Q x y) ‚áí R) ‚ČĒ
begin
  assume P Q R h1 h2;
  refine h1 (őĽ x y hpnq, (‚ąß‚āĎ‚āā hpnq) (h2 x y (‚ąß‚āĎ‚āĀ hpnq)))
end;
// NRM8_13_3: Three-variable version.
opaque symbol NRM8_13_3 [P Q : ŌĄ őĻ ‚Üí ŌĄ őĻ ‚Üí ŌĄ őĻ ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° x, `‚ô° y, `‚ô° z, ¬¨ (P x y z ‚ąß ¬¨ (Q x y z))) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ x, `‚ąÄ y, `‚ąÄ z, P x y z ‚áí Q x y z) ‚áí R) ‚ČĒ
begin
  assume P Q R h1 h2;
  refine h1 (őĽ x y z hpnq, (‚ąß‚āĎ‚āā hpnq) (h2 x y z (‚ąß‚āĎ‚āĀ hpnq)))
end;

// NRM9: x and y distinct; y not free in P; H ‚äĘ ‚ôĘ(x, y) ¬∑ (P ‚áí Q) ‚áí S ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí ‚ąÄy ¬∑ Q) ‚áí S
opaque symbol NRM9 [P : ŌĄ őĻ ‚Üí Prop] [Q : ŌĄ őĻ ‚Üí ŌĄ őĻ ‚Üí Prop] [S : Prop]
  : ŌÄ ((`‚ôĘ x, `‚ąÄ y, P x ‚áí Q x y) ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ x, P x ‚áí `‚ąÄ y, Q x y) ‚áí S) ‚ČĒ
begin
  assume P Q S h1 h2;
  refine h1 (őĽ x y hp, h2 x hp y)
end;
// NRM9f: x and y not distinct or y free in P; z fresh; K = [y := z] Q;
//   H ‚äĘ ‚ôĘ(x, z) ¬∑ (P ‚áí K) ‚áí S ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí ‚ąÄy ¬∑ Q) ‚áí S
// Identity in HOAS.

// ---- NRM10-15: Normal form transformations ----

// NRM10: H ‚äĘ ‚ô°x ¬∑ ¬¨(P ‚ąß Q) ‚áí R ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚ąß Q ‚áí FALSE) ‚áí R
// Identity since ‚ôĘ=‚ô°=‚ąÄ and (P‚ąßQ ‚áí ‚ä•) = ¬¨(P‚ąßQ). OCaml emitter should skip.

// NRM11: H ‚äĘ ‚ô°x ¬∑ ¬¨(TRUE ‚ąß P) ‚áí R ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí FALSE) ‚áí R
opaque symbol NRM11 [P : ŌĄ őĻ ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° x, ¬¨ (‚ä§ ‚ąß P x)) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ x, P x ‚áí ‚ä•) ‚áí R) ‚ČĒ
begin
  assume P R h1 h2;
  refine h1 (őĽ x htpx, h2 x (‚ąß‚āĎ‚āā htpx))
end;

// NRM12: H ‚äĘ ‚ô°x ¬∑ ¬¨(P ‚ąß Q) ‚áí R ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí ¬¨Q) ‚áí R
opaque symbol NRM12 [P Q : ŌĄ őĻ ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° x, ¬¨ (P x ‚ąß Q x)) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ x, P x ‚áí ¬¨ (Q x)) ‚áí R) ‚ČĒ
begin
  assume P Q R h1 h2;
  refine h1 (őĽ x hpq, h2 x (‚ąß‚āĎ‚āĀ hpq) (‚ąß‚āĎ‚āā hpq))
end;

// NRM13: ‚ôĘx.(P‚áíQ)‚áíR ‚Üí ‚ô°x.¬¨(P‚ąß¬¨Q)‚áíR  (2-premise)
opaque symbol NRM13 [P Q : ŌĄ őĻ ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° x, ¬¨ (P x ‚ąß ¬¨ (Q x))) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ x, P x ‚áí Q x) ‚áí R) ‚ČĒ
begin
  assume P Q R h1 h2;
  refine h1 (őĽ x hc, (‚ąß‚āĎ‚āā hc) (h2 x (‚ąß‚āĎ‚āĀ hc)))
end;

// NRM53: ‚ôĘx.(P‚āĀ‚áíP‚āā‚áíQ)‚áíR ‚Üí ‚ô°x.¬¨((P‚āĀ‚ąßP‚āā)‚ąß¬¨Q)‚áíR  (3-premise = NRM5+NRM13)
opaque symbol NRM53 [P1 P2 Q : ŌĄ őĻ ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° x, ¬¨ ((P1 x ‚ąß P2 x) ‚ąß ¬¨ (Q x))) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ x, P1 x ‚áí P2 x ‚áí Q x) ‚áí R) ‚ČĒ
begin
  assume P1 P2 Q R h1 h2;
  refine h1 (őĽ x hc, (‚ąß‚āĎ‚āā hc) (h2 x (‚ąß‚āĎ‚āĀ (‚ąß‚āĎ‚āĀ hc)) (‚ąß‚āĎ‚āā (‚ąß‚āĎ‚āĀ hc))))
end;

// NRM54: ‚ôĘx.(P‚āĀ‚áíP‚āā‚áíP‚āÉ‚áíQ)‚áíR ‚Üí ‚ô°x.¬¨(((P‚āĀ‚ąßP‚āā)‚ąßP‚āÉ)‚ąß¬¨Q)‚áíR  (4-premise = NRM5¬≤+NRM13)
opaque symbol NRM54 [P1 P2 P3 Q : ŌĄ őĻ ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° x, ¬¨ (((P1 x ‚ąß P2 x) ‚ąß P3 x) ‚ąß ¬¨ (Q x))) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ x, P1 x ‚áí P2 x ‚áí P3 x ‚áí Q x) ‚áí R) ‚ČĒ
begin
  assume P1 P2 P3 Q R h1 h2;
  refine h1 (őĽ x hc,
    (‚ąß‚āĎ‚āā hc) (h2 x (‚ąß‚āĎ‚āĀ (‚ąß‚āĎ‚āĀ (‚ąß‚āĎ‚āĀ hc))) (‚ąß‚āĎ‚āā (‚ąß‚āĎ‚āĀ (‚ąß‚āĎ‚āĀ hc))) (‚ąß‚āĎ‚āā (‚ąß‚āĎ‚āĀ hc))))
end;

// NRM13_2: Two-variable version.
opaque symbol NRM13_2 [P Q : ŌĄ őĻ ‚Üí ŌĄ őĻ ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° x, `‚ô° y, ¬¨ (P x y ‚ąß ¬¨ (Q x y))) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ x, `‚ôĘ y, P x y ‚áí Q x y) ‚áí R) ‚ČĒ
begin
  assume P Q R h1 h2;
  refine h1 (őĽ x y hpnq, (‚ąß‚āĎ‚āā hpnq) (h2 x y (‚ąß‚āĎ‚āĀ hpnq)))
end;

// NRM14: H ‚äĘ ‚ô°x ¬∑ ¬¨(TRUE ‚ąß P) ‚áí R ‚Üí H ‚äĘ (‚ôĘx ¬∑ ¬¨P) ‚áí R
opaque symbol NRM14 [P : ŌĄ őĻ ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° x, ¬¨ (‚ä§ ‚ąß P x)) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ x, ¬¨ (P x)) ‚áí R) ‚ČĒ
begin
  assume P R h1 h2;
  refine h1 (őĽ x htpx, h2 x (‚ąß‚āĎ‚āā htpx))
end;

// NRM15: H ‚äĘ ‚ô°x ¬∑ ¬¨(TRUE ‚ąß ¬¨P) ‚áí R ‚Üí H ‚äĘ (‚ôĘx ¬∑ P) ‚áí R
opaque symbol NRM15 [P : ŌĄ őĻ ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° x, ¬¨ (‚ä§ ‚ąß ¬¨ (P x))) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ x, P x) ‚áí R) ‚ČĒ
begin
  assume P R h1 h2;
  refine h1 (őĽ x htnpx, (‚ąß‚āĎ‚āā htnpx) (h2 x))
end;

// NRM14_2: Two-variable version.
opaque symbol NRM14_2 [P : ŌĄ őĻ ‚Üí ŌĄ őĻ ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° x, `‚ô° y, ¬¨ (‚ä§ ‚ąß P x y)) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ x, `‚ôĘ y, ¬¨ (P x y)) ‚áí R) ‚ČĒ
begin
  assume P R h1 h2;
  refine h1 (őĽ x y htpxy, h2 x y (‚ąß‚āĎ‚āā htpxy))
end;

// NRM15_2: Two-variable version.
opaque symbol NRM15_2 [P : ŌĄ őĻ ‚Üí ŌĄ őĻ ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° x, `‚ô° y, ¬¨ (‚ä§ ‚ąß ¬¨ (P x y))) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ x, `‚ôĘ y, P x y) ‚áí R) ‚ČĒ
begin
  assume P R h1 h2;
  refine h1 (őĽ x y htnpxy, (‚ąß‚āĎ‚āā htnpxy) (h2 x y))
end;

// ---- NRM16-19: Hypothesis lookup ----
// These are Schema 0 rules (result = TRUE) used inside
// ALL7's result sub-tree. They prove goals from hypotheses.

// NRM16: ‚ąÄx ¬∑ P in H ‚Üí H ‚äĘ (‚ô°x ¬∑ P) ‚áí Q
opaque symbol NRM16 [P : ŌĄ őĻ ‚Üí Prop] [Q : Prop]
  : ŌÄ (`‚ąÄ x, P x)
  ‚Üí ŌÄ Q
  ‚Üí ŌÄ ((`‚ô° x, P x) ‚áí Q) ‚ČĒ
begin
  assume P Q hp hq ht; refine hq
end;

opaque symbol NRM19 [Q : Prop] [R : ŌĄ őĻ ‚Üí Prop] (E : ŌĄ őĻ)
  : ŌÄ (R E)
  ‚Üí ŌÄ ((`‚ô° x, ¬¨ (‚ä§ ‚ąß R x)) ‚áí Q) ‚ČĒ
begin
  assume Q R E hr hf;
  refine ‚ä•‚āĎ (hf E (‚ąßŠĶĘ ‚ä§ŠĶĘ hr))
end;

// NRM19_2: Two-variable version.
opaque symbol NRM19_2 [Q : Prop] [R : ŌĄ őĻ ‚Üí ŌĄ őĻ ‚Üí Prop] (E F : ŌĄ őĻ)
  : ŌÄ (R E F)
  ‚Üí ŌÄ ((`‚ô° x, `‚ô° y, ¬¨ (‚ä§ ‚ąß R x y)) ‚áí Q) ‚ČĒ
begin
  assume Q R E F hr hf;
  refine ‚ä•‚āĎ (hf E F (‚ąßŠĶĘ ‚ä§ŠĶĘ hr))
end;

// ---- NRM20-23: Equality elimination under ‚ô° ----

opaque symbol NRM20 [P : ŌĄ őĻ ‚Üí ŌĄ őĻ ‚Üí Prop] [Q : Prop] (E : ŌĄ őĻ)
  : ŌÄ ((`‚ô° y, ¬¨ (P E y)) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° x, `‚ô° y, ¬¨ (P x y ‚ąß (x = E))) ‚áí Q) ‚ČĒ
begin
  assume P Q E h1 h2;
  refine h1 (őĽ y hpey, h2 E y (‚ąßŠĶĘ hpey (eq_refl E)))
end;

opaque symbol NRM21 [P : ŌĄ őĻ ‚Üí ŌĄ őĻ ‚Üí Prop] [Q : Prop] (E : ŌĄ őĻ)
  : ŌÄ ((`‚ô° y, ¬¨ (P E y)) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° x, `‚ô° y, ¬¨ (P x y ‚ąß (E = x))) ‚áí Q) ‚ČĒ
begin
  assume P Q E h1 h2;
  refine h1 (őĽ y hpey, h2 E y (‚ąßŠĶĘ hpey (eq_sym (eq_refl E))))
end;

opaque symbol NRM22 [P : ŌĄ őĻ ‚Üí Prop] [Q : Prop] (E : ŌĄ őĻ)
  : ŌÄ (¬¨ (P E) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° x, ¬¨ (P x ‚ąß (x = E))) ‚áí Q) ‚ČĒ
begin
  assume P Q E h1 h2;
  refine h1 (őĽ hpe, h2 E (‚ąßŠĶĘ hpe (eq_refl E)))
end;

opaque symbol NRM23 [P : ŌĄ őĻ ‚Üí Prop] [Q : Prop] (E : ŌĄ őĻ)
  : ŌÄ (¬¨ (P E) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° x, ¬¨ (P x ‚ąß (E = x))) ‚áí Q) ‚ČĒ
begin
  assume P Q E h1 h2;
  refine h1 (őĽ hpe, h2 E (‚ąßŠĶĘ hpe (eq_sym (eq_refl E))))
end;

// ---- NRM24-26: Simple transformations ----

// NRM24: P is not of the form A ‚ąß B;
// H ‚äĘ ‚ô°x ¬∑ ¬¨(TRUE ‚ąß P) ‚áí Q ‚Üí H ‚äĘ ‚ô°x ¬∑ ¬¨P ‚áí Q
opaque symbol NRM24 [P : ŌĄ őĻ ‚Üí Prop] [Q : Prop]
  : ŌÄ ((`‚ô° x, ¬¨ (‚ä§ ‚ąß P x)) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° x, ¬¨ (P x)) ‚áí Q) ‚ČĒ
begin
  assume P Q h1 h2;
  refine h1 (őĽ x htpx, h2 x (‚ąß‚āĎ‚āā htpx))
end;

// NRM25: x not free in P; H ‚äĘ P ‚Üí H ‚äĘ ‚ô°(x) ¬∑ P
opaque symbol NRM25 [P : Prop]
  : ŌÄ P
  ‚Üí ŌÄ (`‚ô° _ : ŌĄ őĻ, P) ‚ČĒ
begin
  assume P hp x; refine hp
end;

// NRM26: y not free in P; H ‚äĘ ‚ô°(x, ...) ¬∑ P ‚Üí H ‚äĘ ‚ô°(x, y, ...) ¬∑ P
opaque symbol NRM26 [P : ŌĄ őĻ ‚Üí Prop]
  : ŌÄ (`‚ô° x, P x)
  ‚Üí ŌÄ (`‚ô° x, `‚ąÄ _ : ŌĄ őĻ, P x) ‚ČĒ
begin
  assume P h x y; refine h x
end;

