// Normalisation (В§A.12) вҖ” tuple-based encoding.
//
// Spec uses `вҷў` (= goal-side n-ary universal) and `вҷЎ` (= hypothesis-
// side n-ary universal). Both reduce propositionally to `!!` via the
// `вҷў_eq_!!` / `вҷЎ_eq_!!` lemmas in lemmas/Tuple.lp; bodies use the dedicated
// `pi_to_вҷў` / `вҷў_to_pi` (and вҷЎ analogues) bridges.

require open pp2lp.B pp2lp.lemmas.Int pp2lp.lemmas.Tuple pp2lp.rules.Res;

// ---- NRM1-7: Logical transformations under `вҷў` ----

// NRM1: x not free in P; H вҠў P вҮ’ S вҶ’ H вҠў (вҷўx В· P) вҮ’ S
opaque symbol NRM1 [n] [P S : Prop]
  : ПҖ (P вҮ’ S)
  вҶ’ ПҖ ((`вҷў _ : Tuple n, P) вҮ’ S) вү”
begin
  assume n P S h1 h2;
  refine h1 (вҷў_to_pi (О» _ : Tuple n, P) h2 (inh_tuple [n]))
end;

// NRM2: x not free in P; H вҠў (P вҮ’ вҷўx В· Q) вҮ’ S вҶ’ H вҠў вҷўx В· (P вҮ’ Q) вҮ’ S
opaque symbol NRM2 [n] [P : Prop] [Q : Tuple n вҶ’ Prop] [S : Prop]
  : ПҖ ((P вҮ’ (`вҷў v, Q v)) вҮ’ S)
  вҶ’ ПҖ ((`вҷў v, P вҮ’ Q v) вҮ’ S) вү”
begin
  assume n P Q S h1 h2;
  refine h1 (О» p,
    pi_to_вҷў Q (О» v, вҷў_to_pi (О» v', P вҮ’ Q v') h2 v p))
end;

// NRM3: x not free in Q; H вҠў (Q вҮ’ S) вҲ§ ((вҲҖx В· В¬P) вҮ’ S) вҶ’ H вҠў вҷўx В· (P вҮ’ Q) вҮ’ S
opaque symbol NRM3 [n] [P : Tuple n вҶ’ Prop] [Q S : Prop]
  : ПҖ (вӢҖ_snoc (Q вҮ’ S) ((`!! v, В¬ (P v)) вҮ’ S))
  вҶ’ ПҖ ((`вҷў v, P v вҮ’ Q) вҮ’ S) вү”
begin
  assume n P Q S h1 h2;
  refine вҲЁвӮ‘ (em (`?? v, P v)) _ _
  { assume hex;
    refine pi_to_??_elim P
      (О» v hpv, (вӢҖвӮӮ_hd h1) (вҷў_to_pi (О» v', P v' вҮ’ Q) h2 v hpv)) hex }
  { assume hnex;
    refine (вӢҖвӮӮ_snd h1) (pi_to_!! (О» v, В¬ (P v))
      (О» v hpv, hnex (pi_to_??_intro P v hpv))) }
end;

// NRM4: x not free in Q; H вҠў (Q вҮ’ вҷўx В· (P вҮ’ R)) вҮ’ S вҶ’ H вҠў вҷўx В· (P вҮ’ Q вҮ’ R) вҮ’ S
opaque symbol NRM4 [n] [P R : Tuple n вҶ’ Prop] [Q S : Prop]
  : ПҖ ((Q вҮ’ (`вҷў v, P v вҮ’ R v)) вҮ’ S)
  вҶ’ ПҖ ((`вҷў v, P v вҮ’ Q вҮ’ R v) вҮ’ S) вү”
begin
  assume n P R Q S h1 h2;
  refine h1 (О» hq,
    pi_to_вҷў (О» v, P v вҮ’ R v)
      (О» v hpv, вҷў_to_pi (О» v', P v' вҮ’ Q вҮ’ R v') h2 v hpv hq))
end;

// NRM5: H вҠў вҷўx В· (P вҲ§ Q вҮ’ R) вҮ’ S вҶ’ H вҠў вҷўx В· (P вҮ’ Q вҮ’ R) вҮ’ S
// Uncurry: `вӢҖ_snoc (P v) (Q v)` reduces to `вӢҖ (вҲҺ вҲ· P v вҲ· Q v)`, so the
// hypothesis splits with `вӢҖвӮӮ_hd`/`вӢҖвӮӮ_snd` to feed the curried body.
opaque symbol NRM5 [n] [P Q R : Tuple n вҶ’ Prop] [S : Prop]
  : ПҖ ((`вҷў v, вӢҖ_snoc (P v) (Q v) вҮ’ R v) вҮ’ S)
  вҶ’ ПҖ ((`вҷў v, P v вҮ’ Q v вҮ’ R v) вҮ’ S) вү”
begin
  assume n P Q R S h1 h2;
  refine h1 (pi_to_вҷў (О» v, вӢҖ_snoc (P v) (Q v) вҮ’ R v)
    (О» v hpq, вҷў_to_pi (О» v', P v' вҮ’ Q v' вҮ’ R v') h2 v
                (вӢҖвӮӮ_hd hpq) (вӢҖвӮӮ_snd hpq)))
end;

// NRM6: H вҠў вҷўx В· (R вҮ’ P) вҮ’ (вҷўx В· (R вҮ’ Q) вҮ’ S) вҶ’ H вҠў вҷўx В· (R вҮ’ P вҲ§ Q) вҮ’ S
// Generalised over a snoc list: the consequent `вӢҖ (qs v вҲ· P v)` splits into
// init `вӢҖ (qs v)` and last `P v`.  init-first lets the emitter chain
// `refine NRM6 _;` for n-conjunct goals, since `вӢҖ (qs v)` is itself a
// `вӢҖ (qs' v вҲ· P' v)` when |qs v| вүҘ 2.
opaque symbol NRM6 [n] [Qs : Tuple n вҶ’ рқ•ғ* o] [P R : Tuple n вҶ’ Prop] [S : Prop]
  : ПҖ ((`вҷў v, R v вҮ’ вӢҖ (Qs v)) вҮ’ ((`вҷў v, R v вҮ’ P v) вҮ’ S))
  вҶ’ ПҖ ((`вҷў v, R v вҮ’ вӢҖ (Qs v вҲ· P v)) вҮ’ S) вү”
begin
  assume n qs P R S h1 h2;
  refine h1
    (pi_to_вҷў (О» v, R v вҮ’ вӢҖ (qs v))
      (О» v hr, вӢҖ_init (вҷў_to_pi (О» v', R v' вҮ’ вӢҖ (qs v' вҲ· P v')) h2 v hr)))
    (pi_to_вҷў (О» v, R v вҮ’ P v)
      (О» v hr, вӢҖ_last (вҷў_to_pi (О» v', R v' вҮ’ вӢҖ (qs v' вҲ· P v')) h2 v hr)))
end;

// NRM7: H вҠў (вҷўx В· P) вҮ’ ((вҷўx В· Q) вҮ’ S) вҶ’ H вҠў вҷўx В· (P вҲ§ Q) вҮ’ S
// Generalised: same shape as NRM6 but without the R вҮ’ antecedent.
opaque symbol NRM7 [n] [Qs : Tuple n вҶ’ рқ•ғ* o] [P : Tuple n вҶ’ Prop] [S : Prop]
  : ПҖ ((`вҷў v, вӢҖ (Qs v))
        вҮ’ ((`вҷў v, P v) вҮ’ S))
  вҶ’ ПҖ ((`вҷў v : Tuple n, вӢҖ (Qs v вҲ· P v)) вҮ’ S) вү”
begin
  assume n qs P S h1 h2;
  refine h1
    (pi_to_вҷў (О» v, вӢҖ (qs v))
      (О» v, вӢҖ_init (вҷў_to_pi (О» v', вӢҖ (qs v' вҲ· P v')) h2 v)))
    (pi_to_вҷў (О» v, P v)
      (О» v, вӢҖ_last (вҷў_to_pi (О» v', вӢҖ (qs v' вҲ· P v')) h2 v)))
end;

// ---- NRM8-9: compoundвҶ”mixed binders (split with `take`/`drop`) ----
//
// NRM8: spec is `(вҷў(x,y) В· Q) вҮ’ S` вҶҗ `(вҷўx В· вҲҖy В· Q) вҮ’ S`.
// Encoded with the n,m-indexed split helpers from B.lp:
//   the conclusion's `Q x y` (clean HO pattern) gets unified back
//   from the premise's `Q (take v) (drop v)` after Lambdapi infers Q.
opaque symbol NRM8 [n m] [Q : Tuple n вҶ’ Tuple m вҶ’ Prop] [S : Prop]
  : ПҖ ((`вҷў v : Tuple (n ++ m), Q (take [n] [m] v) (drop [n] [m] v)) вҮ’ S)
  вҶ’ ПҖ ((`вҷў x : Tuple n, `!! y : Tuple m, Q x y) вҮ’ S) вү”
begin
  assume n m Q S h hnested;
  // hnested : ПҖ (`вҷў x : Tuple n, `!! y : Tuple m, Q x y)
  // Need:    ПҖ (`вҷў v : Tuple (n ++ m), Q (take v) (drop v))
  // Witness: О» v, !!_to_pi (Q x) (вҷў_to_pi (О» x, `!! y, Q x y) hnested x') y'
  //          where x' = take v, y' = drop v.
  refine h (pi_to_вҷў (О» v : Tuple (n ++ m),
                       Q (take [n] [m] v) (drop [n] [m] v))
    (О» v : Tuple (n ++ m),
       !!_to_pi (О» y, Q (take [n] [m] v) y)
                (вҷў_to_pi (О» x, `!! y : Tuple m, Q x y)
                         hnested
                         (take [n] [m] v))
                (drop [n] [m] v)))
end;

// NRM9: spec is `(вҷў(x,y) В· (P вҮ’ Q)) вҮ’ S` вҶҗ `(вҷўx В· (P вҮ’ вҲҖy В· Q)) вҮ’ S`,
// with y not free in P. Same split: premise body is `P (take v) вҮ’ Q (take v) (drop v)`.
opaque symbol NRM9 [n m]
  [P : Tuple n вҶ’ Prop]
  [Q : Tuple n вҶ’ Tuple m вҶ’ Prop]
  [S : Prop]
  : ПҖ ((`вҷў v : Tuple (n ++ m),
         P (take [n] [m] v) вҮ’ Q (take [n] [m] v) (drop [n] [m] v)) вҮ’ S)
  вҶ’ ПҖ ((`вҷў x : Tuple n, P x вҮ’ (`!! y : Tuple m, Q x y)) вҮ’ S) вү”
begin
  assume n m P Q S h hnested;
  refine h (pi_to_вҷў
    (О» v, P (take [n] [m] v) вҮ’ Q (take [n] [m] v) (drop [n] [m] v))
    (О» v hp,
       !!_to_pi (О» y, Q (take [n] [m] v) y)
                (вҷў_to_pi (О» x, P x вҮ’ (`!! y : Tuple m, Q x y))
                         hnested
                         (take [n] [m] v)
                         hp)
                (drop [n] [m] v)))
end;

// ---- NRM10-15: Implication / negation under `вҷў` and `вҷЎ` ----

// NRM10: H вҠў вҷЎx В· В¬(P вҲ§ Q) вҮ’ R вҶ’ H вҠў вҷўx В· (P вҲ§ Q вҮ’ вҠҘ) вҮ’ R
opaque symbol NRM10 [n] [Ps : Tuple n вҶ’ рқ•ғ* o] [Q : Tuple n вҶ’ Prop] [R : Prop]
  : ПҖ ((`вҷЎ v, В¬ вӢҖ (Ps v вҲ· Q v)) вҮ’ R)
  вҶ’ ПҖ ((`вҷў v, вӢҖ (Ps v вҲ· Q v) вҮ’ вҠҘ) вҮ’ R) вү”
begin
  assume n Ps Q R h1 h2;
  refine h1 (pi_to_вҷЎ (О» v, В¬ вӢҖ (Ps v вҲ· Q v))
    (О» v hpq, вҷў_to_pi (О» v', вӢҖ (Ps v' вҲ· Q v') вҮ’ вҠҘ) h2 v hpq))
end;

// NRM11: H вҠў вҷЎx В· В¬(вҠӨ вҲ§ P) вҮ’ R вҶ’ H вҠў вҷўx В· (P вҮ’ вҠҘ) вҮ’ R
opaque symbol NRM11 [n] [P : Tuple n вҶ’ Prop] [R : Prop]
  : ПҖ ((`вҷЎ v, В¬ (вӢҖ_snoc вҠӨ (P v))) вҮ’ R)
  вҶ’ ПҖ ((`вҷў v, P v вҮ’ вҠҘ) вҮ’ R) вү”
begin
  assume n P R h1 h2;
  refine h1 (pi_to_вҷЎ (О» v, В¬ вӢҖ (вҲҺ вҲ· вҠӨ вҲ· P v))
    (О» v htpv, вҷў_to_pi (О» v', P v' вҮ’ вҠҘ) h2 v (вӢҖвӮӮ_snd htpv)))
end;

// NRM12: H вҠў вҷЎx В· В¬(P вҲ§ Q) вҮ’ R вҶ’ H вҠў вҷўx В· (P вҮ’ В¬Q) вҮ’ R
opaque symbol NRM12 [n] [P Q : Tuple n вҶ’ Prop] [R : Prop]
  : ПҖ ((`вҷЎ v, В¬ вӢҖ_snoc (P v) (Q v)) вҮ’ R)
  вҶ’ ПҖ ((`вҷў v, P v вҮ’ В¬ (Q v)) вҮ’ R) вү”
begin
  assume n P Q R h1 h2;
  refine h1 (pi_to_вҷЎ (О» v, В¬ вӢҖ (вҲҺ вҲ· P v вҲ· Q v))
    (О» v hpq, вҷў_to_pi (О» v', P v' вҮ’ В¬ (Q v')) h2 v
                (вӢҖвӮӮ_hd hpq) (вӢҖвӮӮ_snd hpq)))
end;

// NRM13: H вҠў вҷЎx В· В¬(P вҲ§ В¬Q) вҮ’ R вҶ’ H вҠў вҷўx В· (P вҮ’ Q) вҮ’ R
opaque symbol NRM13 [n] [P Q : Tuple n вҶ’ Prop] [R : Prop]
  : ПҖ ((`вҷЎ v, В¬ вӢҖ_snoc (P v) (В¬ Q v)) вҮ’ R)
  вҶ’ ПҖ ((`вҷў v, P v вҮ’ Q v) вҮ’ R) вү”
begin
  assume n P Q R h1 h2;
  refine h1 (pi_to_вҷЎ (О» v, В¬ вӢҖ (вҲҺ вҲ· P v вҲ· В¬ (Q v)))
    (О» v hc, (вӢҖвӮӮ_snd hc) (вҷў_to_pi (О» v', P v' вҮ’ Q v') h2 v (вӢҖвӮӮ_hd hc))))
end;

// NRM14: H вҠў вҷЎx В· В¬(вҠӨ вҲ§ P) вҮ’ R вҶ’ H вҠў (вҷўx В· В¬P) вҮ’ R
opaque symbol NRM14 [n] [P : Tuple n вҶ’ Prop] [R : Prop]
  : ПҖ ((`вҷЎ v, В¬ вӢҖ_snoc вҠӨ (P v)) вҮ’ R)
  вҶ’ ПҖ ((`вҷў v, В¬ (P v)) вҮ’ R) вү”
begin
  assume n P R h1 h2;
  refine h1 (pi_to_вҷЎ (О» v, В¬ вӢҖ (вҲҺ вҲ· вҠӨ вҲ· P v))
    (О» v htpv, вҷў_to_pi (О» v', В¬ (P v')) h2 v (вӢҖвӮӮ_snd htpv)))
end;

// NRM15: H вҠў вҷЎx В· В¬(вҠӨ вҲ§ В¬P) вҮ’ R вҶ’ H вҠў (вҷўx В· P) вҮ’ R
opaque symbol NRM15 [n] [P : Tuple n вҶ’ Prop] [R : Prop]
  : ПҖ ((`вҷЎ v, В¬ вӢҖ_snoc вҠӨ (В¬ P v)) вҮ’ R)
  вҶ’ ПҖ ((`вҷў v, P v) вҮ’ R) вү”
begin
  assume n P R h1 h2;
  refine h1 (pi_to_вҷЎ (О» v, В¬ вӢҖ (вҲҺ вҲ· вҠӨ вҲ· В¬ (P v)))
    (О» v htnpv, (вӢҖвӮӮ_snd htnpv) (вҷў_to_pi P h2 v)))
end;

// ---- NRM16-19: Universal-instantiation patterns ----

// NRM16: вҲҖx.P in H; Q вҶ’ H вҠў (вҷЎx В· P) вҮ’ Q
opaque symbol NRM16 [n] [P : Tuple n вҶ’ Prop] [Q : Prop]
  : ПҖ (`!! v, P v)
  вҶ’ ПҖ Q
  вҶ’ ПҖ ((`вҷЎ v, P v) вҮ’ Q) вү”
begin
  assume n P Q hp hq ht; refine hq
end;

// NRM17: NRM16 with extra spec-level equality side-conditions.
// At the LP level the proof obligation collapses to NRM16's shape.
opaque symbol NRM17 [n] [P : Tuple n вҶ’ Prop] [Q : Prop]
  : ПҖ (`!! v, P v)
  вҶ’ ПҖ Q
  вҶ’ ПҖ ((`вҷЎ v, P v) вҮ’ Q) вү”
begin
  assume n P Q hp hq ht; refine hq
end;

// NRM18: вҲҖx В· В¬(вҠӨ вҲ§ В¬P) in H; вҲғE. [x:=E]P = R вҶ’ H вҠў вҷЎy В· В¬(вҠӨ вҲ§ R) вҮ’ Q
opaque symbol NRM18 [n] [P : Tuple n вҶ’ Prop] [R Q : Prop] (v : Tuple n)
  : ПҖ (`!! u, В¬ вӢҖ_snoc вҠӨ (В¬ P u))
  вҶ’ ПҖ (P v = R)
  вҶ’ ПҖ ((`вҷЎ _ : Tuple n, В¬ вӢҖ_snoc вҠӨ R) вҮ’ Q) вү”
begin
  assume n P R Q v hp heq h;
  // Derive ПҖ (P v) classically.
  have hpv : ПҖ (P v)
    { refine В¬В¬вӮ‘ (P v) _;
      assume hnpv;
      refine !!_to_pi (О» u, В¬ вӢҖ (вҲҺ вҲ· вҠӨ вҲ· В¬ (P u))) hp v (вӢҖвӮӮ_intro вҠӨбөў hnpv) };
  // Transport along heq.
  have hr : ПҖ R { rewrite left heq; refine hpv };
  refine вҠҘвӮ‘ (вҷЎ_to_pi (О» _ : Tuple n, В¬ вӢҖ (вҲҺ вҲ· вҠӨ вҲ· R)) h (inh_tuple [n])
              (вӢҖвӮӮ_intro вҠӨбөў hr))
end;

// NRM19: P in H; вҲғE. [x:=E]R = P вҶ’ H вҠў вҷЎx В· В¬(вҠӨ вҲ§ R) вҮ’ Q
opaque symbol NRM19 [n] [Q : Prop] [R : Tuple n вҶ’ Prop] (v : Tuple n)
  : ПҖ (R v)
  вҶ’ ПҖ ((`вҷЎ u, В¬ вӢҖ_snoc вҠӨ (R u)) вҮ’ Q) вү”
begin
  assume n Q R v hr hf;
  refine вҠҘвӮ‘ (вҷЎ_to_pi (О» u, В¬ вӢҖ (вҲҺ вҲ· вҠӨ вҲ· R u)) hf v (вӢҖвӮӮ_intro вҠӨбөў hr))
end;

// ---- NRM20-23: Substitution (drop a binder pinned by an equality) ----
//
// PP pins *whichever* binder an equality conjunct fixes, at *any* slot k of the
// вҷЎ-block, with the witness E a function of the remaining binders (`#x.#y.(x=y)`
// pins x at y).  `ins`/`rm` (B.lp) splice slot k in and out and `prj_ins`
// (lemmas/Tuple.lp) is the round-trip, so one lemma вҖ” NRM20 вҖ” covers every slot;
// the emitter supplies k and E, and bubbles the pinning equality to the conjunct
// list's *tail* (`qs v вҲ· eq`) first when PP places it elsewhere.  The one shape it
// does NOT route here вҖ” slot-0 head equality with block-closed E (PP's `В¬(x=E вҲ§ вҖҰ)`,
// all of prv) вҖ” takes the NRM20H fast path below, which peels the head equality
// with popl/dropl and so skips that per-site rotation.  NRM21 is the reversed-
// equality (`E = x`) orientation; NRM22/23 (below) are the unary instances PP
// emits with no surrounding block.
//
//   H вҠў вҷЎv'В·В¬(qs[xвӮ–:=E v'])        H вҠў вҷЎvВ·В¬(qs вҲ§ (prj k v = E (rm k v)))
opaque symbol NRM20 [n] (k : в„•) [qs : Tuple (+1 n) вҶ’ рқ•ғ* o] [Q : Prop]
  (E : Tuple n вҶ’ П„ О№)
  : ПҖ ((`вҷЎ v' : Tuple n, В¬ вӢҖ (qs (ins k (E v') v'))) вҮ’ Q)
  вҶ’ ПҖ ((`вҷЎ v : Tuple (+1 n), В¬ вӢҖ (qs v вҲ· (prj k v = E (rm k v)))) вҮ’ Q) вү”
begin
  assume n k qs Q E hsmall hbig;
  refine hsmall (pi_to_вҷЎ (О» v' : Tuple n, В¬ вӢҖ (qs (ins k (E v') v')))
    (О» v' hq,
      вҷЎ_to_pi (О» v, В¬ вӢҖ (qs v вҲ· (prj k v = E (rm k v)))) hbig (ins k (E v') v')
        (вӢҖ_intro hq (prj_ins k (E v') v'))))
end;

// NRM20H: fast path for the common shape вҖ” pinning equality at the conjunct
// *head*, slot 0, E block-closed.  popl/dropl peel the head equality directly (no
// rotation), and slot 0 is a plain `v' вЁҫ E` (no `ins`/`rm`).  Semantically the
// slot-0 head case of NRM20; kept separate only because the rotation NRM20 would
// need here is the per-site cost that dominates prv's NRM20-dense proofs.
opaque symbol NRM20H [n] [ps : Tuple (+1 n) вҶ’ рқ•ғ* o] [Q : Prop] (E : П„ О№)
  : (О  v', ПҖ (popl (ps v') = (prj 0 v' = E)))
  вҶ’ ПҖ ((`вҷЎ v' : Tuple n, В¬ вӢҖ dropl (ps (v' вЁҫ E))) вҮ’ Q)
  вҶ’ ПҖ ((`вҷЎ v : Tuple (+1 n), В¬ вӢҖ (ps v)) вҮ’ Q) вү”
begin
  assume n ps Q E heq hsmall hbig;
  refine hsmall (pi_to_вҷЎ (О» v' : Tuple n, В¬ вӢҖ dropl (ps (v' вЁҫ E)))
    (О» v' hp,
      вҷЎ_to_pi (О» v, В¬ вӢҖ (ps v)) hbig (v' вЁҫ E)
        (вӢҖ_pop_intro (ps (v' вЁҫ E))
          (=вҮ’ (eq_sym (heq (v' вЁҫ E))) (eq_refl E))
          hp)))
end;

// NRM21: NRM20 with the equality reversed (`E (rm k v) = prj k v`).
opaque symbol NRM21 [n] (k : в„•) [qs : Tuple (+1 n) вҶ’ рқ•ғ* o] [Q : Prop]
  (E : Tuple n вҶ’ П„ О№)
  : ПҖ ((`вҷЎ v' : Tuple n, В¬ вӢҖ (qs (ins k (E v') v'))) вҮ’ Q)
  вҶ’ ПҖ ((`вҷЎ v : Tuple (+1 n), В¬ вӢҖ (qs v вҲ· (E (rm k v) = prj k v))) вҮ’ Q) вү”
begin
  assume n k qs Q E hsmall hbig;
  refine hsmall (pi_to_вҷЎ (О» v' : Tuple n, В¬ вӢҖ (qs (ins k (E v') v')))
    (О» v' hq,
      вҷЎ_to_pi (О» v, В¬ вӢҖ (qs v вҲ· (E (rm k v) = prj k v))) hbig (ins k (E v') v')
        (вӢҖ_intro hq (eq_sym (prj_ins k (E v') v')))))
end;

// NRM22: the вҷЎ-body's tail equality pins the binder at E (general list
// form; the вҠӨ-headed NRM14-fed shape is the instance ps := О» _, (вҲҺ вҲ· вҠӨ)).
opaque symbol NRM22 [Q : Prop] [ps : Tuple 1 вҶ’ рқ•ғ* o] (E : П„ О№)
  : ПҖ (В¬ вӢҖ (ps (unit вЁҫ E)) вҮ’ Q)
  вҶ’ ПҖ ((`вҷЎ v : Tuple 1, В¬ вӢҖ (ps v вҲ· (prj 0 v = E))) вҮ’ Q) вү”
begin
  assume Q ps E h1 h2;
  refine h1 (О» hps,
    вҷЎ_to_pi (О» v : Tuple 1, В¬ вӢҖ (ps v вҲ· (prj 0 v = E)))
            h2 (unit вЁҫ E)
            (вӢҖ_intro hps (eq_refl E)))
end;

// NRM23: NRM22 with reversed equality (вҠӨ-headed special case; kept for the
// chain-form nrm23_eq bridge).
opaque symbol NRM23 [Q : Prop] (E : П„ О№)
  : ПҖ (В¬ вҠӨ вҮ’ Q)
  вҶ’ ПҖ ((`вҷЎ v : Tuple 1,
         В¬ вӢҖ (вҲҺ вҲ· вҠӨ вҲ· (E = prj 0 v))) вҮ’ Q) вү”
begin
  assume Q E h1 h2;
  refine h1 (О» ht,
    вҷЎ_to_pi (О» v : Tuple 1, В¬ вӢҖ (вҲҺ вҲ· вҠӨ вҲ· (E = prj 0 v)))
            h2 (unit вЁҫ E)
            (вӢҖвӮӮ_intro ht (eq_refl E)))
end;

// NRM23G: the general-list reversed form (NRM22's exact mirror) вҖ” the
// main-tree emitter uses this one uniformly.
opaque symbol NRM23G [Q : Prop] [ps : Tuple 1 вҶ’ рқ•ғ* o] (E : П„ О№)
  : ПҖ (В¬ вӢҖ (ps (unit вЁҫ E)) вҮ’ Q)
  вҶ’ ПҖ ((`вҷЎ v : Tuple 1, В¬ вӢҖ (ps v вҲ· (E = prj 0 v))) вҮ’ Q) вү”
begin
  assume Q ps E h1 h2;
  refine h1 (О» hps,
    вҷЎ_to_pi (О» v : Tuple 1, В¬ вӢҖ (ps v вҲ· (E = prj 0 v)))
            h2 (unit вЁҫ E)
            (вӢҖ_intro hps (eq_refl E)))
end;

// ---- NRM24-26: Trivial structural rules ----

// NRM24: P not of form A вҲ§ B; H вҠў вҷЎx В· В¬(вҠӨ вҲ§ P) вҮ’ Q вҶ’ H вҠў вҷЎx В· В¬P вҮ’ Q
opaque symbol NRM24 [n] [P : Tuple n вҶ’ Prop] [Q : Prop]
  : ПҖ ((`вҷЎ v, В¬ вӢҖ (вҲҺ вҲ· вҠӨ вҲ· P v)) вҮ’ Q)
  вҶ’ ПҖ ((`вҷЎ v, В¬ (P v)) вҮ’ Q) вү”
begin
  assume n P Q h1 h2;
  refine h1 (pi_to_вҷЎ (О» v, В¬ вӢҖ (вҲҺ вҲ· вҠӨ вҲ· P v))
    (О» v htpv, вҷЎ_to_pi (О» v', В¬ (P v')) h2 v (вӢҖвӮӮ_snd htpv)))
end;

// NRM25: x not free in P; H вҠў P вҶ’ H вҠў вҷЎ(x) В· P
//   = forall2(x).P in PP notation. `pi_to_вҷЎ` with constant predicate
//   (the body doesn't depend on the bound tuple).
opaque symbol NRM25 [n] [P : Prop] [Q : Prop]
  : ПҖ (P вҮ’ Q)
  вҶ’ ПҖ ((`вҷЎ _ : Tuple n, P) вҮ’ Q) вү”
begin
  assume n P Q hp hвҷЎ;
  refine hp (вҷЎ_to_pi (О» _, P) hвҷЎ (inh_tuple [n]))
end;

// NRM26: y not free in P; H вҠў вҷЎ(x,вҖҰ)В·P вҶ’ H вҠў вҷЎ(x,y,вҖҰ)В·P.  PP drops the unused
// binder at *any* slot k; one lemma covers them all вҖ” instantiate the вҷЎ at
// `ins k (el О№) v'`.  The dropped slot is never read, so the dummy is `el О№` (the
// canonical inhabitant), not a misleading рқҹҺ.  The emitter supplies k (the dropped
// var's position, read off the annotation diff against the child's binder list).
opaque symbol NRM26 [n] (k : в„•) [P : Tuple (+1 n) вҶ’ Prop] [Q : Prop]
  : ПҖ ((`вҷЎ v' : Tuple n, P (ins k (el О№) v')) вҮ’ Q)
  вҶ’ ПҖ ((`вҷЎ v : Tuple (+1 n), P v) вҮ’ Q) вү”
begin
  assume n k P Q hp hвҷЎ;
  refine hp (pi_to_вҷЎ (О» v', P (ins k (el О№) v'))
    (О» v', вҷЎ_to_pi (О» v, P v) hвҷЎ (ins k (el О№) v')))
end;

// ---- NRM27-30: Arithmetic solver dispatch (trust-free) ----
//
// PP's solver closes a universal hypothesis `вҷЎ(xвӮҒ,вҖҰ,xвӮҷ)В·В¬(P вҲ§ вҖҰ вҲ§ Q)`
// when the conjunction holds two bounding inequalities `a + xбөў вүӨ рқҹҺ` and
// `b вҲ’ xбөў вүӨ рқҹҺ` with `solveur(a + b) = рқҹҺ`: those force `xбөў = b`, and the
// substituted conjunction `[xбөў := b](P вҲ§ вҖҰ вҲ§ Q)` is satisfiable, so the
// universal-of-negation is *false* and discharges the sequent.
//
// One lemma, NRM29, realises all four PP rules: peel the pinned binder by
// *instantiating* the `вҷЎ`-hypothesis at the solver witness `b` (the membership
// premises the spec carries are solver bookkeeping вҖ” unused here), leaving the
// continuation `вҷўv'В·В¬вӢҖ(ps (v' вЁҫ b v')) вҮ’ R`; the emitter bridges the substituted
// conjunction `вӢҖ (ps (v' вЁҫ b v'))` to вҠӨ with a generated congruence proof (each
// cancelling bound = вҠӨ via `eq_true` + `leq_zero_of_sum_zero` + `prove_sum_eq`).
// NRM27/28 are the `xбөў := рқҹҺ` case (b = рқҹҺ) and NRM30 the unary (вҷЎx) case вҖ” the
// emitter maps all of NRM27/28/30 onto NRM29 with the matching witness.  Only
// NRM29 is corpus-triggered (apero); the others have no replay.

// ---- helper lemmas for the trust-free solver dispatch ----

// `P` provably true вҹ№ `P = вҠӨ`, so a вӢҖ-conjunct the solver discharges can
// be rewritten to вҠӨ and absorbed by `вӢҖ (_ вҲ· вҠӨ) вҶӘ вӢҖ _`.
opaque symbol eq_true (P : Prop) : ПҖ P вҶ’ ПҖ (P = вҠӨ) вү”
begin
  assume P h;
  refine propExt _ _ _ _
  { assume hp; refine вҠӨбөў }
  { assume ht; refine h }
end;

// A sum that arithmetic-normalises to рқҹҺ is вүӨ рқҹҺ.  The emitter builds the
// `E = рқҹҺ` proof with `prove_sum_eq` (add_comm/assoc/opp cancellation).
opaque symbol leq_zero_of_sum_zero (E : П„ О№) : ПҖ (E = рқҹҺ) вҶ’ ПҖ (leq E рқҹҺ) вү”
begin
  assume E h;
  rewrite h;
  refine leq_refl рқҹҺ
end;

// NRM29: multi-binder, pin the prj0 slot to `b v'` (witness a function of
// the remaining binders вҖ” e.g. b v' = вҖ” prj 0 v' for the sum-zero /
// cancelling case).  The emitter supplies `b` and the вҠӨ-normalisation
// bridge for the substituted conjunction `вӢҖ (ps (v' вЁҫ b v'))`.
opaque symbol NRM29 [n] [ps : Tuple (+1 n) вҶ’ рқ•ғ* o] [R : Prop] (b : Tuple n вҶ’ П„ О№)
  : ПҖ ((`вҷў v' : Tuple n, В¬ вӢҖ (ps (v' вЁҫ b v'))) вҮ’ R)
  вҶ’ ПҖ ((`вҷЎ v : Tuple (+1 n), В¬ вӢҖ (ps v)) вҮ’ R) вү”
begin
  assume n ps R b h_prem hвҷЎ;
  refine h_prem (pi_to_вҷў (О» v', В¬ вӢҖ (ps (v' вЁҫ b v')))
    (О» v', вҷЎ_to_pi (О» v, В¬ вӢҖ (ps v)) hвҷЎ (v' вЁҫ b v')))
end;

// ---- `_1` (Result-form) variants вҖ” В§8.13 ----
//
// PP leaves NRM rules *unprimed* in the first-normalisation chain (unlike
// ALL7/ALL9/STOP/IMP), so the emitter primes a chain-context `NRM<k>` to
// `NRM<k>_1` (`Emit_ctx.chain_emit_name`).  Each chain form lifts the base
// rule's premiseвҶ’conclusion implication to a `Res`-to-`Res` map through a
// bridge equality `nrm<k>_eq : conclusion = premise`; the body is the uniform
// `mk_1 (res_tm r) (eq_trans (@nrm<k>_eq вҖҰ) (res_eq r))`.  Every NRM rule that
// can appear in a Res chain needs one (see CLAUDE.md: emitting an undefined
// `NRM<k>_1` shows up as a lambdapi "Unknown symbol", not a fail-loud emit).

symbol NRM1_1 [n] [P Q : Prop]
  (r : Res (P вҮ’ Q)) : Res ((`вҷў _ : Tuple n, P) вҮ’ Q)
  вү” mk_1 (res_tm r) (eq_trans (@nrm1_eq n P Q) (res_eq r));

// NRM2 bridge (evidence form).  PP's chain NRM2 weakens the вҷў-body by a v-free
// hypothesis P (`(вҷўvВ·Q v) вҮ’ S  вҶҰ  (вҷўvВ·(PвҮ’Q v)) вҮ’ S`), sound only given a proof
// of P: under `hp : ПҖ P` the body equivalence `(PвҮ’Q v) вҹә Q v` holds, lifted
// under the вҷў by `!!_cong`.  Unlike the unconditional nrmK_eq bridges this
// takes `hp`, so the emitter must supply it (translate.ml NRM2 chain dispatch).
opaque symbol nrm2_eq [n] [P : Prop] [Q : Tuple n вҶ’ Prop] [S : Prop] (hp : ПҖ P)
  : ПҖ (((`вҷў v, P вҮ’ Q v) вҮ’ S) = ((`вҷў v, Q v) вҮ’ S)) вү”
begin
  assume n P Q S hp;
  have hbody : О  v, ПҖ ((P вҮ’ Q v) = (Q v))
    { assume v; refine propExt _ _ (О» hpq, hpq hp) (О» hq _, hq) };
  have hpred : ПҖ ((`вҷў v, P вҮ’ Q v) = (`вҷў v, Q v))
    { refine eq_trans (вҷў_eq_!! (О» v, P вҮ’ Q v))
        (eq_trans (!!_cong hbody) (eq_sym (вҷў_eq_!! (О» v, Q v)))) };
  rewrite hpred; reflexivity
end;

// NRM2_1 вҖ” chain (Res) form of NRM2, via the evidence-form `nrm2_eq` above.
symbol NRM2_1 [n] [P : Prop] [Q : Tuple n вҶ’ Prop] [S : Prop] (hp : ПҖ P)
  (r : Res ((`вҷў v, Q v) вҮ’ S)) : Res ((`вҷў v, P вҮ’ Q v) вҮ’ S)
  вү” mk_1 (res_tm r) (eq_trans (@nrm2_eq n P Q S hp) (res_eq r));

// NRM14_1 вҖ” chain (Res) form of NRM14.  PP leaves NRM rules *unprimed* in the
// first-normalisation chain (unlike ALL7/ALL9/STOP/IMP), so the emitter maps a
// chain-context `NRM14` to this; `nrm14_eq` (Res.lp) is the bridge equality.
symbol NRM14_1 [n] [P : Tuple n вҶ’ Prop] [R : Prop]
  (r : Res ((`вҷЎ v, В¬ вӢҖ_snoc вҠӨ (P v)) вҮ’ R)) : Res ((`вҷў v, В¬ (P v)) вҮ’ R)
  вү” mk_1 (res_tm r) (eq_trans (@nrm14_eq n P R) (res_eq r));

// NRM13_1 вҖ” chain (Res) form of NRM13, via the `nrm13_eq` bridge (Res.lp).
symbol NRM13_1 [n] [P Q : Tuple n вҶ’ Prop] [R : Prop]
  (r : Res ((`вҷЎ v, В¬ вӢҖ_snoc (P v) (В¬ Q v)) вҮ’ R)) : Res ((`вҷў v, P v вҮ’ Q v) вҮ’ R)
  вү” mk_1 (res_tm r) (eq_trans (@nrm13_eq n P Q R) (res_eq r));

// NRM12_1 вҖ” chain (Res) form of NRM12, via the `nrm12_eq` bridge (Res.lp).
symbol NRM12_1 [n] [P Q : Tuple n вҶ’ Prop] [R : Prop]
  (r : Res ((`вҷЎ v, В¬ вӢҖ_snoc (P v) (Q v)) вҮ’ R)) : Res ((`вҷў v, P v вҮ’ В¬ (Q v)) вҮ’ R)
  вү” mk_1 (res_tm r) (eq_trans (@nrm12_eq n P Q R) (res_eq r));

// NRM15_1 вҖ” chain (Res) form of NRM15, via the `nrm15_eq` bridge (Res.lp).
symbol NRM15_1 [n] [P : Tuple n вҶ’ Prop] [R : Prop]
  (r : Res ((`вҷЎ v, В¬ вӢҖ_snoc вҠӨ (В¬ (P v))) вҮ’ R)) : Res ((`вҷў v, P v) вҮ’ R)
  вү” mk_1 (res_tm r) (eq_trans (@nrm15_eq n P R) (res_eq r));

// NRM5_1 вҖ” chain (Res) form of NRM5, via the `nrm5_eq` bridge (Res.lp).
symbol NRM5_1 [n] [P Q R : Tuple n вҶ’ Prop] [S : Prop]
  (r : Res ((`вҷў v, вӢҖ_snoc (P v) (Q v) вҮ’ R v) вҮ’ S))
  : Res ((`вҷў v, P v вҮ’ Q v вҮ’ R v) вҮ’ S)
  вү” mk_1 (res_tm r) (eq_trans (@nrm5_eq n P Q R S) (res_eq r));

// NRM10_1 вҖ” chain (Res) form of NRM10, via the `nrm10_eq` bridge (Res.lp).
symbol NRM10_1 [n] [Ps : Tuple n вҶ’ рқ•ғ* o] [Q : Tuple n вҶ’ Prop] [R : Prop]
  (r : Res ((`вҷЎ v, В¬ вӢҖ (Ps v вҲ· Q v)) вҮ’ R))
  : Res ((`вҷў v, вӢҖ (Ps v вҲ· Q v) вҮ’ вҠҘ) вҮ’ R)
  вү” mk_1 (res_tm r) (eq_trans (@nrm10_eq n Ps Q R) (res_eq r));

// NRM24_1 вҖ” chain (Res) form of NRM24, via the `nrm24_eq` bridge (Res.lp).
symbol NRM24_1 [n] [P : Tuple n вҶ’ Prop] [Q : Prop]
  (r : Res ((`вҷЎ v, В¬ вӢҖ (вҲҺ вҲ· вҠӨ вҲ· P v)) вҮ’ Q))
  : Res ((`вҷЎ v, В¬ (P v)) вҮ’ Q)
  вү” mk_1 (res_tm r) (eq_trans (@nrm24_eq n P Q) (res_eq r));

// NRM3 bridge: ((вҷўvВ·(P v вҮ’ Q)) вҮ’ S) = ((Q вҮ’ S) вҲ§ ((вҲҖvВ·В¬P v) вҮ’ S)), Q is v-free.
// (Lives here, not Res.lp, because the вҮҗ direction reuses NRM3 itself; the вҮ’
// direction builds the вҷў witness from Q, or vacuously from В¬P v.)
opaque symbol nrm3_eq [n] [P : Tuple n вҶ’ Prop] [Q S : Prop]
  : ПҖ (((`вҷў v, P v вҮ’ Q) вҮ’ S) = вӢҖ_snoc (Q вҮ’ S) ((`!! v, В¬ (P v)) вҮ’ S)) вү”
begin
  assume n P Q S;
  refine propExt _ _
    (О» hres, вӢҖвӮӮ_intro
       (О» hq, hres (pi_to_вҷў (О» v, P v вҮ’ Q) (О» v hpv, hq)))
       (О» hnp, hres (pi_to_вҷў (О» v, P v вҮ’ Q)
                       (О» v hpv, вҠҘвӮ‘ (!!_to_pi (О» v, В¬ (P v)) hnp v hpv)))))
    (О» hprem, @NRM3 n P Q S hprem)
end;

// NRM3_1 вҖ” chain (Res) form of NRM3, via the `nrm3_eq` bridge above.  The
// premise is the snoc-conjunction the emitter discharges with AND4_1.
symbol NRM3_1 [n] [P : Tuple n вҶ’ Prop] [Q S : Prop]
  (r : Res (вӢҖ_snoc (Q вҮ’ S) ((`!! v, В¬ (P v)) вҮ’ S))) : Res ((`вҷў v, P v вҮ’ Q) вҮ’ S)
  вү” mk_1 (res_tm r) (eq_trans (@nrm3_eq n P Q S) (res_eq r));

// NRM23_1 вҖ” chain (Res) form of NRM23, via the `nrm23_eq` bridge (Res.lp).  E is
// implicit here (the emitter emits `NRM23_1 _`, inferring E from the Res target).
symbol NRM23_1 [Q : Prop] [E : П„ О№]
  (r : Res (В¬ вҠӨ вҮ’ Q))
  : Res ((`вҷЎ v : Tuple 1, В¬ вӢҖ (вҲҺ вҲ· вҠӨ вҲ· (E = prj 0 v))) вҮ’ Q)
  вү” mk_1 (res_tm r) (eq_trans (@nrm23_eq Q E) (res_eq r));

// NRM22_1 вҖ” chain (Res) form of NRM22, via the general `nrm22_eq` bridge
// (Res.lp): the body's tail equality pins the binder at E.
symbol NRM22_1 [Q : Prop] [ps : Tuple 1 вҶ’ рқ•ғ* o] [E : П„ О№]
  (r : Res (В¬ вӢҖ (ps (unit вЁҫ E)) вҮ’ Q))
  : Res ((`вҷЎ v : Tuple 1, В¬ вӢҖ (ps v вҲ· (prj 0 v = E))) вҮ’ Q)
  вү” mk_1 (res_tm r) (eq_trans (@nrm22_eq Q ps E) (res_eq r));

// NRM20_1 вҖ” chain (Res) form of NRM20 (drop the binder at slot k pinned by the
// tail equality `prj k v = E (rm k v)`).  PROVED (no postulate): its soundness
// bridge `nrm20_eq : BIG = SMALL` (lemmas/Tuple.lp) is the propExt of the
// main-tree `NRM20` body (вҮ’) and its converse, whose witness is the slot-surgery
// reassembly `ins k (prj k v) (rm k v) = v` (proved there via tuple extensionality
// + the ins_prj/rm_prj trichotomy).  So this is a Schema-1 transport like the
// other `_1` forms.  [qs] is *explicit* (the emitter supplies it as `О» v, вҲҺ вҲ· вҖҰ`):
// on the premise it occurs as `qs (ins k (E v') v')`, a non-Miller application
// lambdapi cannot infer (it OOMs trying), so passing it lets the splice reduce.
symbol NRM20_1 [n] (k : в„•) (qs : Tuple (+1 n) вҶ’ рқ•ғ* o) [Q : Prop]
  (E : Tuple n вҶ’ П„ О№)
  (r : Res ((`вҷЎ v' : Tuple n, В¬ вӢҖ (qs (ins k (E v') v'))) вҮ’ Q))
  : Res ((`вҷЎ v : Tuple (+1 n), В¬ вӢҖ (qs v вҲ· (prj k v = E (rm k v)))) вҮ’ Q)
  вү” mk_1 (res_tm r) (eq_trans (@nrm20_eq n k qs Q E) (res_eq r));

// NRM4_1 вҖ” chain (Res) form of NRM4, via the `nrm4_eq` bridge (Res.lp).
symbol NRM4_1 [n] [P R : Tuple n вҶ’ Prop] [Q S : Prop]
  (r : Res ((Q вҮ’ (`вҷў v, P v вҮ’ R v)) вҮ’ S))
  : Res ((`вҷў v, P v вҮ’ Q вҮ’ R v) вҮ’ S)
  вү” mk_1 (res_tm r) (eq_trans (@nrm4_eq n P R Q S) (res_eq r));

// NRM7_1 вҖ” chain (Res) form of NRM7, via the `nrm7_eq` bridge (Res.lp).
symbol NRM7_1 [n] [Qs : Tuple n вҶ’ рқ•ғ* o] [P : Tuple n вҶ’ Prop] [S : Prop]
  (r : Res ((`вҷў v, вӢҖ (Qs v)) вҮ’ ((`вҷў v, P v) вҮ’ S)))
  : Res ((`вҷў v, вӢҖ (Qs v вҲ· P v)) вҮ’ S)
  вү” mk_1 (res_tm r) (eq_trans (@nrm7_eq n Qs P S) (res_eq r));

// NRM11_1 вҖ” chain (Res) form of NRM11, via the `nrm11_eq` bridge (Res.lp).
symbol NRM11_1 [n] [P : Tuple n вҶ’ Prop] [R : Prop]
  (r : Res ((`вҷЎ v, В¬ вӢҖ_snoc вҠӨ (P v)) вҮ’ R))
  : Res ((`вҷў v, P v вҮ’ вҠҘ) вҮ’ R)
  вү” mk_1 (res_tm r) (eq_trans (@nrm11_eq n P R) (res_eq r));

// NRM25_1 вҖ” chain (Res) form of NRM25, via the `nrm25_eq` bridge (Res.lp).
symbol NRM25_1 [n] [P Q : Prop]
  (r : Res (P вҮ’ Q))
  : Res ((`вҷЎ _ : Tuple n, P) вҮ’ Q)
  вү” mk_1 (res_tm r) (eq_trans (@nrm25_eq n P Q) (res_eq r));

// NRM8_1 вҖ” chain (Res) form of NRM8, via the `nrm8_eq` bridge (Res.lp).
symbol NRM8_1 [n m] [Q : Tuple n вҶ’ Tuple m вҶ’ Prop] [S : Prop]
  (r : Res ((`вҷў v : Tuple (n ++ m), Q (take [n] [m] v) (drop [n] [m] v)) вҮ’ S))
  : Res ((`вҷў x : Tuple n, `!! y : Tuple m, Q x y) вҮ’ S)
  вү” mk_1 (res_tm r) (eq_trans (@nrm8_eq n m Q S) (res_eq r));

// NRM9_1 вҖ” chain (Res) form of NRM9, via the `nrm9_eq` bridge (Res.lp).
symbol NRM9_1 [n m] [P : Tuple n вҶ’ Prop] [Q : Tuple n вҶ’ Tuple m вҶ’ Prop] [S : Prop]
  (r : Res ((`вҷў v : Tuple (n ++ m),
              P (take [n] [m] v) вҮ’ Q (take [n] [m] v) (drop [n] [m] v)) вҮ’ S))
  : Res ((`вҷў x : Tuple n, P x вҮ’ (`!! y : Tuple m, Q x y)) вҮ’ S)
  вү” mk_1 (res_tm r) (eq_trans (@nrm9_eq n m P Q S) (res_eq r));

// NRM6_1 вҖ” chain (Res) form of NRM6, via the `nrm6_eq` bridge (Res.lp).
symbol NRM6_1 [n] [Qs : Tuple n вҶ’ рқ•ғ* o] [P R : Tuple n вҶ’ Prop] [S : Prop]
  (r : Res ((`вҷў v, R v вҮ’ вӢҖ (Qs v)) вҮ’ ((`вҷў v, R v вҮ’ P v) вҮ’ S)))
  : Res ((`вҷў v, R v вҮ’ вӢҖ (Qs v вҲ· P v)) вҮ’ S)
  вү” mk_1 (res_tm r) (eq_trans (@nrm6_eq n Qs P R S) (res_eq r));

// NRM19_1 вҖ” chain (Res) form of NRM19 (a Witness_hyp *discharge*, not a
// transport).  Given the witness v and the in-scope hyp `R v`, the antecedent
// `вҷЎuВ·В¬(вҠӨвҲ§R u)` is refuted (at u := v), so the implication is provable and
// `mk_0 вҲҳ prop_eq_top` seeds the Res at вҠӨ вҖ” the AXM8_1/AXM9_1 seed pattern.  The
// emitter recovers (v, hr) with the same [find_nrm19_match] the base rule uses.
symbol NRM19_1 [n] [Q : Prop] [R : Tuple n вҶ’ Prop] (v : Tuple n) (hr : ПҖ (R v))
  : Res ((`вҷЎ u, В¬ вӢҖ_snoc вҠӨ (R u)) вҮ’ Q)
  вү” mk_0 (prop_eq_top (NRM19 v hr));
