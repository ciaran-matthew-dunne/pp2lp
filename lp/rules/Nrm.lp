// Normalisation (¬ßA.12) ‚ÄĒ tuple-based encoding.
//
// Spec uses `‚ôĘ` (= goal-side n-ary universal) and `‚ô°` (= hypothesis-
// side n-ary universal). Both reduce propositionally to `!!` via the
// `‚ôĘ_eq_!!` / `‚ô°_eq_!!` axioms in Quant.lp; bodies use the dedicated
// `pi_to_‚ôĘ` / `‚ôĘ_to_pi` (and ‚ô° analogues) bridges.

require open pp2lp.B pp2lp.Quant pp2lp.rules.Res;

// ---- NRM1-7: Logical transformations under `‚ôĘ` ----

// NRM1: x not free in P; H ‚äĘ P ‚áí S ‚Üí H ‚äĘ (‚ôĘx ¬∑ P) ‚áí S
opaque symbol NRM1 [n] [P S : Prop]
  : ŌÄ (P ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ _ : Tuple n, P) ‚áí S) ‚ČĒ
begin
  assume n P S h1 h2;
  refine h1 (‚ôĘ_to_pi (őĽ _ : Tuple n, P) h2 (inh_tuple [n]))
end;

// NRM2: x not free in P; H ‚äĘ (P ‚áí ‚ôĘx ¬∑ Q) ‚áí S ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí Q) ‚áí S
opaque symbol NRM2 [n] [P : Prop] [Q : Tuple n ‚Üí Prop] [S : Prop]
  : ŌÄ ((P ‚áí (`‚ôĘ v, Q v)) ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ v, P ‚áí Q v) ‚áí S) ‚ČĒ
begin
  assume n P Q S h1 h2;
  refine h1 (őĽ p,
    pi_to_‚ôĘ Q (őĽ v, ‚ôĘ_to_pi (őĽ v', P ‚áí Q v') h2 v p))
end;

// NRM3: x not free in Q; H ‚äĘ (Q ‚áí S) ‚ąß ((‚ąÄx ¬∑ ¬¨P) ‚áí S) ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí Q) ‚áí S
opaque symbol NRM3 [n] [P : Tuple n ‚Üí Prop] [Q S : Prop]
  : ŌÄ ((Q ‚áí S) ‚ąß ((`!! v, ¬¨ (P v)) ‚áí S))
  ‚Üí ŌÄ ((`‚ôĘ v, P v ‚áí Q) ‚áí S) ‚ČĒ
begin
  assume n P Q S h1 h2;
  refine ‚ą®‚āĎ (em (`?? v, P v)) _ _
  { assume hex;
    refine pi_to_??_elim P
      (őĽ v hpv, (‚ąß‚āĎ‚āĀ h1) (‚ôĘ_to_pi (őĽ v', P v' ‚áí Q) h2 v hpv)) hex }
  { assume hnex;
    refine (‚ąß‚āĎ‚āā h1) (pi_to_!! (őĽ v, ¬¨ (P v))
      (őĽ v hpv, hnex (pi_to_??_intro P v hpv))) }
end;

// NRM4: x not free in Q; H ‚äĘ (Q ‚áí ‚ôĘx ¬∑ (P ‚áí R)) ‚áí S ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí Q ‚áí R) ‚áí S
opaque symbol NRM4 [n] [P R : Tuple n ‚Üí Prop] [Q S : Prop]
  : ŌÄ ((Q ‚áí (`‚ôĘ v, P v ‚áí R v)) ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ v, P v ‚áí Q ‚áí R v) ‚áí S) ‚ČĒ
begin
  assume n P R Q S h1 h2;
  refine h1 (őĽ hq,
    pi_to_‚ôĘ (őĽ v, P v ‚áí R v)
      (őĽ v hpv, ‚ôĘ_to_pi (őĽ v', P v' ‚áí Q ‚áí R v') h2 v hpv hq))
end;

// NRM5: H ‚äĘ ‚ôĘx ¬∑ (P ‚ąß Q ‚áí R) ‚áí S ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí Q ‚áí R) ‚áí S
opaque symbol NRM5 [n] [P Q R : Tuple n ‚Üí Prop] [S : Prop]
  : ŌÄ ((`‚ôĘ v, (P v ‚ąß Q v) ‚áí R v) ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ v, P v ‚áí Q v ‚áí R v) ‚áí S) ‚ČĒ
begin
  assume n P Q R S h1 h2;
  refine h1 (pi_to_‚ôĘ (őĽ v, (P v ‚ąß Q v) ‚áí R v)
    (őĽ v hpq, ‚ôĘ_to_pi (őĽ v', P v' ‚áí Q v' ‚áí R v') h2 v
                (‚ąß‚āĎ‚āĀ hpq) (‚ąß‚āĎ‚āā hpq)))
end;

// NRM6: H ‚äĘ ‚ôĘx ¬∑ (R ‚áí P) ‚áí (‚ôĘx ¬∑ (R ‚áí Q) ‚áí S) ‚Üí H ‚äĘ ‚ôĘx ¬∑ (R ‚áí P ‚ąß Q) ‚áí S
opaque symbol NRM6 [n] [P Q R : Tuple n ‚Üí Prop] [S : Prop]
  : ŌÄ ((`‚ôĘ v, R v ‚áí P v) ‚áí ((`‚ôĘ v, R v ‚áí Q v) ‚áí S))
  ‚Üí ŌÄ ((`‚ôĘ v, R v ‚áí (P v ‚ąß Q v)) ‚áí S) ‚ČĒ
begin
  assume n P Q R S h1 h2;
  refine h1
    (pi_to_‚ôĘ (őĽ v, R v ‚áí P v)
      (őĽ v hr, ‚ąß‚āĎ‚āĀ (‚ôĘ_to_pi (őĽ v', R v' ‚áí (P v' ‚ąß Q v')) h2 v hr)))
    (pi_to_‚ôĘ (őĽ v, R v ‚áí Q v)
      (őĽ v hr, ‚ąß‚āĎ‚āā (‚ôĘ_to_pi (őĽ v', R v' ‚áí (P v' ‚ąß Q v')) h2 v hr)))
end;

// NRM7: H ‚äĘ (‚ôĘx ¬∑ P) ‚áí ((‚ôĘx ¬∑ Q) ‚áí S) ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚ąß Q) ‚áí S
opaque symbol NRM7 [n] [P Q : Tuple n ‚Üí Prop] [S : Prop]
  : ŌÄ ((`‚ôĘ v, P v) ‚áí ((`‚ôĘ v, Q v) ‚áí S))
  ‚Üí ŌÄ ((`‚ôĘ v, P v ‚ąß Q v) ‚áí S) ‚ČĒ
begin
  assume n P Q S h1 h2;
  refine h1
    (pi_to_‚ôĘ P (őĽ v, ‚ąß‚āĎ‚āĀ (‚ôĘ_to_pi (őĽ v', P v' ‚ąß Q v') h2 v)))
    (pi_to_‚ôĘ Q (őĽ v, ‚ąß‚āĎ‚āā (‚ôĘ_to_pi (őĽ v', P v' ‚ąß Q v') h2 v)))
end;

// ---- NRM8-9: compound‚ÜĒmixed binders (split with `take`/`drop`) ----
//
// NRM8: spec is `(‚ôĘ(x,y) ¬∑ Q) ‚áí S` ‚Üź `(‚ôĘx ¬∑ ‚ąÄy ¬∑ Q) ‚áí S`.
// Encoded with the n,m-indexed split helpers from Quant.lp:
//   the conclusion's `Q x y` (clean HO pattern) gets unified back
//   from the premise's `Q (take v) (drop v)` after Lambdapi infers Q.

opaque symbol NRM8 [n m] [Q : Tuple n ‚Üí Tuple m ‚Üí Prop] [S : Prop]
  : ŌÄ ((`‚ôĘ v : Tuple (n ++ m), Q (take [n] [m] v) (drop [n] [m] v))
       ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ x : Tuple n, `!! y : Tuple m, Q x y) ‚áí S) ‚ČĒ
begin
  assume n m Q S h hnested;
  // hnested : ŌÄ (`‚ôĘ x : Tuple n, `!! y : Tuple m, Q x y)
  // Need:    ŌÄ (`‚ôĘ v : Tuple (n ++ m), Q (take v) (drop v))
  // Witness: őĽ v, !!_to_pi (Q x) (‚ôĘ_to_pi (őĽ x, `!! y, Q x y) hnested x') y'
  //          where x' = take v, y' = drop v.
  refine h (pi_to_‚ôĘ (őĽ v : Tuple (n ++ m),
                       Q (take [n] [m] v) (drop [n] [m] v))
    (őĽ v : Tuple (n ++ m),
       !!_to_pi (őĽ y, Q (take [n] [m] v) y)
                (‚ôĘ_to_pi (őĽ x, `!! y : Tuple m, Q x y)
                         hnested
                         (take [n] [m] v))
                (drop [n] [m] v)))
end;

// NRM9: spec is `(‚ôĘ(x,y) ¬∑ (P ‚áí Q)) ‚áí S` ‚Üź `(‚ôĘx ¬∑ (P ‚áí ‚ąÄy ¬∑ Q)) ‚áí S`,
// with y not free in P. Same split: premise body is `P (take v) ‚áí Q (take v) (drop v)`.
opaque symbol NRM9 [n m]
  [P : Tuple n ‚Üí Prop]
  [Q : Tuple n ‚Üí Tuple m ‚Üí Prop]
  [S : Prop]
  : ŌÄ ((`‚ôĘ v : Tuple (n ++ m),
         P (take [n] [m] v) ‚áí Q (take [n] [m] v) (drop [n] [m] v)) ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ x : Tuple n, P x ‚áí (`!! y : Tuple m, Q x y)) ‚áí S) ‚ČĒ
begin
  assume n m P Q S h hnested;
  refine h (pi_to_‚ôĘ
    (őĽ v, P (take [n] [m] v) ‚áí Q (take [n] [m] v) (drop [n] [m] v))
    (őĽ v hp,
       !!_to_pi (őĽ y, Q (take [n] [m] v) y)
                (‚ôĘ_to_pi (őĽ x, P x ‚áí (`!! y : Tuple m, Q x y))
                         hnested
                         (take [n] [m] v)
                         hp)
                (drop [n] [m] v)))
end;

// ---- NRM10-15: Implication / negation under `‚ôĘ` and `‚ô°` ----

// NRM10: H ‚äĘ ‚ô°x ¬∑ ¬¨(P ‚ąß Q) ‚áí R ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚ąß Q ‚áí ‚ä•) ‚áí R
opaque symbol NRM10 [n] [P Q : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° v, ¬¨ (P v ‚ąß Q v)) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ v, (P v ‚ąß Q v) ‚áí ‚ä•) ‚áí R) ‚ČĒ
begin
  assume n P Q R h1 h2;
  refine h1 (pi_to_‚ô° (őĽ v, ¬¨ (P v ‚ąß Q v))
    (őĽ v hpq, ‚ôĘ_to_pi (őĽ v', (P v' ‚ąß Q v') ‚áí ‚ä•) h2 v hpq))
end;

// NRM11: H ‚äĘ ‚ô°x ¬∑ ¬¨(‚ä§ ‚ąß P) ‚áí R ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí ‚ä•) ‚áí R
opaque symbol NRM11 [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° v, ¬¨ (‚ä§ ‚ąß P v)) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ v, P v ‚áí ‚ä•) ‚áí R) ‚ČĒ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_‚ô° (őĽ v, ¬¨ (‚ä§ ‚ąß P v))
    (őĽ v htpv, ‚ôĘ_to_pi (őĽ v', P v' ‚áí ‚ä•) h2 v (‚ąß‚āĎ‚āā htpv)))
end;

// NRM12: H ‚äĘ ‚ô°x ¬∑ ¬¨(P ‚ąß Q) ‚áí R ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí ¬¨Q) ‚áí R
opaque symbol NRM12 [n] [P Q : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° v, ¬¨ (P v ‚ąß Q v)) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ v, P v ‚áí ¬¨ (Q v)) ‚áí R) ‚ČĒ
begin
  assume n P Q R h1 h2;
  refine h1 (pi_to_‚ô° (őĽ v, ¬¨ (P v ‚ąß Q v))
    (őĽ v hpq, ‚ôĘ_to_pi (őĽ v', P v' ‚áí ¬¨ (Q v')) h2 v
                (‚ąß‚āĎ‚āĀ hpq) (‚ąß‚āĎ‚āā hpq)))
end;

// NRM13: H ‚äĘ ‚ô°x ¬∑ ¬¨(P ‚ąß ¬¨Q) ‚áí R ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí Q) ‚áí R
opaque symbol NRM13 [n] [P Q : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° v, ¬¨ (P v ‚ąß ¬¨ (Q v))) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ v, P v ‚áí Q v) ‚áí R) ‚ČĒ
begin
  assume n P Q R h1 h2;
  refine h1 (pi_to_‚ô° (őĽ v, ¬¨ (P v ‚ąß ¬¨ (Q v)))
    (őĽ v hc, (‚ąß‚āĎ‚āā hc) (‚ôĘ_to_pi (őĽ v', P v' ‚áí Q v') h2 v (‚ąß‚āĎ‚āĀ hc))))
end;

// NRM14: H ‚äĘ ‚ô°x ¬∑ ¬¨(‚ä§ ‚ąß P) ‚áí R ‚Üí H ‚äĘ (‚ôĘx ¬∑ ¬¨P) ‚áí R
opaque symbol NRM14 [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° v, ¬¨ (‚ä§ ‚ąß P v)) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ v, ¬¨ (P v)) ‚áí R) ‚ČĒ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_‚ô° (őĽ v, ¬¨ (‚ä§ ‚ąß P v))
    (őĽ v htpv, ‚ôĘ_to_pi (őĽ v', ¬¨ (P v')) h2 v (‚ąß‚āĎ‚āā htpv)))
end;

// NRM15: H ‚äĘ ‚ô°x ¬∑ ¬¨(‚ä§ ‚ąß ¬¨P) ‚áí R ‚Üí H ‚äĘ (‚ôĘx ¬∑ P) ‚áí R
opaque symbol NRM15 [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° v, ¬¨ (‚ä§ ‚ąß ¬¨ (P v))) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ v, P v) ‚áí R) ‚ČĒ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_‚ô° (őĽ v, ¬¨ (‚ä§ ‚ąß ¬¨ (P v)))
    (őĽ v htnpv, (‚ąß‚āĎ‚āā htnpv) (‚ôĘ_to_pi P h2 v)))
end;

// ---- NRM16-19: Universal-instantiation patterns ----

// NRM16: ‚ąÄx.P in H; Q ‚Üí H ‚äĘ (‚ô°x ¬∑ P) ‚áí Q
opaque symbol NRM16 [n] [P : Tuple n ‚Üí Prop] [Q : Prop]
  : ŌÄ (`!! v, P v)
  ‚Üí ŌÄ Q
  ‚Üí ŌÄ ((`‚ô° v, P v) ‚áí Q) ‚ČĒ
begin
  assume n P Q hp hq ht; refine hq
end;

// NRM17: NRM16 with extra spec-level equality side-conditions.
// At the LP level the proof obligation collapses to NRM16's shape.
opaque symbol NRM17 [n] [P : Tuple n ‚Üí Prop] [Q : Prop]
  : ŌÄ (`!! v, P v)
  ‚Üí ŌÄ Q
  ‚Üí ŌÄ ((`‚ô° v, P v) ‚áí Q) ‚ČĒ
begin
  assume n P Q hp hq ht; refine hq
end;

// NRM18: ‚ąÄx ¬∑ ¬¨(‚ä§ ‚ąß ¬¨P) in H; ‚ąÉE. [x:=E]P = R ‚Üí H ‚äĘ ‚ô°y ¬∑ ¬¨(‚ä§ ‚ąß R) ‚áí Q
opaque symbol NRM18 [n] [P : Tuple n ‚Üí Prop] [R Q : Prop] (v : Tuple n)
  : ŌÄ (`!! u, ¬¨ (‚ä§ ‚ąß ¬¨ (P u)))
  ‚Üí ŌÄ (P v = R)
  ‚Üí ŌÄ ((`‚ô° _ : Tuple n, ¬¨ (‚ä§ ‚ąß R)) ‚áí Q) ‚ČĒ
begin
  assume n P R Q v hp heq h;
  // Derive ŌÄ (P v) classically.
  have hpv : ŌÄ (P v)
    { refine ¬¨¬¨‚āĎ (P v) _;
      assume hnpv;
      refine !!_to_pi (őĽ u, ¬¨ (‚ä§ ‚ąß ¬¨ (P u))) hp v (‚ąßŠĶĘ ‚ä§ŠĶĘ hnpv) };
  // Transport along heq.
  have hr : ŌÄ R { rewrite left heq; refine hpv };
  refine ‚ä•‚āĎ (‚ô°_to_pi (őĽ _ : Tuple n, ¬¨ (‚ä§ ‚ąß R)) h (inh_tuple [n])
              (‚ąßŠĶĘ ‚ä§ŠĶĘ hr))
end;

// NRM19: P in H; ‚ąÉE. [x:=E]R = P ‚Üí H ‚äĘ ‚ô°x ¬∑ ¬¨(‚ä§ ‚ąß R) ‚áí Q
opaque symbol NRM19 [n] [Q : Prop] [R : Tuple n ‚Üí Prop] (v : Tuple n)
  : ŌÄ (R v)
  ‚Üí ŌÄ ((`‚ô° u, ¬¨ (‚ä§ ‚ąß R u)) ‚áí Q) ‚ČĒ
begin
  assume n Q R v hr hf;
  refine ‚ä•‚āĎ (‚ô°_to_pi (őĽ u, ¬¨ (‚ä§ ‚ąß R u)) hf v (‚ąßŠĶĘ ‚ä§ŠĶĘ hr))
end;

// ---- NRM20-23: Substitution ----

// NRM20: x not free in E; H ‚äĘ ‚ô°y ¬∑ ¬¨[x:=E]P ‚áí Q
//        ‚Üí H ‚äĘ ‚ô°(x,y) ¬∑ ¬¨(P ‚ąß x = E) ‚áí Q
opaque symbol NRM20 [n] [P : Tuple (+1 n) ‚Üí Prop] [Q : Prop] (E : ŌĄ őĻ)
  : ŌÄ ((`‚ô° y : Tuple n, ¬¨ (P (y ‚®ĺ E))) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° v : Tuple (+1 n),
         ¬¨ (P v ‚ąß (prj 0 v = E))) ‚áí Q) ‚ČĒ
begin
  assume n P Q E h1 h2;
  refine h1 (pi_to_‚ô° (őĽ y, ¬¨ (P (y ‚®ĺ E)))
    (őĽ y hpy,
      ‚ô°_to_pi (őĽ v, ¬¨ (P v ‚ąß (prj 0 v = E))) h2 (y ‚®ĺ E)
        (‚ąßŠĶĘ hpy (eq_refl E))))
end;

// NRM21: dual to NRM20 ‚ÄĒ equality reversed.
opaque symbol NRM21 [n] [P : Tuple (+1 n) ‚Üí Prop] [Q : Prop] (E : ŌĄ őĻ)
  : ŌÄ ((`‚ô° y : Tuple n, ¬¨ (P (y ‚®ĺ E))) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° v : Tuple (+1 n),
         ¬¨ (P v ‚ąß (E = prj 0 v))) ‚áí Q) ‚ČĒ
begin
  assume n P Q E h1 h2;
  refine h1 (pi_to_‚ô° (őĽ y, ¬¨ (P (y ‚®ĺ E)))
    (őĽ y hpy,
      ‚ô°_to_pi (őĽ v, ¬¨ (P v ‚ąß (E = prj 0 v))) h2 (y ‚®ĺ E)
        (‚ąßŠĶĘ hpy (eq_refl E))))
end;

// NRM22: simpler unary version of NRM20 (no extra y-binder).
opaque symbol NRM22 [P : ŌĄ őĻ ‚Üí Prop] [Q : Prop] (E : ŌĄ őĻ)
  : ŌÄ (¬¨ (P E) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° v : Tuple 1, ¬¨ (P (prj 0 v) ‚ąß (prj 0 v = E))) ‚áí Q) ‚ČĒ
begin
  assume P Q E h1 h2;
  refine h1 (őĽ hpe,
    ‚ô°_to_pi (őĽ v : Tuple 1, ¬¨ (P (prj 0 v) ‚ąß (prj 0 v = E)))
            h2 (unit ‚®ĺ E)
            (‚ąßŠĶĘ hpe (eq_refl E)))
end;

// NRM23: NRM22 with reversed equality.
opaque symbol NRM23 [P : ŌĄ őĻ ‚Üí Prop] [Q : Prop] (E : ŌĄ őĻ)
  : ŌÄ (¬¨ (P E) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° v : Tuple 1, ¬¨ (P (prj 0 v) ‚ąß (E = prj 0 v))) ‚áí Q) ‚ČĒ
begin
  assume P Q E h1 h2;
  refine h1 (őĽ hpe,
    ‚ô°_to_pi (őĽ v : Tuple 1, ¬¨ (P (prj 0 v) ‚ąß (E = prj 0 v)))
            h2 (unit ‚®ĺ E)
            (‚ąßŠĶĘ hpe (eq_refl E)))
end;

// ---- NRM24-26: Trivial structural rules ----

// NRM24: P not of form A ‚ąß B; H ‚äĘ ‚ô°x ¬∑ ¬¨(‚ä§ ‚ąß P) ‚áí Q ‚Üí H ‚äĘ ‚ô°x ¬∑ ¬¨P ‚áí Q
opaque symbol NRM24 [n] [P : Tuple n ‚Üí Prop] [Q : Prop]
  : ŌÄ ((`‚ô° v, ¬¨ (‚ä§ ‚ąß P v)) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° v, ¬¨ (P v)) ‚áí Q) ‚ČĒ
begin
  assume n P Q h1 h2;
  refine h1 (pi_to_‚ô° (őĽ v, ¬¨ (‚ä§ ‚ąß P v))
    (őĽ v htpv, ‚ô°_to_pi (őĽ v', ¬¨ (P v')) h2 v (‚ąß‚āĎ‚āā htpv)))
end;

// NRM25: x not free in P; H ‚äĘ P ‚Üí H ‚äĘ ‚ô°(x) ¬∑ P
//   = forall2(x).P in PP notation. `pi_to_‚ô°` with constant predicate
//   (the body doesn't depend on the bound tuple).
opaque symbol NRM25 [n] [P : Prop]
  : ŌÄ P ‚Üí ŌÄ (`‚ô° _ : Tuple n, P) ‚ČĒ
begin
  assume n P hp;
  refine pi_to_‚ô° (őĽ _ : Tuple n, P) (őĽ _, hp)
end;

// NRM26: y not free in P; H ‚äĘ ‚ô°(x,...) ¬∑ P ‚Üí H ‚äĘ ‚ô°(x,y,...) ¬∑ P
//   = extend the binder with a y not appearing in P. The body
//   ignores the new variable.

// Helper: drop the last element of a Tuple (+1 n).
symbol nrm26_drop_last [n] : Tuple (+1 n) ‚Üí Tuple n;
rule nrm26_drop_last [$n] ($w ‚®ĺ _) ‚Ü™ $w;

// Helper: produce P (drop_last v) from a per-tuple-n proof of P.
//   Stays !!-typed so the rewrite rule fires; rule body transports
//   from ‚ô° via `‚ô°_eq_!!`.
symbol nrm26_drop_proof [n] (P : Tuple n ‚Üí Prop)
  : ŌÄ (`!! w, P w)
  ‚Üí ő† v : Tuple (+1 n), ŌÄ (P (nrm26_drop_last v));
rule nrm26_drop_proof [$n] $P $h ($w ‚®ĺ _) ‚Ü™ !!_to_pi $P $h $w;

opaque symbol NRM26 [n] [P : Tuple n ‚Üí Prop]
  : ŌÄ (`‚ô° v, P v)
  ‚Üí ŌÄ (`‚ô° v : Tuple (+1 n), P (nrm26_drop_last v)) ‚ČĒ
begin
  assume n P h;
  refine pi_to_‚ô° (őĽ v : Tuple (+1 n), P (nrm26_drop_last v))
    (nrm26_drop_proof P (=‚áí (‚ô°_eq_!! P) h))
end;

// ---- NRM27-30: Arithmetic solver dispatch ----
//
// These rules encode arithmetic solver outputs. Their full encoding
// requires arithmetic-solver infrastructure (see Arith.lp's solver
// rules). Stubs for now.
//
// NRM27: (xŠĶĘ ‚Č§ 0) and (‚ąíxŠĶĘ ‚Č§ 0) in conjunction; R = [xŠĶĘ := 0]‚Ä¶
//   ‚Üí ‚ôĘ‚Ä¶ ¬∑ ¬¨R  ‚äĘ  ‚ô°(x‚āĀ,...,x‚āô) ¬∑ ¬¨(P ‚ąß ‚čĮ ‚ąß Q)
// NRM28-30: variants with solver dispatch.
// TODO: implement once Arith.lp solver rules are wired.

// ---- `_1` (Result-form) variants ‚ÄĒ ¬ß8.13 ----
//
// Per discussion, no NRM_1 rules are emitted in the current corpus.
// NRM1_1 is the lone exception ‚ÄĒ it strips a constant ‚ôĘ-binder via
// `nrm1_eq`, mirroring NRM1's role at the chain level.

symbol NRM1_1 [n] [P Q : Prop]
  (r : Res (P ‚áí Q)) : Res ((`‚ôĘ _ : Tuple n, P) ‚áí Q)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm1_eq n P Q) (res_eq r));
