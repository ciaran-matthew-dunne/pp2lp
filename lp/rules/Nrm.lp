// Normalisation (¬ßA.12) ‚Äî tuple-based encoding.
//
// Spec uses `‚ô¢` (= goal-side n-ary universal) and `‚ô°` (= hypothesis-
// side n-ary universal). Both reduce propositionally to `!!` via the
// `‚ô¢_eq_!!` / `‚ô°_eq_!!` axioms in Quant.lp; bodies use the dedicated
// `pi_to_‚ô¢` / `‚ô¢_to_pi` (and ‚ô° analogues) bridges.

require open pp2lp.B pp2lp.Quant;

// ---- NRM1-7: Logical transformations under `‚ô¢` ----

// NRM1: x not free in P; H ‚ä¢ P ‚áí S ‚Üí H ‚ä¢ (‚ô¢x ¬∑ P) ‚áí S
opaque symbol NRM1 [n] [P S : Prop]
  : œÄ (P ‚áí S)
  ‚Üí œÄ ((`‚ô¢ _ : Tuple n, P) ‚áí S) ‚âî
begin
  assume n P S h1 h2;
  refine h1 (‚ô¢_to_pi (Œª _ : Tuple n, P) h2 (inh_tuple [n]))
end;

// NRM2: x not free in P; H ‚ä¢ (P ‚áí ‚ô¢x ¬∑ Q) ‚áí S ‚Üí H ‚ä¢ ‚ô¢x ¬∑ (P ‚áí Q) ‚áí S
opaque symbol NRM2 [n] [P : Prop] [Q : Tuple n ‚Üí Prop] [S : Prop]
  : œÄ ((P ‚áí (`‚ô¢ v, Q v)) ‚áí S)
  ‚Üí œÄ ((`‚ô¢ v, P ‚áí Q v) ‚áí S) ‚âî
begin
  assume n P Q S h1 h2;
  refine h1 (Œª p,
    pi_to_‚ô¢ Q (Œª v, ‚ô¢_to_pi (Œª v', P ‚áí Q v') h2 v p))
end;

// NRM3: x not free in Q; H ‚ä¢ (Q ‚áí S) ‚àß ((‚àÄx ¬∑ ¬¨P) ‚áí S) ‚Üí H ‚ä¢ ‚ô¢x ¬∑ (P ‚áí Q) ‚áí S
opaque symbol NRM3 [n] [P : Tuple n ‚Üí Prop] [Q S : Prop]
  : œÄ ((Q ‚áí S) ‚àß ((`!! v, ¬¨ (P v)) ‚áí S))
  ‚Üí œÄ ((`‚ô¢ v, P v ‚áí Q) ‚áí S) ‚âî
begin
  assume n P Q S h1 h2;
  refine ‚à®‚Çë (em (`?? v, P v)) _ _
  { assume hex;
    refine pi_to_??_elim P
      (Œª v hpv, (‚àß‚Çë‚ÇÅ h1) (‚ô¢_to_pi (Œª v', P v' ‚áí Q) h2 v hpv)) hex }
  { assume hnex;
    refine (‚àß‚Çë‚ÇÇ h1) (pi_to_!! (Œª v, ¬¨ (P v))
      (Œª v hpv, hnex (pi_to_??_intro P v hpv))) }
end;

// NRM4: x not free in Q; H ‚ä¢ (Q ‚áí ‚ô¢x ¬∑ (P ‚áí R)) ‚áí S ‚Üí H ‚ä¢ ‚ô¢x ¬∑ (P ‚áí Q ‚áí R) ‚áí S
opaque symbol NRM4 [n] [P R : Tuple n ‚Üí Prop] [Q S : Prop]
  : œÄ ((Q ‚áí (`‚ô¢ v, P v ‚áí R v)) ‚áí S)
  ‚Üí œÄ ((`‚ô¢ v, P v ‚áí Q ‚áí R v) ‚áí S) ‚âî
begin
  assume n P R Q S h1 h2;
  refine h1 (Œª hq,
    pi_to_‚ô¢ (Œª v, P v ‚áí R v)
      (Œª v hpv, ‚ô¢_to_pi (Œª v', P v' ‚áí Q ‚áí R v') h2 v hpv hq))
end;

// NRM5: H ‚ä¢ ‚ô¢x ¬∑ (P ‚àß Q ‚áí R) ‚áí S ‚Üí H ‚ä¢ ‚ô¢x ¬∑ (P ‚áí Q ‚áí R) ‚áí S
opaque symbol NRM5 [n] [P Q R : Tuple n ‚Üí Prop] [S : Prop]
  : œÄ ((`‚ô¢ v, (P v ‚àß Q v) ‚áí R v) ‚áí S)
  ‚Üí œÄ ((`‚ô¢ v, P v ‚áí Q v ‚áí R v) ‚áí S) ‚âî
begin
  assume n P Q R S h1 h2;
  refine h1 (pi_to_‚ô¢ (Œª v, (P v ‚àß Q v) ‚áí R v)
    (Œª v hpq, ‚ô¢_to_pi (Œª v', P v' ‚áí Q v' ‚áí R v') h2 v
                (‚àß‚Çë‚ÇÅ hpq) (‚àß‚Çë‚ÇÇ hpq)))
end;

// NRM6: H ‚ä¢ ‚ô¢x ¬∑ (R ‚áí P) ‚áí (‚ô¢x ¬∑ (R ‚áí Q) ‚áí S) ‚Üí H ‚ä¢ ‚ô¢x ¬∑ (R ‚áí P ‚àß Q) ‚áí S
opaque symbol NRM6 [n] [P Q R : Tuple n ‚Üí Prop] [S : Prop]
  : œÄ ((`‚ô¢ v, R v ‚áí P v) ‚áí ((`‚ô¢ v, R v ‚áí Q v) ‚áí S))
  ‚Üí œÄ ((`‚ô¢ v, R v ‚áí (P v ‚àß Q v)) ‚áí S) ‚âî
begin
  assume n P Q R S h1 h2;
  refine h1
    (pi_to_‚ô¢ (Œª v, R v ‚áí P v)
      (Œª v hr, ‚àß‚Çë‚ÇÅ (‚ô¢_to_pi (Œª v', R v' ‚áí (P v' ‚àß Q v')) h2 v hr)))
    (pi_to_‚ô¢ (Œª v, R v ‚áí Q v)
      (Œª v hr, ‚àß‚Çë‚ÇÇ (‚ô¢_to_pi (Œª v', R v' ‚áí (P v' ‚àß Q v')) h2 v hr)))
end;

// NRM7: H ‚ä¢ (‚ô¢x ¬∑ P) ‚áí ((‚ô¢x ¬∑ Q) ‚áí S) ‚Üí H ‚ä¢ ‚ô¢x ¬∑ (P ‚àß Q) ‚áí S
opaque symbol NRM7 [n] [P Q : Tuple n ‚Üí Prop] [S : Prop]
  : œÄ ((`‚ô¢ v, P v) ‚áí ((`‚ô¢ v, Q v) ‚áí S))
  ‚Üí œÄ ((`‚ô¢ v, P v ‚àß Q v) ‚áí S) ‚âî
begin
  assume n P Q S h1 h2;
  refine h1
    (pi_to_‚ô¢ P (Œª v, ‚àß‚Çë‚ÇÅ (‚ô¢_to_pi (Œª v', P v' ‚àß Q v') h2 v)))
    (pi_to_‚ô¢ Q (Œª v, ‚àß‚Çë‚ÇÇ (‚ô¢_to_pi (Œª v', P v' ‚àß Q v') h2 v)))
end;

// ---- NRM8-9: compound‚Üîmixed binders (split with `take`/`drop`) ----
//
// NRM8: spec is `(‚ô¢(x,y) ¬∑ Q) ‚áí S` ‚Üê `(‚ô¢x ¬∑ ‚àÄy ¬∑ Q) ‚áí S`.
// Encoded with the n,m-indexed split helpers from Quant.lp:
//   the conclusion's `Q x y` (clean HO pattern) gets unified back
//   from the premise's `Q (take v) (drop v)` after Lambdapi infers Q.

opaque symbol NRM8 [n m] [Q : Tuple n ‚Üí Tuple m ‚Üí Prop] [S : Prop]
  : œÄ ((`‚ô¢ v : Tuple (n ++ m), Q (take [n] [m] v) (drop [n] [m] v))
       ‚áí S)
  ‚Üí œÄ ((`‚ô¢ x : Tuple n, `!! y : Tuple m, Q x y) ‚áí S) ‚âî
begin
  assume n m Q S h hnested;
  // hnested : œÄ (`‚ô¢ x : Tuple n, `!! y : Tuple m, Q x y)
  // Need:    œÄ (`‚ô¢ v : Tuple (n ++ m), Q (take v) (drop v))
  // Witness: Œª v, !!_to_pi (Q x) (‚ô¢_to_pi (Œª x, `!! y, Q x y) hnested x') y'
  //          where x' = take v, y' = drop v.
  refine h (pi_to_‚ô¢ (Œª v : Tuple (n ++ m),
                       Q (take [n] [m] v) (drop [n] [m] v))
    (Œª v : Tuple (n ++ m),
       !!_to_pi (Œª y, Q (take [n] [m] v) y)
                (‚ô¢_to_pi (Œª x, `!! y : Tuple m, Q x y)
                         hnested
                         (take [n] [m] v))
                (drop [n] [m] v)))
end;

// NRM9: spec is `(‚ô¢(x,y) ¬∑ (P ‚áí Q)) ‚áí S` ‚Üê `(‚ô¢x ¬∑ (P ‚áí ‚àÄy ¬∑ Q)) ‚áí S`,
// with y not free in P. Same split: premise body is `P (take v) ‚áí Q (take v) (drop v)`.
opaque symbol NRM9 [n m]
  [P : Tuple n ‚Üí Prop]
  [Q : Tuple n ‚Üí Tuple m ‚Üí Prop]
  [S : Prop]
  : œÄ ((`‚ô¢ v : Tuple (n ++ m),
         P (take [n] [m] v) ‚áí Q (take [n] [m] v) (drop [n] [m] v)) ‚áí S)
  ‚Üí œÄ ((`‚ô¢ x : Tuple n, P x ‚áí (`!! y : Tuple m, Q x y)) ‚áí S) ‚âî
begin
  assume n m P Q S h hnested;
  refine h (pi_to_‚ô¢
    (Œª v, P (take [n] [m] v) ‚áí Q (take [n] [m] v) (drop [n] [m] v))
    (Œª v hp,
       !!_to_pi (Œª y, Q (take [n] [m] v) y)
                (‚ô¢_to_pi (Œª x, P x ‚áí (`!! y : Tuple m, Q x y))
                         hnested
                         (take [n] [m] v)
                         hp)
                (drop [n] [m] v)))
end;

// ---- NRM10-15: Implication / negation under `‚ô¢` and `‚ô°` ----

// NRM10: H ‚ä¢ ‚ô°x ¬∑ ¬¨(P ‚àß Q) ‚áí R ‚Üí H ‚ä¢ ‚ô¢x ¬∑ (P ‚àß Q ‚áí ‚ä•) ‚áí R
opaque symbol NRM10 [n] [P Q : Tuple n ‚Üí Prop] [R : Prop]
  : œÄ ((`‚ô° v, ¬¨ (P v ‚àß Q v)) ‚áí R)
  ‚Üí œÄ ((`‚ô¢ v, (P v ‚àß Q v) ‚áí ‚ä•) ‚áí R) ‚âî
begin
  assume n P Q R h1 h2;
  refine h1 (pi_to_‚ô° (Œª v, ¬¨ (P v ‚àß Q v))
    (Œª v hpq, ‚ô¢_to_pi (Œª v', (P v' ‚àß Q v') ‚áí ‚ä•) h2 v hpq))
end;

// NRM11: H ‚ä¢ ‚ô°x ¬∑ ¬¨(‚ä§ ‚àß P) ‚áí R ‚Üí H ‚ä¢ ‚ô¢x ¬∑ (P ‚áí ‚ä•) ‚áí R
opaque symbol NRM11 [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : œÄ ((`‚ô° v, ¬¨ (‚ä§ ‚àß P v)) ‚áí R)
  ‚Üí œÄ ((`‚ô¢ v, P v ‚áí ‚ä•) ‚áí R) ‚âî
begin
  assume n P R h1 h2;
  refine h1 (pi_to_‚ô° (Œª v, ¬¨ (‚ä§ ‚àß P v))
    (Œª v htpv, ‚ô¢_to_pi (Œª v', P v' ‚áí ‚ä•) h2 v (‚àß‚Çë‚ÇÇ htpv)))
end;

// NRM12: H ‚ä¢ ‚ô°x ¬∑ ¬¨(P ‚àß Q) ‚áí R ‚Üí H ‚ä¢ ‚ô¢x ¬∑ (P ‚áí ¬¨Q) ‚áí R
opaque symbol NRM12 [n] [P Q : Tuple n ‚Üí Prop] [R : Prop]
  : œÄ ((`‚ô° v, ¬¨ (P v ‚àß Q v)) ‚áí R)
  ‚Üí œÄ ((`‚ô¢ v, P v ‚áí ¬¨ (Q v)) ‚áí R) ‚âî
begin
  assume n P Q R h1 h2;
  refine h1 (pi_to_‚ô° (Œª v, ¬¨ (P v ‚àß Q v))
    (Œª v hpq, ‚ô¢_to_pi (Œª v', P v' ‚áí ¬¨ (Q v')) h2 v
                (‚àß‚Çë‚ÇÅ hpq) (‚àß‚Çë‚ÇÇ hpq)))
end;

// NRM13: H ‚ä¢ ‚ô°x ¬∑ ¬¨(P ‚àß ¬¨Q) ‚áí R ‚Üí H ‚ä¢ ‚ô¢x ¬∑ (P ‚áí Q) ‚áí R
opaque symbol NRM13 [n] [P Q : Tuple n ‚Üí Prop] [R : Prop]
  : œÄ ((`‚ô° v, ¬¨ (P v ‚àß ¬¨ (Q v))) ‚áí R)
  ‚Üí œÄ ((`‚ô¢ v, P v ‚áí Q v) ‚áí R) ‚âî
begin
  assume n P Q R h1 h2;
  refine h1 (pi_to_‚ô° (Œª v, ¬¨ (P v ‚àß ¬¨ (Q v)))
    (Œª v hc, (‚àß‚Çë‚ÇÇ hc) (‚ô¢_to_pi (Œª v', P v' ‚áí Q v') h2 v (‚àß‚Çë‚ÇÅ hc))))
end;

// NRM14: H ‚ä¢ ‚ô°x ¬∑ ¬¨(‚ä§ ‚àß P) ‚áí R ‚Üí H ‚ä¢ (‚ô¢x ¬∑ ¬¨P) ‚áí R
opaque symbol NRM14 [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : œÄ ((`‚ô° v, ¬¨ (‚ä§ ‚àß P v)) ‚áí R)
  ‚Üí œÄ ((`‚ô¢ v, ¬¨ (P v)) ‚áí R) ‚âî
begin
  assume n P R h1 h2;
  refine h1 (pi_to_‚ô° (Œª v, ¬¨ (‚ä§ ‚àß P v))
    (Œª v htpv, ‚ô¢_to_pi (Œª v', ¬¨ (P v')) h2 v (‚àß‚Çë‚ÇÇ htpv)))
end;

// NRM15: H ‚ä¢ ‚ô°x ¬∑ ¬¨(‚ä§ ‚àß ¬¨P) ‚áí R ‚Üí H ‚ä¢ (‚ô¢x ¬∑ P) ‚áí R
opaque symbol NRM15 [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : œÄ ((`‚ô° v, ¬¨ (‚ä§ ‚àß ¬¨ (P v))) ‚áí R)
  ‚Üí œÄ ((`‚ô¢ v, P v) ‚áí R) ‚âî
begin
  assume n P R h1 h2;
  refine h1 (pi_to_‚ô° (Œª v, ¬¨ (‚ä§ ‚àß ¬¨ (P v)))
    (Œª v htnpv, (‚àß‚Çë‚ÇÇ htnpv) (‚ô¢_to_pi P h2 v)))
end;

// ---- NRM16-19: Universal-instantiation patterns ----

// NRM16: ‚àÄx.P in H; Q ‚Üí H ‚ä¢ (‚ô°x ¬∑ P) ‚áí Q
opaque symbol NRM16 [n] [P : Tuple n ‚Üí Prop] [Q : Prop]
  : œÄ (`!! v, P v)
  ‚Üí œÄ Q
  ‚Üí œÄ ((`‚ô° v, P v) ‚áí Q) ‚âî
begin
  assume n P Q hp hq ht; refine hq
end;

// NRM17: NRM16 with extra spec-level equality side-conditions.
// At the LP level the proof obligation collapses to NRM16's shape.
opaque symbol NRM17 [n] [P : Tuple n ‚Üí Prop] [Q : Prop]
  : œÄ (`!! v, P v)
  ‚Üí œÄ Q
  ‚Üí œÄ ((`‚ô° v, P v) ‚áí Q) ‚âî
begin
  assume n P Q hp hq ht; refine hq
end;

// NRM18: ‚àÄx ¬∑ ¬¨(‚ä§ ‚àß ¬¨P) in H; ‚àÉE. [x:=E]P = R ‚Üí H ‚ä¢ ‚ô°y ¬∑ ¬¨(‚ä§ ‚àß R) ‚áí Q
opaque symbol NRM18 [n] [P : Tuple n ‚Üí Prop] [R Q : Prop] (v : Tuple n)
  : œÄ (`!! u, ¬¨ (‚ä§ ‚àß ¬¨ (P u)))
  ‚Üí œÄ (P v = R)
  ‚Üí œÄ ((`‚ô° _ : Tuple n, ¬¨ (‚ä§ ‚àß R)) ‚áí Q) ‚âî
begin
  assume n P R Q v hp heq h;
  // Derive œÄ (P v) classically.
  have hpv : œÄ (P v)
    { refine ¬¨¬¨‚Çë (P v) _;
      assume hnpv;
      refine !!_to_pi (Œª u, ¬¨ (‚ä§ ‚àß ¬¨ (P u))) hp v (‚àß·µ¢ ‚ä§·µ¢ hnpv) };
  // Transport along heq.
  have hr : œÄ R { rewrite left heq; refine hpv };
  refine ‚ä•‚Çë (‚ô°_to_pi (Œª _ : Tuple n, ¬¨ (‚ä§ ‚àß R)) h (inh_tuple [n])
              (‚àß·µ¢ ‚ä§·µ¢ hr))
end;

// NRM19: P in H; ‚àÉE. [x:=E]R = P ‚Üí H ‚ä¢ ‚ô°x ¬∑ ¬¨(‚ä§ ‚àß R) ‚áí Q
opaque symbol NRM19 [n] [Q : Prop] [R : Tuple n ‚Üí Prop] (v : Tuple n)
  : œÄ (R v)
  ‚Üí œÄ ((`‚ô° u, ¬¨ (‚ä§ ‚àß R u)) ‚áí Q) ‚âî
begin
  assume n Q R v hr hf;
  refine ‚ä•‚Çë (‚ô°_to_pi (Œª u, ¬¨ (‚ä§ ‚àß R u)) hf v (‚àß·µ¢ ‚ä§·µ¢ hr))
end;

// ---- NRM20-23: Substitution ----

// NRM20: x not free in E; H ‚ä¢ ‚ô°y ¬∑ ¬¨[x:=E]P ‚áí Q
//        ‚Üí H ‚ä¢ ‚ô°(x,y) ¬∑ ¬¨(P ‚àß x = E) ‚áí Q
opaque symbol NRM20 [n] [P : Tuple (+1 n) ‚Üí Prop] [Q : Prop] (E : œÑ Œπ)
  : œÄ ((`‚ô° y : Tuple n, ¬¨ (P (y ‚®æ E))) ‚áí Q)
  ‚Üí œÄ ((`‚ô° v : Tuple (+1 n),
         ¬¨ (P v ‚àß (prj 0 v = E))) ‚áí Q) ‚âî
begin
  assume n P Q E h1 h2;
  refine h1 (pi_to_‚ô° (Œª y, ¬¨ (P (y ‚®æ E)))
    (Œª y hpy,
      ‚ô°_to_pi (Œª v, ¬¨ (P v ‚àß (prj 0 v = E))) h2 (y ‚®æ E)
        (‚àß·µ¢ hpy (eq_refl E))))
end;

// NRM21: dual to NRM20 ‚Äî equality reversed.
opaque symbol NRM21 [n] [P : Tuple (+1 n) ‚Üí Prop] [Q : Prop] (E : œÑ Œπ)
  : œÄ ((`‚ô° y : Tuple n, ¬¨ (P (y ‚®æ E))) ‚áí Q)
  ‚Üí œÄ ((`‚ô° v : Tuple (+1 n),
         ¬¨ (P v ‚àß (E = prj 0 v))) ‚áí Q) ‚âî
begin
  assume n P Q E h1 h2;
  refine h1 (pi_to_‚ô° (Œª y, ¬¨ (P (y ‚®æ E)))
    (Œª y hpy,
      ‚ô°_to_pi (Œª v, ¬¨ (P v ‚àß (E = prj 0 v))) h2 (y ‚®æ E)
        (‚àß·µ¢ hpy (eq_refl E))))
end;

// NRM22: simpler unary version of NRM20 (no extra y-binder).
opaque symbol NRM22 [P : œÑ Œπ ‚Üí Prop] [Q : Prop] (E : œÑ Œπ)
  : œÄ (¬¨ (P E) ‚áí Q)
  ‚Üí œÄ ((`‚ô° v : Tuple 1, ¬¨ (P (prj 0 v) ‚àß (prj 0 v = E))) ‚áí Q) ‚âî
begin
  assume P Q E h1 h2;
  refine h1 (Œª hpe,
    ‚ô°_to_pi (Œª v : Tuple 1, ¬¨ (P (prj 0 v) ‚àß (prj 0 v = E)))
            h2 (unit ‚®æ E)
            (‚àß·µ¢ hpe (eq_refl E)))
end;

// NRM23: NRM22 with reversed equality.
opaque symbol NRM23 [P : œÑ Œπ ‚Üí Prop] [Q : Prop] (E : œÑ Œπ)
  : œÄ (¬¨ (P E) ‚áí Q)
  ‚Üí œÄ ((`‚ô° v : Tuple 1, ¬¨ (P (prj 0 v) ‚àß (E = prj 0 v))) ‚áí Q) ‚âî
begin
  assume P Q E h1 h2;
  refine h1 (Œª hpe,
    ‚ô°_to_pi (Œª v : Tuple 1, ¬¨ (P (prj 0 v) ‚àß (E = prj 0 v)))
            h2 (unit ‚®æ E)
            (‚àß·µ¢ hpe (eq_refl E)))
end;

// ---- NRM24-26: Trivial structural rules ----

// NRM24: P not of form A ‚àß B; H ‚ä¢ ‚ô°x ¬∑ ¬¨(‚ä§ ‚àß P) ‚áí Q ‚Üí H ‚ä¢ ‚ô°x ¬∑ ¬¨P ‚áí Q
opaque symbol NRM24 [n] [P : Tuple n ‚Üí Prop] [Q : Prop]
  : œÄ ((`‚ô° v, ¬¨ (‚ä§ ‚àß P v)) ‚áí Q)
  ‚Üí œÄ ((`‚ô° v, ¬¨ (P v)) ‚áí Q) ‚âî
begin
  assume n P Q h1 h2;
  refine h1 (pi_to_‚ô° (Œª v, ¬¨ (‚ä§ ‚àß P v))
    (Œª v htpv, ‚ô°_to_pi (Œª v', ¬¨ (P v')) h2 v (‚àß‚Çë‚ÇÇ htpv)))
end;

// NRM25: x not free in P; H ‚ä¢ P ‚Üí H ‚ä¢ ‚ô°(x) ¬∑ P
//   = forall2(x).P in PP notation. `pi_to_‚ô°` with constant predicate
//   (the body doesn't depend on the bound tuple).
opaque symbol NRM25 [n] [P : Prop]
  : œÄ P ‚Üí œÄ (`‚ô° _ : Tuple n, P) ‚âî
begin
  assume n P hp;
  refine pi_to_‚ô° (Œª _ : Tuple n, P) (Œª _, hp)
end;

// NRM26: y not free in P; H ‚ä¢ ‚ô°(x,...) ¬∑ P ‚Üí H ‚ä¢ ‚ô°(x,y,...) ¬∑ P
//   = extend the binder with a y not appearing in P. The body
//   ignores the new variable.

// Helper: drop the last element of a Tuple (+1 n).
symbol nrm26_drop_last [n] : Tuple (+1 n) ‚Üí Tuple n;
rule nrm26_drop_last [$n] ($w ‚®æ _) ‚Ü™ $w;

// Helper: produce P (drop_last v) from a per-tuple-n proof of P.
//   Stays !!-typed so the rewrite rule fires; rule body transports
//   from ‚ô° via `‚ô°_eq_!!`.
symbol nrm26_drop_proof [n] (P : Tuple n ‚Üí Prop)
  : œÄ (`!! w, P w)
  ‚Üí ŒÝ v : Tuple (+1 n), œÄ (P (nrm26_drop_last v));
rule nrm26_drop_proof [$n] $P $h ($w ‚®æ _) ‚Ü™ !!_to_pi $P $h $w;

opaque symbol NRM26 [n] [P : Tuple n ‚Üí Prop]
  : œÄ (`‚ô° v, P v)
  ‚Üí œÄ (`‚ô° v : Tuple (+1 n), P (nrm26_drop_last v)) ‚âî
begin
  assume n P h;
  refine pi_to_‚ô° (Œª v : Tuple (+1 n), P (nrm26_drop_last v))
    (nrm26_drop_proof P (=‚áí (‚ô°_eq_!! P) h))
end;

