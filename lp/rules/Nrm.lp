// Normalisation (┬πA.12) έΑΦ shallow encoding
//
// With HOAS and έβλ/έβκ defined as έΙΑ in B.lp:
// - Compound variables (έρ╛) become nested έΙΑ
// - Substitution is HOAS application
// - Non-freeness is implicit (Prop vs ╧Ε ╬╣ έΗΤ Prop)
require open pp2lp.B;

// ---- NRM1-7: Logical transformations under έβλ ----

// NRM1: x not free in P; H έΛλ P έΘΤ S έΗΤ H έΛλ (έβλx ┬╖ P) έΘΤ S
opaque symbol NRM1 [P S : Prop]
  : ╧Α (P έΘΤ S)
  έΗΤ ╧Α ((`έβλ _ : ╧Ε ╬╣, P) έΘΤ S) έΚΦ
begin
  assume P S h1 h2;
  refine h1 (h2 inh)
end;

// NRM2: x not free in P; H έΛλ (P έΘΤ έβλx ┬╖ Q) έΘΤ S έΗΤ H έΛλ έβλx ┬╖ (P έΘΤ Q) έΘΤ S
opaque symbol NRM2 [P : Prop] [Q : ╧Ε ╬╣ έΗΤ Prop] [S : Prop]
  : ╧Α ((P έΘΤ (`έβλ x, Q x)) έΘΤ S)
  έΗΤ ╧Α ((`έβλ x, P έΘΤ Q x) έΘΤ S) έΚΦ
begin
  assume P Q S h1 h2;
  refine h1 (╬╗ hp x, h2 x hp)
end;

// NRM3: x not free in Q; Q is not FALSE; H έΛλ (Q έΘΤ S) έΙπ ((έΙΑx ┬╖ ┬υP) έΘΤ S) έΗΤ H έΛλ έβλx ┬╖ (P έΘΤ Q) έΘΤ S
opaque symbol NRM3 [P : ╧Ε ╬╣ έΗΤ Prop] [Q S : Prop]
  : ╧Α ((Q έΘΤ S) έΙπ ((`έΙΑ x, ┬υ (P x)) έΘΤ S))
  έΗΤ ╧Α ((`έβλ x, P x έΘΤ Q) έΘΤ S) έΚΦ
begin
  assume P Q S h1 h2;
  refine έΙρέΓΣ (em (`έΙΔ x, P x)) _ _ {
    assume hex;
    refine έΙΔέΓΣ hex (╬╗ x hpx, (έΙπέΓΣέΓΒ h1) (h2 x hpx))
  } {
    assume hnex;
    refine (έΙπέΓΣέΓΓ h1) (╬╗ x hpx, hnex (έΙΔά╡λ x hpx))
  }
end;

// NRM4: x not free in Q; H έΛλ (Q έΘΤ έβλx ┬╖ (P έΘΤ R)) έΘΤ S έΗΤ H έΛλ έβλx ┬╖ (P έΘΤ (Q έΘΤ R)) έΘΤ S
opaque symbol NRM4 [P R : ╧Ε ╬╣ έΗΤ Prop] [Q S : Prop]
  : ╧Α ((Q έΘΤ (`έβλ x, P x έΘΤ R x)) έΘΤ S)
  έΗΤ ╧Α ((`έβλ x, P x έΘΤ Q έΘΤ R x) έΘΤ S) έΚΦ
begin
  assume P R Q S h1 h2;
  refine h1 (╬╗ hq x hpx, h2 x hpx hq)
end;

// NRM5: H έΛλ έβλx ┬╖ (P έΙπ Q έΘΤ R) έΘΤ S έΗΤ H έΛλ έβλx ┬╖ (P έΘΤ (Q έΘΤ R)) έΘΤ S
opaque symbol NRM5 [P Q R : ╧Ε ╬╣ έΗΤ Prop] [S : Prop]
  : ╧Α ((`έβλ x, P x έΙπ Q x έΘΤ R x) έΘΤ S)
  έΗΤ ╧Α ((`έβλ x, P x έΘΤ Q x έΘΤ R x) έΘΤ S) έΚΦ
begin
  assume P Q R S h1 h2;
  refine h1 (╬╗ x hpq, h2 x (έΙπέΓΣέΓΒ hpq) (έΙπέΓΣέΓΓ hpq))
end;

// NRM5_2: Two-variable version.
opaque symbol NRM5_2 [P Q R : ╧Ε ╬╣ έΗΤ ╧Ε ╬╣ έΗΤ Prop] [S : Prop]
  : ╧Α ((`έβλ x, `έβλ y, P x y έΙπ Q x y έΘΤ R x y) έΘΤ S)
  έΗΤ ╧Α ((`έβλ x, `έβλ y, P x y έΘΤ Q x y έΘΤ R x y) έΘΤ S) έΚΦ
begin
  assume P Q R S h1 h2;
  refine h1 (╬╗ x y hpq, h2 x y (έΙπέΓΣέΓΒ hpq) (έΙπέΓΣέΓΓ hpq))
end;

// NRM6: H έΛλ έβλx ┬╖ (R έΘΤ P) έΘΤ (έβλx ┬╖ (R έΘΤ Q) έΘΤ S) έΗΤ H έΛλ έβλx ┬╖ (R έΘΤ P έΙπ Q) έΘΤ S
opaque symbol NRM6 [P Q R : ╧Ε ╬╣ έΗΤ Prop] [S : Prop]
  : ╧Α ((`έβλ x, R x έΘΤ P x) έΘΤ ((`έβλ x, R x έΘΤ Q x) έΘΤ S))
  έΗΤ ╧Α ((`έβλ x, R x έΘΤ P x έΙπ Q x) έΘΤ S) έΚΦ
begin
  assume P Q R S h1 h2;
  refine h1 (╬╗ x hr, έΙπέΓΣέΓΒ (h2 x hr)) (╬╗ x hr, έΙπέΓΣέΓΓ (h2 x hr))
end;

// NRM7: H έΛλ (έβλx ┬╖ P) έΘΤ ((έβλx ┬╖ Q) έΘΤ S) έΗΤ H έΛλ έβλx ┬╖ (P έΙπ Q) έΘΤ S
opaque symbol NRM7 [P Q : ╧Ε ╬╣ έΗΤ Prop] [S : Prop]
  : ╧Α ((`έβλ x, P x) έΘΤ ((`έβλ x, Q x) έΘΤ S))
  έΗΤ ╧Α ((`έβλ x, P x έΙπ Q x) έΘΤ S) έΚΦ
begin
  assume P Q S h1 h2;
  refine h1 (╬╗ x, έΙπέΓΣέΓΒ (h2 x)) (╬╗ x, έΙπέΓΣέΓΓ (h2 x))
end;

// NRM7_2: Two-variable version.
opaque symbol NRM7_2 [P Q : ╧Ε ╬╣ έΗΤ ╧Ε ╬╣ έΗΤ Prop] [S : Prop]
  : ╧Α ((`έβλ x, `έβλ y, P x y) έΘΤ ((`έβλ x, `έβλ y, Q x y) έΘΤ S))
  έΗΤ ╧Α ((`έβλ x, `έβλ y, P x y έΙπ Q x y) έΘΤ S) έΚΦ
begin
  assume P Q S h1 h2;
  refine h1 (╬╗ x y, έΙπέΓΣέΓΒ (h2 x y)) (╬╗ x y, έΙπέΓΣέΓΓ (h2 x y))
end;

opaque symbol NRM8 [Q : ╧Ε ╬╣ έΗΤ ╧Ε ╬╣ έΗΤ Prop] [S : Prop]
  : ╧Α ((`έβλ x, `έβλ y, Q x y) έΘΤ S)
  έΗΤ ╧Α ((`έβλ x, `έΙΑ y, Q x y) έΘΤ S) έΚΦ
begin
  assume Q S h; refine h
end;

opaque symbol NRM9 [P : ╧Ε ╬╣ έΗΤ Prop] [Q : ╧Ε ╬╣ έΗΤ ╧Ε ╬╣ έΗΤ Prop] [S : Prop]
  : ╧Α ((`έβλ x, `έβλ y, P x έΘΤ Q x y) έΘΤ S)
  έΗΤ ╧Α ((`έβλ x, P x έΘΤ `έΙΑ y, Q x y) έΘΤ S) έΚΦ
begin
  assume P Q S h1 h2;
  refine h1 (╬╗ x y hp, h2 x hp y)
end;


// ---- NRM10-15: Normal form transformations ----

opaque symbol NRM10 [P Q : ╧Ε ╬╣ έΗΤ Prop] [R : Prop]
  : ╧Α ((`έβκ x, ┬υ (P x έΙπ Q x)) έΘΤ R)
  έΗΤ ╧Α ((`έβλ x, (P x έΙπ Q x) έΘΤ έΛξ) έΘΤ R) έΚΦ
begin
  admit;
end;

opaque symbol NRM11 [P : ╧Ε ╬╣ έΗΤ Prop] [R : Prop]
  : ╧Α ((`έβκ x, ┬υ (έΛν έΙπ P x)) έΘΤ R)
  έΗΤ ╧Α ((`έβλ x, P x έΘΤ έΛξ) έΘΤ R) έΚΦ
begin
  admit;
end;

opaque symbol NRM12 [P Q : ╧Ε ╬╣ έΗΤ Prop] [R : Prop]
  : ╧Α ((`έβκ x, ┬υ (P x έΙπ Q x)) έΘΤ R)
  έΗΤ ╧Α ((`έβλ x, P x έΘΤ ┬υ (Q x)) έΘΤ R) έΚΦ
begin
  assume P Q R h1 h2;
  refine h1 (╬╗ x hpq, h2 x (έΙπέΓΣέΓΒ hpq) (έΙπέΓΣέΓΓ hpq))
end;

opaque symbol NRM13 [P Q : ╧Ε ╬╣ έΗΤ Prop] [R : Prop]
  : ╧Α ((`έβκ x, ┬υ (P x έΙπ ┬υ (Q x))) έΘΤ R)
  έΗΤ ╧Α ((`έβλ x, P x έΘΤ Q x) έΘΤ R) έΚΦ
begin
  assume P Q R h1 h2;
  refine h1 (╬╗ x hc, (έΙπέΓΣέΓΓ hc) (h2 x (έΙπέΓΣέΓΒ hc)))
end;

// NRM13_2: Two-variable version.
opaque symbol NRM13_2 [P Q : ╧Ε ╬╣ έΗΤ ╧Ε ╬╣ έΗΤ Prop] [R : Prop]
  : ╧Α ((`έβκ x, `έβκ y, ┬υ (P x y έΙπ ┬υ (Q x y))) έΘΤ R)
  έΗΤ ╧Α ((`έβλ x, `έβλ y, P x y έΘΤ Q x y) έΘΤ R) έΚΦ
begin
  assume P Q R h1 h2;
  refine h1 (╬╗ x y hpnq, (έΙπέΓΣέΓΓ hpnq) (h2 x y (έΙπέΓΣέΓΒ hpnq)))
end;

opaque symbol NRM14 [P : ╧Ε ╬╣ έΗΤ Prop] [R : Prop]
  : ╧Α ((`έβκ x, ┬υ (έΛν έΙπ P x)) έΘΤ R)
  έΗΤ ╧Α ((`έβλ x, ┬υ P x) έΘΤ R) έΚΦ
begin
  assume P R h1 h2;
  refine h1 (╬╗ x htpx, h2 x (έΙπέΓΣέΓΓ htpx))
end;

// NRM14_2: Two-variable version.
opaque symbol NRM14_2 [P : ╧Ε ╬╣ έΗΤ ╧Ε ╬╣ έΗΤ Prop] [R : Prop]
  : ╧Α ((`έβκ x, `έβκ y, ┬υ (έΛν έΙπ P x y)) έΘΤ R)
  έΗΤ ╧Α ((`έβλ x, `έβλ y, ┬υ (P x y)) έΘΤ R) έΚΦ
begin
  assume P R h1 h2;
  refine h1 (╬╗ x y htpxy, h2 x y (έΙπέΓΣέΓΓ htpxy))
end;

opaque symbol NRM15 [P : ╧Ε ╬╣ έΗΤ Prop] [R : Prop]
  : ╧Α ((`έβκ x, ┬υ (έΛν έΙπ ┬υ P x)) έΘΤ R)
  έΗΤ ╧Α ((`έβλ x, P x) έΘΤ R) έΚΦ
begin
  assume P R h1 h2;
  refine h1 (╬╗ x htnpx, (έΙπέΓΣέΓΓ htnpx) (h2 x))
end;

// NRM15_2: Two-variable version.
opaque symbol NRM15_2 [P : ╧Ε ╬╣ έΗΤ ╧Ε ╬╣ έΗΤ Prop] [R : Prop]
  : ╧Α ((`έβκ x, `έβκ y, ┬υ (έΛν έΙπ ┬υ (P x y))) έΘΤ R)
  έΗΤ ╧Α ((`έβλ x, `έβλ y, P x y) έΘΤ R) έΚΦ
begin
  assume P R h1 h2;
  refine h1 (╬╗ x y htnpxy, (έΙπέΓΣέΓΓ htnpxy) (h2 x y))
end;

opaque symbol NRM16 [P : ╧Ε ╬╣ έΗΤ Prop] [Q : Prop]
  : ╧Α (`έΙΑ x, P x)
  έΗΤ ╧Α Q
  έΗΤ ╧Α ((`έβκ x, P x) έΘΤ Q) έΚΦ
begin
  assume P Q hp hq ht; refine hq
end;

opaque symbol NRM17 [P : ╧Ε ╬╣ έΗΤ Prop] [Q : Prop]
  : ╧Α (`έΙΑ x, P x)
  έΗΤ ╧Α Q
  έΗΤ ╧Α ((`έβκ x, P x) έΘΤ Q) έΚΦ
begin
  assume P Q hp hq ht; refine hq
end;

opaque symbol NRM18 [P : ╧Ε ╬╣ έΗΤ Prop] [R Q : Prop] (E : ╧Ε ╬╣)
  : ╧Α (`έΙΑ x, ┬υ (έΛν έΙπ ┬υ P x))
  έΗΤ ╧Α (P E = R)
  έΗΤ ╧Α ((`έβκ y, ┬υ (έΛν έΙπ R)) έΘΤ Q) έΚΦ
begin
  admit
end;

opaque symbol NRM19 [Q : Prop] [R : ╧Ε ╬╣ έΗΤ Prop] (E : ╧Ε ╬╣)
  : ╧Α (R E)
  έΗΤ ╧Α ((`έβκ x, ┬υ (έΛν έΙπ R x)) έΘΤ Q) έΚΦ
begin
  assume Q R E hr hf;
  refine έΛξέΓΣ (hf E (έΙπά╡λ έΛνά╡λ hr))
end;

// NRM19_2: Two-variable version.
opaque symbol NRM19_2 [Q : Prop] [R : ╧Ε ╬╣ έΗΤ ╧Ε ╬╣ έΗΤ Prop] (E F : ╧Ε ╬╣)
  : ╧Α (R E F)
  έΗΤ ╧Α ((`έβκ x, `έβκ y, ┬υ (έΛν έΙπ R x y)) έΘΤ Q) έΚΦ
begin
  assume Q R E F hr hf;
  refine έΛξέΓΣ (hf E F (έΙπά╡λ έΛνά╡λ hr))
end;

// ---- NRM20-23: Equality elimination under έβκ ----

opaque symbol NRM20 [P : ╧Ε ╬╣ έΗΤ ╧Ε ╬╣ έΗΤ Prop] [Q : Prop] (E : ╧Ε ╬╣)
  : ╧Α ((`έβκ y, ┬υ (P E y)) έΘΤ Q)
  έΗΤ ╧Α ((`έβκ x, `έβκ y, ┬υ (P x y έΙπ (x = E))) έΘΤ Q) έΚΦ
begin
  assume P Q E h1 h2;
  refine h1 (╬╗ y hpey, h2 E y (έΙπά╡λ hpey (eq_refl E)))
end;

opaque symbol NRM21 [P : ╧Ε ╬╣ έΗΤ ╧Ε ╬╣ έΗΤ Prop] [Q : Prop] (E : ╧Ε ╬╣)
  : ╧Α ((`έβκ y, ┬υ (P E y)) έΘΤ Q)
  έΗΤ ╧Α ((`έβκ x, `έβκ y, ┬υ (P x y έΙπ (E = x))) έΘΤ Q) έΚΦ
begin
  assume P Q E h1 h2;
  refine h1 (╬╗ y hpey, h2 E y (έΙπά╡λ hpey (eq_sym (eq_refl E))))
end;

opaque symbol NRM22 [P : ╧Ε ╬╣ έΗΤ Prop] [Q : Prop] (E : ╧Ε ╬╣)
  : ╧Α (┬υ (P E) έΘΤ Q)
  έΗΤ ╧Α ((`έβκ x, ┬υ (P x έΙπ (x = E))) έΘΤ Q) έΚΦ
begin
  assume P Q E h1 h2;
  refine h1 (╬╗ hpe, h2 E (έΙπά╡λ hpe (eq_refl E)))
end;

opaque symbol NRM23 [P : ╧Ε ╬╣ έΗΤ Prop] [Q : Prop] (E : ╧Ε ╬╣)
  : ╧Α (┬υ (P E) έΘΤ Q)
  έΗΤ ╧Α ((`έβκ x, ┬υ (P x έΙπ (E = x))) έΘΤ Q) έΚΦ
begin
  assume P Q E h1 h2;
  refine h1 (╬╗ hpe, h2 E (έΙπά╡λ hpe (eq_sym (eq_refl E))))
end;

// ---- NRM24-26: Simple transformations ----

// NRM24: P is not of the form A έΙπ B;
// H έΛλ έβκx ┬╖ ┬υ(TRUE έΙπ P) έΘΤ Q έΗΤ H έΛλ έβκx ┬╖ ┬υP έΘΤ Q
// Identical to NRM14 in HOAS (έβλ=έβκ=έΙΑ).
opaque symbol NRM24 [P : ╧Ε ╬╣ έΗΤ Prop] [Q : Prop]
  : ╧Α ((`έβκ x, ┬υ (έΛν έΙπ P x)) έΘΤ Q)
  έΗΤ ╧Α ((`έβκ x, ┬υ (P x)) έΘΤ Q) έΚΦ
begin
  assume P Q h1 h2;
  refine h1 (╬╗ x htpx, h2 x (έΙπέΓΣέΓΓ htpx))
end;

// NRM25: x not free in P; H έΛλ P έΗΤ H έΛλ έβκ(x) ┬╖ P
opaque symbol NRM25 [P : Prop]
  : ╧Α P
  έΗΤ ╧Α (`έβκ _ : ╧Ε ╬╣, P) έΚΦ
begin
  assume P hp x; refine hp
end;

// NRM26: y not free in P; H έΛλ έβκ(x, ...) ┬╖ P έΗΤ H έΛλ έβκ(x, y, ...) ┬╖ P
opaque symbol NRM26 [P : ╧Ε ╬╣ έΗΤ Prop]
  : ╧Α (`έβκ x, P x)
  έΗΤ ╧Α (`έβκ x, `έΙΑ _ : ╧Ε ╬╣, P x) έΚΦ
begin
  assume P h x y; refine h x
end;

// ---- NRM27-30: Arithmetic solver dispatch ----
//
// NRM27: (xά╡λ έΚν 0) and (έΙΤxά╡λ έΚν 0) in (P έΙπ...έΙπ Q); R = [xά╡λ := 0](P έΙπ...έΙπ Q)
//   έΗΤ H έΛλ έβλ(xέΓΒ,...,xά╡λέΓΜέΓΒ,xά╡λέΓΛέΓΒ,...,xέΓβ) ┬╖ ┬υR έΗΤ H έΛλ έβκ(xέΓΒ,...,xέΓβ) ┬╖ ┬υ(P έΙπ...έΙπ Q)
// NRM28: (x έΚν 0) and (έΙΤx έΚν 0) in (P έΙπ...έΙπ Q); S = [x := 0](P έΙπ...έΙπ Q)
//   έΗΤ H έΛλ ┬υ(S) έΘΤ R έΗΤ H έΛλ (έβκ(x) ┬╖ ┬υ(P έΙπ...έΙπ Q)) έΘΤ R
// NRM29: (a + xά╡λ έΚν 0) and (b έΙΤ xά╡λ έΚν 0) in (P έΙπ...έΙπ Q); solver(a+b) = 0; S = [xά╡λ := b](P έΙπ...έΙπ Q)
//   έΗΤ H έΛλ έβλ(...) ┬╖ ┬υS έΘΤ R έΗΤ H έΛλ (έβκ(xέΓΒ,...,xέΓβ) ┬╖ ┬υ(P έΙπ...έΙπ Q)) έΘΤ R
// NRM30: (a + x έΚν 0) and (b έΙΤ x έΚν 0) in (P έΙπ...έΙπ Q); solver(a+b) = 0; S = [x := b](P έΙπ...έΙπ Q)
//   έΗΤ H έΛλ ┬υS έΘΤ R έΗΤ H έΛλ (έβκx ┬╖ ┬υ(P έΙπ...έΙπ Q)) έΘΤ R
// TODO: all require arithmetic solver infrastructure
