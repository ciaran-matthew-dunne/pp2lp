// Normalisation (¬ßA.12) ‚ÄĒ tuple-based encoding.
//
// Spec uses `‚ôĘ` (= goal-side n-ary universal) and `‚ô°` (= hypothesis-
// side n-ary universal). Both reduce propositionally to `!!` via the
// `‚ôĘ_eq_!!` / `‚ô°_eq_!!` lemmas in lemmas/Tuple.lp; bodies use the dedicated
// `pi_to_‚ôĘ` / `‚ôĘ_to_pi` (and ‚ô° analogues) bridges.

require open pp2lp.B pp2lp.lemmas.Int pp2lp.lemmas.Tuple pp2lp.rules.Res;

// ---- NRM1-7: Logical transformations under `‚ôĘ` ----

// NRM1: x not free in P; H ‚äĘ P ‚áí S ‚Üí H ‚äĘ (‚ôĘx ¬∑ P) ‚áí S
opaque symbol NRM1 [n] [P S : Prop]
  : ŌÄ (P ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ _ : Tuple n, P) ‚áí S) ‚ČĒ
begin
  assume n P S h1 h2;
  refine h1 (‚ôĘ_to_pi (őĽ _ : Tuple n, P) h2 (inh_tuple [n]))
end;

// NRM2: x not free in P; H ‚äĘ (P ‚áí ‚ôĘx ¬∑ Q) ‚áí S ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí Q) ‚áí S
opaque symbol NRM2 [n] [P : Prop] [Q : Tuple n ‚Üí Prop] [S : Prop]
  : ŌÄ ((P ‚áí (`‚ôĘ v, Q v)) ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ v, P ‚áí Q v) ‚áí S) ‚ČĒ
begin
  assume n P Q S h1 h2;
  refine h1 (őĽ p,
    pi_to_‚ôĘ Q (őĽ v, ‚ôĘ_to_pi (őĽ v', P ‚áí Q v') h2 v p))
end;

// NRM3: x not free in Q; H ‚äĘ (Q ‚áí S) ‚ąß ((‚ąÄx ¬∑ ¬¨P) ‚áí S) ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí Q) ‚áí S
opaque symbol NRM3 [n] [P : Tuple n ‚Üí Prop] [Q S : Prop]
  : ŌÄ (‚čÄ_snoc (Q ‚áí S) ((`!! v, ¬¨ (P v)) ‚áí S))
  ‚Üí ŌÄ ((`‚ôĘ v, P v ‚áí Q) ‚áí S) ‚ČĒ
begin
  assume n P Q S h1 h2;
  refine ‚ą®‚āĎ (em (`?? v, P v)) _ _
  { assume hex;
    refine pi_to_??_elim P
      (őĽ v hpv, (‚čÄ‚āā_hd h1) (‚ôĘ_to_pi (őĽ v', P v' ‚áí Q) h2 v hpv)) hex }
  { assume hnex;
    refine (‚čÄ‚āā_snd h1) (pi_to_!! (őĽ v, ¬¨ (P v))
      (őĽ v hpv, hnex (pi_to_??_intro P v hpv))) }
end;

// NRM4: x not free in Q; H ‚äĘ (Q ‚áí ‚ôĘx ¬∑ (P ‚áí R)) ‚áí S ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí Q ‚áí R) ‚áí S
opaque symbol NRM4 [n] [P R : Tuple n ‚Üí Prop] [Q S : Prop]
  : ŌÄ ((Q ‚áí (`‚ôĘ v, P v ‚áí R v)) ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ v, P v ‚áí Q ‚áí R v) ‚áí S) ‚ČĒ
begin
  assume n P R Q S h1 h2;
  refine h1 (őĽ hq,
    pi_to_‚ôĘ (őĽ v, P v ‚áí R v)
      (őĽ v hpv, ‚ôĘ_to_pi (őĽ v', P v' ‚áí Q ‚áí R v') h2 v hpv hq))
end;

// NRM5: H ‚äĘ ‚ôĘx ¬∑ (P ‚ąß Q ‚áí R) ‚áí S ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí Q ‚áí R) ‚áí S
// Uncurry: `‚čÄ_snoc (P v) (Q v)` reduces to `‚čÄ (‚ąé ‚ą∑ P v ‚ą∑ Q v)`, so the
// hypothesis splits with `‚čÄ‚āā_hd`/`‚čÄ‚āā_snd` to feed the curried body.
opaque symbol NRM5 [n] [P Q R : Tuple n ‚Üí Prop] [S : Prop]
  : ŌÄ ((`‚ôĘ v, ‚čÄ_snoc (P v) (Q v) ‚áí R v) ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ v, P v ‚áí Q v ‚áí R v) ‚áí S) ‚ČĒ
begin
  assume n P Q R S h1 h2;
  refine h1 (pi_to_‚ôĘ (őĽ v, ‚čÄ_snoc (P v) (Q v) ‚áí R v)
    (őĽ v hpq, ‚ôĘ_to_pi (őĽ v', P v' ‚áí Q v' ‚áí R v') h2 v
                (‚čÄ‚āā_hd hpq) (‚čÄ‚āā_snd hpq)))
end;

// NRM6: H ‚äĘ ‚ôĘx ¬∑ (R ‚áí P) ‚áí (‚ôĘx ¬∑ (R ‚áí Q) ‚áí S) ‚Üí H ‚äĘ ‚ôĘx ¬∑ (R ‚áí P ‚ąß Q) ‚áí S
// Generalised over a snoc list: the consequent `‚čÄ (qs v ‚ą∑ P v)` splits into
// init `‚čÄ (qs v)` and last `P v`.  init-first lets the emitter chain
// `refine NRM6 _;` for n-conjunct goals, since `‚čÄ (qs v)` is itself a
// `‚čÄ (qs' v ‚ą∑ P' v)` when |qs v| ‚Č• 2.
opaque symbol NRM6 [n] [Qs : Tuple n ‚Üí ūĚēÉ* o] [P R : Tuple n ‚Üí Prop] [S : Prop]
  : ŌÄ ((`‚ôĘ v, R v ‚áí ‚čÄ (Qs v)) ‚áí ((`‚ôĘ v, R v ‚áí P v) ‚áí S))
  ‚Üí ŌÄ ((`‚ôĘ v, R v ‚áí ‚čÄ (Qs v ‚ą∑ P v)) ‚áí S) ‚ČĒ
begin
  assume n qs P R S h1 h2;
  refine h1
    (pi_to_‚ôĘ (őĽ v, R v ‚áí ‚čÄ (qs v))
      (őĽ v hr, ‚čÄ_init (‚ôĘ_to_pi (őĽ v', R v' ‚áí ‚čÄ (qs v' ‚ą∑ P v')) h2 v hr)))
    (pi_to_‚ôĘ (őĽ v, R v ‚áí P v)
      (őĽ v hr, ‚čÄ_last (‚ôĘ_to_pi (őĽ v', R v' ‚áí ‚čÄ (qs v' ‚ą∑ P v')) h2 v hr)))
end;

// NRM7: H ‚äĘ (‚ôĘx ¬∑ P) ‚áí ((‚ôĘx ¬∑ Q) ‚áí S) ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚ąß Q) ‚áí S
// Generalised: same shape as NRM6 but without the R ‚áí antecedent.
opaque symbol NRM7 [n] [Qs : Tuple n ‚Üí ūĚēÉ* o] [P : Tuple n ‚Üí Prop] [S : Prop]
  : ŌÄ ((`‚ôĘ v, ‚čÄ (Qs v))
        ‚áí ((`‚ôĘ v, P v) ‚áí S))
  ‚Üí ŌÄ ((`‚ôĘ v : Tuple n, ‚čÄ (Qs v ‚ą∑ P v)) ‚áí S) ‚ČĒ
begin
  assume n qs P S h1 h2;
  refine h1
    (pi_to_‚ôĘ (őĽ v, ‚čÄ (qs v))
      (őĽ v, ‚čÄ_init (‚ôĘ_to_pi (őĽ v', ‚čÄ (qs v' ‚ą∑ P v')) h2 v)))
    (pi_to_‚ôĘ (őĽ v, P v)
      (őĽ v, ‚čÄ_last (‚ôĘ_to_pi (őĽ v', ‚čÄ (qs v' ‚ą∑ P v')) h2 v)))
end;

// ---- NRM8-9: compound‚ÜĒmixed binders (split with `take`/`drop`) ----
//
// NRM8: spec is `(‚ôĘ(x,y) ¬∑ Q) ‚áí S` ‚Üź `(‚ôĘx ¬∑ ‚ąÄy ¬∑ Q) ‚áí S`.
// Encoded with the n,m-indexed split helpers from B.lp:
//   the conclusion's `Q x y` (clean HO pattern) gets unified back
//   from the premise's `Q (take v) (drop v)` after Lambdapi infers Q.
opaque symbol NRM8 [n m] [Q : Tuple n ‚Üí Tuple m ‚Üí Prop] [S : Prop]
  : ŌÄ ((`‚ôĘ v : Tuple (n ++ m), Q (take [n] [m] v) (drop [n] [m] v)) ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ x : Tuple n, `!! y : Tuple m, Q x y) ‚áí S) ‚ČĒ
begin
  assume n m Q S h hnested;
  // hnested : ŌÄ (`‚ôĘ x : Tuple n, `!! y : Tuple m, Q x y)
  // Need:    ŌÄ (`‚ôĘ v : Tuple (n ++ m), Q (take v) (drop v))
  // Witness: őĽ v, !!_to_pi (Q x) (‚ôĘ_to_pi (őĽ x, `!! y, Q x y) hnested x') y'
  //          where x' = take v, y' = drop v.
  refine h (pi_to_‚ôĘ (őĽ v : Tuple (n ++ m),
                       Q (take [n] [m] v) (drop [n] [m] v))
    (őĽ v : Tuple (n ++ m),
       !!_to_pi (őĽ y, Q (take [n] [m] v) y)
                (‚ôĘ_to_pi (őĽ x, `!! y : Tuple m, Q x y)
                         hnested
                         (take [n] [m] v))
                (drop [n] [m] v)))
end;

// NRM9: spec is `(‚ôĘ(x,y) ¬∑ (P ‚áí Q)) ‚áí S` ‚Üź `(‚ôĘx ¬∑ (P ‚áí ‚ąÄy ¬∑ Q)) ‚áí S`,
// with y not free in P. Same split: premise body is `P (take v) ‚áí Q (take v) (drop v)`.
opaque symbol NRM9 [n m]
  [P : Tuple n ‚Üí Prop]
  [Q : Tuple n ‚Üí Tuple m ‚Üí Prop]
  [S : Prop]
  : ŌÄ ((`‚ôĘ v : Tuple (n ++ m),
         P (take [n] [m] v) ‚áí Q (take [n] [m] v) (drop [n] [m] v)) ‚áí S)
  ‚Üí ŌÄ ((`‚ôĘ x : Tuple n, P x ‚áí (`!! y : Tuple m, Q x y)) ‚áí S) ‚ČĒ
begin
  assume n m P Q S h hnested;
  refine h (pi_to_‚ôĘ
    (őĽ v, P (take [n] [m] v) ‚áí Q (take [n] [m] v) (drop [n] [m] v))
    (őĽ v hp,
       !!_to_pi (őĽ y, Q (take [n] [m] v) y)
                (‚ôĘ_to_pi (őĽ x, P x ‚áí (`!! y : Tuple m, Q x y))
                         hnested
                         (take [n] [m] v)
                         hp)
                (drop [n] [m] v)))
end;

// ---- NRM10-15: Implication / negation under `‚ôĘ` and `‚ô°` ----

// NRM10: H ‚äĘ ‚ô°x ¬∑ ¬¨(P ‚ąß Q) ‚áí R ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚ąß Q ‚áí ‚ä•) ‚áí R
opaque symbol NRM10 [n] [Ps : Tuple n ‚Üí ūĚēÉ* o] [Q : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° v, ¬¨ ‚čÄ (Ps v ‚ą∑ Q v)) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ v, ‚čÄ (Ps v ‚ą∑ Q v) ‚áí ‚ä•) ‚áí R) ‚ČĒ
begin
  assume n Ps Q R h1 h2;
  refine h1 (pi_to_‚ô° (őĽ v, ¬¨ ‚čÄ (Ps v ‚ą∑ Q v))
    (őĽ v hpq, ‚ôĘ_to_pi (őĽ v', ‚čÄ (Ps v' ‚ą∑ Q v') ‚áí ‚ä•) h2 v hpq))
end;

// NRM11: H ‚äĘ ‚ô°x ¬∑ ¬¨(‚ä§ ‚ąß P) ‚áí R ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí ‚ä•) ‚áí R
opaque symbol NRM11 [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° v, ¬¨ (‚čÄ_snoc ‚ä§ (P v))) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ v, P v ‚áí ‚ä•) ‚áí R) ‚ČĒ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_‚ô° (őĽ v, ¬¨ ‚čÄ (‚ąé ‚ą∑ ‚ä§ ‚ą∑ P v))
    (őĽ v htpv, ‚ôĘ_to_pi (őĽ v', P v' ‚áí ‚ä•) h2 v (‚čÄ‚āā_snd htpv)))
end;

// NRM12: H ‚äĘ ‚ô°x ¬∑ ¬¨(P ‚ąß Q) ‚áí R ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí ¬¨Q) ‚áí R
opaque symbol NRM12 [n] [P Q : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° v, ¬¨ ‚čÄ_snoc (P v) (Q v)) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ v, P v ‚áí ¬¨ (Q v)) ‚áí R) ‚ČĒ
begin
  assume n P Q R h1 h2;
  refine h1 (pi_to_‚ô° (őĽ v, ¬¨ ‚čÄ (‚ąé ‚ą∑ P v ‚ą∑ Q v))
    (őĽ v hpq, ‚ôĘ_to_pi (őĽ v', P v' ‚áí ¬¨ (Q v')) h2 v
                (‚čÄ‚āā_hd hpq) (‚čÄ‚āā_snd hpq)))
end;

// NRM13: H ‚äĘ ‚ô°x ¬∑ ¬¨(P ‚ąß ¬¨Q) ‚áí R ‚Üí H ‚äĘ ‚ôĘx ¬∑ (P ‚áí Q) ‚áí R
opaque symbol NRM13 [n] [P Q : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° v, ¬¨ ‚čÄ_snoc (P v) (¬¨ Q v)) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ v, P v ‚áí Q v) ‚áí R) ‚ČĒ
begin
  assume n P Q R h1 h2;
  refine h1 (pi_to_‚ô° (őĽ v, ¬¨ ‚čÄ (‚ąé ‚ą∑ P v ‚ą∑ ¬¨ (Q v)))
    (őĽ v hc, (‚čÄ‚āā_snd hc) (‚ôĘ_to_pi (őĽ v', P v' ‚áí Q v') h2 v (‚čÄ‚āā_hd hc))))
end;

// NRM14: H ‚äĘ ‚ô°x ¬∑ ¬¨(‚ä§ ‚ąß P) ‚áí R ‚Üí H ‚äĘ (‚ôĘx ¬∑ ¬¨P) ‚áí R
opaque symbol NRM14 [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° v, ¬¨ ‚čÄ_snoc ‚ä§ (P v)) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ v, ¬¨ (P v)) ‚áí R) ‚ČĒ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_‚ô° (őĽ v, ¬¨ ‚čÄ (‚ąé ‚ą∑ ‚ä§ ‚ą∑ P v))
    (őĽ v htpv, ‚ôĘ_to_pi (őĽ v', ¬¨ (P v')) h2 v (‚čÄ‚āā_snd htpv)))
end;

// NRM15: H ‚äĘ ‚ô°x ¬∑ ¬¨(‚ä§ ‚ąß ¬¨P) ‚áí R ‚Üí H ‚äĘ (‚ôĘx ¬∑ P) ‚áí R
opaque symbol NRM15 [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ ((`‚ô° v, ¬¨ ‚čÄ_snoc ‚ä§ (¬¨ P v)) ‚áí R)
  ‚Üí ŌÄ ((`‚ôĘ v, P v) ‚áí R) ‚ČĒ
begin
  assume n P R h1 h2;
  refine h1 (pi_to_‚ô° (őĽ v, ¬¨ ‚čÄ (‚ąé ‚ą∑ ‚ä§ ‚ą∑ ¬¨ (P v)))
    (őĽ v htnpv, (‚čÄ‚āā_snd htnpv) (‚ôĘ_to_pi P h2 v)))
end;

// ---- NRM16-19: Universal-instantiation patterns ----

// NRM16: ‚ąÄx.P in H; Q ‚Üí H ‚äĘ (‚ô°x ¬∑ P) ‚áí Q
opaque symbol NRM16 [n] [P : Tuple n ‚Üí Prop] [Q : Prop]
  : ŌÄ (`!! v, P v)
  ‚Üí ŌÄ Q
  ‚Üí ŌÄ ((`‚ô° v, P v) ‚áí Q) ‚ČĒ
begin
  assume n P Q hp hq ht; refine hq
end;

// NRM17: NRM16 with extra spec-level equality side-conditions.
// At the LP level the proof obligation collapses to NRM16's shape.
opaque symbol NRM17 [n] [P : Tuple n ‚Üí Prop] [Q : Prop]
  : ŌÄ (`!! v, P v)
  ‚Üí ŌÄ Q
  ‚Üí ŌÄ ((`‚ô° v, P v) ‚áí Q) ‚ČĒ
begin
  assume n P Q hp hq ht; refine hq
end;

// NRM18: ‚ąÄx ¬∑ ¬¨(‚ä§ ‚ąß ¬¨P) in H; ‚ąÉE. [x:=E]P = R ‚Üí H ‚äĘ ‚ô°y ¬∑ ¬¨(‚ä§ ‚ąß R) ‚áí Q
opaque symbol NRM18 [n] [P : Tuple n ‚Üí Prop] [R Q : Prop] (v : Tuple n)
  : ŌÄ (`!! u, ¬¨ ‚čÄ_snoc ‚ä§ (¬¨ P u))
  ‚Üí ŌÄ (P v = R)
  ‚Üí ŌÄ ((`‚ô° _ : Tuple n, ¬¨ ‚čÄ_snoc ‚ä§ R) ‚áí Q) ‚ČĒ
begin
  assume n P R Q v hp heq h;
  // Derive ŌÄ (P v) classically.
  have hpv : ŌÄ (P v)
    { refine ¬¨¬¨‚āĎ (P v) _;
      assume hnpv;
      refine !!_to_pi (őĽ u, ¬¨ ‚čÄ (‚ąé ‚ą∑ ‚ä§ ‚ą∑ ¬¨ (P u))) hp v (‚čÄ‚āā_intro ‚ä§ŠĶĘ hnpv) };
  // Transport along heq.
  have hr : ŌÄ R { rewrite left heq; refine hpv };
  refine ‚ä•‚āĎ (‚ô°_to_pi (őĽ _ : Tuple n, ¬¨ ‚čÄ (‚ąé ‚ą∑ ‚ä§ ‚ą∑ R)) h (inh_tuple [n])
              (‚čÄ‚āā_intro ‚ä§ŠĶĘ hr))
end;

// NRM19: P in H; ‚ąÉE. [x:=E]R = P ‚Üí H ‚äĘ ‚ô°x ¬∑ ¬¨(‚ä§ ‚ąß R) ‚áí Q
opaque symbol NRM19 [n] [Q : Prop] [R : Tuple n ‚Üí Prop] (v : Tuple n)
  : ŌÄ (R v)
  ‚Üí ŌÄ ((`‚ô° u, ¬¨ ‚čÄ_snoc ‚ä§ (R u)) ‚áí Q) ‚ČĒ
begin
  assume n Q R v hr hf;
  refine ‚ä•‚āĎ (‚ô°_to_pi (őĽ u, ¬¨ ‚čÄ (‚ąé ‚ą∑ ‚ä§ ‚ą∑ R u)) hf v (‚čÄ‚āā_intro ‚ä§ŠĶĘ hr))
end;

// ---- NRM20-23: Substitution (drop a binder pinned by an equality) ----
//
// PP pins *whichever* binder an equality conjunct fixes, at *any* slot k of the
// ‚ô°-block, with the witness E a function of the remaining binders (`#x.#y.(x=y)`
// pins x at y).  `ins`/`rm` (B.lp) splice slot k in and out and `prj_ins`
// (lemmas/Tuple.lp) is the round-trip, so one lemma ‚ÄĒ NRM20 ‚ÄĒ covers every slot;
// the emitter supplies k and E, and bubbles the pinning equality to the conjunct
// list's *tail* (`qs v ‚ą∑ eq`) first when PP places it elsewhere.  The one shape it
// does NOT route here ‚ÄĒ slot-0 head equality with block-closed E (PP's `¬¨(x=E ‚ąß ‚Ä¶)`,
// all of prv) ‚ÄĒ takes the NRM20H fast path below, which peels the head equality
// with popl/dropl and so skips that per-site rotation.  NRM21 is the reversed-
// equality (`E = x`) orientation; NRM22/23 (below) are the unary instances PP
// emits with no surrounding block.
//
//   H ‚äĘ ‚ô°v'¬∑¬¨(qs[x‚āĖ:=E v'])        H ‚äĘ ‚ô°v¬∑¬¨(qs ‚ąß (prj k v = E (rm k v)))
opaque symbol NRM20 [n] (k : ‚Ąē) [qs : Tuple (+1 n) ‚Üí ūĚēÉ* o] [Q : Prop]
  (E : Tuple n ‚Üí ŌĄ őĻ)
  : ŌÄ ((`‚ô° v' : Tuple n, ¬¨ ‚čÄ (qs (ins k (E v') v'))) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° v : Tuple (+1 n), ¬¨ ‚čÄ (qs v ‚ą∑ (prj k v = E (rm k v)))) ‚áí Q) ‚ČĒ
begin
  assume n k qs Q E hsmall hbig;
  refine hsmall (pi_to_‚ô° (őĽ v' : Tuple n, ¬¨ ‚čÄ (qs (ins k (E v') v')))
    (őĽ v' hq,
      ‚ô°_to_pi (őĽ v, ¬¨ ‚čÄ (qs v ‚ą∑ (prj k v = E (rm k v)))) hbig (ins k (E v') v')
        (‚čÄ_intro hq (prj_ins k (E v') v'))))
end;

// NRM20H: fast path for the common shape ‚ÄĒ pinning equality at the conjunct
// *head*, slot 0, E block-closed.  popl/dropl peel the head equality directly (no
// rotation), and slot 0 is a plain `v' ‚®ĺ E` (no `ins`/`rm`).  Semantically the
// slot-0 head case of NRM20; kept separate only because the rotation NRM20 would
// need here is the per-site cost that dominates prv's NRM20-dense proofs.
opaque symbol NRM20H [n] [ps : Tuple (+1 n) ‚Üí ūĚēÉ* o] [Q : Prop] (E : ŌĄ őĻ)
  : (ő† v', ŌÄ (popl (ps v') = (prj 0 v' = E)))
  ‚Üí ŌÄ ((`‚ô° v' : Tuple n, ¬¨ ‚čÄ dropl (ps (v' ‚®ĺ E))) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° v : Tuple (+1 n), ¬¨ ‚čÄ (ps v)) ‚áí Q) ‚ČĒ
begin
  assume n ps Q E heq hsmall hbig;
  refine hsmall (pi_to_‚ô° (őĽ v' : Tuple n, ¬¨ ‚čÄ dropl (ps (v' ‚®ĺ E)))
    (őĽ v' hp,
      ‚ô°_to_pi (őĽ v, ¬¨ ‚čÄ (ps v)) hbig (v' ‚®ĺ E)
        (‚čÄ_pop_intro (ps (v' ‚®ĺ E))
          (=‚áí (eq_sym (heq (v' ‚®ĺ E))) (eq_refl E))
          hp)))
end;

// NRM21: NRM20 with the equality reversed (`E (rm k v) = prj k v`).
opaque symbol NRM21 [n] (k : ‚Ąē) [qs : Tuple (+1 n) ‚Üí ūĚēÉ* o] [Q : Prop]
  (E : Tuple n ‚Üí ŌĄ őĻ)
  : ŌÄ ((`‚ô° v' : Tuple n, ¬¨ ‚čÄ (qs (ins k (E v') v'))) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° v : Tuple (+1 n), ¬¨ ‚čÄ (qs v ‚ą∑ (E (rm k v) = prj k v))) ‚áí Q) ‚ČĒ
begin
  assume n k qs Q E hsmall hbig;
  refine hsmall (pi_to_‚ô° (őĽ v' : Tuple n, ¬¨ ‚čÄ (qs (ins k (E v') v')))
    (őĽ v' hq,
      ‚ô°_to_pi (őĽ v, ¬¨ ‚čÄ (qs v ‚ą∑ (E (rm k v) = prj k v))) hbig (ins k (E v') v')
        (‚čÄ_intro hq (eq_sym (prj_ins k (E v') v')))))
end;

// NRM22: the ‚ô°-body's tail equality pins the binder at E (general list
// form; the ‚ä§-headed NRM14-fed shape is the instance ps := őĽ _, (‚ąé ‚ą∑ ‚ä§)).
opaque symbol NRM22 [Q : Prop] [ps : Tuple 1 ‚Üí ūĚēÉ* o] (E : ŌĄ őĻ)
  : ŌÄ (¬¨ ‚čÄ (ps (unit ‚®ĺ E)) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° v : Tuple 1, ¬¨ ‚čÄ (ps v ‚ą∑ (prj 0 v = E))) ‚áí Q) ‚ČĒ
begin
  assume Q ps E h1 h2;
  refine h1 (őĽ hps,
    ‚ô°_to_pi (őĽ v : Tuple 1, ¬¨ ‚čÄ (ps v ‚ą∑ (prj 0 v = E)))
            h2 (unit ‚®ĺ E)
            (‚čÄ_intro hps (eq_refl E)))
end;

// NRM23: NRM22 with reversed equality (‚ä§-headed special case; kept for the
// chain-form nrm23_eq bridge).
opaque symbol NRM23 [Q : Prop] (E : ŌĄ őĻ)
  : ŌÄ (¬¨ ‚ä§ ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° v : Tuple 1,
         ¬¨ ‚čÄ (‚ąé ‚ą∑ ‚ä§ ‚ą∑ (E = prj 0 v))) ‚áí Q) ‚ČĒ
begin
  assume Q E h1 h2;
  refine h1 (őĽ ht,
    ‚ô°_to_pi (őĽ v : Tuple 1, ¬¨ ‚čÄ (‚ąé ‚ą∑ ‚ä§ ‚ą∑ (E = prj 0 v)))
            h2 (unit ‚®ĺ E)
            (‚čÄ‚āā_intro ht (eq_refl E)))
end;

// NRM23G: the general-list reversed form (NRM22's exact mirror) ‚ÄĒ the
// main-tree emitter uses this one uniformly.
opaque symbol NRM23G [Q : Prop] [ps : Tuple 1 ‚Üí ūĚēÉ* o] (E : ŌĄ őĻ)
  : ŌÄ (¬¨ ‚čÄ (ps (unit ‚®ĺ E)) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° v : Tuple 1, ¬¨ ‚čÄ (ps v ‚ą∑ (E = prj 0 v))) ‚áí Q) ‚ČĒ
begin
  assume Q ps E h1 h2;
  refine h1 (őĽ hps,
    ‚ô°_to_pi (őĽ v : Tuple 1, ¬¨ ‚čÄ (ps v ‚ą∑ (E = prj 0 v)))
            h2 (unit ‚®ĺ E)
            (‚čÄ_intro hps (eq_refl E)))
end;

// ---- NRM24-26: Trivial structural rules ----

// NRM24: P not of form A ‚ąß B; H ‚äĘ ‚ô°x ¬∑ ¬¨(‚ä§ ‚ąß P) ‚áí Q ‚Üí H ‚äĘ ‚ô°x ¬∑ ¬¨P ‚áí Q
opaque symbol NRM24 [n] [P : Tuple n ‚Üí Prop] [Q : Prop]
  : ŌÄ ((`‚ô° v, ¬¨ ‚čÄ (‚ąé ‚ą∑ ‚ä§ ‚ą∑ P v)) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° v, ¬¨ (P v)) ‚áí Q) ‚ČĒ
begin
  assume n P Q h1 h2;
  refine h1 (pi_to_‚ô° (őĽ v, ¬¨ ‚čÄ (‚ąé ‚ą∑ ‚ä§ ‚ą∑ P v))
    (őĽ v htpv, ‚ô°_to_pi (őĽ v', ¬¨ (P v')) h2 v (‚čÄ‚āā_snd htpv)))
end;

// NRM25: x not free in P; H ‚äĘ P ‚Üí H ‚äĘ ‚ô°(x) ¬∑ P
//   = forall2(x).P in PP notation. `pi_to_‚ô°` with constant predicate
//   (the body doesn't depend on the bound tuple).
opaque symbol NRM25 [n] [P : Prop] [Q : Prop]
  : ŌÄ (P ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° _ : Tuple n, P) ‚áí Q) ‚ČĒ
begin
  assume n P Q hp h‚ô°;
  refine hp (‚ô°_to_pi (őĽ _, P) h‚ô° (inh_tuple [n]))
end;

// NRM26: y not free in P; H ‚äĘ ‚ô°(x,‚Ä¶)¬∑P ‚Üí H ‚äĘ ‚ô°(x,y,‚Ä¶)¬∑P.  PP drops the unused
// binder at *any* slot k; one lemma covers them all ‚ÄĒ instantiate the ‚ô° at
// `ins k (el őĻ) v'`.  The dropped slot is never read, so the dummy is `el őĻ` (the
// canonical inhabitant), not a misleading ūĚüé.  The emitter supplies k (the dropped
// var's position, read off the annotation diff against the child's binder list).
opaque symbol NRM26 [n] (k : ‚Ąē) [P : Tuple (+1 n) ‚Üí Prop] [Q : Prop]
  : ŌÄ ((`‚ô° v' : Tuple n, P (ins k (el őĻ) v')) ‚áí Q)
  ‚Üí ŌÄ ((`‚ô° v : Tuple (+1 n), P v) ‚áí Q) ‚ČĒ
begin
  assume n k P Q hp h‚ô°;
  refine hp (pi_to_‚ô° (őĽ v', P (ins k (el őĻ) v'))
    (őĽ v', ‚ô°_to_pi (őĽ v, P v) h‚ô° (ins k (el őĻ) v')))
end;

// ---- NRM27-30: Arithmetic solver dispatch (trust-free) ----
//
// PP's solver closes a universal hypothesis `‚ô°(x‚āĀ,‚Ä¶,x‚āô)¬∑¬¨(P ‚ąß ‚Ä¶ ‚ąß Q)`
// when the conjunction holds two bounding inequalities `a + xŠĶĘ ‚Č§ ūĚüé` and
// `b ‚ąí xŠĶĘ ‚Č§ ūĚüé` with `solveur(a + b) = ūĚüé`: those force `xŠĶĘ = b`, and the
// substituted conjunction `[xŠĶĘ := b](P ‚ąß ‚Ä¶ ‚ąß Q)` is satisfiable, so the
// universal-of-negation is *false* and discharges the sequent.
//
// One lemma, NRM29, realises all four PP rules: peel the pinned binder by
// *instantiating* the `‚ô°`-hypothesis at the solver witness `b` (the membership
// premises the spec carries are solver bookkeeping ‚ÄĒ unused here), leaving the
// continuation `‚ôĘv'¬∑¬¨‚čÄ(ps (v' ‚®ĺ b v')) ‚áí R`; the emitter bridges the substituted
// conjunction `‚čÄ (ps (v' ‚®ĺ b v'))` to ‚ä§ with a generated congruence proof (each
// cancelling bound = ‚ä§ via `eq_true` + `leq_zero_of_sum_zero` + `prove_sum_eq`).
// NRM27/28 are the `xŠĶĘ := ūĚüé` case (b = ūĚüé) and NRM30 the unary (‚ô°x) case ‚ÄĒ the
// emitter maps all of NRM27/28/30 onto NRM29 with the matching witness.  Only
// NRM29 is corpus-triggered (apero); the others have no replay.

// ---- helper lemmas for the trust-free solver dispatch ----

// `P` provably true ‚üĻ `P = ‚ä§`, so a ‚čÄ-conjunct the solver discharges can
// be rewritten to ‚ä§ and absorbed by `‚čÄ (_ ‚ą∑ ‚ä§) ‚Ü™ ‚čÄ _`.
opaque symbol eq_true (P : Prop) : ŌÄ P ‚Üí ŌÄ (P = ‚ä§) ‚ČĒ
begin
  assume P h;
  refine propExt _ _ _ _
  { assume hp; refine ‚ä§ŠĶĘ }
  { assume ht; refine h }
end;

// A sum that arithmetic-normalises to ūĚüé is ‚Č§ ūĚüé.  The emitter builds the
// `E = ūĚüé` proof with `prove_sum_eq` (add_comm/assoc/opp cancellation).
opaque symbol leq_zero_of_sum_zero (E : ŌĄ őĻ) : ŌÄ (E = ūĚüé) ‚Üí ŌÄ (leq E ūĚüé) ‚ČĒ
begin
  assume E h;
  rewrite h;
  refine leq_refl ūĚüé
end;

// NRM29: multi-binder, pin the prj0 slot to `b v'` (witness a function of
// the remaining binders ‚ÄĒ e.g. b v' = ‚ÄĒ prj 0 v' for the sum-zero /
// cancelling case).  The emitter supplies `b` and the ‚ä§-normalisation
// bridge for the substituted conjunction `‚čÄ (ps (v' ‚®ĺ b v'))`.
opaque symbol NRM29 [n] [ps : Tuple (+1 n) ‚Üí ūĚēÉ* o] [R : Prop] (b : Tuple n ‚Üí ŌĄ őĻ)
  : ŌÄ ((`‚ôĘ v' : Tuple n, ¬¨ ‚čÄ (ps (v' ‚®ĺ b v'))) ‚áí R)
  ‚Üí ŌÄ ((`‚ô° v : Tuple (+1 n), ¬¨ ‚čÄ (ps v)) ‚áí R) ‚ČĒ
begin
  assume n ps R b h_prem h‚ô°;
  refine h_prem (pi_to_‚ôĘ (őĽ v', ¬¨ ‚čÄ (ps (v' ‚®ĺ b v')))
    (őĽ v', ‚ô°_to_pi (őĽ v, ¬¨ ‚čÄ (ps v)) h‚ô° (v' ‚®ĺ b v')))
end;

// ---- `_1` (Result-form) variants ‚ÄĒ ¬ß8.13 ----
//
// PP leaves NRM rules *unprimed* in the first-normalisation chain (unlike
// ALL7/ALL9/STOP/IMP), so the emitter primes a chain-context `NRM<k>` to
// `NRM<k>_1` (`Emit_ctx.chain_emit_name`).  Each chain form lifts the base
// rule's premise‚Üíconclusion implication to a `Res`-to-`Res` map through a
// bridge equality `nrm<k>_eq : conclusion = premise`; the body is the uniform
// `mk_1 (res_tm r) (eq_trans (@nrm<k>_eq ‚Ä¶) (res_eq r))`.  Every NRM rule that
// can appear in a Res chain needs one (see CLAUDE.md: emitting an undefined
// `NRM<k>_1` shows up as a lambdapi "Unknown symbol", not a fail-loud emit).

symbol NRM1_1 [n] [P Q : Prop]
  (r : Res (P ‚áí Q)) : Res ((`‚ôĘ _ : Tuple n, P) ‚áí Q)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm1_eq n P Q) (res_eq r));

// NRM2 bridge (evidence form).  PP's chain NRM2 weakens the ‚ôĘ-body by a v-free
// hypothesis P (`(‚ôĘv¬∑Q v) ‚áí S  ‚Ü¶  (‚ôĘv¬∑(P‚áíQ v)) ‚áí S`), sound only given a proof
// of P: under `hp : ŌÄ P` the body equivalence `(P‚áíQ v) ‚üļ Q v` holds, lifted
// under the ‚ôĘ by `!!_cong`.  Unlike the unconditional nrmK_eq bridges this
// takes `hp`, so the emitter must supply it (translate.ml NRM2 chain dispatch).
opaque symbol nrm2_eq [n] [P : Prop] [Q : Tuple n ‚Üí Prop] [S : Prop] (hp : ŌÄ P)
  : ŌÄ (((`‚ôĘ v, P ‚áí Q v) ‚áí S) = ((`‚ôĘ v, Q v) ‚áí S)) ‚ČĒ
begin
  assume n P Q S hp;
  have hbody : ő† v, ŌÄ ((P ‚áí Q v) = (Q v))
    { assume v; refine propExt _ _ (őĽ hpq, hpq hp) (őĽ hq _, hq) };
  have hpred : ŌÄ ((`‚ôĘ v, P ‚áí Q v) = (`‚ôĘ v, Q v))
    { refine eq_trans (‚ôĘ_eq_!! (őĽ v, P ‚áí Q v))
        (eq_trans (!!_cong hbody) (eq_sym (‚ôĘ_eq_!! (őĽ v, Q v)))) };
  rewrite hpred; reflexivity
end;

// NRM2_1 ‚ÄĒ chain (Res) form of NRM2, via the evidence-form `nrm2_eq` above.
symbol NRM2_1 [n] [P : Prop] [Q : Tuple n ‚Üí Prop] [S : Prop] (hp : ŌÄ P)
  (r : Res ((`‚ôĘ v, Q v) ‚áí S)) : Res ((`‚ôĘ v, P ‚áí Q v) ‚áí S)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm2_eq n P Q S hp) (res_eq r));

// NRM14_1 ‚ÄĒ chain (Res) form of NRM14.  PP leaves NRM rules *unprimed* in the
// first-normalisation chain (unlike ALL7/ALL9/STOP/IMP), so the emitter maps a
// chain-context `NRM14` to this; `nrm14_eq` (Res.lp) is the bridge equality.
symbol NRM14_1 [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  (r : Res ((`‚ô° v, ¬¨ ‚čÄ_snoc ‚ä§ (P v)) ‚áí R)) : Res ((`‚ôĘ v, ¬¨ (P v)) ‚áí R)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm14_eq n P R) (res_eq r));

// NRM13_1 ‚ÄĒ chain (Res) form of NRM13, via the `nrm13_eq` bridge (Res.lp).
symbol NRM13_1 [n] [P Q : Tuple n ‚Üí Prop] [R : Prop]
  (r : Res ((`‚ô° v, ¬¨ ‚čÄ_snoc (P v) (¬¨ Q v)) ‚áí R)) : Res ((`‚ôĘ v, P v ‚áí Q v) ‚áí R)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm13_eq n P Q R) (res_eq r));

// NRM12_1 ‚ÄĒ chain (Res) form of NRM12, via the `nrm12_eq` bridge (Res.lp).
symbol NRM12_1 [n] [P Q : Tuple n ‚Üí Prop] [R : Prop]
  (r : Res ((`‚ô° v, ¬¨ ‚čÄ_snoc (P v) (Q v)) ‚áí R)) : Res ((`‚ôĘ v, P v ‚áí ¬¨ (Q v)) ‚áí R)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm12_eq n P Q R) (res_eq r));

// NRM15_1 ‚ÄĒ chain (Res) form of NRM15, via the `nrm15_eq` bridge (Res.lp).
symbol NRM15_1 [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  (r : Res ((`‚ô° v, ¬¨ ‚čÄ_snoc ‚ä§ (¬¨ (P v))) ‚áí R)) : Res ((`‚ôĘ v, P v) ‚áí R)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm15_eq n P R) (res_eq r));

// NRM5_1 ‚ÄĒ chain (Res) form of NRM5, via the `nrm5_eq` bridge (Res.lp).
symbol NRM5_1 [n] [P Q R : Tuple n ‚Üí Prop] [S : Prop]
  (r : Res ((`‚ôĘ v, ‚čÄ_snoc (P v) (Q v) ‚áí R v) ‚áí S))
  : Res ((`‚ôĘ v, P v ‚áí Q v ‚áí R v) ‚áí S)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm5_eq n P Q R S) (res_eq r));

// NRM10_1 ‚ÄĒ chain (Res) form of NRM10, via the `nrm10_eq` bridge (Res.lp).
symbol NRM10_1 [n] [Ps : Tuple n ‚Üí ūĚēÉ* o] [Q : Tuple n ‚Üí Prop] [R : Prop]
  (r : Res ((`‚ô° v, ¬¨ ‚čÄ (Ps v ‚ą∑ Q v)) ‚áí R))
  : Res ((`‚ôĘ v, ‚čÄ (Ps v ‚ą∑ Q v) ‚áí ‚ä•) ‚áí R)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm10_eq n Ps Q R) (res_eq r));

// NRM24_1 ‚ÄĒ chain (Res) form of NRM24, via the `nrm24_eq` bridge (Res.lp).
symbol NRM24_1 [n] [P : Tuple n ‚Üí Prop] [Q : Prop]
  (r : Res ((`‚ô° v, ¬¨ ‚čÄ (‚ąé ‚ą∑ ‚ä§ ‚ą∑ P v)) ‚áí Q))
  : Res ((`‚ô° v, ¬¨ (P v)) ‚áí Q)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm24_eq n P Q) (res_eq r));

// NRM3 bridge: ((‚ôĘv¬∑(P v ‚áí Q)) ‚áí S) = ((Q ‚áí S) ‚ąß ((‚ąÄv¬∑¬¨P v) ‚áí S)), Q is v-free.
// (Lives here, not Res.lp, because the ‚áź direction reuses NRM3 itself; the ‚áí
// direction builds the ‚ôĘ witness from Q, or vacuously from ¬¨P v.)
opaque symbol nrm3_eq [n] [P : Tuple n ‚Üí Prop] [Q S : Prop]
  : ŌÄ (((`‚ôĘ v, P v ‚áí Q) ‚áí S) = ‚čÄ_snoc (Q ‚áí S) ((`!! v, ¬¨ (P v)) ‚áí S)) ‚ČĒ
begin
  assume n P Q S;
  refine propExt _ _
    (őĽ hres, ‚čÄ‚āā_intro
       (őĽ hq, hres (pi_to_‚ôĘ (őĽ v, P v ‚áí Q) (őĽ v hpv, hq)))
       (őĽ hnp, hres (pi_to_‚ôĘ (őĽ v, P v ‚áí Q)
                       (őĽ v hpv, ‚ä•‚āĎ (!!_to_pi (őĽ v, ¬¨ (P v)) hnp v hpv)))))
    (őĽ hprem, @NRM3 n P Q S hprem)
end;

// NRM3_1 ‚ÄĒ chain (Res) form of NRM3, via the `nrm3_eq` bridge above.  The
// premise is the snoc-conjunction the emitter discharges with AND4_1.
symbol NRM3_1 [n] [P : Tuple n ‚Üí Prop] [Q S : Prop]
  (r : Res (‚čÄ_snoc (Q ‚áí S) ((`!! v, ¬¨ (P v)) ‚áí S))) : Res ((`‚ôĘ v, P v ‚áí Q) ‚áí S)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm3_eq n P Q S) (res_eq r));

// NRM23_1 ‚ÄĒ chain (Res) form of NRM23, via the `nrm23_eq` bridge (Res.lp).  E is
// implicit here (the emitter emits `NRM23_1 _`, inferring E from the Res target).
symbol NRM23_1 [Q : Prop] [E : ŌĄ őĻ]
  (r : Res (¬¨ ‚ä§ ‚áí Q))
  : Res ((`‚ô° v : Tuple 1, ¬¨ ‚čÄ (‚ąé ‚ą∑ ‚ä§ ‚ą∑ (E = prj 0 v))) ‚áí Q)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm23_eq Q E) (res_eq r));

// NRM22_1 ‚ÄĒ chain (Res) form of NRM22, via the general `nrm22_eq` bridge
// (Res.lp): the body's tail equality pins the binder at E.
symbol NRM22_1 [Q : Prop] [ps : Tuple 1 ‚Üí ūĚēÉ* o] [E : ŌĄ őĻ]
  (r : Res (¬¨ ‚čÄ (ps (unit ‚®ĺ E)) ‚áí Q))
  : Res ((`‚ô° v : Tuple 1, ¬¨ ‚čÄ (ps v ‚ą∑ (prj 0 v = E))) ‚áí Q)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm22_eq Q ps E) (res_eq r));

// NRM4_1 ‚ÄĒ chain (Res) form of NRM4, via the `nrm4_eq` bridge (Res.lp).
symbol NRM4_1 [n] [P R : Tuple n ‚Üí Prop] [Q S : Prop]
  (r : Res ((Q ‚áí (`‚ôĘ v, P v ‚áí R v)) ‚áí S))
  : Res ((`‚ôĘ v, P v ‚áí Q ‚áí R v) ‚áí S)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm4_eq n P R Q S) (res_eq r));

// NRM7_1 ‚ÄĒ chain (Res) form of NRM7, via the `nrm7_eq` bridge (Res.lp).
symbol NRM7_1 [n] [Qs : Tuple n ‚Üí ūĚēÉ* o] [P : Tuple n ‚Üí Prop] [S : Prop]
  (r : Res ((`‚ôĘ v, ‚čÄ (Qs v)) ‚áí ((`‚ôĘ v, P v) ‚áí S)))
  : Res ((`‚ôĘ v, ‚čÄ (Qs v ‚ą∑ P v)) ‚áí S)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm7_eq n Qs P S) (res_eq r));

// NRM11_1 ‚ÄĒ chain (Res) form of NRM11, via the `nrm11_eq` bridge (Res.lp).
symbol NRM11_1 [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  (r : Res ((`‚ô° v, ¬¨ ‚čÄ_snoc ‚ä§ (P v)) ‚áí R))
  : Res ((`‚ôĘ v, P v ‚áí ‚ä•) ‚áí R)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm11_eq n P R) (res_eq r));

// NRM25_1 ‚ÄĒ chain (Res) form of NRM25, via the `nrm25_eq` bridge (Res.lp).
symbol NRM25_1 [n] [P Q : Prop]
  (r : Res (P ‚áí Q))
  : Res ((`‚ô° _ : Tuple n, P) ‚áí Q)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm25_eq n P Q) (res_eq r));

// NRM8_1 ‚ÄĒ chain (Res) form of NRM8, via the `nrm8_eq` bridge (Res.lp).
symbol NRM8_1 [n m] [Q : Tuple n ‚Üí Tuple m ‚Üí Prop] [S : Prop]
  (r : Res ((`‚ôĘ v : Tuple (n ++ m), Q (take [n] [m] v) (drop [n] [m] v)) ‚áí S))
  : Res ((`‚ôĘ x : Tuple n, `!! y : Tuple m, Q x y) ‚áí S)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm8_eq n m Q S) (res_eq r));

// NRM9_1 ‚ÄĒ chain (Res) form of NRM9, via the `nrm9_eq` bridge (Res.lp).
symbol NRM9_1 [n m] [P : Tuple n ‚Üí Prop] [Q : Tuple n ‚Üí Tuple m ‚Üí Prop] [S : Prop]
  (r : Res ((`‚ôĘ v : Tuple (n ++ m),
              P (take [n] [m] v) ‚áí Q (take [n] [m] v) (drop [n] [m] v)) ‚áí S))
  : Res ((`‚ôĘ x : Tuple n, P x ‚áí (`!! y : Tuple m, Q x y)) ‚áí S)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm9_eq n m P Q S) (res_eq r));

// NRM6_1 ‚ÄĒ chain (Res) form of NRM6, via the `nrm6_eq` bridge (Res.lp).
symbol NRM6_1 [n] [Qs : Tuple n ‚Üí ūĚēÉ* o] [P R : Tuple n ‚Üí Prop] [S : Prop]
  (r : Res ((`‚ôĘ v, R v ‚áí ‚čÄ (Qs v)) ‚áí ((`‚ôĘ v, R v ‚áí P v) ‚áí S)))
  : Res ((`‚ôĘ v, R v ‚áí ‚čÄ (Qs v ‚ą∑ P v)) ‚áí S)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (@nrm6_eq n Qs P R S) (res_eq r));

// NRM19_1 ‚ÄĒ chain (Res) form of NRM19 (a Witness_hyp *discharge*, not a
// transport).  Given the witness v and the in-scope hyp `R v`, the antecedent
// `‚ô°u¬∑¬¨(‚ä§‚ąßR u)` is refuted (at u := v), so the implication is provable and
// `mk_0 ‚ąė prop_eq_top` seeds the Res at ‚ä§ ‚ÄĒ the AXM8_1/AXM9_1 seed pattern.  The
// emitter recovers (v, hr) with the same [find_nrm19_match] the base rule uses.
symbol NRM19_1 [n] [Q : Prop] [R : Tuple n ‚Üí Prop] (v : Tuple n) (hr : ŌÄ (R v))
  : Res ((`‚ô° u, ¬¨ ‚čÄ_snoc ‚ä§ (R u)) ‚áí Q)
  ‚ČĒ mk_0 (prop_eq_top (NRM19 v hr));
