// Normalisation (┬ДA.12) Рђћ shallow encoding
//
// With HOAS and РЎб/РЎА defined as Рѕђ in B.lp:
// - Compound variables (РеЙ) become nested Рѕђ
// - Substitution is HOAS application
// - Non-freeness is implicit (Prop vs ¤ё ╬╣ Рєњ Prop)
require open pp2lp.B;

// ---- NRM1-7: Logical transformations under РЎб ----

// NRM1: x not free in P; H Ріб P РЄњ S Рєњ H Ріб (РЎбx ┬и P) РЄњ S
opaque symbol NRM1 [P S : Prop]
  : ¤ђ (P РЄњ S)
  Рєњ ¤ђ ((`РЎб _ : ¤ё ╬╣, P) РЄњ S) РЅћ
begin
  assume P S h1 h2;
  refine h1 (h2 inh)
end;

// NRM2: x not free in P; H Ріб (P РЄњ РЎбx ┬и Q) РЄњ S Рєњ H Ріб РЎбx ┬и (P РЄњ Q) РЄњ S
opaque symbol NRM2 [P : Prop] [Q : ¤ё ╬╣ Рєњ Prop] [S : Prop]
  : ¤ђ ((P РЄњ (`РЎб x, Q x)) РЄњ S)
  Рєњ ¤ђ ((`РЎб x, P РЄњ Q x) РЄњ S) РЅћ
begin
  assume P Q S h1 h2;
  refine h1 (╬╗ hp x, h2 x hp)
end;

// NRM3: x not free in Q; Q is not FALSE; H Ріб (Q РЄњ S) РѕД ((Рѕђx ┬и ┬гP) РЄњ S) Рєњ H Ріб РЎбx ┬и (P РЄњ Q) РЄњ S
opaque symbol NRM3 [P : ¤ё ╬╣ Рєњ Prop] [Q S : Prop]
  : ¤ђ ((Q РЄњ S) РѕД ((`Рѕђ x, ┬г (P x)) РЄњ S))
  Рєњ ¤ђ ((`РЎб x, P x РЄњ Q) РЄњ S) РЅћ
begin
  assume P Q S h1 h2;
  refine РѕеРѓЉ (em (`РѕЃ x, P x)) _ _ {
    assume hex;
    refine РѕЃРѓЉ hex (╬╗ x hpx, (РѕДРѓЉРѓЂ h1) (h2 x hpx))
  } {
    assume hnex;
    refine (РѕДРѓЉРѓѓ h1) (╬╗ x hpx, hnex (РѕЃрхб x hpx))
  }
end;

opaque symbol NRM4 [P R : ¤ё ╬╣ Рєњ Prop] [Q S : Prop]
  : ¤ђ ((Q РЄњ (`РЎб x, P x РЄњ R x)) РЄњ S)
  Рєњ ¤ђ ((`РЎб x, P x РЄњ Q РЄњ R x) РЄњ S) РЅћ
begin
  assume P R Q S h1 h2;
  refine h1 (╬╗ hq x hpx, h2 x hpx hq)
end;

opaque symbol NRM5 [P Q R : ¤ё ╬╣ Рєњ Prop] [S : Prop]
  : ¤ђ ((`РЎб x, P x РѕД Q x РЄњ R x) РЄњ S)
  Рєњ ¤ђ ((`РЎб x, P x РЄњ Q x РЄњ R x) РЄњ S) РЅћ
begin
  assume P Q R S h1 h2;
  refine h1 (╬╗ x hpq, h2 x (РѕДРѓЉРѓЂ hpq) (РѕДРѓЉРѓѓ hpq))
end;

// NRM5_2: Two-variable version.
opaque symbol NRM5_2 [P Q R : ¤ё ╬╣ Рєњ ¤ё ╬╣ Рєњ Prop] [S : Prop]
  : ¤ђ ((`РЎб x, `РЎб y, P x y РѕД Q x y РЄњ R x y) РЄњ S)
  Рєњ ¤ђ ((`РЎб x, `РЎб y, P x y РЄњ Q x y РЄњ R x y) РЄњ S) РЅћ
begin
  assume P Q R S h1 h2;
  refine h1 (╬╗ x y hpq, h2 x y (РѕДРѓЉРѓЂ hpq) (РѕДРѓЉРѓѓ hpq))
end;

// NRM6: H Ріб РЎбx ┬и (R РЄњ P) РЄњ (РЎбx ┬и (R РЄњ Q) РЄњ S) Рєњ H Ріб РЎбx ┬и (R РЄњ P РѕД Q) РЄњ S
opaque symbol NRM6 [P Q R : ¤ё ╬╣ Рєњ Prop] [S : Prop]
  : ¤ђ ((`РЎб x, R x РЄњ P x) РЄњ ((`РЎб x, R x РЄњ Q x) РЄњ S))
  Рєњ ¤ђ ((`РЎб x, R x РЄњ P x РѕД Q x) РЄњ S) РЅћ
begin
  assume P Q R S h1 h2;
  refine h1 (╬╗ x hr, РѕДРѓЉРѓЂ (h2 x hr)) (╬╗ x hr, РѕДРѓЉРѓѓ (h2 x hr))
end;

// NRM7: H Ріб (РЎбx ┬и P) РЄњ ((РЎбx ┬и Q) РЄњ S) Рєњ H Ріб РЎбx ┬и (P РѕД Q) РЄњ S
opaque symbol NRM7 [P Q : ¤ё ╬╣ Рєњ Prop] [S : Prop]
  : ¤ђ ((`РЎб x, P x) РЄњ ((`РЎб x, Q x) РЄњ S))
  Рєњ ¤ђ ((`РЎб x, P x РѕД Q x) РЄњ S) РЅћ
begin
  assume P Q S h1 h2;
  refine h1 (╬╗ x, РѕДРѓЉРѓЂ (h2 x)) (╬╗ x, РѕДРѓЉРѓѓ (h2 x))
end;

// NRM7_2: Two-variable version.
opaque symbol NRM7_2 [P Q : ¤ё ╬╣ Рєњ ¤ё ╬╣ Рєњ Prop] [S : Prop]
  : ¤ђ ((`РЎб x, `РЎб y, P x y) РЄњ ((`РЎб x, `РЎб y, Q x y) РЄњ S))
  Рєњ ¤ђ ((`РЎб x, `РЎб y, P x y РѕД Q x y) РЄњ S) РЅћ
begin
  assume P Q S h1 h2;
  refine h1 (╬╗ x y, РѕДРѓЉРѓЂ (h2 x y)) (╬╗ x y, РѕДРѓЉРѓѓ (h2 x y))
end;

opaque symbol NRM8 [Q : ¤ё ╬╣ Рєњ ¤ё ╬╣ Рєњ Prop] [S : Prop]
  : ¤ђ ((`РЎб x, `РЎб y, Q x y) РЄњ S)
  Рєњ ¤ђ ((`РЎб x, `Рѕђ y, Q x y) РЄњ S) РЅћ
begin
  assume Q S h; refine h
end;

opaque symbol NRM9 [P : ¤ё ╬╣ Рєњ Prop] [Q : ¤ё ╬╣ Рєњ ¤ё ╬╣ Рєњ Prop] [S : Prop]
  : ¤ђ ((`РЎб x, `РЎб y, P x РЄњ Q x y) РЄњ S)
  Рєњ ¤ђ ((`РЎб x, P x РЄњ `Рѕђ y, Q x y) РЄњ S) РЅћ
begin
  assume P Q S h1 h2;
  refine h1 (╬╗ x y hp, h2 x hp y)
end;

opaque symbol NRM10 [P Q : ¤ё ╬╣ Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА x, ┬г (P x РѕД Q x)) РЄњ R)
  Рєњ ¤ђ ((`РЎб x, (P x РѕД Q x) РЄњ РіЦ) РЄњ R) РЅћ
begin
  admit;
end;

opaque symbol NRM11 [P : ¤ё ╬╣ Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА x, ┬г (Ріц РѕД P x)) РЄњ R)
  Рєњ ¤ђ ((`РЎб x, P x РЄњ РіЦ) РЄњ R) РЅћ
begin
  admit;
end;

opaque symbol NRM12 [P Q : ¤ё ╬╣ Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА x, ┬г (P x РѕД Q x)) РЄњ R)
  Рєњ ¤ђ ((`РЎб x, P x РЄњ ┬г (Q x)) РЄњ R) РЅћ
begin
  assume P Q R h1 h2;
  refine h1 (╬╗ x hpq, h2 x (РѕДРѓЉРѓЂ hpq) (РѕДРѓЉРѓѓ hpq))
end;

opaque symbol NRM13 [P Q : ¤ё ╬╣ Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА x, ┬г (P x РѕД ┬г (Q x))) РЄњ R)
  Рєњ ¤ђ ((`РЎб x, P x РЄњ Q x) РЄњ R) РЅћ
begin
  assume P Q R h1 h2;
  refine h1 (╬╗ x hc, (РѕДРѓЉРѓѓ hc) (h2 x (РѕДРѓЉРѓЂ hc)))
end;

// NRM13_2: Two-variable version.
opaque symbol NRM13_2 [P Q : ¤ё ╬╣ Рєњ ¤ё ╬╣ Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА x, `РЎА y, ┬г (P x y РѕД ┬г (Q x y))) РЄњ R)
  Рєњ ¤ђ ((`РЎб x, `РЎб y, P x y РЄњ Q x y) РЄњ R) РЅћ
begin
  assume P Q R h1 h2;
  refine h1 (╬╗ x y hpnq, (РѕДРѓЉРѓѓ hpnq) (h2 x y (РѕДРѓЉРѓЂ hpnq)))
end;

opaque symbol NRM14 [P : ¤ё ╬╣ Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА x, ┬г (Ріц РѕД P x)) РЄњ R)
  Рєњ ¤ђ ((`РЎб x, ┬г P x) РЄњ R) РЅћ
begin
  assume P R h1 h2;
  refine h1 (╬╗ x htpx, h2 x (РѕДРѓЉРѓѓ htpx))
end;

// NRM14_2: Two-variable version.
opaque symbol NRM14_2 [P : ¤ё ╬╣ Рєњ ¤ё ╬╣ Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА x, `РЎА y, ┬г (Ріц РѕД P x y)) РЄњ R)
  Рєњ ¤ђ ((`РЎб x, `РЎб y, ┬г (P x y)) РЄњ R) РЅћ
begin
  assume P R h1 h2;
  refine h1 (╬╗ x y htpxy, h2 x y (РѕДРѓЉРѓѓ htpxy))
end;

opaque symbol NRM15 [P : ¤ё ╬╣ Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА x, ┬г (Ріц РѕД ┬г P x)) РЄњ R)
  Рєњ ¤ђ ((`РЎб x, P x) РЄњ R) РЅћ
begin
  assume P R h1 h2;
  refine h1 (╬╗ x htnpx, (РѕДРѓЉРѓѓ htnpx) (h2 x))
end;

// NRM15_2: Two-variable version.
opaque symbol NRM15_2 [P : ¤ё ╬╣ Рєњ ¤ё ╬╣ Рєњ Prop] [R : Prop]
  : ¤ђ ((`РЎА x, `РЎА y, ┬г (Ріц РѕД ┬г (P x y))) РЄњ R)
  Рєњ ¤ђ ((`РЎб x, `РЎб y, P x y) РЄњ R) РЅћ
begin
  assume P R h1 h2;
  refine h1 (╬╗ x y htnpxy, (РѕДРѓЉРѓѓ htnpxy) (h2 x y))
end;

opaque symbol NRM16 [P : ¤ё ╬╣ Рєњ Prop] [Q : Prop]
  : ¤ђ (`Рѕђ x, P x)
  Рєњ ¤ђ Q
  Рєњ ¤ђ ((`РЎА x, P x) РЄњ Q) РЅћ
begin
  assume P Q hp hq ht; refine hq
end;

opaque symbol NRM17 [P : ¤ё ╬╣ Рєњ Prop] [Q : Prop]
  : ¤ђ (`Рѕђ x, P x)
  Рєњ ¤ђ Q
  Рєњ ¤ђ ((`РЎА x, P x) РЄњ Q) РЅћ
begin
  assume P Q hp hq ht; refine hq
end;

opaque symbol NRM18 [P : ¤ё ╬╣ Рєњ Prop] [R Q : Prop] (E : ¤ё ╬╣)
  : ¤ђ (`Рѕђ x, ┬г (Ріц РѕД ┬г P x))
  Рєњ ¤ђ (P E = R)
  Рєњ ¤ђ ((`РЎА y, ┬г (Ріц РѕД R)) РЄњ Q) РЅћ
begin
  admit
end;

opaque symbol NRM19 [Q : Prop] [R : ¤ё ╬╣ Рєњ Prop] (E : ¤ё ╬╣)
  : ¤ђ (R E)
  Рєњ ¤ђ ((`РЎА x, ┬г (Ріц РѕД R x)) РЄњ Q) РЅћ
begin
  assume Q R E hr hf;
  refine РіЦРѓЉ (hf E (РѕДрхб Ріцрхб hr))
end;

// NRM19_2: Two-variable version.
opaque symbol NRM19_2 [Q : Prop] [R : ¤ё ╬╣ Рєњ ¤ё ╬╣ Рєњ Prop] (E F : ¤ё ╬╣)
  : ¤ђ (R E F)
  Рєњ ¤ђ ((`РЎА x, `РЎА y, ┬г (Ріц РѕД R x y)) РЄњ Q) РЅћ
begin
  assume Q R E F hr hf;
  refine РіЦРѓЉ (hf E F (РѕДрхб Ріцрхб hr))
end;

opaque symbol NRM20 [P : ¤ё ╬╣ Рєњ ¤ё ╬╣ Рєњ Prop] [Q : Prop] (E : ¤ё ╬╣)
  : ¤ђ ((`РЎА y, ┬г (P E y)) РЄњ Q)
  Рєњ ¤ђ ((`РЎА x, `РЎА y, ┬г (P x y РѕД (x = E))) РЄњ Q) РЅћ
begin
  assume P Q E h1 h2;
  refine h1 (╬╗ y hpey, h2 E y (РѕДрхб hpey (eq_refl E)))
end;

opaque symbol NRM21 [P : ¤ё ╬╣ Рєњ ¤ё ╬╣ Рєњ Prop] [Q : Prop] (E : ¤ё ╬╣)
  : ¤ђ ((`РЎА y, ┬г (P E y)) РЄњ Q)
  Рєњ ¤ђ ((`РЎА x, `РЎА y, ┬г (P x y РѕД (E = x))) РЄњ Q) РЅћ
begin
  assume P Q E h1 h2;
  refine h1 (╬╗ y hpey, h2 E y (РѕДрхб hpey (eq_sym (eq_refl E))))
end;

opaque symbol NRM22 [P : ¤ё ╬╣ Рєњ Prop] [Q : Prop] (E : ¤ё ╬╣)
  : ¤ђ (┬г (P E) РЄњ Q)
  Рєњ ¤ђ ((`РЎА x, ┬г (P x РѕД (x = E))) РЄњ Q) РЅћ
begin
  assume P Q E h1 h2;
  refine h1 (╬╗ hpe, h2 E (РѕДрхб hpe (eq_refl E)))
end;

opaque symbol NRM23 [P : ¤ё ╬╣ Рєњ Prop] [Q : Prop] (E : ¤ё ╬╣)
  : ¤ђ (┬г (P E) РЄњ Q)
  Рєњ ¤ђ ((`РЎА x, ┬г (P x РѕД (E = x))) РЄњ Q) РЅћ
begin
  assume P Q E h1 h2;
  refine h1 (╬╗ hpe, h2 E (РѕДрхб hpe (eq_sym (eq_refl E))))
end;

opaque symbol NRM24 [P : ¤ё ╬╣ Рєњ Prop] [Q : Prop]
  : ¤ђ ((`РЎА x, ┬г (Ріц РѕД P x)) РЄњ Q)
  Рєњ ¤ђ ((`РЎА x, ┬г (P x)) РЄњ Q) РЅћ
begin
  assume P Q h1 h2;
  refine h1 (╬╗ x htpx, h2 x (РѕДРѓЉРѓѓ htpx))
end;

// NRM25: x not free in P; H Ріб P Рєњ H Ріб РЎА(x) ┬и P
opaque symbol NRM25 [P : Prop]
  : ¤ђ P
  Рєњ ¤ђ (`РЎА _ : ¤ё ╬╣, P) РЅћ
begin
  assume P hp x; refine hp
end;

// NRM26: y not free in P; H Ріб РЎА(x, ...) ┬и P Рєњ H Ріб РЎА(x, y, ...) ┬и P
opaque symbol NRM26 [P : ¤ё ╬╣ Рєњ Prop]
  : ¤ђ (`РЎА x, P x)
  Рєњ ¤ђ (`РЎА x, `Рѕђ _ : ¤ё ╬╣, P x) РЅћ
begin
  assume P h x y; refine h x
end;

// ---- NRM27-30: Arithmetic solver dispatch ----
//
// NRM27: (xрхб РЅц 0) and (Рѕњxрхб РЅц 0) in (P РѕД...РѕД Q); R = [xрхб := 0](P РѕД...РѕД Q)
//   Рєњ H Ріб РЎб(xРѓЂ,...,xрхбРѓІРѓЂ,xрхбРѓіРѓЂ,...,xРѓЎ) ┬и ┬гR Рєњ H Ріб РЎА(xРѓЂ,...,xРѓЎ) ┬и ┬г(P РѕД...РѕД Q)
// NRM28: (x РЅц 0) and (Рѕњx РЅц 0) in (P РѕД...РѕД Q); S = [x := 0](P РѕД...РѕД Q)
//   Рєњ H Ріб ┬г(S) РЄњ R Рєњ H Ріб (РЎА(x) ┬и ┬г(P РѕД...РѕД Q)) РЄњ R
// NRM29: (a + xрхб РЅц 0) and (b Рѕњ xрхб РЅц 0) in (P РѕД...РѕД Q); solver(a+b) = 0; S = [xрхб := b](P РѕД...РѕД Q)
//   Рєњ H Ріб РЎб(...) ┬и ┬гS РЄњ R Рєњ H Ріб (РЎА(xРѓЂ,...,xРѓЎ) ┬и ┬г(P РѕД...РѕД Q)) РЄњ R
// NRM30: (a + x РЅц 0) and (b Рѕњ x РЅц 0) in (P РѕД...РѕД Q); solver(a+b) = 0; S = [x := b](P РѕД...РѕД Q)
//   Рєњ H Ріб ┬гS РЄњ R Рєњ H Ріб (РЎАx ┬и ┬г(P РѕД...РѕД Q)) РЄњ R
// TODO: all require arithmetic solver infrastructure
