// Equivalence (┬ДA.4) Рђћ shallow encoding
require open pp2lp.B pp2lp.Quant pp2lp.rules.Res;

// EQV1: H Ріб P РЄњ (┬гQ РЄњ R); H Ріб ┬гP РЄњ (Q РЄњ R) Рєњ H Ріб ┬г(P РЄћ Q) РЄњ R
opaque symbol EQV1 [P Q R]
  : ¤ђ (P РЄњ (┬г Q РЄњ R))
  Рєњ ¤ђ (┬г P РЄњ (Q РЄњ R))
  Рєњ ¤ђ (┬г (P РЄћ Q) РЄњ R) РЅћ
begin
  assume P Q R h1 h2 h3;
  refine РѕеРѓЉ (em P) _ _ {
    assume hp;
    refine РѕеРѓЉ (em Q) _ _ {
      assume hq;
      have heqv : ¤ђ (P РЄћ Q) {
        refine РѕДрхб (╬╗ _, hq) (╬╗ _, hp)
      };
      refine РіЦРѓЉ (h3 heqv)
    } {
      assume hnq; refine h1 hp hnq
    }
  } {
    assume hnp;
    refine РѕеРѓЉ (em Q) _ _ {
      assume hq; refine h2 hnp hq
    } {
      assume hnq;
      have heqv : ¤ђ (P РЄћ Q) {
        refine РѕДрхб (╬╗ hp, РіЦРѓЉ (hnp hp)) (╬╗ hq, РіЦРѓЉ (hnq hq))
      };
      refine РіЦРѓЉ (h3 heqv)
    }
  }
end;

// EQV2: H Ріб P РЄњ ┬гQ; H Ріб ┬гQ РЄњ P Рєњ H Ріб ┬г(P РЄћ Q)
opaque symbol EQV2 [P Q]
  : ¤ђ (P РЄњ ┬г Q)
  Рєњ ¤ђ (┬г Q РЄњ P)
  Рєњ ¤ђ (┬г (P РЄћ Q)) РЅћ
begin
  assume P Q h1 h2 h3;
  have h3a : ¤ђ (P РЄњ Q) {refine РѕДРѓЉРѓЂ h3};
  have h3b : ¤ђ (Q РЄњ P) {refine РѕДРѓЉРѓѓ h3};
  refine РѕеРѓЉ (em Q) _ _ {
    assume hq;
    have hp : ¤ђ P {refine h3b hq};
    have hnq : ¤ђ (┬г Q) {refine h1 hp};
    refine hnq hq
  } {
    assume hnq;
    have hp : ¤ђ P {refine h2 hnq};
    have hq : ¤ђ Q {refine h3a hp};
    refine hnq hq
  }
end;

// EQV3: H Ріб P РЄњ (Q РЄњ R); H Ріб ┬гP РЄњ (┬гQ РЄњ R) Рєњ H Ріб (P РЄћ Q) РЄњ R
opaque symbol EQV3 [P Q R]
  : ¤ђ (P РЄњ (Q РЄњ R))
  Рєњ ¤ђ (┬г P РЄњ (┬г Q РЄњ R))
  Рєњ ¤ђ ((P РЄћ Q) РЄњ R) РЅћ
begin
  assume P Q R h1 h2 h3;
  have h3a : ¤ђ (P РЄњ Q) {refine РѕДРѓЉРѓЂ h3};
  have h3b : ¤ђ (Q РЄњ P) {refine РѕДРѓЉРѓѓ h3};
  refine РѕеРѓЉ (em P) _ _ {
    assume hp;
    have hq : ¤ђ Q {refine h3a hp};
    refine h1 hp hq
  } {
    assume hnp;
    refine РѕеРѓЉ (em Q) _ _ {
      assume hq;
      have hp : ¤ђ P {refine h3b hq};
      refine РіЦРѓЉ (hnp hp)
    } {
      assume hnq; refine h2 hnp hnq
    }
  }
end;

// EQV4: H Ріб P РЄњ Q; H Ріб Q РЄњ P Рєњ H Ріб P РЄћ Q
opaque symbol EQV4 [P Q]
  : ¤ђ (P РЄњ Q)
  Рєњ ¤ђ (Q РЄњ P)
  Рєњ ¤ђ (P РЄћ Q) РЅћ
begin
  assume P Q h1 h2;
  refine РѕДрхб h1 h2
end;

// ---- `_1` (Result-form) variants Рђћ ┬Д8.13 ----

// EQV1_1: Schema 2 Рђћ combine.
symbol EQV1_1 [P Q R : Prop]
  (r1 : Res (P РЄњ ┬г Q РЄњ R)) (r2 : Res (┬г P РЄњ Q РЄњ R))
  : Res (┬г (P РЄћ Q) РЄњ R)
  РЅћ mk_res (concat (res_ts r1) (res_ts r2))
      (eq_trans eqv1_eq
        (eq_trans (conj_eq (res_eq r1) (res_eq r2))
                  (conj_concat_eq (res_ts r1) (res_ts r2))));

// EQV2_1: Schema 2 Рђћ combine.
symbol EQV2_1 [P Q : Prop]
  (r1 : Res (P РЄњ ┬г Q)) (r2 : Res (┬г Q РЄњ P))
  : Res (┬г (P РЄћ Q))
  РЅћ mk_res (concat (res_ts r1) (res_ts r2))
      (eq_trans eqv2_eq
        (eq_trans (conj_eq (res_eq r1) (res_eq r2))
                  (conj_concat_eq (res_ts r1) (res_ts r2))));

// EQV3_1: Schema 2 Рђћ combine.
symbol EQV3_1 [P Q R : Prop]
  (r1 : Res (P РЄњ Q РЄњ R)) (r2 : Res (┬г P РЄњ ┬г Q РЄњ R))
  : Res ((P РЄћ Q) РЄњ R)
  РЅћ mk_res (concat (res_ts r1) (res_ts r2))
      (eq_trans eqv3_eq
        (eq_trans (conj_eq (res_eq r1) (res_eq r2))
                  (conj_concat_eq (res_ts r1) (res_ts r2))));

// EQV4_1: Schema 2 Рђћ combine.
symbol EQV4_1 [P Q : Prop]
  (r1 : Res (P РЄњ Q)) (r2 : Res (Q РЄњ P))
  : Res (P РЄћ Q)
  РЅћ mk_res (concat (res_ts r1) (res_ts r2))
      (eq_trans eqv4_eq
        (eq_trans (conj_eq (res_eq r1) (res_eq r2))
                  (conj_concat_eq (res_ts r1) (res_ts r2))));
