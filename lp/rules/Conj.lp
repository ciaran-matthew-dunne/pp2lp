// Conjunction (¬ІA.1) вАФ shallow encoding over the snoc list рЭХГ*.
//
// PP's вИІ is left-associative, so a conjunction goal `вЛА (ps вИЈ P)` splits
// structurally: init = `вЛА ps`, last = `P`.  Each rule pattern-matches the
// `вИЈ` directly; Lambdapi infers `ps`/`P` from the goal (via the `вЛА`
// unification rule in ConjList.lp).
require open pp2lp.B pp2lp.ConjList pp2lp.Quant pp2lp.rules.Res;

// ---- Base rules ----

// AND1: H вКҐ ¬ђP вЗТ R; H вКҐ ¬ђвЛАps вЗТ R вЖТ H вКҐ ¬ђвЛА(psвИЈP) вЗТ R
opaque symbol AND1 [ps : рЭХГ* o] [P R : Prop]
  : ѕА (¬ђ P вЗТ R)
  вЖТ ѕА (¬ђ вЛА ps вЗТ R)
  вЖТ ѕА (¬ђ вЛА (ps вИЈ P) вЗТ R) вЙФ
begin
  assume ps P R h1 h2 h3;
  have hnand : ѕА (¬ђ (вЛА ps вИІ P))
    { assume hand; refine h3 (вЛА_intro (вИІвВСвВБ hand) (вИІвВСвВВ hand)) };
  have hor : ѕА (¬ђ вЛА ps вИ® ¬ђ P)
    { refine =вЗТ (deMorgan_вИІ (вЛА ps) P) hnand };
  refine вИ®вВС hor _ _
    { assume hni; refine h2 hni }
    { assume hnp; refine h1 hnp }
end;

// AND2: H вКҐ вЛАps вЗТ ¬ђP вЖТ H вКҐ ¬ђвЛА(psвИЈP)
opaque symbol AND2 [ps : рЭХГ* o] [P : Prop]
  : ѕА (вЛА ps вЗТ ¬ђ P)
  вЖТ ѕА (¬ђ вЛА (ps вИЈ P)) вЙФ
begin
  assume ps P h1 hc;
  refine h1 (вЛА_init hc) (вЛА_last hc)
end;

// AND3: H вКҐ вЛАps вЗТ (P вЗТ R) вЖТ H вКҐ вЛА(psвИЈP) вЗТ R
opaque symbol AND3 [ps : рЭХГ* o] [P R : Prop]
  : ѕА (вЛА ps вЗТ (P вЗТ R))
  вЖТ ѕА (вЛА (ps вИЈ P) вЗТ R) вЙФ
begin
  assume ps P R h hc;
  refine h (вЛА_init hc) (вЛА_last hc)
end;

// AND4: H вКҐ P; H вКҐ вЛАps вЖТ H вКҐ вЛА(psвИЈP)   (PP order: last then init)
opaque symbol AND4 [ps : рЭХГ* o] [P : Prop]
  : ѕА P
  вЖТ ѕА (вЛА ps)
  вЖТ ѕА (вЛА (ps вИЈ P)) вЙФ
begin
  assume ps P h1 h2;
  refine вЛА_intro h2 h1
end;

// AND5: modus ponens within a conjunction.
opaque symbol AND5 [C C' r : Prop]
  : (ѕА C вЖТ ѕА C')
  вЖТ ѕА (C' вЗТ r)
  вЖТ ѕА (C вЗТ r) вЙФ
begin
  assume C C' r fwd hsub hc;
  refine hsub (fwd hc)
end;

// ---- `_1` (Result-form) variants вАФ ¬І8.13 ----

// AND1_1: Schema 2 вАФ combine two Res children into Res (¬ђвЛА(psвИЈP) вЗТ R).
symbol AND1_1 [ps : рЭХГ* o] [P R : Prop]
  (r1 : Res (¬ђ P вЗТ R)) (r2 : Res (¬ђ вЛА ps вЗТ R))
  : Res (¬ђ вЛА (ps вИЈ P) вЗТ R)
  вЙФ mk_res (concat (res_ts r1) (res_ts r2))
      (eq_trans and1_eq
        (eq_trans (conj_eq (res_eq r1) (res_eq r2))
                  (conj_concat_eq (res_ts r1) (res_ts r2))));

// AND2_1: Schema 1 вАФ passthrough Res child.
symbol AND2_1 [ps : рЭХГ* o] [P : Prop]
  (r : Res (вЛА ps вЗТ ¬ђ P)) : Res (¬ђ вЛА (ps вИЈ P))
  вЙФ mk_1 (res_tm r) (eq_trans and2_eq (res_eq r));

// AND3_1: Schema 1 вАФ passthrough Res child.
symbol AND3_1 [ps : рЭХГ* o] [P R : Prop]
  (r : Res (вЛА ps вЗТ (P вЗТ R))) : Res (вЛА (ps вИЈ P) вЗТ R)
  вЙФ mk_1 (res_tm r) (eq_trans and3_eq (res_eq r));

// AND4_1: Schema 2 вАФ combine two Res children into Res (вЛА (ps вИЈ P)).
// `and4_eq` reorders `вЛА (ps вИЈ P)` to the last-first binary `P вИІ вЛА ps`,
// then it follows the same `conj_eq`/`conj_concat_eq` chain as every combine.
symbol AND4_1 [ps : рЭХГ* o] [P : Prop]
  (r1 : Res P) (r2 : Res (вЛА ps)) : Res (вЛА (ps вИЈ P))
  вЙФ mk_res (concat (res_ts r1) (res_ts r2))
      (eq_trans and4_eq
        (eq_trans (conj_eq (res_eq r1) (res_eq r2))
                  (conj_concat_eq (res_ts r1) (res_ts r2))));

// AND5_1: Schema 1 with antecedent congruence on the implication's LHS.
// Mirrors AND5's PP shape: an extraction `fwd : ѕА C вЖТ ѕА C'` plus its
// inverse `bwd` build the propositional equality on antecedents.
symbol AND5_1 [C C' r : Prop]
  (fwd : ѕА C вЖТ ѕА C') (bwd : ѕА C' вЖТ ѕА C) (rr : Res (C' вЗТ r))
  : Res (C вЗТ r)
  вЙФ mk_1 (res_tm rr) (eq_trans (ante_cong fwd bwd) (res_eq rr));
