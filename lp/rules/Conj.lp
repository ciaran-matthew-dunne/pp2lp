// Conjunction (¬ßA.1) ‚Äî shallow encoding
require open pp2lp.B;

// ---- Base rules ----

// AND1: H ‚ä¢ ¬¨Q ‚áí R; H ‚ä¢ ¬¨P ‚áí R ‚Üí H ‚ä¢ ¬¨(P ‚àß Q) ‚áí R
opaque symbol AND1 [P Q R]
  : œÄ (¬¨ Q ‚áí R)
  ‚Üí œÄ (¬¨ P ‚áí R)
  ‚Üí œÄ (¬¨ (P ‚àß Q) ‚áí R) ‚âî
begin
  assume P Q R h1 h2 h3;
  have h : œÄ (¬¨ P ‚à® ¬¨ Q)
    { refine =‚áí (deMorgan_‚àß P Q) h3 };
  refine ‚à®‚Çë h _ _
    { assume hnp; refine h2 hnp }
    { assume hnq; refine h1 hnq }
end;

// AND2: H ‚ä¢ P ‚áí ¬¨Q ‚Üí H ‚ä¢ ¬¨(P ‚àß Q)
opaque symbol AND2 [P Q]
  : œÄ (P ‚áí ¬¨ Q)
  ‚Üí œÄ (¬¨ (P ‚àß Q)) ‚âî
begin
  assume P Q h1 h2;
  refine h1 (‚àß‚Çë‚ÇÅ h2) (‚àß‚Çë‚ÇÇ h2)
end;

// AND3: H ‚ä¢ P ‚áí (Q ‚áí R) ‚Üí H ‚ä¢ (P ‚àß Q) ‚áí R
opaque symbol AND3 [P Q R]
  : œÄ (P ‚áí (Q ‚áí R))
  ‚Üí œÄ ((P ‚àß Q) ‚áí R) ‚âî
begin
  assume P Q R h1 h2;
  refine h1 (‚àß‚Çë‚ÇÅ h2) (‚àß‚Çë‚ÇÇ h2)
end;

// AND4: H ‚ä¢ Q; H ‚ä¢ P ‚Üí H ‚ä¢ P ‚àß Q
opaque symbol AND4 [P Q]
  : œÄ Q
  ‚Üí œÄ P
  ‚Üí œÄ (P ‚àß Q) ‚âî
begin
  assume P Q h1 h2;
  refine ‚àß·µ¢ h2 h1
end;

// AND5: modus ponens within a conjunction.
// The caller supplies a forward function that rebuilds the conjunction
// with (A ‚áí B) at position j replaced by B (using ‚àß‚Çë‚ÇÅ/‚àß‚Çë‚ÇÇ/‚àß·µ¢).
opaque symbol AND5 [C C' r : Prop]
  : (œÄ C ‚Üí œÄ C')
  ‚Üí œÄ (C' ‚áí r)
  ‚Üí œÄ (C ‚áí r) ‚âî
begin
  assume C C' r fwd hsub hc;
  refine hsub (fwd hc)
end;

// ---- Primed variants (equality-based) ----

// AND1_1: multi-premise, rewrites ¬¨(P‚àßQ)‚áíR = (¬¨Q‚áíR) ‚àß (¬¨P‚áíR).
opaque symbol AND1_1 [P Q R S1 S2 : Prop]
  : œÄ ((¬¨ Q ‚áí R) = S1)
  ‚Üí œÄ ((¬¨ P ‚áí R) = S2)
  ‚Üí œÄ ((¬¨ (P ‚àß Q) ‚áí R) = (S1 ‚àß S2)) ‚âî
begin
  assume P Q R S1 S2 h1 h2;
  have eq : œÄ ((¬¨ (P ‚àß Q) ‚áí R) = ((¬¨ Q ‚áí R) ‚àß (¬¨ P ‚áí R)))
    { refine propExt _ _ _ _
      { assume h; refine ‚àß·µ¢
        (Œª hnq, h (Œª hpq, hnq (‚àß‚Çë‚ÇÇ hpq)))
        (Œª hnp, h (Œª hpq, hnp (‚àß‚Çë‚ÇÅ hpq))) }
      { assume h hnpq;
        have hnpnq : œÄ (¬¨ P ‚à® ¬¨ Q) { refine =‚áí (deMorgan_‚àß P Q) hnpq };
        refine ‚à®‚Çë hnpnq _ _
        { assume hnp; refine ‚àß‚Çë‚ÇÇ h hnp }
        { assume hnq; refine ‚àß‚Çë‚ÇÅ h hnq } } };
  rewrite eq; rewrite h1; rewrite h2; reflexivity
end;

// AND2_1: pass-through. ¬¨(P‚àßQ) = (P ‚áí ¬¨Q).
opaque symbol AND2_1 [P Q S : Prop]
  : œÄ ((P ‚áí ¬¨ Q) = S)
  ‚Üí œÄ (¬¨ (P ‚àß Q) = S) ‚âî
begin
  assume P Q S h;
  have eq : œÄ (¬¨ (P ‚àß Q) = (P ‚áí ¬¨ Q))
    { refine propExt _ _ _ _
      { assume h1 hp hq; refine h1 (‚àß·µ¢ hp hq) }
      { assume h1 h2; refine h1 (‚àß‚Çë‚ÇÅ h2) (‚àß‚Çë‚ÇÇ h2) } };
  rewrite eq; refine h
end;

// AND3_1: pass-through. (P‚àßQ)‚áíR = P‚áíQ‚áíR.
opaque symbol AND3_1 [P Q R S : Prop]
  : œÄ ((P ‚áí Q ‚áí R) = S)
  ‚Üí œÄ (((P ‚àß Q) ‚áí R) = S) ‚âî
begin
  assume P Q R S h;
  have eq : œÄ (((P ‚àß Q) ‚áí R) = (P ‚áí Q ‚áí R))
    { refine propExt _ _ _ _
      { assume h1 hp hq; refine h1 (‚àß·µ¢ hp hq) }
      { assume h1 h2; refine h1 (‚àß‚Çë‚ÇÅ h2) (‚àß‚Çë‚ÇÇ h2) } };
  rewrite eq; refine h
end;

// AND4_1: multi-premise. P‚àßQ = S1 ‚àß S2 (rewrites under ‚àß).
opaque symbol AND4_1 [P Q S1 S2 : Prop]
  : œÄ (Q = S1)
  ‚Üí œÄ (P = S2)
  ‚Üí œÄ ((P ‚àß Q) = (S1 ‚àß S2)) ‚âî
begin
  assume P Q S1 S2 h1 h2;
  rewrite ‚àß_com; rewrite h1; rewrite h2; reflexivity
end;

// AND5_1: equality-based modus ponens within a conjunction.
// Forward/backward functions convert between C and C'.
opaque symbol AND5_1 [C C' r s : Prop]
  : (œÄ C ‚Üí œÄ C')
  ‚Üí (œÄ C' ‚Üí œÄ C)
  ‚Üí œÄ ((C' ‚áí r) = s)
  ‚Üí œÄ ((C ‚áí r) = s) ‚âî
begin
  assume C C' r s fwd bwd heq;
  have eq : œÄ ((C ‚áí r) = (C' ‚áí r))
    { refine propExt _ _ _ _
      { assume hcr hc'; refine hcr (bwd hc') }
      { assume hc'r hc; refine hc'r (fwd hc) } };
  rewrite eq; refine heq
end;
