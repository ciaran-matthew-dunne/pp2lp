// Universal quantification (В§A.7) вҖ” tuple-based encoding.
//
// Compound bindings in PP traces map to `!! v : Tuple n, P v`. The
// per-arity scaffolding the previous version of this file carried
// (ALL5_2, ALL7_2, ALL7_3, ALL7_2i, ALL7_3i, вҖҰ) is gone: the uniform
// tuple-indexed forms below subsume every arity.
//
// ALL1вҖ“4 are compoundвҶ”nested conversions. Per the spec convention,
// `x` is an n-tuple bundle and `y` is the singleton trailing var,
// so the rule peels one layer at a time:
//
//   compound : `!! v : Tuple (+1 n), P v
//   nested   : `!! w : Tuple n, `!! y : Tuple 1, P (w вЁҫ prj 0 y)
//
// Tuple (+1 n) constructors are exactly `(w вЁҫ a)`, so the harder
// direction (nested вҶ’ compound) is provable by a rewrite rule that
// pattern-matches on the constructor.

require open pp2lp.B pp2lp.Quant pp2lp.rules.Res;

// Helper: nested вҶ’ compound. Defined by rewrite rule on the
// tuple constructor `($w вЁҫ $a)`. Used by ALL2, ALL3.
symbol nested_to_compound [n] (P : Tuple (+1 n) вҶ’ Prop)
  (h : ПҖ (`!! w : Tuple n, `!! y : Tuple 1, P (w вЁҫ prj 0 y)))
  : О  v : Tuple (+1 n), ПҖ (P v);
rule nested_to_compound [$n] $P $h ($w вЁҫ $a) вҶӘ
  !!_to_pi (О» y, $P ($w вЁҫ prj 0 y))
           (!!_to_pi (О» w, `!! y : Tuple 1, $P (w вЁҫ prj 0 y)) $h $w)
           (unit вЁҫ $a);

// ALL1: H вҠў В¬(вҲҖ(x,y)В·P) вҮ’ R вҶ’ H вҠў В¬(вҲҖxВ·вҲҖyВ·P) вҮ’ R
opaque symbol ALL1 [n] [P : Tuple (+1 n) вҶ’ Prop] [R : Prop]
  : ПҖ (В¬ (`!! v : Tuple (+1 n), P v) вҮ’ R)
  вҶ’ ПҖ (В¬ (`!! w : Tuple n, `!! y : Tuple 1, P (w вЁҫ prj 0 y)) вҮ’ R) вү”
begin
  assume n P R h hnnested;
  refine h _;
  assume hcompound;
  refine hnnested _;
  refine pi_to_!! _ _; assume w;
  refine pi_to_!! _ _; assume y;
  refine !!_to_pi P hcompound (w вЁҫ prj 0 y)
end;

// ALL2: H вҠў В¬(вҲҖ(x,y)В·P) вҶ’ H вҠў В¬(вҲҖxВ·вҲҖyВ·P)
opaque symbol ALL2 [n] [P : Tuple (+1 n) вҶ’ Prop]
  : ПҖ (В¬ (`!! v : Tuple (+1 n), P v))
  вҶ’ ПҖ (В¬ (`!! w : Tuple n, `!! y : Tuple 1, P (w вЁҫ prj 0 y))) вү”
begin
  assume n P h hnested;
  refine h (pi_to_!! P (nested_to_compound P hnested))
end;

// ALL3: H вҠў (вҲҖ(x,y)В·P) вҮ’ R вҶ’ H вҠў (вҲҖxВ·вҲҖyВ·P) вҮ’ R
opaque symbol ALL3 [n] [P : Tuple (+1 n) вҶ’ Prop] [R : Prop]
  : ПҖ ((`!! v : Tuple (+1 n), P v) вҮ’ R)
  вҶ’ ПҖ ((`!! w : Tuple n, `!! y : Tuple 1, P (w вЁҫ prj 0 y)) вҮ’ R) вү”
begin
  assume n P R h hnested;
  refine h (pi_to_!! P (nested_to_compound P hnested))
end;

// ALL3R: ALL3 with the *outer* binder appended last.  A branching
// continuation's goal `(!! v, res_tm (ПҒ v)) вҮ’ R` is structurally nested
// when the chain result is itself a universal; merging it with ALL3 would
// put the inner binder at `prj 0`, the opposite of the renderer's
// slot order (first PP binder вҶҰ prj 0).  ALL3R appends the outer
// element instead (`y вЁҫ prj 0 w`), so its compound premise matches the
// renderer's convention and downstream hyp searches stay consistent.
symbol nested_to_compoundR [n] (P : Tuple (+1 n) вҶ’ Prop)
  (h : ПҖ (`!! w : Tuple 1, `!! y : Tuple n, P (y вЁҫ prj 0 w)))
  : О  v : Tuple (+1 n), ПҖ (P v);
rule nested_to_compoundR [$n] $P $h ($y вЁҫ $a) вҶӘ
  !!_to_pi (О» y, $P (y вЁҫ $a))
           (!!_to_pi (О» w, `!! y : Tuple $n, $P (y вЁҫ prj 0 w)) $h (unit вЁҫ $a))
           $y;

opaque symbol ALL3R [n] [P : Tuple (+1 n) вҶ’ Prop] [R : Prop]
  : ПҖ ((`!! v : Tuple (+1 n), P v) вҮ’ R)
  вҶ’ ПҖ ((`!! w : Tuple 1, `!! y : Tuple n, P (y вЁҫ prj 0 w)) вҮ’ R) вү”
begin
  assume n P R h hnested;
  refine h (pi_to_!! P (nested_to_compoundR P hnested))
end;

// ALL4: H вҠў вҲҖ(x,y)В·P вҶ’ H вҠў вҲҖxВ·вҲҖyВ·P
opaque symbol ALL4 [n] [P : Tuple (+1 n) вҶ’ Prop]
  : ПҖ (`!! v : Tuple (+1 n), P v)
  вҶ’ ПҖ (`!! w : Tuple n, `!! y : Tuple 1, P (w вЁҫ prj 0 y)) вү”
begin
  assume n P h;
  refine pi_to_!! _ _; assume w;
  refine pi_to_!! _ _; assume y;
  refine !!_to_pi P h (w вЁҫ prj 0 y)
end;

// ALL5: H вҠў вҲҖ-block, В¬P вҮ’ R вҶ’ H вҠў В¬(вҲҖ-block, P) вҮ’ R
// "x not free in R" means R : Prop (uniform across arities).

opaque symbol ALL5 [n] [P : Tuple n вҶ’ Prop] [R : Prop]
  : ПҖ (`!! v, В¬ (P v) вҮ’ R)
  вҶ’ ПҖ (В¬ (`!! v, P v) вҮ’ R) вү”
begin
  assume n P R h1 h2;
  refine В¬В¬вӮ‘ R _;
  assume hnr;
  refine h2 (pi_to_!! P (О» v,
    В¬В¬вӮ‘ (P v) (О» hnpv, hnr (!!_to_pi (О» v, В¬ (P v) вҮ’ R) h1 v hnpv))))
end;

// ALL6: H вҠў (вҲҖ-block, P) вҮ’ вҠҘ вҶ’ H вҠў В¬(вҲҖ-block, P)
// Definitional in HOAS: В¬Q вүЎ Q вҮ’ вҠҘ.

opaque symbol ALL6 [n] [P : Tuple n вҶ’ Prop]
  : ПҖ ((`!! v, P v) вҮ’ вҠҘ)
  вҶ’ ПҖ (В¬ (`!! v, P v)) вү”
begin assume n P h; refine h end;

// ALL7: result-based form.
//   premise 1: per-tuple Res chain ПҒ producing res_tm (ПҒ v) for each v
//   premise 2: ((`вҷў v, res_tm (ПҒ v)) вҮ’ Q) (continuation)
//   conclusion: (`!! v, P v) вҮ’ Q
//
// Per spec: H вҠў (вҷўx В· R) вҮ’ Q | H вҠў (вҲҖx В· P) вҮ’ Q. The continuation
// premise is the "after-normalisation" form, marked вҷў; the conclusion
// matches PP's `!`-binder, encoded as `!!`.

opaque symbol ALL7 [n] [P : Tuple n вҶ’ Prop] [Q : Prop]
  (ПҒ : О  v : Tuple n, Res (P v))
  : ПҖ ((`вҷў v, res_tm (ПҒ v)) вҮ’ Q) вҶ’ ПҖ ((`!! v, P v) вҮ’ Q) вү”
begin
  assume n P Q ПҒ h_after h_P;
  refine h_after (pi_to_вҷў (О» v, res_tm (ПҒ v))
    (О» v, =вҮ’ (res_eq (ПҒ v)) (!!_to_pi P h_P v)))
end;

// ALL8: H вҠў P вҶ’ H вҠў вҲҖ-block, P
// Universal-introduction. Spec premise is the body P with the bound
// variable free in context; HOAS-encoded as a per-tuple proof family
// (О  v, ПҖ (P v)). With `!!` rigid we need `pi_to_!!` to bridge.

opaque symbol ALL8 [n] [P : Tuple n вҶ’ Prop]
  : (О  v : Tuple n, ПҖ (P v)) вҶ’ ПҖ (`!! v, P v)
  вү” О» f, pi_to_!! _ f;

// ALL9: H, (вҲҖ-block, T) вҠў Q вҶ’ H вҠў (вҷЎ-block, T) вҮ’ Q
// Transport antecedent вҷЎ вҶ’ !! via `вҷЎ_eq_!!`, then apply h.

opaque symbol ALL9 [n] [T : Tuple n вҶ’ Prop] [Q : Prop]
  : (ПҖ (`!! v, T v) вҶ’ ПҖ Q)
  вҶ’ ПҖ ((`вҷЎ v, T v) вҮ’ Q) вү”
begin
  assume n T Q h hheart;
  refine h (=вҮ’ (вҷЎ_eq_!! T) hheart)
end;

// ---- `_1` (Result-form) variants вҖ” В§8.13 ----
//
// ALL1вҖ“ALL6: Schema 1 passthrough. ALL1вҖ“4 are compoundвҶ”nested
// conversions whose LP encoding is HOAS-identity at the value level;
// res_tm propagates via `trust` for the equality bridge between the
// compound and nested forms.
// ALL5: Schema 1 вҖ” passthrough through the `В¬вҲҖ вҮ’ R = вҲҖ В¬ вҮ’ R` bridge.
// ALL6: Schema 1 вҖ” passthrough through `В¬P вүЎ P вҮ’ вҠҘ`.
// ALL7' / ALL8' / ALL9': special cases (see spec В§8.13).

symbol ALL1_1 [n] [P : Tuple (+1 n) вҶ’ Prop] [R : Prop]
  (r : Res (В¬ (`!! v : Tuple (+1 n), P v) вҮ’ R))
  : Res (В¬ (`!! w : Tuple n, `!! y : Tuple 1, P (w вЁҫ prj 0 y)) вҮ’ R)
  вү” mk_1 (res_tm r) trust;

symbol ALL2_1 [n] [P : Tuple (+1 n) вҶ’ Prop]
  (r : Res (В¬ (`!! v : Tuple (+1 n), P v)))
  : Res (В¬ (`!! w : Tuple n, `!! y : Tuple 1, P (w вЁҫ prj 0 y)))
  вү” mk_1 (res_tm r) trust;

symbol ALL3_1 [n] [P : Tuple (+1 n) вҶ’ Prop] [R : Prop]
  (r : Res ((`!! v : Tuple (+1 n), P v) вҮ’ R))
  : Res ((`!! w : Tuple n, `!! y : Tuple 1, P (w вЁҫ prj 0 y)) вҮ’ R)
  вү” mk_1 (res_tm r) trust;

// Chain form of ALL3R (outer binder appended last; see ALL3R above).
symbol ALL3R_1 [n] [P : Tuple (+1 n) вҶ’ Prop] [R : Prop]
  (r : Res ((`!! v : Tuple (+1 n), P v) вҮ’ R))
  : Res ((`!! w : Tuple 1, `!! y : Tuple n, P (y вЁҫ prj 0 w)) вҮ’ R)
  вү” mk_1 (res_tm r) trust;

symbol ALL4_1 [n] [P : Tuple (+1 n) вҶ’ Prop]
  (r : Res (`!! v : Tuple (+1 n), P v))
  : Res (`!! w : Tuple n, `!! y : Tuple 1, P (w вЁҫ prj 0 y))
  вү” mk_1 (res_tm r) trust;

symbol ALL5_1 [n] [P : Tuple n вҶ’ Prop] [R : Prop]
  (r : Res (`!! v, В¬ (P v) вҮ’ R))
  : Res (В¬ (`!! v, P v) вҮ’ R)
  вү” mk_1 (res_tm r) trust;

symbol ALL6_1 [n] [P : Tuple n вҶ’ Prop]
  (r : Res ((`!! v, P v) вҮ’ вҠҘ))
  : Res (В¬ (`!! v, P v))
  вү” mk_1 (res_tm r) (res_eq r);

// ALL7_1 (ALL7'): branching quantifier вҖ” per-tuple Res chain ПҒ +
// continuation r. The continuation premise uses `вҷў`
// (post-normalisation form per spec).
symbol ALL7_1 [n] [P : Tuple n вҶ’ Prop] [Q : Prop]
  (ПҒ : О  v : Tuple n, Res (P v))
  (r : Res ((`вҷў v, res_tm (ПҒ v)) вҮ’ Q))
  : Res ((`!! v, P v) вҮ’ Q) вү”
begin
  assume n P Q ПҒ r;
  refine mk_1 (res_tm r) _;
  have h1 : ПҖ ((`!! v, P v) = (`вҷў v, res_tm (ПҒ v)))
    { refine eq_trans (!!_cong (О» v, res_eq (ПҒ v)))
        (eq_sym (вҷў_eq_!! (О» v, res_tm (ПҒ v)))) };
  have h2 : ПҖ (((`!! v, P v) вҮ’ Q) = ((`вҷў v, res_tm (ПҒ v)) вҮ’ Q))
    { rewrite h1; reflexivity };
  refine eq_trans h2 (res_eq r)
end;

// ALL8_1 (ALL8'): congruence under вҲҖ-block.
symbol ALL8_1 [n] [P : Tuple n вҶ’ Prop]
  (ПҒ : О  v : Tuple n, Res (P v)) : Res (`!! v, P v)
  вү” mk_1 (`!! v, res_tm (ПҒ v))
           (!!_cong (О» v, res_eq (ПҒ v)));

// ALL9_1 (ALL9'): result-form ALL9 (вҷЎ-block removal), mapping to (вҲҖxВ·P) вҮ’ R.
symbol ALL9_1 [n] [T : Tuple n вҶ’ Prop] [Q : Prop]
  (r : Res Q) : Res ((`вҷЎ v, T v) вҮ’ Q)
  вү” mk_1 ((`!! v, T v) вҮ’ res_tm r)
          (eq_trans (imp_cong_l (вҷЎ_eq_!! T)) (imp_cong_r (res_eq r)));
