// Universal quantification (¬ІA.7) вАФ tuple-based encoding.
//
// Compound bindings in PP traces map to `!! v : Tuple n, P v`. The
// per-arity scaffolding the previous version of this file carried
// (ALL5_2, ALL7_2, ALL7_3, ALL7_2i, ALL7_3i, вА¶) is gone: the uniform
// tuple-indexed forms below subsume every arity.
//
// ALL1вАУ4 are compoundвЖФnested conversions (¬ІA.7 regroupement).  All four are now
// CURRIED, like ALL3: P : Tuple n вЖТ Tuple 1 вЖТ Prop, so the nested conclusion is
//
//   nested   : `!! w : Tuple n, `!! y : Tuple 1, P w y
//
// where `P w y` is a *pattern* (P applied to the distinct bound tuples) вАФ hence
// `refine ALLn _` infers P, no explicit predicate.  The compound premise splits
// v : Tuple (n ++ 1) with take/drop:
//
//   compound : `!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v)
//
// The two forms are equal (`!!_split_eq`, lemmas/Tuple.lp, proved once by propExt
// over reconstruction `tcat` + projection `take`/`drop`), so ALL1/2/4 are one-line
// transports of it; ALL3 keeps its direct projection proof.  Replaces the previous
// compound-`P (w в®Њ prj 0 y)` encoding (non-pattern, so unemittable).

require open pp2lp.B pp2lp.lemmas.Int pp2lp.lemmas.Tuple pp2lp.rules.Res;

// ALL1: H вКҐ ¬ђ(вИА(x,y)¬ЈP) вЗТ R вЖТ H вКҐ ¬ђ(вИАx¬ЈвИАy¬ЈP) вЗТ R
opaque symbol ALL1 [n] [P : Tuple n вЖТ Tuple 1 вЖТ Prop] [R : Prop]
  : ѕА (¬ђ (`!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v)) вЗТ R)
  вЖТ ѕА (¬ђ (`!! w : Tuple n, `!! y : Tuple 1, P w y) вЗТ R) вЙФ
begin
  assume n P R h;
  refine =вЗТ (imp_cong_l (not_cong (!!_split_eq P))) h
end;

// ALL2: H вКҐ ¬ђ(вИА(x,y)¬ЈP) вЖТ H вКҐ ¬ђ(вИАx¬ЈвИАy¬ЈP)
opaque symbol ALL2 [n] [P : Tuple n вЖТ Tuple 1 вЖТ Prop]
  : ѕА (¬ђ (`!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v)))
  вЖТ ѕА (¬ђ (`!! w : Tuple n, `!! y : Tuple 1, P w y)) вЙФ
begin
  assume n P h;
  refine =вЗТ (not_cong (!!_split_eq P)) h
end;

// ALL3: H вКҐ (вИА(x,y)¬ЈP) вЗТ R вЖТ H вКҐ (вИАx¬ЈвИАy¬ЈP) вЗТ R   (¬ІA.7 regroupement)
//
// Curried encoding: P : Tuple n вЖТ Tuple 1 вЖТ Prop, so the nested conclusion is
// `!! w, !! y, P w y` вАФ P sits at a *pattern* position (applied to the distinct
// bound tuples w, y), hence the emitter need not pass it explicitly: `refine
// ALL3 _` infers it from the goal.  The compound premise splits v with
// take/drop, whose prj-commute rules reduce `P (take v) (drop v)` to the
// renderer's slot order (first PP var вЖ¶ prj 0, the trailing var вЖ¶ prj n).  That
// slot order is exactly what the old `ALL3R` variant was hand-rolling, so ALL3R
// is gone вАФ take/drop subsume it.
opaque symbol ALL3 [n] [P : Tuple n вЖТ Tuple 1 вЖТ Prop] [R : Prop]
  : ѕА ((`!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v)) вЗТ R)
  вЖТ ѕА ((`!! w : Tuple n, `!! y : Tuple 1, P w y) вЗТ R) вЙФ
begin
  assume n P R h hn;
  refine h _;
  refine pi_to_!! _ _; assume v;
  refine !!_to_pi (ќї y, P (take [n] [1] v) y)
           (!!_to_pi (ќї w, `!! y : Tuple 1, P w y) hn (take [n] [1] v))
           (drop [n] [1] v)
end;

// ALL4: H вКҐ вИА(x,y)¬ЈP вЖТ H вКҐ вИАx¬ЈвИАy¬ЈP
opaque symbol ALL4 [n] [P : Tuple n вЖТ Tuple 1 вЖТ Prop]
  : ѕА (`!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v))
  вЖТ ѕА (`!! w : Tuple n, `!! y : Tuple 1, P w y) вЙФ
begin
  assume n P h;
  refine =вЗТ (!!_split_eq P) h
end;

// ALL5: H вКҐ вИА-block, ¬ђP вЗТ R вЖТ H вКҐ ¬ђ(вИА-block, P) вЗТ R
// "x not free in R" means R : Prop (uniform across arities).

opaque symbol ALL5 [n] [P : Tuple n вЖТ Prop] [R : Prop]
  : ѕА (`!! v, ¬ђ (P v) вЗТ R)
  вЖТ ѕА (¬ђ (`!! v, P v) вЗТ R) вЙФ
begin
  assume n P R h1 h2;
  refine ¬ђ¬ђвВС R _;
  assume hnr;
  refine h2 (pi_to_!! P (ќї v,
    ¬ђ¬ђвВС (P v) (ќї hnpv, hnr (!!_to_pi (ќї v, ¬ђ (P v) вЗТ R) h1 v hnpv))))
end;

// ALL6: H вКҐ (вИА-block, P) вЗТ вК• вЖТ H вКҐ ¬ђ(вИА-block, P)
// Definitional in HOAS: ¬ђQ вЙ° Q вЗТ вК•.

opaque symbol ALL6 [n] [P : Tuple n вЖТ Prop]
  : ѕА ((`!! v, P v) вЗТ вК•)
  вЖТ ѕА (¬ђ (`!! v, P v)) вЙФ
begin assume n P h; refine h end;

// ALL7: result-based form.
//   premise 1: per-tuple Res chain ѕБ producing res_tm (ѕБ v) for each v
//   premise 2: ((`вЩҐ v, res_tm (ѕБ v)) вЗТ Q) (continuation)
//   conclusion: (`!! v, P v) вЗТ Q
//
// Per spec: H вКҐ (вЩҐx ¬Ј R) вЗТ Q | H вКҐ (вИАx ¬Ј P) вЗТ Q. The continuation
// premise is the "after-normalisation" form, marked вЩҐ; the conclusion
// matches PP's `!`-binder, encoded as `!!`.

opaque symbol ALL7 [n] [P : Tuple n вЖТ Prop] [Q : Prop]
  (ѕБ : ќ† v : Tuple n, Res (P v))
  : ѕА ((`вЩҐ v, res_tm (ѕБ v)) вЗТ Q) вЖТ ѕА ((`!! v, P v) вЗТ Q) вЙФ
begin
  assume n P Q ѕБ h_after h_P;
  refine h_after (pi_to_вЩҐ (ќї v, res_tm (ѕБ v))
    (ќї v, =вЗТ (res_eq (ѕБ v)) (!!_to_pi P h_P v)))
end;

// ALL8: H вКҐ P вЖТ H вКҐ вИА-block, P
// Universal-introduction. Spec premise is the body P with the bound
// variable free in context; HOAS-encoded as a per-tuple proof family
// (ќ† v, ѕА (P v)). With `!!` rigid we need `pi_to_!!` to bridge.

opaque symbol ALL8 [n] [P : Tuple n вЖТ Prop]
  : (ќ† v : Tuple n, ѕА (P v)) вЖТ ѕА (`!! v, P v)
  вЙФ ќї f, pi_to_!! _ f;

// ALL9: H, (вИА-block, T) вКҐ Q вЖТ H вКҐ (вЩ°-block, T) вЗТ Q
// Transport antecedent вЩ° вЖТ !! via `вЩ°_eq_!!`, then apply h.

opaque symbol ALL9 [n] [T : Tuple n вЖТ Prop] [Q : Prop]
  : (ѕА (`!! v, T v) вЖТ ѕА Q)
  вЖТ ѕА ((`вЩ° v, T v) вЗТ Q) вЙФ
begin
  assume n T Q h hheart;
  refine h (=вЗТ (вЩ°_eq_!! T) hheart)
end;

// ---- `_1` (Result-form) variants вАФ ¬І8.13 ----
//
// ALL1_1вАУALL4_1 are the Res-chain forms of the ¬ІA.7 quantifier regroupement.  PP
// emits them PRIMED inside a result chain (`[ALL3_1]`, вА¶), where flatten_binds
// cannot reach вАФ the merged binder is born inside `res_tm`, not in the goal.  Each
// transports the curried base rule's compoundвЖФnested equality (`!!_split_eq`,
// lemmas/Tuple.lp) through the Schema-1 result bridge `mk_1 (res_tm r) (eq_trans
// <concl = prem> (res_eq r))` вАФ trust-free.  (They replace the trust-bodied
// placeholders deleted 2026-06-12, now that the base rules are curried.)

// ALL1_1: chain form of ALL1 (¬ђ(вИА-merge) вЗТ R).
symbol ALL1_1 [n] [P : Tuple n вЖТ Tuple 1 вЖТ Prop] [R : Prop]
  (r : Res (¬ђ (`!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v)) вЗТ R))
  : Res (¬ђ (`!! w : Tuple n, `!! y : Tuple 1, P w y) вЗТ R)
  вЙФ mk_1 (res_tm r)
      (eq_trans (eq_sym (imp_cong_l (not_cong (!!_split_eq P)))) (res_eq r));

// ALL2_1: chain form of ALL2 (¬ђ(вИА-merge)).
symbol ALL2_1 [n] [P : Tuple n вЖТ Tuple 1 вЖТ Prop]
  (r : Res (¬ђ (`!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v))))
  : Res (¬ђ (`!! w : Tuple n, `!! y : Tuple 1, P w y))
  вЙФ mk_1 (res_tm r) (eq_trans (eq_sym (not_cong (!!_split_eq P))) (res_eq r));

// ALL3_1: chain form of ALL3 ((вИА-merge) вЗТ R).
symbol ALL3_1 [n] [P : Tuple n вЖТ Tuple 1 вЖТ Prop] [R : Prop]
  (r : Res ((`!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v)) вЗТ R))
  : Res ((`!! w : Tuple n, `!! y : Tuple 1, P w y) вЗТ R)
  вЙФ mk_1 (res_tm r) (eq_trans (eq_sym (imp_cong_l (!!_split_eq P))) (res_eq r));

// ALL4_1: chain form of ALL4 (вИА-merge).
symbol ALL4_1 [n] [P : Tuple n вЖТ Tuple 1 вЖТ Prop]
  (r : Res (`!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v)))
  : Res (`!! w : Tuple n, `!! y : Tuple 1, P w y)
  вЙФ mk_1 (res_tm r) (eq_trans (eq_sym (!!_split_eq P)) (res_eq r));

// ALL6: Schema 1 вАФ passthrough through `¬ђP вЙ° P вЗТ вК•` (a genuine HOAS identity).
// ALL7' / ALL8' / ALL9': special cases (see spec ¬І8.13).

symbol ALL6_1 [n] [P : Tuple n вЖТ Prop]
  (r : Res ((`!! v, P v) вЗТ вК•))
  : Res (¬ђ (`!! v, P v))
  вЙФ mk_1 (res_tm r) (res_eq r);

// ALL7_1 (ALL7'): branching quantifier вАФ per-tuple Res chain ѕБ +
// continuation r. The continuation premise uses `вЩҐ`
// (post-normalisation form per spec).
symbol ALL7_1 [n] [P : Tuple n вЖТ Prop] [Q : Prop]
  (ѕБ : ќ† v : Tuple n, Res (P v))
  (r : Res ((`вЩҐ v, res_tm (ѕБ v)) вЗТ Q))
  : Res ((`!! v, P v) вЗТ Q) вЙФ
begin
  assume n P Q ѕБ r;
  refine mk_1 (res_tm r) _;
  have h1 : ѕА ((`!! v, P v) = (`вЩҐ v, res_tm (ѕБ v)))
    { refine eq_trans (!!_cong (ќї v, res_eq (ѕБ v)))
        (eq_sym (вЩҐ_eq_!! (ќї v, res_tm (ѕБ v)))) };
  have h2 : ѕА (((`!! v, P v) вЗТ Q) = ((`вЩҐ v, res_tm (ѕБ v)) вЗТ Q))
    { rewrite h1; reflexivity };
  refine eq_trans h2 (res_eq r)
end;

// ALL8_1 (ALL8'): congruence under вИА-block.
symbol ALL8_1 [n] [P : Tuple n вЖТ Prop]
  (ѕБ : ќ† v : Tuple n, Res (P v)) : Res (`!! v, P v)
  вЙФ mk_1 (`!! v, res_tm (ѕБ v))
           (!!_cong (ќї v, res_eq (ѕБ v)));

// ALL9_1 (ALL9'): result-form ALL9 (вЩ°-block removal), mapping to (вИАx¬ЈP) вЗТ R.
symbol ALL9_1 [n] [T : Tuple n вЖТ Prop] [Q : Prop]
  (r : Res Q) : Res ((`вЩ° v, T v) вЗТ Q)
  вЙФ mk_1 ((`!! v, T v) вЗТ res_tm r)
          (eq_trans (imp_cong_l (вЩ°_eq_!! T)) (imp_cong_r (res_eq r)));
