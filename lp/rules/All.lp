// Universal quantification (¬ІA.7) вАФ shallow encoding
//
// With HOAS:
// - вЩҐ and вЩ° are defined as aliases for вИА in B.lp.
// - Variable renaming (ALL5f, ALL7f, ALL8f) is handled by
//   ќ±-equivalence вАФ these collapse into ALL5, ALL7, ALL8.
// - Compound variables (ALL1-4) don't exist; nested вИА IS
//   the only form. The OCaml emitter should skip ALL1-4.
// - ALL6 is definitional (¬ђQ вЙ° Q вЗТ вК•).
require open pp2lp.B;

// ---- Identity rules (no-ops in HOAS) ----
//
// ALL5f, ALL7f, ALL8f: Variable renaming variants of ALL5,
//   ALL7, ALL8. In HOAS, ќ±-equivalence is automatic, so
//   these collapse into their base forms.

// ALL1-4: Compound variable flattening (identity in HOAS).
// ALL1: x,y distinct; H вКҐ ¬ђ(вИА(x,y)¬ЈP) вЗТ R вЖТ H вКҐ ¬ђ(вИАx¬ЈвИАy¬ЈP) вЗТ R
opaque symbol ALL1 [P : ѕД ќє вЖТ ѕД ќє вЖТ Prop] [R : Prop] (nf : ѕА вК§)
  : ѕА (¬ђ (`вИА x, `вИА y, P x y) вЗТ R)
  вЖТ ѕА (¬ђ (`вИА x, `вИА y, P x y) вЗТ R) вЙФ
begin assume P R nf h; refine h end;

// ALL2: same pattern for NOT(вИА) flattening
opaque symbol ALL2 [P : ѕД ќє вЖТ ѕД ќє вЖТ Prop] (nf : ѕА вК§)
  : ѕА (¬ђ (`вИА x, `вИА y, P x y))
  вЖТ ѕА (¬ђ (`вИА x, `вИА y, P x y)) вЙФ
begin assume P nf h; refine h end;

// ALL3: compound variable flattening for positive вИА вЗТ R
opaque symbol ALL3 [P : ѕД ќє вЖТ ѕД ќє вЖТ Prop] [R : Prop] (nf : ѕА вК§)
  : ѕА ((`вИА x, `вИА y, P x y) вЗТ R)
  вЖТ ѕА ((`вИА x, `вИА y, P x y) вЗТ R) вЙФ
begin assume P R nf h; refine h end;

// ALL4: flattening for вИА with implication
opaque symbol ALL4 [P : ѕД ќє вЖТ ѕД ќє вЖТ Prop] [Q : Prop] (nf : ѕА вК§)
  : ѕА ((`вИА x, `вИА y, P x y) вЗТ Q)
  вЖТ ѕА ((`вИА x, `вИА y, P x y) вЗТ Q) вЙФ
begin assume P Q nf h; refine h end;

// ALL6: H вКҐ (вИАx¬ЈP) вЗТ FALSE вЖТ H вКҐ ¬ђ(вИАx¬ЈP)
// Definitional: ¬ђQ вЙ° Q вЗТ вК•.
opaque symbol ALL6 [P : ѕД ќє вЖТ Prop]
  : ѕА ((`вИА x, P x) вЗТ вК•)
  вЖТ ѕА (¬ђ (`вИА x, P x)) вЙФ
begin assume P h; refine h end;

// ---- Substantive rules ----

// ALL5: x not free in R; H вКҐ вИАx¬Ј(¬ђP вЗТ R) вЖТ H вКҐ ¬ђ(вИАx¬ЈP) вЗТ R
// "x not free in R" means R : Prop (not ѕД ќє вЖТ Prop).
opaque symbol ALL5 [P : ѕД ќє вЖТ Prop] [R : Prop]
  : ѕА (`вИА x, ¬ђ (P x) вЗТ R)
  вЖТ ѕА (¬ђ (`вИА x, P x) вЗТ R) вЙФ
begin
  assume P R h1 h2;
  refine ¬ђ¬ђвВС R _;
  assume hnr;
  refine h2 (ќї x, ¬ђ¬ђвВС (P x) (ќї hnpx, hnr (h1 x hnpx)))
end;

// ALL5_2: Two-variable version.
opaque symbol ALL5_2 [P : ѕД ќє вЖТ ѕД ќє вЖТ Prop] [R : Prop]
  : ѕА (`вИА x, `вИА y, ¬ђ (P x y) вЗТ R)
  вЖТ ѕА (¬ђ (`вИА x, `вИА y, P x y) вЗТ R) вЙФ
begin
  assume P R h1 h2;
  refine ¬ђ¬ђвВС R _;
  assume hnr;
  refine h2 (ќї x y, ¬ђ¬ђвВС (P x y) (ќї hnpxy, hnr (h1 x y hnpxy)))
end;

// ALL7: x not free in H; (H вКҐ P) вЗЭ R; H вКҐ (вЩҐx¬ЈR) вЗТ Q вЖТ H вКҐ (вИАx¬ЈP) вЗТ Q
// First premise: P(x) = R(x) for all x (equality-based normalisation result).
// Second premise: (вЩҐx R(x)) вЗТ Q.
opaque symbol ALL7 [P : ѕД ќє вЖТ Prop] (R : ѕД ќє вЖТ Prop) [Q : Prop]
  : ѕА (`вИА x, P x = R x)
  вЖТ ѕА ((`вЩҐ x, R x) вЗТ Q)
  вЖТ ѕА ((`вИА x, P x) вЗТ Q) вЙФ
begin
  assume P R Q h1 h2 hP;
  refine h2 (ќї x, =вЗТ (h1 x) (hP x))
end;

// ALL7_2: Two-variable version for compound вИА(x,y).
opaque symbol ALL7_2 [P : ѕД ќє вЖТ ѕД ќє вЖТ Prop] (R : ѕД ќє вЖТ ѕД ќє вЖТ Prop) [Q : Prop]
  : ѕА (`вИА x, `вИА y, P x y = R x y)
  вЖТ ѕА ((`вЩҐ x, `вЩҐ y, R x y) вЗТ Q)
  вЖТ ѕА ((`вИА x, `вИА y, P x y) вЗТ Q) вЙФ
begin
  assume P R Q h1 h2 hP;
  refine h2 (ќї x y, =вЗТ (h1 x y) (hP x y))
end;

// ALL7i/ALL7_2i: R implicit вАФ inferred from the equality proof.
// The emitter provides the equality proof; Lambdapi infers R from its RHS.
opaque symbol ALL7i [P R : ѕД ќє вЖТ Prop] [Q : Prop]
  : ѕА (`вИА x, P x = R x)
  вЖТ ѕА ((`вЩҐ x, R x) вЗТ Q)
  вЖТ ѕА ((`вИА x, P x) вЗТ Q) вЙФ
begin
  assume P R Q h1 h2 hP;
  refine h2 (ќї x, =вЗТ (h1 x) (hP x))
end;

opaque symbol ALL7_2i [P R : ѕД ќє вЖТ ѕД ќє вЖТ Prop] [Q : Prop]
  : ѕА (`вИА x, `вИА y, P x y = R x y)
  вЖТ ѕА ((`вЩҐ x, `вЩҐ y, R x y) вЗТ Q)
  вЖТ ѕА ((`вИА x, `вИА y, P x y) вЗТ Q) вЙФ
begin
  assume P R Q h1 h2 hP;
  refine h2 (ќї x y, =вЗТ (h1 x y) (hP x y))
end;

// ALL8: x not free in H; H вКҐ P вЖТ H вКҐ вИАx¬ЈP
// Identity in HOAS: ѕА(вИАx, P x) is already ќ†x, ѕА(P x).
// The emitter handles вИА-introduction via assume.
opaque symbol ALL8 [P : ѕД ќє вЖТ Prop]
  : ѕА (`вИА x, P x)
  вЖТ ѕА (`вИА x, P x) вЙФ
begin
  assume P h; refine h
end;

// ALL9: H, (вИАx¬ЈT) вКҐ Q вЖТ H вКҐ (вЩ°x¬ЈT) вЗТ Q
opaque symbol ALL9 [T : ѕД ќє вЖТ Prop] [Q : Prop]
  : (ѕА (`вИА x, T x) вЖТ ѕА Q)
  вЖТ ѕА ((`вЩ° x, T x) вЗТ Q) вЙФ
begin
  assume T Q h; refine h
end;
