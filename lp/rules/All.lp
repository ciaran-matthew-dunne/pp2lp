// Universal quantification (¬ßA.7) ‚ÄĒ tuple-based encoding.
//
// Compound bindings in PP traces map to `!! v : Tuple n, P v`. The
// per-arity scaffolding the previous version of this file carried
// (ALL5_2, ALL7_2, ALL7_3, ALL7_2i, ALL7_3i, ‚Ä¶) is gone: the uniform
// tuple-indexed forms below subsume every arity.
//
// ALL1‚Äď4 are compound‚ÜĒnested conversions (¬ßA.7 regroupement).  All four are now
// CURRIED, like ALL3: P : Tuple n ‚Üí Tuple 1 ‚Üí Prop, so the nested conclusion is
//
//   nested   : `!! w : Tuple n, `!! y : Tuple 1, P w y
//
// where `P w y` is a *pattern* (P applied to the distinct bound tuples) ‚ÄĒ hence
// `refine ALLn _` infers P, no explicit predicate.  The compound premise splits
// v : Tuple (n ++ 1) with take/drop:
//
//   compound : `!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v)
//
// The two forms are equal (`!!_split_eq`, lemmas/Tuple.lp, proved once by propExt
// over reconstruction `tcat` + projection `take`/`drop`), so ALL1/2/4 are one-line
// transports of it; ALL3 keeps its direct projection proof.  Replaces the previous
// compound-`P (w ‚®ĺ prj 0 y)` encoding (non-pattern, so unemittable).

require open pp2lp.B pp2lp.lemmas.Int pp2lp.lemmas.Tuple pp2lp.rules.Res;

// ALL1: H ‚äĘ ¬¨(‚ąÄ(x,y)¬∑P) ‚áí R ‚Üí H ‚äĘ ¬¨(‚ąÄx¬∑‚ąÄy¬∑P) ‚áí R
opaque symbol ALL1 [n] [P : Tuple n ‚Üí Tuple 1 ‚Üí Prop] [R : Prop]
  : ŌÄ (¬¨ (`!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v)) ‚áí R)
  ‚Üí ŌÄ (¬¨ (`!! w : Tuple n, `!! y : Tuple 1, P w y) ‚áí R) ‚ČĒ
begin
  assume n P R h;
  refine =‚áí (imp_cong_l (not_cong (!!_split_eq P))) h
end;

// ALL2: H ‚äĘ ¬¨(‚ąÄ(x,y)¬∑P) ‚Üí H ‚äĘ ¬¨(‚ąÄx¬∑‚ąÄy¬∑P)
opaque symbol ALL2 [n] [P : Tuple n ‚Üí Tuple 1 ‚Üí Prop]
  : ŌÄ (¬¨ (`!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v)))
  ‚Üí ŌÄ (¬¨ (`!! w : Tuple n, `!! y : Tuple 1, P w y)) ‚ČĒ
begin
  assume n P h;
  refine =‚áí (not_cong (!!_split_eq P)) h
end;

// ALL3: H ‚äĘ (‚ąÄ(x,y)¬∑P) ‚áí R ‚Üí H ‚äĘ (‚ąÄx¬∑‚ąÄy¬∑P) ‚áí R   (¬ßA.7 regroupement)
//
// Curried encoding: P : Tuple n ‚Üí Tuple 1 ‚Üí Prop, so the nested conclusion is
// `!! w, !! y, P w y` ‚ÄĒ P sits at a *pattern* position (applied to the distinct
// bound tuples w, y), hence the emitter need not pass it explicitly: `refine
// ALL3 _` infers it from the goal.  The compound premise splits v with
// take/drop, whose prj-commute rules reduce `P (take v) (drop v)` to the
// renderer's slot order (first PP var ‚Ü¶ prj 0, the trailing var ‚Ü¶ prj n).  That
// slot order is exactly what the old `ALL3R` variant was hand-rolling, so ALL3R
// is gone ‚ÄĒ take/drop subsume it.
opaque symbol ALL3 [n] [P : Tuple n ‚Üí Tuple 1 ‚Üí Prop] [R : Prop]
  : ŌÄ ((`!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v)) ‚áí R)
  ‚Üí ŌÄ ((`!! w : Tuple n, `!! y : Tuple 1, P w y) ‚áí R) ‚ČĒ
begin
  assume n P R h hn;
  refine h _;
  refine pi_to_!! _ _; assume v;
  refine !!_to_pi (őĽ y, P (take [n] [1] v) y)
           (!!_to_pi (őĽ w, `!! y : Tuple 1, P w y) hn (take [n] [1] v))
           (drop [n] [1] v)
end;

// ALL4: H ‚äĘ ‚ąÄ(x,y)¬∑P ‚Üí H ‚äĘ ‚ąÄx¬∑‚ąÄy¬∑P
opaque symbol ALL4 [n] [P : Tuple n ‚Üí Tuple 1 ‚Üí Prop]
  : ŌÄ (`!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v))
  ‚Üí ŌÄ (`!! w : Tuple n, `!! y : Tuple 1, P w y) ‚ČĒ
begin
  assume n P h;
  refine =‚áí (!!_split_eq P) h
end;

// ALL5: H ‚äĘ ‚ąÄ-block, ¬¨P ‚áí R ‚Üí H ‚äĘ ¬¨(‚ąÄ-block, P) ‚áí R
// "x not free in R" means R : Prop (uniform across arities).

opaque symbol ALL5 [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ (`!! v, ¬¨ (P v) ‚áí R)
  ‚Üí ŌÄ (¬¨ (`!! v, P v) ‚áí R) ‚ČĒ
begin
  assume n P R h1 h2;
  refine ¬¨¬¨‚āĎ R _;
  assume hnr;
  refine h2 (pi_to_!! P (őĽ v,
    ¬¨¬¨‚āĎ (P v) (őĽ hnpv, hnr (!!_to_pi (őĽ v, ¬¨ (P v) ‚áí R) h1 v hnpv))))
end;

// ALL6: H ‚äĘ (‚ąÄ-block, P) ‚áí ‚ä• ‚Üí H ‚äĘ ¬¨(‚ąÄ-block, P)
// Definitional in HOAS: ¬¨Q ‚Č° Q ‚áí ‚ä•.

opaque symbol ALL6 [n] [P : Tuple n ‚Üí Prop]
  : ŌÄ ((`!! v, P v) ‚áí ‚ä•)
  ‚Üí ŌÄ (¬¨ (`!! v, P v)) ‚ČĒ
begin assume n P h; refine h end;

// ALL7: result-based form.
//   premise 1: per-tuple Res chain ŌĀ producing res_tm (ŌĀ v) for each v
//   premise 2: ((`‚ôĘ v, res_tm (ŌĀ v)) ‚áí Q) (continuation)
//   conclusion: (`!! v, P v) ‚áí Q
//
// Per spec: H ‚äĘ (‚ôĘx ¬∑ R) ‚áí Q | H ‚äĘ (‚ąÄx ¬∑ P) ‚áí Q. The continuation
// premise is the "after-normalisation" form, marked ‚ôĘ; the conclusion
// matches PP's `!`-binder, encoded as `!!`.

opaque symbol ALL7 [n] [P : Tuple n ‚Üí Prop] [Q : Prop]
  (ŌĀ : ő† v : Tuple n, Res (P v))
  : ŌÄ ((`‚ôĘ v, res_tm (ŌĀ v)) ‚áí Q) ‚Üí ŌÄ ((`!! v, P v) ‚áí Q) ‚ČĒ
begin
  assume n P Q ŌĀ h_after h_P;
  refine h_after (pi_to_‚ôĘ (őĽ v, res_tm (ŌĀ v))
    (őĽ v, =‚áí (res_eq (ŌĀ v)) (!!_to_pi P h_P v)))
end;

// ALL8: H ‚äĘ P ‚Üí H ‚äĘ ‚ąÄ-block, P
// Universal-introduction. Spec premise is the body P with the bound
// variable free in context; HOAS-encoded as a per-tuple proof family
// (ő† v, ŌÄ (P v)). With `!!` rigid we need `pi_to_!!` to bridge.

opaque symbol ALL8 [n] [P : Tuple n ‚Üí Prop]
  : (ő† v : Tuple n, ŌÄ (P v)) ‚Üí ŌÄ (`!! v, P v)
  ‚ČĒ őĽ f, pi_to_!! _ f;

// ALL9: H, (‚ąÄ-block, T) ‚äĘ Q ‚Üí H ‚äĘ (‚ô°-block, T) ‚áí Q
// Transport antecedent ‚ô° ‚Üí !! via `‚ô°_eq_!!`, then apply h.

opaque symbol ALL9 [n] [T : Tuple n ‚Üí Prop] [Q : Prop]
  : (ŌÄ (`!! v, T v) ‚Üí ŌÄ Q)
  ‚Üí ŌÄ ((`‚ô° v, T v) ‚áí Q) ‚ČĒ
begin
  assume n T Q h hheart;
  refine h (=‚áí (‚ô°_eq_!! T) hheart)
end;

// ---- `_1` (Result-form) variants ‚ÄĒ ¬ß8.13 ----
//
symbol ALL1_1 [n] [P : Tuple n ‚Üí Tuple 1 ‚Üí Prop] [R : Prop]
  (r : Res (¬¨ (`!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v)) ‚áí R))
  : Res (¬¨ (`!! w : Tuple n, `!! y : Tuple 1, P w y) ‚áí R)
  ‚ČĒ mk_1 (res_tm r)
      (eq_trans (eq_sym (imp_cong_l (not_cong (!!_split_eq P)))) (res_eq r));

symbol ALL2_1 [n] [P : Tuple n ‚Üí Tuple 1 ‚Üí Prop]
  (r : Res (¬¨ (`!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v))))
  : Res (¬¨ (`!! w : Tuple n, `!! y : Tuple 1, P w y))
  ‚ČĒ mk_1 (res_tm r) (eq_trans (eq_sym (not_cong (!!_split_eq P))) (res_eq r));

symbol ALL3_1 [n] [P : Tuple n ‚Üí Tuple 1 ‚Üí Prop] [R : Prop]
  (r : Res ((`!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v)) ‚áí R))
  : Res ((`!! w : Tuple n, `!! y : Tuple 1, P w y) ‚áí R)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (eq_sym (imp_cong_l (!!_split_eq P))) (res_eq r));

symbol ALL4_1 [n] [P : Tuple n ‚Üí Tuple 1 ‚Üí Prop]
  (r : Res (`!! v : Tuple (n ++ 1), P (take [n] [1] v) (drop [n] [1] v)))
  : Res (`!! w : Tuple n, `!! y : Tuple 1, P w y)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (eq_sym (!!_split_eq P)) (res_eq r));

opaque symbol all5_eq [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  : ŌÄ ((`!! v, ¬¨ (P v) ‚áí R) = (¬¨ (`!! v, P v) ‚áí R)) ‚ČĒ
begin
  assume n P R;
  refine propExt _ _ (őĽ h1, ALL5 h1) _;
  assume h2;
  refine pi_to_!! (őĽ v, ¬¨ (P v) ‚áí R)
    (őĽ v hnpv, h2 (őĽ hall, hnpv (!!_to_pi P hall v)))
end;

// ALL5_1: chain form of ALL5 (¬ß8.13 Schema 1).  The prem‚Üíconcl link is the
// classical equivalence `all5_eq`, transported onto the result like the merge
// `_1` forms transport their congruence.
symbol ALL5_1 [n] [P : Tuple n ‚Üí Prop] [R : Prop]
  (r : Res (`!! v, ¬¨ (P v) ‚áí R))
  : Res (¬¨ (`!! v, P v) ‚áí R)
  ‚ČĒ mk_1 (res_tm r) (eq_trans (eq_sym all5_eq) (res_eq r));

// ALL6: Schema 1 ‚ÄĒ passthrough through `¬¨P ‚Č° P ‚áí ‚ä•` (a genuine HOAS identity).
symbol ALL6_1 [n] [P : Tuple n ‚Üí Prop]
  (r : Res ((`!! v, P v) ‚áí ‚ä•))
  : Res (¬¨ (`!! v, P v))
  ‚ČĒ mk_1 (res_tm r) (res_eq r);

// ALL7' / ALL8' / ALL9': special cases (see spec ¬ß8.13).
symbol ALL7_1 [n] [P : Tuple n ‚Üí Prop] [Q : Prop]
  (ŌĀ : ő† v : Tuple n, Res (P v))
  (r : Res ((`‚ôĘ v, res_tm (ŌĀ v)) ‚áí Q))
  : Res ((`!! v, P v) ‚áí Q) ‚ČĒ
begin
  assume n P Q ŌĀ r;
  refine mk_1 (res_tm r) _;
  have h1 : ŌÄ ((`!! v, P v) = (`‚ôĘ v, res_tm (ŌĀ v)))
    { refine eq_trans (!!_cong (őĽ v, res_eq (ŌĀ v)))
        (eq_sym (‚ôĘ_eq_!! (őĽ v, res_tm (ŌĀ v)))) };
  have h2 : ŌÄ (((`!! v, P v) ‚áí Q) = ((`‚ôĘ v, res_tm (ŌĀ v)) ‚áí Q))
    { rewrite h1; reflexivity };
  refine eq_trans h2 (res_eq r)
end;

// ALL8_1 (ALL8'): congruence under ‚ąÄ-block.
symbol ALL8_1 [n] [P : Tuple n ‚Üí Prop]
  (ŌĀ : ő† v : Tuple n, Res (P v)) : Res (`!! v, P v)
  ‚ČĒ mk_1 (`!! v, res_tm (ŌĀ v))
           (!!_cong (őĽ v, res_eq (ŌĀ v)));

// ALL8_1‚āÄ: the ‚ä§-collapsing ALL8'.  When every element's result is VRAI (`res_tm
// (ŌĀ v) ‚Č° ‚ä§`, as for an AXM8_1/Schema-0 leaf body), PP's `‚ąÄx¬∑VRAI = VRAI` FIN
// normalisation collapses the universal ‚ÄĒ but the plain `ALL8_1` above keeps the
// binder, leaving `res_tm = !! v, ‚ä§` where the continuation (VR3‚Ä¶) wants bare ‚ä§.
// This form takes the per-element ‚ä§-proofs (the emitter supplies `őĽ v, eq_refl`,
// sound because the leaf's res_tm reduces to ‚ä§) and produces `mk_0` ‚ÄĒ so res_tm
// reduces *cleanly* to ‚ä§ (empty list, no stuck `!!` binder), matching PP.
symbol ALL8_1‚āÄ [n] [P : Tuple n ‚Üí Prop]
  (ŌĀ : ő† v : Tuple n, Res (P v))
  (htop : ő† v : Tuple n, ŌÄ (res_tm (ŌĀ v) = ‚ä§))
  : Res (`!! v, P v)
  ‚ČĒ mk_0 (eq_trans (!!_cong (őĽ v, eq_trans (res_eq (ŌĀ v)) (htop v)))
                   (!!_const ‚ä§));

// ALL9_1 (ALL9'): result-form ALL9 (‚ô°-block removal), mapping to (‚ąÄx¬∑P) ‚áí R.
symbol ALL9_1 [n] [T : Tuple n ‚Üí Prop] [Q : Prop]
  (r : Res Q) : Res ((`‚ô° v, T v) ‚áí Q)
  ‚ČĒ mk_1 ((`!! v, T v) ‚áí res_tm r)
          (eq_trans (imp_cong_l (‚ô°_eq_!! T)) (imp_cong_r (res_eq r)));
