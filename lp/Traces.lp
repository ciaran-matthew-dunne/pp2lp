// Traces.lp ‚Äî PP trace reconstructions (shallow encoding)
require open pp2lp.B
  pp2lp.rules.Conj pp2lp.rules.Disj
  pp2lp.rules.Impl pp2lp.rules.Equiv
  pp2lp.rules.Neg pp2lp.rules.Axm
  pp2lp.rules.TrueFalse
  pp2lp.rules.All pp2lp.rules.Xst
  pp2lp.rules.Nrm pp2lp.rules.Eq
  pp2lp.rules.Arith pp2lp.rules.Rw;

// ---- Trace 01: ¬¨(p ‚àß q) ‚áí (¬¨p ‚à® ¬¨q) ----
opaque symbol {|01|} (p q : Prop) :
  œÄ (¬¨ (p ‚àß q) ‚áí (¬¨ p ‚à® ¬¨ q)) ‚âî
begin
  assume p q;
  refine AND1 _ _
  { refine IMP4 _; assume hnq; refine OR4 _; refine AXM4 hnq }
  { refine IMP4 _; assume hnp; refine OR4 _; refine NOT1 _; refine AXM1 hnp }
end;

// ---- Trace 02: ¬¨(p ‚àß ¬¨p) ----
opaque symbol {|02|} (p : Prop) :
  œÄ (¬¨ (p ‚àß ¬¨ p)) ‚âî
begin
  assume p;
  refine AND2 _; refine IMP4 _; assume hp; refine NOT2 hp
end;

// ---- Trace 03: (p ‚àß q) ‚áí (q ‚àß p) ----
// AR10(q) is a solver no-op; just IMP4.
opaque symbol {|03|} (p q : Prop) :
  œÄ ((p ‚àß q) ‚áí (q ‚àß p)) ‚âî
begin
  assume p q;
  refine AND3 _; refine IMP4 _; assume hq;
  refine IMP4 _; assume hp;
  refine AND4 _ _ { refine AXM3 hq } { refine AXM3 hp }
end;

// ---- Trace 04: (a ‚àß p ‚àß (p ‚áí q) ‚àß c) ‚áí q ----
// TODO: requires list-based AND5/AXM8 infrastructure.

// ---- Trace 05: ¬¨(p ‚à® q) ‚áí ¬¨p ----
opaque symbol {|05|} (p q : Prop) :
  œÄ (¬¨ (p ‚à® q) ‚áí ¬¨ p) ‚âî
begin
  assume p q;
  refine OR1 _; refine IMP4 _; assume hnq; refine AXM4 hnq
end;

// ---- Trace 06: ¬¨(p ‚àß ¬¨p ‚à® (q ‚àß ¬¨q)) ----
opaque symbol {|06|} (p q : Prop) :
  œÄ (¬¨ ((p ‚àß ¬¨ p) ‚à® (q ‚àß ¬¨ q))) ‚âî
begin
  assume p q;
  refine OR2 _ _
  { refine AND2 _; refine IMP4 _; assume hq; refine NOT2 hq }
  { refine AND2 _; refine IMP4 _; assume hp; refine NOT2 hp }
end;

// ---- Trace 07: (p ‚à® q) ‚áí (q ‚à® p) ----
opaque symbol {|07|} (p q : Prop) :
  œÄ ((p ‚à® q) ‚áí (q ‚à® p)) ‚âî
begin
  assume p q;
  refine OR3 _ _
  { refine IMP4 _; assume hq; refine OR4 _; refine AXM2 hq }
  { refine IMP4 _; assume hp; refine OR4 _; refine AXM4 hp }
end;

// ---- Trace 08: ¬¨(p ‚áí q) ‚áí ¬¨q ----
opaque symbol {|08|} (p q : Prop) :
  œÄ (¬¨ (p ‚áí q) ‚áí ¬¨ q) ‚âî
begin
  assume p q;
  refine IMP1 _; refine IMP4 _; assume hp; refine AXM7
end;

// ---- Trace 09: ¬¨((p ‚à® ¬¨p) ‚áí (p ‚àß ¬¨p)) ----
opaque symbol {|09|} (p : Prop) :
  œÄ (¬¨ ((p ‚à® ¬¨ p) ‚áí (p ‚àß ¬¨ p))) ‚âî
begin
  assume p;
  refine IMP2 _ _
  { refine AND2 _; refine IMP4 _; assume hp; refine NOT2 hp }
  { refine OR4 _; refine AXM7 }
end;

// ---- Trace 10: (p ‚áí ¬¨p) ‚áí ¬¨p ----
opaque symbol {|10|} (p : Prop) :
  œÄ ((p ‚áí ¬¨ p) ‚áí ¬¨ p) ‚âî
begin
  assume p;
  refine IMP3 _ _ { refine AXM7 } { refine AXM7 }
end;

// ---- Trace 11: p ‚áí (p ‚áí p ‚àß p) ----
opaque symbol {|11|} (p : Prop) :
  œÄ (p ‚áí (p ‚áí (p ‚àß p))) ‚âî
begin
  assume p;
  refine IMP4 _; assume hp;
  refine IMP5 _;
  refine AND4 _ _ { refine AXM3 hp } { refine AXM3 hp }
end;

// ---- Trace 12: ¬¨(p ‚áî p) ‚áí q ----
opaque symbol {|12|} (p q : Prop) :
  œÄ (¬¨ (p ‚áî p) ‚áí q) ‚âî
begin
  assume p q;
  refine EQV1 _ _
  { refine IMP4 _; assume hp; refine AXM2 hp }
  { refine IMP4 _; assume hnp; refine AXM1 hnp }
end;

// ---- Trace 13: ¬¨(p ‚áî ¬¨p) ----
opaque symbol {|13|} (p : Prop) :
  œÄ (¬¨ (p ‚áî ¬¨ p)) ‚âî
begin
  assume p;
  refine EQV2 _ _
  { refine IMP4 _; assume hp; refine NOT2 hp }
  { refine NOT1 _; refine AXM7 }
end;

// ---- Trace 14: (p ‚áî ¬¨p) ‚áí q ----
opaque symbol {|14|} (p q : Prop) :
  œÄ ((p ‚áî ¬¨ p) ‚áí q) ‚âî
begin
  assume p q;
  refine EQV3 _ _
  { refine IMP4 _; assume hp; refine AXM2 hp }
  { refine IMP4 _; assume hnp; refine NOT1 _; refine AXM1 hnp }
end;

// ---- Trace 15: p ‚áî p ----
opaque symbol {|15|} (p : Prop) :
  œÄ (p ‚áî p) ‚âî
begin
  assume p;
  refine EQV4 _ _ { refine AXM7 } { refine AXM7 }
end;

// ---- Trace 16: ¬¨q ‚áí (p ‚áí (q ‚áí r)) ----
opaque symbol {|16|} (p q r : Prop) :
  œÄ (¬¨ q ‚áí (p ‚áí (q ‚áí r))) ‚âî
begin
  assume p q r;
  refine IMP4 _; assume hnq; refine AXM5 hnq
end;

// ---- Trace 17: q ‚áí (p ‚áí (¬¨q ‚áí r)) ----
opaque symbol {|17|} (p q r : Prop) :
  œÄ (q ‚áí (p ‚áí (¬¨ q ‚áí r))) ‚âî
begin
  assume p q r;
  refine IMP4 _; assume hq; refine AXM6 hq
end;

// ---- Trace 18: ‚àÄa.(‚àÄx.¬¨(‚ä§ ‚àß x=x)) ‚áí (a=a ‚áí p) ----
// ALL7 with R(x) = ‚ä• (result of normalising ¬¨(‚ä§‚àßx=x)).
opaque symbol {|18|} (p : Prop) :
  œÄ (`‚àÄ a : œÑ Œπ, (`‚àÄ x : œÑ Œπ, ¬¨ (‚ä§ ‚àß (x = x)))
    ‚áí ((a = a) ‚áí p)) ‚âî
begin
  assume p a;
  refine ALL7 (Œª _, ‚ä•) _ _
  { assume x;
    refine AND2_1 (VR3_1 (EVR2_1 STOP_1)) }
  { refine NRM1 _; refine FX3 }
end;

// ---- Trace 20: ¬¨(‚àÄx.‚àÄy.(x = y)) ‚áí p ‚à® ¬¨p ----
// ALL1 (identity), ALL5 (¬¨‚àÄ elimination), IMP4, OR4, AXM7
opaque symbol {|20|} (p : Prop) :
  œÄ (¬¨ (`‚àÄ x : œÑ Œπ, `‚àÄ y : œÑ Œπ, x = y) ‚áí (p ‚à® ¬¨ p)) ‚âî
begin
  assume p;
  // ALL1 is identity in HOAS (‚àÄx.‚àÄy = ‚àÄx.‚àÄy)
  // ALL5 with P(x) = ‚àÄy.(x=y), R = p ‚à® ¬¨p
  refine ALL5 _; assume x;
  // Goal: ¬¨(‚àÄy.x=y) ‚áí (p ‚à® ¬¨p)
  refine IMP4 _; assume h0;
  refine OR4 _; refine AXM7
end;

// ---- Trace 22: ¬¨(‚àÄx.‚àÄy.¬¨(x = x)) ----
// ALL2/ALL6 (identity), ALL7 with R=‚ä•, NRM1, AXM7
opaque symbol {|22|} :
  œÄ (¬¨ (`‚àÄ x : œÑ Œπ, `‚àÄ y : œÑ Œπ, ¬¨ (x = x))) ‚âî
begin
  // Goal: (‚àÄx.‚àÄy.¬¨(x=x)) ‚áí ‚ä•
  // ALL7 with P(x) = ‚àÄy.¬¨(x=x), R(x) = ‚ä•
  refine ALL7 (Œª _, ‚ä•) _ _
  { assume x;
    // Goal: (‚àÄy.¬¨(x=x)) = ‚ä•
    // ‚àÄy.¬¨(x=x) = ¬¨(x=x) (‚àÄ_const) = ‚ä• (EVR2_1)
    rewrite ‚àÄ_const; refine EVR2_1 STOP_1 }
  { // Goal: (‚ô¢x.‚ä•) ‚áí ‚ä• = (‚àÄx.‚ä•) ‚áí ‚ä•
    refine NRM1 _; refine AXM7 }
end;

// ---- Trace 26: ‚àÄ(a,b).(a=b ‚áí ‚àÄx.‚àÄy.(x=y ‚áí (x=a ‚áí y=b))) ----
// ALL8, OPR1, ALL4 (identity), ALL8, OPR1, AXM7
opaque symbol {|26|} :
  œÄ (`‚àÄ a : œÑ Œπ, `‚àÄ b : œÑ Œπ,
    (a = b) ‚áí (`‚àÄ x : œÑ Œπ, `‚àÄ y : œÑ Œπ,
      (x = y) ‚áí ((x = a) ‚áí (y = b)))) ‚âî
begin
  refine ALL8 _;
  assume a b;
  refine OPR1 (Œª z, `‚àÄ x : œÑ Œπ, `‚àÄ y : œÑ Œπ, (x = y) ‚áí ((x = z) ‚áí (y = b))) _;
  // ALL4 is identity in HOAS
  refine ALL8 _;
  assume x y;
  refine OPR1 (Œª z, (z = b) ‚áí (y = b)) _;
  refine AXM7
end;

// ---- Trace 28: ¬¨‚ä§ ‚áí p ----
opaque symbol {|28|} (p : Prop) :
  œÄ (¬¨ ‚ä§ ‚áí p) ‚âî
begin
  assume p; refine VR1
end;

// ---- Trace 29: ¬¨‚ä• ‚áí ‚ä§ ----
opaque symbol {|29|} :
  œÄ (¬¨ ‚ä• ‚áí ‚ä§) ‚âî
begin
  refine FX1 _; refine VR4
end;

// ---- Trace 30: ¬¨‚ä• ----
opaque symbol {|30|} :
  œÄ (¬¨ ‚ä•) ‚âî
begin
  refine FX2
end;
