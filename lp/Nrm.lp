// Normalisation rules (spec ┬ДA.12)
require open pp2lp.B pp2lp.Eq pp2lp.Interp;

// ---- first Рєњ second normalisation ----------------
// NRM1: x not free in P; H Ріб P РЄњ S  РЪ╣  H Ріб (РЎбx ┬и P) РЄњ S
symbol NRM1 [H x P S]
  : РЂЄ (pnf x P) Рєњ (H РіЕ P РЄњ S) Рєњ (H РіЕ (РЎб x P) РЄњ S);

// NRM2: x not free in P; H Ріб (P РЄњ РЎбx ┬и Q) РЄњ S  РЪ╣  H Ріб РЎбx ┬и (P РЄњ Q) РЄњ S
symbol NRM2 [H x P Q S]
  : РЂЄ (pnf x P) Рєњ (H РіЕ (P РЄњ РЎб x Q) РЄњ S) Рєњ (H РіЕ (РЎб x (P РЄњ Q)) РЄњ S);

// NRM3: x not free in Q; Q РЅа FALSE; H Ріб (Q РЄњ S) РѕД ((Рѕђx ┬и ┬гP) РЄњ S)
//   РЪ╣  H Ріб РЎбx ┬и (P РЄњ Q) РЄњ S
symbol NRM3 [H x P Q S]
  : РЂЄ (pnf x Q) Рєњ (H РіЕ (Q РЄњ S) РѕД ((Рѕђ x (┬г P)) РЄњ S))
  Рєњ (H РіЕ (РЎб x (P РЄњ Q)) РЄњ S);

// NRM4: x not free in Q; H Ріб (Q РЄњ РЎбx ┬и (P РЄњ R)) РЄњ S
//   РЪ╣  H Ріб РЎбx ┬и (P РЄњ (Q РЄњ R)) РЄњ S
symbol NRM4 [H x P Q R S]
  : РЂЄ (pnf x Q) Рєњ (H РіЕ (Q РЄњ РЎб x (P РЄњ R)) РЄњ S)
  Рєњ (H РіЕ (РЎб x (P РЄњ (Q РЄњ R))) РЄњ S);

// NRM5: H Ріб РЎбx ┬и (P РѕД Q РЄњ R) РЄњ S  РЪ╣  H Ріб РЎбx ┬и (P РЄњ (Q РЄњ R)) РЄњ S
symbol NRM5 [H x P Q R S]
  : (H РіЕ (РЎб x (P РѕД Q РЄњ R)) РЄњ S) Рєњ (H РіЕ (РЎб x (P РЄњ (Q РЄњ R))) РЄњ S);

// NRM6: H Ріб РЎбx ┬и (R РЄњ P) РЄњ (РЎбx ┬и (R РЄњ Q) РЄњ S)
//   РЪ╣  H Ріб РЎбx ┬и (R РЄњ P РѕД Q) РЄњ S
symbol NRM6 [H x P Q R S]
  : (H РіЕ (РЎб x (R РЄњ P)) РЄњ ((РЎб x (R РЄњ Q)) РЄњ S))
  Рєњ (H РіЕ (РЎб x (R РЄњ P РѕД Q)) РЄњ S);

// NRM7: H Ріб (РЎбx ┬и P) РЄњ ((РЎбx ┬и Q) РЄњ S)  РЪ╣  H Ріб РЎбx ┬и (P РѕД Q) РЄњ S
symbol NRM7 [H x P Q S]
  : (H РіЕ (РЎб x P) РЄњ ((РЎб x Q) РЄњ S))
  Рєњ (H РіЕ (РЎб x (P РѕД Q)) РЄњ S);

// NRM8: suppress quantifications under РЎб.
// Case 1: x, y distinct.
symbol NRM8 [H x y Q S]
  : РЂЄ (nf y (#prd (РЎб x (Рѕђ y Q))))  // x, y distinct
  Рєњ (H РіЕ (РЎб (x РеЙ y) Q) РЄњ S) Рєњ (H РіЕ (РЎб x (Рѕђ y Q)) РЄњ S);

// Case 2: x, y not distinct; z fresh; K = [y := z] Q.
symbol NRM8f [H x y z] [Q K : Prd] [S]
  : РЂЄ (psub y (#var z) Q == K)
  Рєњ (H РіЕ (РЎб (x РеЙ z) K) РЄњ S) Рєњ (H РіЕ (РЎб x (Рѕђ y Q)) РЄњ S);

// NRM9: suppress quantifications in implication under РЎб.
// Case 1: x, y distinct; y not free in P.
symbol NRM9 [H x y P Q S]
  : РЂЄ (nf y (#prd (РЎб x (P РЄњ Рѕђ y Q))))  // x, y distinct
  Рєњ РЂЄ (pnf y P)                          // y not free in P
  Рєњ (H РіЕ (РЎб (x РеЙ y) (P РЄњ Q)) РЄњ S)
  Рєњ (H РіЕ (РЎб x (P РЄњ Рѕђ y Q)) РЄњ S);

// Case 2: x, y not distinct or y free in P; z fresh; K = [y := z] Q.
symbol NRM9f [H x y z P] [Q K : Prd] [S]
  : РЂЄ (pnf z P and pnf z Q)  // z fresh
  Рєњ РЂЄ (psub y (#var z) Q == K)
  Рєњ (H РіЕ (РЎб (x РеЙ z) (P РЄњ K)) РЄњ S)
  Рєњ (H РіЕ (РЎб x (P РЄњ Рѕђ y Q)) РЄњ S);

// ---- second Рєњ third normalisation ----------------
// NRM10: H Ріб РЎАx ┬и ┬г(P РѕД Q) РЄњ R  РЪ╣  H Ріб РЎбx ┬и (P РѕД Q РЄњ FALSE) РЄњ R
symbol NRM10 [H x P Q R]
  : (H РіЕ (РЎА x (┬г (P РѕД Q))) РЄњ R)
  Рєњ (H РіЕ (РЎб x ((P РѕД Q) РЄњ FALSE)) РЄњ R);

// NRM11: H Ріб РЎАx ┬и ┬г(TRUE РѕД P) РЄњ R  РЪ╣  H Ріб РЎбx ┬и (P РЄњ FALSE) РЄњ R
symbol NRM11 [H x P R]
  : (H РіЕ (РЎА x (┬г (TRUE РѕД P))) РЄњ R)
  Рєњ (H РіЕ (РЎб x (P РЄњ FALSE)) РЄњ R);

// NRM12: H Ріб РЎАx ┬и ┬г(P РѕД Q) РЄњ R  РЪ╣  H Ріб РЎбx ┬и (P РЄњ ┬гQ) РЄњ R
symbol NRM12 [H x P Q R]
  : (H РіЕ (РЎА x (┬г (P РѕД Q))) РЄњ R)
  Рєњ (H РіЕ (РЎб x (P РЄњ ┬г Q)) РЄњ R);

// NRM13: H Ріб РЎАx ┬и ┬г(P РѕД ┬гQ) РЄњ R  РЪ╣  H Ріб РЎбx ┬и (P РЄњ Q) РЄњ R
symbol NRM13 [H x P Q R]
  : (H РіЕ (РЎА x (┬г (P РѕД ┬г Q))) РЄњ R)
  Рєњ (H РіЕ (РЎб x (P РЄњ Q)) РЄњ R);

// NRM14: H Ріб РЎАx ┬и ┬г(TRUE РѕД P) РЄњ R  РЪ╣  H Ріб (РЎбx ┬и ┬гP) РЄњ R
symbol NRM14 [H x P R]
  : (H РіЕ (РЎА x (┬г (TRUE РѕД P))) РЄњ R)
  Рєњ (H РіЕ (РЎб x (┬г P)) РЄњ R);

// NRM15: H Ріб РЎАx ┬и ┬г(TRUE РѕД ┬гP) РЄњ R  РЪ╣  H Ріб (РЎбx ┬и P) РЄњ R
symbol NRM15 [H x P R]
  : (H РіЕ (РЎА x (┬г (TRUE РѕД ┬г P))) РЄњ R)
  Рєњ (H РіЕ (РЎб x P) РЄњ R);

// NRM16: Рѕђx ┬и P is in H  РЪ╣  H Ріб (РЎАx ┬и P) РЄњ Q
symbol NRM16 [H x P Q]
  : РЂЄ (Рѕђ x P dans H) Рєњ (H РіЕ (РЎА x P) РЄњ Q);

// ---- contradictions on hypothesis promotion ----------------
// NRM17: Рѕђx ┬и ┬г(TRUE РѕД P) is in H; РѕЃE. [x := E] P = R
//   РЪ╣  H Ріб РЎАy ┬и ┬г(TRUE РѕД ┬гR) РЄњ Q
symbol NRM17 [H x y P R Q]
  : РЂЄ (Рѕђ x (┬г (TRUE РѕД P)) dans H)
  Рєњ (H РіЕ (РЎА y (┬г (TRUE РѕД ┬г R))) РЄњ Q);

// NRM18: Рѕђx ┬и ┬г(TRUE РѕД ┬гP) is in H; РѕЃE. [x := E] P = R
//   РЪ╣  H Ріб РЎАy ┬и ┬г(TRUE РѕД R) РЄњ Q
symbol NRM18 [H x y P R Q]
  : РЂЄ (Рѕђ x (┬г (TRUE РѕД ┬г P)) dans H)
  Рєњ (H РіЕ (РЎА y (┬г (TRUE РѕД R))) РЄњ Q);

// NRM19: P is in H; РѕЃE. [x := E] R = P  РЪ╣  H Ріб РЎАx ┬и ┬г(TRUE РѕД R) РЄњ Q
symbol NRM19 [H x P R Q]
  : РЂЄ (P dans H)
  Рєњ (H РіЕ (РЎА x (┬г (TRUE РѕД R))) РЄњ Q);

// ---- one-point rules (NRM20РђЊNRM24) ----------------
// NRM20: x not free in E; H Ріб РЎАy ┬и ┬г[x := E]P РЄњ Q
//   РЪ╣  H Ріб РЎА(x,y) ┬и ┬г(P РѕД x = E) РЄњ Q
symbol NRM20 [H x y E P Q]
  : РЂЄ (enf x E)
  Рєњ (H РіЕ (РЎА y (┬г (psub x E P))) РЄњ Q)
  Рєњ (H РіЕ (РЎА (x РеЙ y) (┬г (P РѕД (#var x = E)))) РЄњ Q);

// NRM21: x not free in E; H Ріб РЎАy ┬и ┬г[x := E]P РЄњ Q
//   РЪ╣  H Ріб РЎА(x,y) ┬и ┬г(P РѕД E = x) РЄњ Q
symbol NRM21 [H x y E P Q]
  : РЂЄ (enf x E)
  Рєњ (H РіЕ (РЎА y (┬г (psub x E P))) РЄњ Q)
  Рєњ (H РіЕ (РЎА (x РеЙ y) (┬г (P РѕД (E = #var x)))) РЄњ Q);

// NRM22: x not free in E; H Ріб ┬г[x := E]P РЄњ Q
//   РЪ╣  H Ріб РЎАx ┬и ┬г(P РѕД x = E) РЄњ Q
symbol NRM22 [H x E P Q]
  : РЂЄ (enf x E)
  Рєњ (H РіЕ ┬г (psub x E P) РЄњ Q)
  Рєњ (H РіЕ (РЎА x (┬г (P РѕД (#var x = E)))) РЄњ Q);

// NRM23: x not free in E; H Ріб ┬г[x := E]P РЄњ Q
//   РЪ╣  H Ріб РЎАx ┬и ┬г(P РѕД E = x) РЄњ Q
symbol NRM23 [H x E P Q]
  : РЂЄ (enf x E)
  Рєњ (H РіЕ ┬г (psub x E P) РЄњ Q)
  Рєњ (H РіЕ (РЎА x (┬г (P РѕД (E = #var x)))) РЄњ Q);

// NRM24: P is not of the form A РѕД B;
//   H Ріб РЎАx ┬и ┬г(TRUE РѕД P) РЄњ Q  РЪ╣  H Ріб РЎАx ┬и ┬гP РЄњ Q
symbol NRM24 [H x P Q]
  : (H РіЕ (РЎА x (┬г (TRUE РѕД P))) РЄњ Q)
  Рєњ (H РіЕ (РЎА x (┬г P)) РЄњ Q);

// NRM25: x not free in P; H Ріб P  РЪ╣  H Ріб РЎА(x) ┬и P
symbol NRM25 [H x P]
  : РЂЄ (pnf x P) Рєњ (H РіЕ P) Рєњ (H РіЕ РЎА x P);

// NRM26: y not free in P; H Ріб РЎА(x,...) ┬и P  РЪ╣  H Ріб РЎА(x,y,...) ┬и P
symbol NRM26 [H x y P]
  : РЂЄ (pnf y P) Рєњ (H РіЕ РЎА x P) Рєњ (H РіЕ РЎА (x РеЙ y) P);

// NRM27РђЊNRM30: arithmetic normalisation (use of solver to eliminate variables).
symbol NRM27 [H xs P R]
  : (H РіЕ R) Рєњ (H РіЕ РЎА xs P);

symbol NRM28 [H x P S R]
  : (H РіЕ ┬г S РЄњ R) Рєњ (H РіЕ (РЎА x (┬г P)) РЄњ R);

symbol NRM29 [H xs P S R]
  : (H РіЕ S РЄњ R) Рєњ (H РіЕ (РЎА xs (┬г P)) РЄњ R);

symbol NRM29_1 [H xs P S R]
  : (H РіЕ S РЄњ R) Рєњ (H РіЕ (РЎА xs (┬г P)) РЄњ R);

symbol NRM30 [H x P S R]
  : (H РіЕ ┬г S РЄњ R) Рєњ (H РіЕ (РЎА x (┬г P)) РЄњ R);

symbol NRM30_1 [H x P S R]
  : (H РіЕ ┬г S РЄњ R) Рєњ (H РіЕ (РЎА x (┬г P)) РЄњ R);

// ---- primed (result-producing) variants ----------------

// NRM1': Schema 1.
symbol NRM1' [H x P S]
  : РЂЄ (pnf x P)
  Рєњ Res (H РЪЮ P РЄњ S) Рєњ Res (H РЪЮ (РЎб x P) РЄњ S)
РЅћ ╬╗ _ ¤Ђ, result (obtain ¤Ђ);

symbol NRM2' [H x P Q S]
  : РЂЄ (pnf x P) Рєњ Res (H РЪЮ (P РЄњ РЎб x Q) РЄњ S) Рєњ Res (H РЪЮ (РЎб x (P РЄњ Q)) РЄњ S)
РЅћ ╬╗ _ ¤Ђ, result (obtain ¤Ђ);

symbol NRM3' [H x P Q S]
  : РЂЄ (pnf x Q) Рєњ Res (H РЪЮ (Q РЄњ S) РѕД ((Рѕђ x (┬г P)) РЄњ S))
  Рєњ Res (H РЪЮ (РЎб x (P РЄњ Q)) РЄњ S)
РЅћ ╬╗ _ ¤Ђ, result (obtain ¤Ђ);

symbol NRM4' [H x P Q R S]
  : РЂЄ (pnf x Q) Рєњ Res (H РЪЮ (Q РЄњ РЎб x (P РЄњ R)) РЄњ S)
  Рєњ Res (H РЪЮ (РЎб x (P РЄњ (Q РЄњ R))) РЄњ S)
РЅћ ╬╗ _ ¤Ђ, result (obtain ¤Ђ);

symbol NRM5' [H x P Q R S]
  : Res (H РЪЮ (РЎб x (P РѕД Q РЄњ R)) РЄњ S) Рєњ Res (H РЪЮ (РЎб x (P РЄњ (Q РЄњ R))) РЄњ S)
РЅћ ╬╗ ¤Ђ, result (obtain ¤Ђ);

symbol NRM6' [H x P Q R S]
  : Res (H РЪЮ (РЎб x (R РЄњ P)) РЄњ ((РЎб x (R РЄњ Q)) РЄњ S))
  Рєњ Res (H РЪЮ (РЎб x (R РЄњ P РѕД Q)) РЄњ S)
РЅћ ╬╗ ¤Ђ, result (obtain ¤Ђ);

symbol NRM7' [H x P Q S]
  : Res (H РЪЮ (РЎб x P) РЄњ ((РЎб x Q) РЄњ S))
  Рєњ Res (H РЪЮ (РЎб x (P РѕД Q)) РЄњ S)
РЅћ ╬╗ ¤Ђ, result (obtain ¤Ђ);

symbol NRM8' [H x y Q S]
  : РЂЄ (nf y (#prd (РЎб x (Рѕђ y Q))))
  Рєњ Res (H РЪЮ (РЎб (x РеЙ y) Q) РЄњ S) Рєњ Res (H РЪЮ (РЎб x (Рѕђ y Q)) РЄњ S)
РЅћ ╬╗ _ ¤Ђ, result (obtain ¤Ђ);

symbol NRM8f' [H x y z] [Q K : Prd] [S]
  : РЂЄ (psub y (#var z) Q == K)
  Рєњ Res (H РЪЮ (РЎб (x РеЙ z) K) РЄњ S) Рєњ Res (H РЪЮ (РЎб x (Рѕђ y Q)) РЄњ S)
РЅћ ╬╗ _ ¤Ђ, result (obtain ¤Ђ);

symbol NRM9' [H x y P Q S]
  : РЂЄ (nf y (#prd (РЎб x (P РЄњ Рѕђ y Q))))
  Рєњ РЂЄ (pnf y P)
  Рєњ Res (H РЪЮ (РЎб (x РеЙ y) (P РЄњ Q)) РЄњ S)
  Рєњ Res (H РЪЮ (РЎб x (P РЄњ Рѕђ y Q)) РЄњ S)
РЅћ ╬╗ _ _ ¤Ђ, result (obtain ¤Ђ);

symbol NRM9f' [H x y z P] [Q K : Prd] [S]
  : РЂЄ (pnf z P and pnf z Q)
  Рєњ РЂЄ (psub y (#var z) Q == K)
  Рєњ Res (H РЪЮ (РЎб (x РеЙ z) (P РЄњ K)) РЄњ S)
  Рєњ Res (H РЪЮ (РЎб x (P РЄњ Рѕђ y Q)) РЄњ S)
РЅћ ╬╗ _ _ ¤Ђ, result (obtain ¤Ђ);

symbol NRM10' [H x P Q R]
  : Res (H РЪЮ (РЎА x (┬г (P РѕД Q))) РЄњ R) Рєњ Res (H РЪЮ (РЎб x ((P РѕД Q) РЄњ FALSE)) РЄњ R)
РЅћ ╬╗ ¤Ђ, result (obtain ¤Ђ);

symbol NRM11' [H x P R]
  : Res (H РЪЮ (РЎА x (┬г (TRUE РѕД P))) РЄњ R) Рєњ Res (H РЪЮ (РЎб x (P РЄњ FALSE)) РЄњ R)
РЅћ ╬╗ ¤Ђ, result (obtain ¤Ђ);

symbol NRM12' [H x P Q R]
  : Res (H РЪЮ (РЎА x (┬г (P РѕД Q))) РЄњ R) Рєњ Res (H РЪЮ (РЎб x (P РЄњ ┬г Q)) РЄњ R)
РЅћ ╬╗ ¤Ђ, result (obtain ¤Ђ);

symbol NRM13' [H x P Q R]
  : Res (H РЪЮ (РЎА x (┬г (P РѕД ┬г Q))) РЄњ R) Рєњ Res (H РЪЮ (РЎб x (P РЄњ Q)) РЄњ R)
РЅћ ╬╗ ¤Ђ, result (obtain ¤Ђ);

symbol NRM14' [H x P R]
  : Res (H РЪЮ (РЎА x (┬г (TRUE РѕД P))) РЄњ R) Рєњ Res (H РЪЮ (РЎб x (┬г P)) РЄњ R)
РЅћ ╬╗ ¤Ђ, result (obtain ¤Ђ);

symbol NRM15' [H x P R]
  : Res (H РЪЮ (РЎА x (┬г (TRUE РѕД ┬г P))) РЄњ R) Рєњ Res (H РЪЮ (РЎб x P) РЄњ R)
РЅћ ╬╗ ¤Ђ, result (obtain ¤Ђ);

// NRM16': Schema 0.
symbol NRM16' [H x P Q]
  : РЂЄ (Рѕђ x P dans H) Рєњ Res (H РЪЮ (РЎА x P) РЄњ Q)
РЅћ ╬╗ _, result TRUE;

// NRM17': Schema 0.
symbol NRM17' [H x y P R Q]
  : РЂЄ (Рѕђ x (┬г (TRUE РѕД P)) dans H)
  Рєњ Res (H РЪЮ (РЎА y (┬г (TRUE РѕД ┬г R))) РЄњ Q)
РЅћ ╬╗ _, result TRUE;

// NRM18': Schema 0.
symbol NRM18' [H x y P R Q]
  : РЂЄ (Рѕђ x (┬г (TRUE РѕД ┬г P)) dans H)
  Рєњ Res (H РЪЮ (РЎА y (┬г (TRUE РѕД R))) РЄњ Q)
РЅћ ╬╗ _, result TRUE;

// NRM19': Schema 0.
symbol NRM19' [H x P R Q]
  : РЂЄ (P dans H)
  Рєњ Res (H РЪЮ (РЎА x (┬г (TRUE РѕД R))) РЄњ Q)
РЅћ ╬╗ _, result TRUE;

// NRM20': Schema 1.
symbol NRM20' [H x y E P Q]
  : РЂЄ (enf x E)
  Рєњ Res (H РЪЮ (РЎА y (┬г (psub x E P))) РЄњ Q)
  Рєњ Res (H РЪЮ (РЎА (x РеЙ y) (┬г (P РѕД (#var x = E)))) РЄњ Q)
РЅћ ╬╗ _ ¤Ђ, result (obtain ¤Ђ);

// NRM21': Schema 1.
symbol NRM21' [H x y E P Q]
  : РЂЄ (enf x E)
  Рєњ Res (H РЪЮ (РЎА y (┬г (psub x E P))) РЄњ Q)
  Рєњ Res (H РЪЮ (РЎА (x РеЙ y) (┬г (P РѕД (E = #var x)))) РЄњ Q)
РЅћ ╬╗ _ ¤Ђ, result (obtain ¤Ђ);

// NRM22': Schema 1.
symbol NRM22' [H x E P Q]
  : РЂЄ (enf x E)
  Рєњ Res (H РЪЮ ┬г (psub x E P) РЄњ Q)
  Рєњ Res (H РЪЮ (РЎА x (┬г (P РѕД (#var x = E)))) РЄњ Q)
РЅћ ╬╗ _ ¤Ђ, result (obtain ¤Ђ);

// NRM23': Schema 1.
symbol NRM23' [H x E P Q]
  : РЂЄ (enf x E)
  Рєњ Res (H РЪЮ ┬г (psub x E P) РЄњ Q)
  Рєњ Res (H РЪЮ (РЎА x (┬г (P РѕД (E = #var x)))) РЄњ Q)
РЅћ ╬╗ _ ¤Ђ, result (obtain ¤Ђ);

// NRM24': Schema 1.
symbol NRM24' [H x P Q]
  : Res (H РЪЮ (РЎА x (┬г (TRUE РѕД P))) РЄњ Q)
  Рєњ Res (H РЪЮ (РЎА x (┬г P)) РЄњ Q)
РЅћ ╬╗ ¤Ђ, result (obtain ¤Ђ);

// NRM25': Schema 1.
symbol NRM25' [H x P]
  : РЂЄ (pnf x P) Рєњ Res (H РЪЮ P) Рєњ Res (H РЪЮ РЎА x P)
РЅћ ╬╗ _ ¤Ђ, result (obtain ¤Ђ);

