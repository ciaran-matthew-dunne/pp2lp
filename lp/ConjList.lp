// ---- 2-element helpers ----
//
// PP's NRM/AXM/EQ rules whose shape is a binary `вИІ` become `вЛА (вИО вИЈ P вИЈ Q)`.
// `вЛАвВВ_intro` replaces `вИІбµҐ`, `вЛАвВВ_hd` replaces `вИІвВСвВБ`, `вЛАвВВ_snd` replaces `вИІвВСвВВ`.
// All three are pure snoc-list surgery вАФ no singleton collapse needed:
// `вЛАвВВ_hd` peels Q off with вЛА_init, then P off the remainder with вЛА_last.

opaque symbol вЛАвВВ_intro [P Q : Prop]
  : ѕА P вЖТ ѕА Q вЖТ ѕА (вЛА (вИО вИЈ P вИЈ Q)) вЙФ
begin
  assume P Q hP hQ;
  refine вЛА_intro (вЛА_intro вЛА_nil_prf hP) hQ
end;

opaque symbol вЛАвВВ_hd [P Q : Prop]
  : ѕА (вЛА (вИО вИЈ P вИЈ Q)) вЖТ ѕА P вЙФ
begin
  assume P Q h;
  refine вЛА_init h           // вЛА_init h : ѕА (вЛА (вИО вИЈ P)) вЙ° ѕА P (singleton collapse)
end;

opaque symbol вЛАвВВ_snd [P Q : Prop]
  : ѕА (вЛА (вИО вИЈ P вИЈ Q)) вЖТ ѕА Q вЙФ
begin
  assume P Q h;
  refine вЛА_last h
end;
