// ConjList.lp Рђћ Abstract n-ary conjunction РІђ over ­ЮЋЃ o

require open Stdlib.Set Stdlib.Prop Stdlib.Eq
            Stdlib.List Stdlib.Impred;

injective symbol РІђ : ­ЮЋЃ o Рєњ Prop;

notation РІђ prefix 30;

// ---- init/last decomposition (proposition-level) ----

// РІђ_init_list : list-level init (all but last)
symbol РІђ_init_list : ­ЮЋЃ o Рєњ ­ЮЋЃ o;
rule РІђ_init_list (_ РИг РќА) Рєф РќА
with РІђ_init_list ($x РИг $y РИг $rest) Рєф $x РИг РІђ_init_list ($y РИг $rest);

// РІђ_init : proposition-level init Рђћ collapses singletons
symbol РІђ_init : ¤ё o Рєњ ¤ё o;
rule РІђ_init (РІђ ($x РИг $y РИг РќА)) Рєф $x;
rule РІђ_init (РІђ ($x РИг $y РИг $z РИг $rest))
  Рєф РІђ ($x РИг РІђ_init_list ($y РИг $z РИг $rest));

// РІђ_last : proposition-level last Рђћ walks the list to its tail
// without going through stdlib `last`.  Mirrors РІђ_init's case
// split: singleton returns the only element, longer recurses.
symbol РІђ_last : ¤ё o Рєњ ¤ё o;
rule РІђ_last (РІђ ($x РИг РќА)) Рєф $x;
rule РІђ_last (РІђ ($x РИг $y РИг $rest))
  Рєф РІђ_last (РІђ ($y РИг $rest));

// РІђ_join: combines the `last` and `init` Res-terms produced by
// AND4_1 into a single binary `РѕД`.  Argument order is (last, init)
// to match what `РІђ_split` + `РѕД_com` give in the AND4_1 equality
// proof Рђћ keeping res_tm shape stable preserves the
// (P, Q) order downstream NRM6/NRM7 etc. depend on.
symbol РІђ_join : ¤ё o Рєњ ¤ё o Рєњ ¤ё o;
rule РІђ_join $last $init Рєф $last РѕД $init;

// ---- Eliminators for init/last decomposition ----

symbol РІђ_front [ps : ­ЮЋЃ o] : ¤ђ (РІђ ps) Рєњ ¤ђ (РІђ_init (РІђ ps));
symbol РІђ_back  [ps : ­ЮЋЃ o] : ¤ђ (РІђ ps) Рєњ ¤ђ (РІђ_last (РІђ ps));
symbol РІђ_rejoin [ps : ­ЮЋЃ o] : ¤ђ (РІђ_init (РІђ ps)) Рєњ ¤ђ (РІђ_last (РІђ ps)) Рєњ ¤ђ (РІђ ps);

// ---- Split equality: РІђ ps = РІђ_init(РІђ ps) РѕД РІђ_last(РІђ ps) ----

symbol РІђ_split [ps : ­ЮЋЃ o]
  : ¤ђ (РІђ ps = (РІђ_init (РІђ ps) РѕД РІђ_last (РІђ ps)));

// ---- Equalities (apply via `rewrite` in rule proofs) ----

symbol РІђ_nil  : ¤ђ (РІђ РќА = Ріц);
symbol РІђ_one  (P : Prop) : ¤ђ (РІђ (P РИг РќА) = P);
symbol РІђ_cons (P : Prop) (rest : ­ЮЋЃ o)
  : ¤ђ (РІђ (P РИг rest) = (P РѕД РІђ rest));

// ---- Derived equalities ----

opaque symbol РІђ_bin (P Q : Prop)
  : ¤ђ (РІђ (P РИг Q РИг РќА) = (P РѕД Q)) РЅћ
begin
  assume P Q;
  rewrite РІђ_cons P (Q РИг РќА);
  rewrite РІђ_one Q;
  reflexivity
end;

// ---- Eliminators / introduction ----

symbol РІђ_hd (P : Prop) (rest : ­ЮЋЃ o)
  : ¤ђ (РІђ (P РИг rest)) Рєњ ¤ђ P;
symbol РІђ_tl (P : Prop) (rest : ­ЮЋЃ o)
  : ¤ђ (РІђ (P РИг rest)) Рєњ ¤ђ (РІђ rest);
symbol РІђ_intro (P : Prop) (rest : ­ЮЋЃ o)
  : ¤ђ P Рєњ ¤ђ (РІђ rest) Рєњ ¤ђ (РІђ (P РИг rest));

// ---- Nil proof (base case for РІђ_intro chains) ----

opaque symbol РІђ_nil_prf : ¤ђ (РІђ РќА) РЅћ
begin
  rewrite РІђ_nil;
  refine Ріцрхб
end;
