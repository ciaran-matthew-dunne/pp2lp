// ConjList.lp вАФ n-ary conjunction вЛА over a snoc list рЭХГ*.
//
// PP treats вИІ as left-associative, so the *last* conjunct is the most
// recently added вАФ i.e. the outer constructor of a snoc list.  That makes
// PP's AND rules a single structural match on `ps вИЈ P`:
//
//     init = вЛА ps     last = P
//
// A conjunction is *always* `вЛА <list>`, never a native `вИІ`.  The four
// eliminators below are the complete (trusted) axiomatisation вАФ no `вИІ`,
// no `вК§`, nothing to rewrite at any use site, so the singleton
// (`вЛА (вИО вИЈ P) = P`) and nil (`вЛА вИО = вК§`) collapses never arise.

require open pp2lp.B;

// snoc-based list: grows on the right (вИЈ), empty tail is вИО.
(a : Set) inductive рЭХГ* : TYPE вЙФ
  | вИО : рЭХГ* a
  | вИЈ : рЭХГ* a вЖТ ѕД a вЖТ рЭХГ* a;
notation вИЈ infix left 5;


symbol list* : Set вЖТ Set;
rule ѕД (list* $a) вЖ™ рЭХГ* $a;

symbol ite [a] : рЭФє вЖТ ѕД a вЖТ ѕД a вЖТ ѕД a;
rule ite true $x _  вЖ™ $x
with ite false _ $y вЖ™ $y;

symbol is_nil [a] : рЭХГ* a вЖТ рЭФє;
rule is_nil вИО       вЖ™ true
with is_nil (_ вИЈ _) вЖ™ false;

symbol concat [a] : рЭХГ* a вЖТ рЭХГ* a вЖТ рЭХГ* a;
rule concat $xs вИО вЖ™ $xs
with concat вИО $ys вЖ™ $ys
with concat $xs ($ys вИЈ $y) вЖ™ (concat $xs $ys) вИЈ $y;

symbol dropl [a] : рЭХГ* a вЖТ рЭХГ* a;
rule dropl вИО          вЖ™ вИО
with dropl ($xs вИЈ $x) вЖ™ ite (is_nil $xs) вИО ((dropl $xs) вИЈ $x);

symbol popl [a] : рЭХГ* a вЖТ ѕД a;
rule popl ($xs вИЈ $x) вЖ™ ite (is_nil $xs) $x (popl $xs);

symbol pushl [a] : ѕД a вЖТ рЭХГ* a вЖТ рЭХГ* a;
rule pushl $x вИО вЖ™ (вИО вИЈ $x)
with pushl $x ($ys вИЈ $y) вЖ™ (pushl $x $ys) вИЈ $y;

// n-ary conjunction.
injective symbol вЛА : рЭХГ* o вЖТ Prop;
notation вЛА prefix 30;
rule вЛА (вИО вИЈ $p) вЖ™ $p;

// TODO. make non-sequential.
sequential symbol вЛА_snoc : Prop вЖТ Prop вЖТ Prop;
rule вЛА_snoc (вЛА $ps) $p вЖ™ вЛА ($ps вИЈ $p)
with вЛА_snoc $p $q вЖ™ вЛА (вИО вИЈ $p вИЈ $q);

symbol conj : рЭХГ* o вЖТ ѕД o;
rule conj вИО вЖ™ вК§
with conj ($p вИЈ $q) вЖ™ ite (is_nil $p) ($q) (вЛА ($p вИЈ $q));

injective symbol Res : ѕД o вЖТ TYPE;
symbol mk_res [t] (ts : рЭХГ* o) : ѕА (t = conj ts) вЖТ Res t;
symbol res_ts [t] (r : Res t) : рЭХГ* o;
symbol res_eq [t] (r : Res t) : ѕА (t = conj (res_ts r));
rule res_ts (mk_res $ts _)  вЖ™ $ts;
rule res_eq (mk_res _ $prf) вЖ™ $prf;

// Defined (not a pattern rule) so `res_tm r вЙ° conj (res_ts r)` holds for a
// *variable* r too вАФ passthrough `_1` rules rely on this conversion.
symbol res_tm [t] (r : Res t) : ѕД o вЙФ conj (res_ts r);

// Singleton constructor вАФ same signature as the old single-term `mk_1`,
// so every schema-0/1 (leaf / passthrough / single-result) `_1` rule keeps
// working verbatim: `conj (вИО вИЈ x) вЙ° x`, so `prf : ѕА (t = x)` still fits.
// Only schema-2 combines build a real list (via `concat` + `mk_res`).
symbol mk_1 [t] (x : ѕД o) (prf : ѕА (t = x)) : Res t вЙФ mk_res (вИО вИЈ x) prf;


// ---- Axiomatisation: structural intro / eliminators ----
//
// `вЛА_init`/`вЛА_last` peel the snoc list one conjunct at a time and
// `вЛА_intro` grows it; `вЛА_nil_prf` is the empty conjunction.

symbol вЛА_nil_prf : ѕА (вЛА вИО);
symbol вЛА_intro [ps : рЭХГ* o] [P : Prop] : ѕА (вЛА ps) вЖТ ѕА P вЖТ ѕА (вЛА (ps вИЈ P));
symbol вЛА_init  [ps : рЭХГ* o] [P : Prop] : ѕА (вЛА (ps вИЈ P)) вЖТ ѕА (вЛА ps);
symbol вЛА_last  [ps : рЭХГ* o] [P : Prop] : ѕА (вЛА (ps вИЈ P)) вЖТ ѕА P;

// Head-intro: re-add a conjunct at the FRONT (`pushl` end).  The structural
// eliminators above only touch the *last* conjunct, but PP's left-associative
// вИІ puts the most significant conjunct (e.g. NRM20's `x = E`) *first* вАФ at the
// head of the snoc list.  Derived from `вЛА_intro`/`вЛА_init`/`вЛА_last` by induction,
// so it applies to an abstract `ls` where `pushl` is stuck.
opaque symbol вЛА_push_front (P : Prop)
  : ќ† ls : рЭХГ* o, ѕА P вЖТ ѕА (вЛА ls) вЖТ ѕА (вЛА (pushl P ls)) вЙФ
begin
  assume P;
  induction
  { assume hP hnil; refine hP }
  { assume ls' ih y hP hc;  // induction binds the IH *before* the element
    refine вЛА_intro (ih hP (вЛА_init hc)) (вЛА_last hc) }
end;

// ---- Result-chain combinators ----
//
// `conj` of a snoc decomposes into init-conj вИІ last; `concat` of two
// conjunct lists is the вИІ of their conjs.  `conj_concat_eq` is the
// equality the schema-2 `_1` rules use to combine two children's lists.

symbol conj_snoc (qs : рЭХГ* o) (y : Prop)
  : ѕА (conj (qs вИЈ y) = (conj qs вИІ y));
//begin
//  induction
//  { assume y; refine eq_sym (вК§вИІ y) }
//  { assume qs' q _ih y;
//    refine propExt _ _ _ _
//    { assume h; refine вИІбµҐ (вЛА_init h) (вЛА_last h) }
//    { assume h; refine вЛА_intro (вИІвВСвВБ h) (вИІвВСвВВ h) } }
//end;

symbol conj_concat_eq (l1 l2 : рЭХГ* o)
  : ѕА ((conj l1 вИІ conj l2) = conj (concat l1 l2));
//begin
//  assume l1;
//  induction
//  { refine вИІвК§ (conj l1) }
//  { assume l2' ih y;
//    have hL : ѕА (conj (l2' вИЈ y) = (conj l2' вИІ y)) { refine conj_snoc l2' y };
//    have hR : ѕА (conj (concat l1 (l2' вИЈ y)) = (conj (concat l1 l2') вИІ y))
//      { refine conj_snoc (concat l1 l2') y };
