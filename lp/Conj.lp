require open pp2lp.B pp2lp.Eq pp2lp.Interp;

// induction principle on hyp-lists (moved from PP.lp)
symbol Hyp_ind (M : Hyp тЖТ Prop)
  : ╧А (M тж│)
  тЖТ (╬а H, ╧А (M H) тЖТ ╬а Q, ╧А (M (H тИ╖ Q)))
  тЖТ ╬а H, ╧А (M H) тЙФ
begin
  assume M base step;
  induction
  { refine base }
  { assume H ih Q; refine step H ih Q }
end;

// soundness of conjunction containment check.
symbol contient_sound [N C]
  : тБЗ (N contient C) тЖТ (╧А (sat vnil C) тЖТ ╧А (sat vnil N));

// soundness of conjunction removal.
symbol retirer_sound [N C]
  : тБЗ (N contient C) тЖТ (╧А (sat vnil C) тЖТ ╧А (sat vnil (retirer N C)));


// ---- conjunction (spec ┬зA.1) ----------------
opaque symbol AND1 [H P Q R]
  : (H тКй ┬м Q тЗТ R) тЖТ (H тКй ┬м P тЗТ R) тЖТ (H тКй ┬м (P тИз Q) тЗТ R) тЙФ
begin
  assume H P Q R; simplify;
  assume one two h npq;
  apply тИитВС (em (sat vnil P))
  { assume hp; refine one h (╬╗ hq, npq (тИзс╡в hp hq)) }
  { assume hnp; refine two h hnp }
end;

opaque symbol AND2 [H P Q]
  : (H тКй P тЗТ ┬м Q) тЖТ (H тКй ┬м (P тИз Q)) тЙФ
begin
  assume H P Q; simplify;
  assume one h pq;
  refine one h (тИзтВСтВБ pq) (тИзтВСтВВ pq)
end;

opaque symbol AND3 [H P Q R]
  : (H тКй P тЗТ (Q тЗТ R)) тЖТ (H тКй (P тИз Q) тЗТ R) тЙФ
begin
  assume H P Q R; simplify;
  assume one h pq;
  refine one h (тИзтВСтВБ pq) (тИзтВСтВВ pq)
end;


opaque symbol AND4 [H P Q]
  : (H тКй Q) тЖТ (H тКй P) тЖТ (H тКй P тИз Q) тЙФ
begin
  assume H P Q; simplify;
  assume one two h;
  refine тИзс╡в (two h) (one h)
end;

// AND5 тАФ to be implemented.
// AND5 | P тИз ┬╖┬╖┬╖ contains A; H тКв P тИз ┬╖┬╖┬╖ тИз B тИз ┬╖┬╖┬╖ тЗТ R | H тКв P тИз ┬╖┬╖┬╖ тИз (A тЗТ B) тИз ┬╖┬╖┬╖ тЗТ R

// ---- primed (result-producing) variants ----------------

// AND1': two antecedents тЖТ Schema 2.
symbol AND1' [H P Q R]
  : Res (H тЯЭ ┬м Q тЗТ R) тЖТ Res (H тЯЭ ┬м P тЗТ R) тЖТ Res (H тЯЭ ┬м (P тИз Q) тЗТ R)
тЙФ ╬╗ ╧БтВБ ╧БтВВ, result (obtain ╧БтВБ тИз obtain ╧БтВВ);

// AND2': one antecedent тЖТ Schema 1.
symbol AND2' [H P Q]
  : Res (H тЯЭ P тЗТ ┬м Q) тЖТ Res (H тЯЭ ┬м (P тИз Q))
тЙФ ╬╗ ╧Б, result (obtain ╧Б);

// AND3': one antecedent тЖТ Schema 1.
symbol AND3' [H P Q R]
  : Res (H тЯЭ P тЗТ (Q тЗТ R)) тЖТ Res (H тЯЭ (P тИз Q) тЗТ R)
тЙФ ╬╗ ╧Б, result (obtain ╧Б);

// AND4': two antecedents тЖТ Schema 2.
symbol AND4' [H P Q]
  : Res (H тЯЭ Q) тЖТ Res (H тЯЭ P) тЖТ Res (H тЯЭ P тИз Q)
тЙФ ╬╗ ╧БтВБ ╧БтВВ, result (obtain ╧БтВБ тИз obtain ╧БтВВ);

// AND5': Schema 1.
symbol AND5' [H P Q A B R]
  : тБЗ ((P тИз Q) contient (A тЗТ B))
  тЖТ тБЗ (retirer (A тЗТ B) (P тИз Q) contient A)
  тЖТ Res (H тЯЭ retirer (A тЗТ B) (P тИз Q) тИз B тЗТ R)
  тЖТ Res (H тЯЭ (P тИз Q) тЗТ R)
тЙФ ╬╗ _ _ ╧Б, result (obtain ╧Б);
