// Tuple-based n-ary quantifier machinery тАФ foundations.
//
// `!!` and `??` are n-ary universal/existential quantifiers
// indexed by a Tuple n. The substantive rules (ALL4, ALL5, ALL7,
// XST5, XST7, XST8, тАж) live in lp/rules/All.lp and lp/rules/Xst.lp;
// this file only exposes the kernel needed to state and use them.
//
//   Tuple n        : an n-tuple of ╧Д ╬╣ values
//   prj k v        : k-th projection (counts from the right;
//                    prj 0 v is the most recently appended element,
//                    which corresponds to the *outermost* `!!` binder)
//   `!! v : Tuple n, P v
//                  : `тИА x_1 ... тИА x_n, P (unit ти╛ x_1 ти╛ тАж ти╛ x_n)`
//                    declared `quantifier`, so the standard sugar
//                    works:  `!! v, body`  тЙб  `!! (╬╗ v, body)`
//   `?? v : Tuple n, P v
//                  : analogous, with тИГ at every layer.
//
// Bridges:
//   pi_to_!!  : (╬а v, ╧А (P v))         тЖТ ╧А (`!! v, P v)   тАФ intro
//   !!_to_pi  : ╧А (`!! v, P v)         тЖТ ╬а v, ╧А (P v)     тАФ elim
//   pi_to_??_intro : ╬а v, ╧А (P v) тЖТ ╧А (`?? v, P v)        тАФ intro
//   pi_to_??_elim  : (╬а v, ╧А (P v) тЖТ ╧А R) тЖТ ╧А (`?? v, P v) тЖТ ╧А R
//                                                          тАФ elim
require open pp2lp.B ;

// ---- Tuple ------------------------------------------------------

inductive Tuple : тДХ тЖТ TYPE тЙФ
  | unit : Tuple 0
  | ти╛ [n] : Tuple n тЖТ ╧Д ╬╣ тЖТ Tuple (+1 n);
notation ти╛ infix left 5;
//type ind_Tuple;
// k-th projection. prj 0 picks the rightmost (most recently
// appended) element.
symbol prj [n] (k : тДХ) (_ : Tuple n) : ╧Д ╬╣;
rule prj (+1 $n) ($t ти╛ _) тЖк prj $n $t
with prj 0       (_ ти╛ $x) тЖк $x;

// Canonical inhabitant of `Tuple n` тАФ every slot filled with `inh`.
// Used when a rule needs a witness tuple but its predicate is
// independent of the tuple's contents.
symbol inh_tuple [n] : Tuple n;
rule inh_tuple [0] тЖк unit
with inh_tuple [+1 $n] тЖк inh_tuple [$n] ти╛ inh;

// ---- Tuple split: `++`, take, drop --------------------------------
// Custom natural-number addition that recurses on the LEFT, unlike
// Stdlib.Nat.+ which only reduces when the right arg is `+1 _`. This
// lets `Tuple ((+1 n) ++ m)` reduce to `Tuple (+1 (n ++ m))` so its
// inhabitants are recognisable as tuple constructors `(_ ти╛ _)`.
symbol ++ : тДХ тЖТ тДХ тЖТ тДХ; notation ++ infix 5;
rule 0 ++ $m тЖк $m
with +1 $n ++ $m тЖк +1 ($n ++ $m);

// `take [n] [m]` extracts the leftmost n elements of a (n+m)-tuple.
// `drop [n] [m]` extracts the rightmost m elements (what remains).
// Convention: in `(unit ти╛ x_1 ти╛ тАж ти╛ x_n ти╛ y_1 ти╛ тАж ти╛ y_m)`, take returns
// `(unit ти╛ x_1 ти╛ тАж ти╛ x_n)` and drop returns `(unit ти╛ y_1 ти╛ тАж ти╛ y_m)`.
// Concretely, drop strips the rightmost m elements first; take returns
// what's left after recursively peeling.
//
// Compared to inh-based subtraction: avoids needing `(n + m) - n = m`
// to be definitional (which it isn't for abstract n, m). Indices are
// kept explicit so call sites can name them and the rules fire.
symbol take [n m] (v : Tuple (n ++ m)) : Tuple n;
symbol drop [n m] (v : Tuple (n ++ m)) : Tuple m;
rule drop [0]      [_]  $v        тЖк $v
with drop [+1 $n] [$m] ($v ти╛ _)   тЖк drop [$n] [$m] $v
with take [0]      [_]  _         тЖк unit
with take [+1 $n] [$m] ($v ти╛ $x)  тЖк take [$n] [$m] $v ти╛ $x;

// `prj` commutes through `take`/`drop` even when `v` is abstract (the
// rules above only fire on a concrete `_ ти╛ _`).  `take` keeps the low
// (rightmost) indices unchanged; `drop` keeps the leftmost m, shifted up
// by n.  This lets an NRM8/9-split compound binder's body project exactly
// as a flat `Tuple (n ++ m)` would тАФ `prj k v` тАФ so emitter renderings
// over the bound tuple need no take/drop awareness.
rule prj $k (take [$n] [$m] $v) тЖк prj $k $v
with prj $k (drop [$n] [$m] $v) тЖк prj ($n ++ $k) $v;

// ---- `!!` n-ary universal --------------------------------------

// Kept *rigid* (no reduction rules). If `!!` reduced eagerly to
// nested тИА, the surface form would vanish from goals before any
// tactic could see it тАФ and implicit-arg inference of `n` and `P`
// at call sites would need to invert the reduction (higher-order
// unification across rewriting), which Lambdapi can't.
constant symbol !! [n] : (Tuple n тЖТ Prop) тЖТ Prop;
notation !! quantifier;

constant symbol pi_to_!! [n] (P : Tuple n тЖТ Prop)
  : (╬а v : Tuple n, ╧А (P v)) тЖТ ╧А (`!! v, P v);

constant symbol !!_to_pi [n] (P : Tuple n тЖТ Prop)
  : ╧А (`!! v, P v) тЖТ ╬а v : Tuple n, ╧А (P v);

// ---- `??` n-ary existential ------------------------------------
//
// Kept *rigid* like `!!`. Earlier we let `??` reduce to nested тИГ,
// but that broke implicit-P inference at sites like XST7_1's body
// (HO-unification can't invert the reduction). Bridges are
// axiomatised below.

constant symbol ?? [n] : (Tuple n тЖТ Prop) тЖТ Prop;
notation ?? quantifier;

constant symbol pi_to_??_intro [n] (P : Tuple n тЖТ Prop)
  : ╬а v : Tuple n, ╧А (P v) тЖТ ╧А (`?? v, P v);

constant symbol pi_to_??_elim [n] (P : Tuple n тЖТ Prop) [R : Prop]
  : (╬а v : Tuple n, ╧А (P v) тЖТ ╧А R) тЖТ ╧А (`?? v, P v) тЖТ ╧А R;

// ---- Common derived lemmas -------------------------------------

// Pointwise equality lifts to `!!` equality.
opaque symbol !!_cong [n] [P R : Tuple n тЖТ Prop]
  : (╬а v : Tuple n, ╧А (P v = R v))
  тЖТ ╧А ((`!! v, P v) = (`!! v, R v)) тЙФ
begin
  assume n P R h;
  refine propExt _ _ _ _
  { assume hP; refine pi_to_!! R (╬╗ v, =тЗТ (h v) (!!_to_pi P hP v)) }
  { assume hR; refine pi_to_!! P (╬╗ v, =тЗТ (eq_sym (h v)) (!!_to_pi R hR v)) }
end;

// Pointwise equality lifts to `??` equality.
opaque symbol ??_cong [n] [P R : Tuple n тЖТ Prop]
  : (╬а v : Tuple n, ╧А (P v = R v))
  тЖТ ╧А ((`?? v, P v) = (`?? v, R v)) тЙФ
begin
  assume n P R h;
  refine propExt _ _ _ _
  { assume hP; refine pi_to_??_elim P
      (╬╗ v hPv, pi_to_??_intro R v (=тЗТ (h v) hPv)) hP }
  { assume hR; refine pi_to_??_elim R
      (╬╗ v hRv, pi_to_??_intro P v (=тЗТ (eq_sym (h v)) hRv)) hR }
end;

// `!!_const`: drop a constant `!!`-binder. Tuple-n analogue of
// Stdlib.PropExt's `тИА_const`. Both directions go through `inh_tuple`.
opaque symbol !!_const [n] (P : Prop)
  : ╧А ((`!! _ : Tuple n, P) = P) тЙФ
begin
  assume n P;
  refine propExt _ _ _ _
  { assume h; refine !!_to_pi (╬╗ _ : Tuple n, P) h (inh_tuple [n]) }
  { assume h; refine pi_to_!! (╬╗ _ : Tuple n, P) (╬╗ _, h) }
end;

// ---- тЩв / тЩб : PP normalisation quantifiers ----------------------
//
// Spec uses `тЩв` (= ASCII `forall`) for goal-side n-ary universals and
// `тЩб` (= ASCII `forall2`) for hypothesis-side ones. Semantically both
// are nested тИА тАФ they only carry a proof-search role.
//
// Kept *rigid* (constant, no rewrite rules) for the same reason `!!`
// is rigid. The reduction to `!!` is axiomatised: `pi_to_тЩв` /
// `тЩв_to_pi` are the per-tuple bridges; `тЩв_eq_!!` follows from
// `propExt`. NRM rules state their types in spec notation; bodies use
// the dedicated bridges or transport via `тЩв_eq_!!` where helpers are
// `!!`-typed.

symbol тЩв [n] : (Tuple n тЖТ Prop) тЖТ Prop тЙФ !!;
notation тЩв quantifier;

constant symbol pi_to_тЩв [n] (P : Tuple n тЖТ Prop)
  : (╬а v : Tuple n, ╧А (P v)) тЖТ ╧А (`тЩв v, P v);

constant symbol тЩв_to_pi [n] (P : Tuple n тЖТ Prop)
  : ╧А (`тЩв v, P v) тЖТ ╬а v : Tuple n, ╧А (P v);

symbol тЩб [n] : (Tuple n тЖТ Prop) тЖТ Prop тЙФ !!;
notation тЩб quantifier;

constant symbol pi_to_тЩб [n] (P : Tuple n тЖТ Prop)
  : (╬а v : Tuple n, ╧А (P v)) тЖТ ╧А (`тЩб v, P v);

constant symbol тЩб_to_pi [n] (P : Tuple n тЖТ Prop)
  : ╧А (`тЩб v, P v) тЖТ ╬а v : Tuple n, ╧А (P v);

// Both тЩв and тЩб are propositionally equal to `!!` тАФ derived from the
// bridges via `propExt`.
opaque symbol тЩв_eq_!! [n] (P : Tuple n тЖТ Prop)
  : ╧А ((`тЩв v, P v) = (`!! v, P v)) тЙФ
begin
  assume n P;
  refine propExt _ _ _ _
  { assume h; refine pi_to_!! P (тЩв_to_pi P h) }
  { assume h; refine pi_to_тЩв P (!!_to_pi P h) }
end;

opaque symbol тЩб_eq_!! [n] (P : Tuple n тЖТ Prop)
  : ╧А ((`тЩб v, P v) = (`!! v, P v)) тЙФ
begin
  assume n P;
  refine propExt _ _ _ _
  { assume h; refine pi_to_!! P (тЩб_to_pi P h) }
  { assume h; refine pi_to_тЩб P (!!_to_pi P h) }
end;



// ---- Res: ╬г-type for normalisation chains ----------------------
// `Res t = (t' : ╧Д a) ├Ч ╧А (t = t')` packages a normalised term with
// a proof of equality to the original. Lives here (not in Res.lp)
// because the result-based ALL7/XST8 in All.lp/Xst.lp need it.
//
