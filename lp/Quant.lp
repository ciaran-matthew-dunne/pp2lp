// Tuple-based n-ary quantifier machinery Рђћ foundations.
//
// `!!` and `??` are n-ary universal/existential quantifiers
// indexed by a Tuple n. The substantive rules (ALL4, ALL5, ALL7,
// XST5, XST7, XST8, Рђд) live in lp/rules/All.lp and lp/rules/Xst.lp;
// this file only exposes the kernel needed to state and use them.
//
//   Tuple n        : an n-tuple of ¤ё ╬╣ values
//   prj k v        : k-th projection (counts from the right;
//                    prj 0 v is the most recently appended element,
//                    which corresponds to the *outermost* `!!` binder)
//   `!! v : Tuple n, P v
//                  : `Рѕђ x_1 ... Рѕђ x_n, P (unit РеЙ x_1 РеЙ Рђд РеЙ x_n)`
//                    declared `quantifier`, so the standard sugar
//                    works:  `!! v, body`  РЅА  `!! (╬╗ v, body)`
//   `?? v : Tuple n, P v
//                  : analogous, with РѕЃ at every layer.
//
// Bridges:
//   pi_to_!!  : (╬а v, ¤ђ (P v))         Рєњ ¤ђ (`!! v, P v)   Рђћ intro
//   !!_to_pi  : ¤ђ (`!! v, P v)         Рєњ ╬а v, ¤ђ (P v)     Рђћ elim
//   pi_to_??_intro : ╬а v, ¤ђ (P v) Рєњ ¤ђ (`?? v, P v)        Рђћ intro
//   pi_to_??_elim  : (╬а v, ¤ђ (P v) Рєњ ¤ђ R) Рєњ ¤ђ (`?? v, P v) Рєњ ¤ђ R
//                                                          Рђћ elim
require open pp2lp.B;

// ---- Tuple ------------------------------------------------------

inductive Tuple : РёЋ Рєњ TYPE РЅћ
  | unit : Tuple 0
  | РеЙ [n] : Tuple n Рєњ ¤ё ╬╣ Рєњ Tuple (+1 n);
notation РеЙ infix left 5;
//type ind_Tuple;
// k-th projection. prj 0 picks the rightmost (most recently
// appended) element.
symbol prj [n] (k : РёЋ) (_ : Tuple n) : ¤ё ╬╣;
rule prj (+1 $n) ($t РеЙ _) Рєф prj $n $t
with prj 0       (_ РеЙ $x) Рєф $x;

// Canonical inhabitant of `Tuple n` Рђћ every slot filled with `inh`.
// Used when a rule needs a witness tuple but its predicate is
// independent of the tuple's contents.
symbol inh_tuple [n] : Tuple n;
rule inh_tuple [0] Рєф unit
with inh_tuple [+1 $n] Рєф inh_tuple [$n] РеЙ inh;

// ---- Tuple split: `++`, take, drop --------------------------------
// Custom natural-number addition that recurses on the LEFT, unlike
// Stdlib.Nat.+ which only reduces when the right arg is `+1 _`. This
// lets `Tuple ((+1 n) ++ m)` reduce to `Tuple (+1 (n ++ m))` so its
// inhabitants are recognisable as tuple constructors `(_ РеЙ _)`.
symbol ++ : РёЋ Рєњ РёЋ Рєњ РёЋ; notation ++ infix 5;
rule 0 ++ $m Рєф $m
with +1 $n ++ $m Рєф +1 ($n ++ $m);

// `take [n] [m]` extracts the leftmost n elements of a (n+m)-tuple.
// `drop [n] [m]` extracts the rightmost m elements (what remains).
// Convention: in `(unit РеЙ x_1 РеЙ Рђд РеЙ x_n РеЙ y_1 РеЙ Рђд РеЙ y_m)`, take returns
// `(unit РеЙ x_1 РеЙ Рђд РеЙ x_n)` and drop returns `(unit РеЙ y_1 РеЙ Рђд РеЙ y_m)`.
// Concretely, drop strips the rightmost m elements first; take returns
// what's left after recursively peeling.
//
// Compared to inh-based subtraction: avoids needing `(n + m) - n = m`
// to be definitional (which it isn't for abstract n, m). Indices are
// kept explicit so call sites can name them and the rules fire.
symbol take [n m] (v : Tuple (n ++ m)) : Tuple n;
symbol drop [n m] (v : Tuple (n ++ m)) : Tuple m;
rule drop [0]      [_]  $v        Рєф $v
with drop [+1 $n] [$m] ($v РеЙ _)   Рєф drop [$n] [$m] $v
with take [0]      [_]  _         Рєф unit
with take [+1 $n] [$m] ($v РеЙ $x)  Рєф take [$n] [$m] $v РеЙ $x;

// ---- `!!` n-ary universal --------------------------------------

// Kept *rigid* (no reduction rules). If `!!` reduced eagerly to
// nested Рѕђ, the surface form would vanish from goals before any
// tactic could see it Рђћ and implicit-arg inference of `n` and `P`
// at call sites would need to invert the reduction (higher-order
// unification across rewriting), which Lambdapi can't.
constant symbol !! [n] : (Tuple n Рєњ Prop) Рєњ Prop;
notation !! quantifier;

constant symbol pi_to_!! [n] (P : Tuple n Рєњ Prop)
  : (╬а v : Tuple n, ¤ђ (P v)) Рєњ ¤ђ (`!! v, P v);

constant symbol !!_to_pi [n] (P : Tuple n Рєњ Prop)
  : ¤ђ (`!! v, P v) Рєњ ╬а v : Tuple n, ¤ђ (P v);

// ---- `??` n-ary existential ------------------------------------
//
// Kept *rigid* like `!!`. Earlier we let `??` reduce to nested РѕЃ,
// but that broke implicit-P inference at sites like XST7_1's body
// (HO-unification can't invert the reduction). Bridges are
// axiomatised below.

constant symbol ?? [n] : (Tuple n Рєњ Prop) Рєњ Prop;
notation ?? quantifier;

constant symbol pi_to_??_intro [n] (P : Tuple n Рєњ Prop)
  : ╬а v : Tuple n, ¤ђ (P v) Рєњ ¤ђ (`?? v, P v);

constant symbol pi_to_??_elim [n] (P : Tuple n Рєњ Prop) [R : Prop]
  : (╬а v : Tuple n, ¤ђ (P v) Рєњ ¤ђ R) Рєњ ¤ђ (`?? v, P v) Рєњ ¤ђ R;

// ---- Common derived lemmas -------------------------------------

// Pointwise equality lifts to `!!` equality.
opaque symbol !!_cong [n] [P R : Tuple n Рєњ Prop]
  : (╬а v : Tuple n, ¤ђ (P v = R v))
  Рєњ ¤ђ ((`!! v, P v) = (`!! v, R v)) РЅћ
begin
  assume n P R h;
  refine propExt _ _ _ _
  { assume hP; refine pi_to_!! R (╬╗ v, =РЄњ (h v) (!!_to_pi P hP v)) }
  { assume hR; refine pi_to_!! P (╬╗ v, =РЄњ (eq_sym (h v)) (!!_to_pi R hR v)) }
end;

// Pointwise equality lifts to `??` equality.
opaque symbol ??_cong [n] [P R : Tuple n Рєњ Prop]
  : (╬а v : Tuple n, ¤ђ (P v = R v))
  Рєњ ¤ђ ((`?? v, P v) = (`?? v, R v)) РЅћ
begin
  assume n P R h;
  refine propExt _ _ _ _
  { assume hP; refine pi_to_??_elim P
      (╬╗ v hPv, pi_to_??_intro R v (=РЄњ (h v) hPv)) hP }
  { assume hR; refine pi_to_??_elim R
      (╬╗ v hRv, pi_to_??_intro P v (=РЄњ (eq_sym (h v)) hRv)) hR }
end;

// `!!_const`: drop a constant `!!`-binder. Tuple-n analogue of
// Stdlib.PropExt's `Рѕђ_const`. Both directions go through `inh_tuple`.
opaque symbol !!_const [n] (P : Prop)
  : ¤ђ ((`!! _ : Tuple n, P) = P) РЅћ
begin
  assume n P;
  refine propExt _ _ _ _
  { assume h; refine !!_to_pi (╬╗ _ : Tuple n, P) h (inh_tuple [n]) }
  { assume h; refine pi_to_!! (╬╗ _ : Tuple n, P) (╬╗ _, h) }
end;

// ---- РЎб / РЎА : PP normalisation quantifiers ----------------------
//
// Spec uses `РЎб` (= ASCII `forall`) for goal-side n-ary universals and
// `РЎА` (= ASCII `forall2`) for hypothesis-side ones. Semantically both
// are nested Рѕђ Рђћ they only carry a proof-search role.
//
// Kept *rigid* (constant, no rewrite rules) for the same reason `!!`
// is rigid. The reduction to `!!` is axiomatised: `pi_to_РЎб` /
// `РЎб_to_pi` are the per-tuple bridges; `РЎб_eq_!!` follows from
// `propExt`. NRM rules state their types in spec notation; bodies use
// the dedicated bridges or transport via `РЎб_eq_!!` where helpers are
// `!!`-typed.

constant symbol РЎб [n] : (Tuple n Рєњ Prop) Рєњ Prop;
notation РЎб quantifier;

constant symbol pi_to_РЎб [n] (P : Tuple n Рєњ Prop)
  : (╬а v : Tuple n, ¤ђ (P v)) Рєњ ¤ђ (`РЎб v, P v);

constant symbol РЎб_to_pi [n] (P : Tuple n Рєњ Prop)
  : ¤ђ (`РЎб v, P v) Рєњ ╬а v : Tuple n, ¤ђ (P v);

constant symbol РЎА [n] : (Tuple n Рєњ Prop) Рєњ Prop;
notation РЎА quantifier;

constant symbol pi_to_РЎА [n] (P : Tuple n Рєњ Prop)
  : (╬а v : Tuple n, ¤ђ (P v)) Рєњ ¤ђ (`РЎА v, P v);

constant symbol РЎА_to_pi [n] (P : Tuple n Рєњ Prop)
  : ¤ђ (`РЎА v, P v) Рєњ ╬а v : Tuple n, ¤ђ (P v);

// Both РЎб and РЎА are propositionally equal to `!!` Рђћ derived from the
// bridges via `propExt`.
opaque symbol РЎб_eq_!! [n] (P : Tuple n Рєњ Prop)
  : ¤ђ ((`РЎб v, P v) = (`!! v, P v)) РЅћ
begin
  assume n P;
  refine propExt _ _ _ _
  { assume h; refine pi_to_!! P (РЎб_to_pi P h) }
  { assume h; refine pi_to_РЎб P (!!_to_pi P h) }
end;

opaque symbol РЎА_eq_!! [n] (P : Tuple n Рєњ Prop)
  : ¤ђ ((`РЎА v, P v) = (`!! v, P v)) РЅћ
begin
  assume n P;
  refine propExt _ _ _ _
  { assume h; refine pi_to_!! P (РЎА_to_pi P h) }
  { assume h; refine pi_to_РЎА P (!!_to_pi P h) }
end;

// ---- Res: ╬Б-type for normalisation chains ----------------------
// `Res t = (t' : ¤ё a) ├Ќ ¤ђ (t = t')` packages a normalised term with
// a proof of equality to the original. Lives here (not in Res.lp)
// because the result-based ALL7/XST8 in All.lp/Xst.lp need it.
injective symbol Res [a : Set] : ¤ё a Рєњ TYPE;
symbol mk_1 [a t] (t' : ¤ё a) : ¤ђ (t = t') Рєњ Res t;
symbol res_tm [a t] : Res [a] t Рєњ ¤ё a;
symbol res_eq [a t] (r : Res [a] t) : ¤ђ (t = res_tm r);
rule res_tm (mk_1 $t' _) Рєф $t';
rule res_eq (mk_1 _ $prf) Рєф $prf;
