&

THEORY Interval IS
    band(binhyp(c <= a),
        binhyp(b <= d))
    =>
    a..b <: c..d
    ;
    band(binhyp(a <= b),
        band(binhyp(b+1=c),
            binhyp(c <= d))) &
    blvar(Q) &
    Q\(a,b,c,d)
    =>
    a..b\/c..d == a..d
    ;
    band(binhyp(not(P = {}),
    band(binhyp(not(Q = {})),
    band(binhyp(P = a..b),
    band(binhyp(Q = c..d),
         binhyp(b+1 = c))))))
    =>
    P\/Q = a..d
END
&
THEORY ArithMin IS
    band(binhyp(x: E),
        binhyp(a<=min(f[E])))
    => 
    a<=f(x)
END
&
THEORY ApplyFun IS
    blvar(Q) &
    Q\(x,y,a,b)
    =>({x|->a,y|->b}(x) == a)
    ;
    blvar(Q) &
    Q\(x,y,a,b)
    =>({x|->a,y|->b}(y) == b)
END
