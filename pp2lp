#!/usr/bin/env python3
"""pp2lp — translate Atelier B Predicate-Prover replays to Lambdapi and type-check them.

Round trip: formula → PP → .trace → REPLAY → .replay → pp2lp → .lp → lambdapi check.
Drive it with `pp2lp run` (emit + check) and `pp2lp gen` (regenerate inputs via krt);
the OCaml engine under ocaml/_build/ is an internal detail.  See CLAUDE.md for the
design, or `pp2lp run --help` / `pp2lp gen --help` for options.
"""
from __future__ import annotations

import argparse
import concurrent.futures
import difflib
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import time
from pathlib import Path

try:
    import resource  # POSIX-only; caps child address space / CPU
except ImportError:  # pragma: no cover
    resource = None

ROOT = Path(__file__).resolve().parent
ENGINE = ROOT / "ocaml" / "_build" / "default" / "bin" / "main.exe"
BENCH = ROOT / "lp" / "bench"
RESULTS_DIR = ROOT / "bench" / "results"

# ── Safety caps for child processes (env-tunable; 0 disables) ──────────────
CHECK_TIMEOUT = float(os.environ.get("PP2LP_CHECK_TIMEOUT", "60"))   # lambdapi, s
EMIT_TIMEOUT = float(os.environ.get("PP2LP_EMIT_TIMEOUT", "30"))     # engine emit, s
CHILD_MEM_GB = float(os.environ.get("PP2LP_CHECK_MEM_GB", "4"))      # RLIMIT_AS, GiB

# ── Colour ─────────────────────────────────────────────────────────────────
COLOR = sys.stdout.isatty() and not os.environ.get("NO_COLOR")


def _c(code, t):
    return f"\033[{code}m{t}\033[0m" if COLOR else str(t)


def green(t):  return _c("32", t)
def yellow(t): return _c("33", t)
def red(t):    return _c("31", t)
def dim(t):    return _c("2", t)
def bold(t):   return _c("1", t)


ICON = {"ok": green("✓"), "warn": yellow("⚠"), "emit_fail": red("✗"), "lp_fail": red("✗")}


def fmt_ms(ms: float) -> str:
    return f"{ms / 1000:.1f}s" if ms >= 1000 else f"{ms:.0f}ms"


# ── Child-process limits ───────────────────────────────────────────────────
def _child_limits(timeout: float):
    if resource is None or os.name != "posix":
        return None

    def apply():
        if CHILD_MEM_GB > 0:
            n = int(CHILD_MEM_GB * 1024 ** 3)
            try:
                resource.setrlimit(resource.RLIMIT_AS, (n, n))
            except (ValueError, OSError):
                pass
        if timeout > 0:
            cpu = int(timeout) + 10
            try:
                resource.setrlimit(resource.RLIMIT_CPU, (cpu, cpu))
            except (ValueError, OSError):
                pass

    return apply


def _run_lambdapi(args):
    """Run `lambdapi check <args>` under the standard safety caps: wall-clock
    CHECK_TIMEOUT, RLIMIT_AS/CPU via _child_limits, and its own session group
    so a runaway child can't take down the host.  The single place those caps
    are wired — callers handle FileNotFoundError / TimeoutExpired."""
    return subprocess.run(["lambdapi", "check", *args],
                          capture_output=True, text=True,
                          timeout=CHECK_TIMEOUT or None,
                          preexec_fn=_child_limits(CHECK_TIMEOUT),
                          start_new_session=True)


# ── Build the engine ───────────────────────────────────────────────────────
def ensure_build() -> tuple[bool, str]:
    try:
        r = subprocess.run(["dune", "build"], cwd=ROOT / "ocaml",
                           capture_output=True, text=True)
    except FileNotFoundError:
        return False, "dune not found on PATH"
    return r.returncode == 0, r.stderr.strip()


# ── Error classification: engine stderr text → code ────────────────────────
# The engine's messages are stable (we own them).  Map them to a machine code,
# mirroring CLAUDE.md's "Common errors" table.
_ERROR_RULES = [
    (re.compile(r"unknown rule"),               "E_UNKNOWN_RULE"),
    (re.compile(r"unsupported arity"),          "E_ARITY"),
    (re.compile(r"arity \d+ unsupported"),      "E_DISPATCH"),
    (re.compile(r"no sequent continuation"),    "E_REPLAY_TRUNCATED"),
    (re.compile(r"INS contradiction"),          "E_INS"),
    (re.compile(r"tree-build error|unconsumed|expected a .*child"), "E_TREE_BUILD"),
    (re.compile(r"parse error|replay-line parse|unrecognised line"), "E_PARSE"),
]


def classify_error(text: str) -> str:
    for rx, code in _ERROR_RULES:
        if rx.search(text):
            return code
    return "E_EMIT"


# ── Provenance: the engine writes a side-channel line→rule TSV (no comments
#    in the generated .lp); we read it back and join errors to rules. ───────
def read_map(path: Path) -> list[dict]:
    """Parse the engine's provenance TSV: lp_line, rule, replay_line, goal."""
    out = []
    try:
        for line in path.read_text(encoding="utf-8").splitlines():
            parts = line.split("\t", 3)
            if len(parts) == 4:
                out.append({"lp_line": int(parts[0]), "rule": parts[1],
                            "replay_line": int(parts[2]), "goal": parts[3]})
    except (OSError, ValueError):
        pass
    return out


def join_prov(lp_line: int, smap: list[dict]) -> dict | None:
    """Nearest-preceding provenance entry for a given .lp line — i.e. the rule
    whose emitted block the error falls inside."""
    best = None
    for e in smap:
        if e["lp_line"] <= lp_line and (best is None or e["lp_line"] > best["lp_line"]):
            best = e
    return best


# ── Run the engine ─────────────────────────────────────────────────────────
def engine(*engine_args, env=None, timeout=EMIT_TIMEOUT):
    return subprocess.run(
        [str(ENGINE), *engine_args], cwd=ROOT, capture_output=True, text=True,
        timeout=timeout or None, preexec_fn=_child_limits(timeout),
        start_new_session=True, env=env)


def rel(p: Path) -> str:
    return str(p.relative_to(ROOT)) if p.is_relative_to(ROOT) else str(p)


def emit(replay: Path, out: Path) -> dict:
    """Emit the clean .lp (no comments) and read the side-channel provenance
    map.  Returns {ok, warnings, error|None, smap}."""
    out.parent.mkdir(parents=True, exist_ok=True)
    fd, mappath = tempfile.mkstemp(suffix=".provmap")
    os.close(fd)
    mapfile = Path(mappath)
    try:
        try:
            r = engine("emit", "--map", str(mapfile), rel(replay), timeout=EMIT_TIMEOUT)
        except FileNotFoundError:
            return {"ok": False, "warnings": [],
                    "error": {"code": "E_NO_ENGINE", "message": "engine binary missing"}}
        except subprocess.TimeoutExpired:
            return {"ok": False, "warnings": [],
                    "error": {"code": "E_TIMEOUT",
                              "message": f"emit timed out after {EMIT_TIMEOUT:.0f}s"}}
        warnings = [l[len("WARNING: "):] for l in r.stderr.splitlines() if l.startswith("WARNING: ")]
        errors = [l for l in r.stderr.splitlines() if l and not l.startswith("WARNING: ")]
        if r.returncode != 0:
            msg = "\n".join(errors) or r.stderr.strip()
            code = classify_error(msg)
            return {"ok": False, "warnings": warnings,
                    "error": {"code": code, "message": msg}}
        out.write_text(r.stdout, encoding="utf-8")
        return {"ok": True, "warnings": warnings, "error": None, "smap": read_map(mapfile)}
    finally:
        mapfile.unlink(missing_ok=True)


def lp_check(lp: Path) -> dict:
    """Type-check with lambdapi --json.  Returns {ok, diagnostics, raw, timeout}."""
    try:
        r = _run_lambdapi(["--json", "-c", str(lp)])
    except FileNotFoundError:
        return {"ok": False, "diagnostics": [], "raw": [], "timeout": False,
                "no_lambdapi": True}
    except subprocess.TimeoutExpired:
        return {"ok": False, "diagnostics": [], "raw": [], "timeout": True}
    diagnostics, raw = [], []
    for line in (r.stdout + "\n" + r.stderr).splitlines():
        line = line.rstrip()
        if not line:
            continue
        try:
            ev = json.loads(line)
        except json.JSONDecodeError:
            raw.append(line)
            continue
        if ev.get("kind") == "diagnostic":
            diagnostics.append(ev)
    return {"ok": r.returncode == 0, "diagnostics": diagnostics,
            "raw": raw, "timeout": False}


def diag_loc(ev: dict) -> tuple[str, int | None, int | None]:
    rng = ev.get("range") or {}
    start = rng.get("start") or {}
    return ev.get("file", "?"), start.get("line"), start.get("col")


# ── Check one trace (emit + check + provenance join) ───────────────────────
def check_one(replay: Path, lp_debug: str | None = None) -> dict:
    out = replay.with_suffix(".lp")
    for stale in out.parent.glob(f"{out.stem}.lp.*"):   # clear last run's debug trace
        stale.unlink(missing_ok=True)
    t0 = time.monotonic()
    em = emit(replay, out)
    t_emit = (time.monotonic() - t0) * 1000
    res = {"name": replay.stem, "lp": rel(out),
           "emit_ms": t_emit, "check_ms": 0.0, "warnings": em["warnings"]}
    if not em["ok"]:
        res["status"] = "emit_fail"
        res["error"] = em["error"]
        return res

    smap = em["smap"]                   # side-channel map; powers the join

    t1 = time.monotonic()
    chk = lp_check(out)
    res["check_ms"] = (time.monotonic() - t1) * 1000
    if chk.get("no_lambdapi"):
        res["status"] = "lp_fail"
        res["error"] = {"code": "E_NO_LAMBDAPI",
                        "message": "lambdapi not found on PATH"}
        return res
    if chk["timeout"]:
        res["status"] = "lp_fail"
        res["error"] = {"code": "E_LP_TIMEOUT",
                        "message": f"lambdapi timed out after {CHECK_TIMEOUT:.0f}s"}
        return res
    if not chk["ok"]:
        errs = [e for e in chk["diagnostics"] if e.get("severity") != "warning"]
        diags = []
        for e in errs:
            f, line, col = diag_loc(e)
            prov = join_prov(line, smap) if line is not None else None
            diags.append({"lp_loc": f"{Path(f).name}:{line}:{col}" if line else Path(f).name,
                          "message": (e.get("message") or "").strip(),
                          "provenance": prov})
        res["status"] = "lp_fail"
        head = (errs[0].get("message") or "").strip().splitlines() if errs else []
        res["error"] = {"code": "E_LP_CHECK",
                        # summary only; the full body lives in diagnostics[].message
                        "message": head[0] if head else "type-check failed",
                        "diagnostics": diags,
                        "raw": chk["raw"] if not errs else []}
        if lp_debug:
            _write_debug_trace(out, diags, lp_debug)
        return res
    res["status"] = "warn" if em["warnings"] else "ok"
    res["error"] = None
    return res


# ── Target resolution ──────────────────────────────────────────────────────
def _suite_names() -> list[str]:
    """Bench subdirs that look like suites (skip dotfiles / __pycache__)."""
    return [p.name for p in sorted(BENCH.iterdir())
            if p.is_dir() and not p.name.startswith((".", "_"))]


def resolve_target(target: str):
    """Return ('suite', suite, [replays]) or ('single', suite, replay).
    Each benchmark lives in its own directory: SUITE/NAME/NAME.replay."""
    if "/" in target:
        suite, name = target.split("/", 1)
        sdir = BENCH / suite
        if not sdir.is_dir():
            sys.exit(f"pp2lp: no such suite '{suite}' (available: {', '.join(_suite_names())})")
        replay = sdir / name / f"{name}.replay"
        if not replay.exists():
            names = [p.stem for p in sorted(sdir.glob("*/*.replay"))]
            guess = difflib.get_close_matches(name, names, n=1, cutoff=0.6)
            if guess:
                tail = f" — did you mean '{guess[0]}'?"
            elif names:
                tail = f" ({len(names)} available; `pp2lp run {suite}` lists them)"
            else:
                tail = " (no .replay files yet — run `pp2lp gen`)"
            sys.exit(f"pp2lp: no replay '{name}' in suite '{suite}'{tail}")
        return "single", suite, replay
    suite = target
    d = BENCH / suite
    if not d.is_dir():
        sys.exit(f"pp2lp: no such suite '{suite}' (available: {', '.join(_suite_names())})")
    replays = sorted(d.glob("*/*.replay"))   # one benchmark per subdirectory
    if not replays:
        sys.exit(f"pp2lp: no .replay files under {rel(d)} (run `pp2lp gen {suite}`)")
    return "suite", suite, replays


# ── Printing ───────────────────────────────────────────────────────────────


def _clip(s: str, n: int = 200) -> str:
    return s if len(s) <= n else s[:n - 1] + "…"


_TERM_W = min(shutil.get_terminal_size((90, 24)).columns, 100)
_TRACE_HOT = ("failed", "unsolved", "Unsolvable", "no unif_rule", "internal error")


def _numbered(lines: list[str], start: int, indent: str, mark=(), color=None,
              clip: int | None = 200) -> None:
    """Print `lines` with a line-number gutter (1-based, from `start`).  Numbers in
    `mark` get a red `>`; `color` styles each line; `clip` caps line width — None
    means full width, used for the untruncated debug traces."""
    width = max(len(str(start + len(lines) - 1)), 1)
    for k, text in enumerate(lines):
        n = start + k
        marker = red(">") if n in mark else " "
        shown = _clip(text, clip) if clip else text
        print(f"{indent}  {marker} {n:>{width}} | {color(shown) if color else shown}")


def _trace_style(t: str) -> str:
    """Per-line styling for a debug trace: red for the failure line, plain for a
    `≡` constraint, dim for the rest."""
    if any(k in t for k in _TRACE_HOT):
        return red(t)
    return t if "≡" in t else dim(t)


def print_failure(res: dict, replay: Path, indent: str = "   ", context: int = 2) -> None:
    """The default failure window: a code snippet from each related file, headed
    by its `filename:position` — the emitted .lp at the error line, the .replay
    proof step that produced it, and the failing rule's lp/rules type signature.
    `--lp-debug=CODE` adds a <name>.lp.debug lambdapi-trace snippet."""
    err = res.get("error") or {}
    diags = err.get("diagnostics", [])
    if not diags:                       # emit_fail / timeout / unstructured
        first = (err.get("message") or "").splitlines()
        if err.get("code"):
            print(f"{indent}{red(err['code'])}  {first[0] if first else ''}")
            first = first[1:]
        for line in first:
            print(f"{indent}  {_clip(line)}")
        raw = err.get("raw") or []                  # unstructured lambdapi output
        for line in raw[:20]:
            print(f"{indent}  {dim(_clip(line))}")
        if len(raw) > 20:
            print(f"{indent}  {dim('… (+%d more lines)' % (len(raw) - 20))}")
        return
    # ── one snippet panel per related file, each headed by filename:position ──
    d0 = diags[0]
    prov0 = d0.get("provenance")
    _section(d0["lp_loc"])                              # e.g. name.lp:23:4
    m = re.match(r".*:(\d+):", d0["lp_loc"])
    if m:
        _print_source_context(ROOT / res["lp"], int(m.group(1)), indent, context)
    if prov0:
        _section(f"{replay.name}:{prov0['replay_line']}")
        _print_source_context(replay, prov0["replay_line"], indent, 3)
        sig = _rule_signature(prov0["rule"])
        if sig:
            path, start, end = sig
            _section(f"{path.name}:{start}")
            _numbered(path.read_text(encoding="utf-8").splitlines()[start - 1:end], start,
                      indent, mark={start})
        else:
            _section(prov0["rule"])
            print(f"{indent}  {dim('(symbol %s not found under lp/rules/)' % prov0['rule'])}")
    else:
        print(f"{indent}  {dim('(no PP rule maps to this line)')}")
    lp = ROOT / res["lp"]
    debug = lp.with_name(lp.name + ".debug")           # the --lp-debug probe trace
    if debug.exists():
        _section(debug.name)
        _print_trace_file(debug, indent)
    if len(diags) > 1:
        more = len(diags) - 1
        print(f"{indent}  {dim('(+%d more lambdapi error%s)' % (more, '' if more == 1 else 's'))}")


def _distill(out: list) -> list[str]:
    """Clean a scoped lambdapi debug trace: keep the `[tag] …` entries, drop the
    giant `[tag] solve {…metas…}` state dump, surface (rather than spew) a crash."""
    cleaned = []
    for l in out:
        s = l.rstrip()
        if "Assertion failed" in s or s.lstrip().startswith("Uncaught"):
            cleaned.append("(lambdapi internal error on this debug code)")
            break
        t = s.strip()
        tag = re.match(r"\[[a-z]+\] ", t)
        if tag and not t.startswith(tag.group(0) + "solve {"):
            cleaned.append(t)
    return cleaned or ["(no debug activity captured for this code)"]


def debug_probe(lp_path: Path, fail_line: int, code: str) -> list[str]:
    """Turn lambdapi `debug +<code>;` on immediately before the failing tactic, run
    lambdapi, and return the cleaned trace (scoped — only that tactic's activity,
    since the proof errors there).  `code` is raw lambdapi flags (u/r/t/w/…)."""
    lines = lp_path.read_text(encoding="utf-8").splitlines()
    i = fail_line - 1
    if not (0 <= i < len(lines)):
        return []
    # Inject `debug +code;` *into* the failing line, after any leading whitespace
    # and subgoal-opener `{`s, so it lands at a valid tactic position — a bare
    # `debug …;` line before a `{`-opener is a lambdapi syntax error.  No matching
    # `-code;` is needed: the proof errors at this tactic, nothing after it runs.
    pre = re.match(r"\s*(?:\{\s*)*", lines[i]).group(0)
    injected = f"{pre}debug +{code}; {lines[i][len(pre):]}"
    probe_lines = lines[:i] + [injected] + lines[i + 1:]
    probe = lp_path.with_name(lp_path.stem + "_dbg.lp")
    probe.write_text("\n".join(probe_lines) + "\n", encoding="utf-8")
    try:
        r = _run_lambdapi(["--no-colors", "-w", str(probe)])
        out = (r.stdout + r.stderr).splitlines()
    except subprocess.TimeoutExpired:
        out = ["(debug probe timed out)"]
    finally:
        for p in (probe, probe.with_suffix(".lpo")):
            try:
                p.unlink()
            except OSError:
                pass
    return _distill(out)


def _write_debug_trace(lp: Path, diags: list, code: str) -> None:
    """Run the scoped `debug +<code>` probe at the located failure and write its
    cleaned trace to `<name>.lp.debug` (gitignored); print_failure surfaces it."""
    if not diags:
        return
    m = re.match(r".*:(\d+):", diags[0]["lp_loc"])
    if not m:                          # no line to scope a probe to
        return
    trace = debug_probe(lp, int(m.group(1)), code)
    lp.with_name(lp.name + ".debug").write_text("\n".join(trace) + "\n", encoding="utf-8")


def _print_trace_file(path: Path, indent: str) -> None:
    """Render the debug trace as a full, untruncated numbered snippet — the failure
    line(s) marked with `>` and styled red, `≡` constraints plain, the rest dim."""
    lines = path.read_text(encoding="utf-8").splitlines()
    hot = {k + 1 for k, t in enumerate(lines) if any(h in t for h in _TRACE_HOT)}
    _numbered(lines, 1, indent, mark=hot, color=_trace_style, clip=None)


def _print_source_context(src: Path, line: int, indent, context):
    try:
        lines = src.read_text(encoding="utf-8").splitlines()
    except OSError:
        return
    if not (1 <= line <= len(lines)):
        return
    lo = max(0, line - 1 - context)
    hi = min(len(lines), line + context)
    _numbered(lines[lo:hi], lo + 1, indent, mark={line})


# ── Rule signature lookup (lp/rules/*.lp) ──────────────────────────────────
def _rule_signature(rule: str):
    """The failing rule's declaration in lp/rules/*.lp as (path, start_line, end_line)
    — the `symbol …` line through the line holding its `≔`/`;`.  None if not found."""
    name = rule.lstrip("@")
    rx = re.compile(r"(?:opaque\s+|sequential\s+|injective\s+|constant\s+)*symbol\s+"
                    + re.escape(name) + r"\b.*?(?=≔|;)", re.DOTALL)
    for f in sorted((ROOT / "lp" / "rules").glob("*.lp")):
        text = f.read_text(encoding="utf-8")
        m = rx.search(text)
        if m:
            start = text.count("\n", 0, m.start()) + 1
            end = text.count("\n", 0, m.end()) + 1
            return f, start, end
    return None


# ── Per-trace printing + single-trace dossier ──────────────────────────────
def _print_trace(res: dict, replay: Path, timing: bool = False) -> None:
    """A heavy-ruled header for the trace (so one benchmark is clearly delimited
    from the next), its warnings, and — on failure — the snippet window."""
    timing_txt = (f"  emit {fmt_ms(res['emit_ms'])} / check {fmt_ms(res['check_ms'])}"
                  if timing else "")
    visible = 6 + len(res["name"]) + len(timing_txt)   # "━━ " + icon + " " + name + timing + " "
    print(f"━━ {ICON[res['status']]} {bold(res['name'])}{dim(timing_txt)} "
          + "━" * max(3, _TERM_W - visible))
    for w in res["warnings"]:
        print(f"   {dim(w)}")
    if res["status"] in ("emit_fail", "lp_fail"):
        print_failure(res, replay)


def dossier(replay: Path, res: dict):
    """Everything an agent needs about one trace, in one call — the failure window
    of related-file snippets (plus a .lp.debug snippet when --lp-debug is given)."""
    _print_trace(res, replay, timing=True)


def _section(title):
    pad = max(3, _TERM_W - len(title) - 7)      # "   " indent + "── " + " " before dashes
    print(f"   {dim(f'── {title} ' + '─' * pad)}")


# ── The `run` command ──────────────────────────────────────────────────────
def cmd_run(args) -> int:
    if args.lp_debug is not None and not re.fullmatch(r"[a-zA-Z]+", args.lp_debug):
        sys.exit(f"pp2lp: --lp-debug code {args.lp_debug!r} must be lambdapi flags (letters "
                 f"like u/r/t/w) — put the target before it, e.g. "
                 f"`pp2lp run SUITE/NAME --lp-debug=u`")
    if not args.no_build:
        ok, err = ensure_build()
        if not ok:
            if args.json:
                print(json.dumps({"ok": False, "error": {"code": "E_BUILD", "message": err}}))
            else:
                print(red("build failed:"))
                print(err)
            return 1

    kind, suite, target = resolve_target(args.target)
    if kind == "single":
        res = check_one(target, args.lp_debug)
        if args.json:
            print(json.dumps(res, ensure_ascii=False, indent=2))
        else:
            dossier(target, res)
        return 0 if res["status"] in ("ok", "warn") else 1

    # ── suite: parallel emit+check, strict gate ──
    return _run_suite(args, suite, target)


def _run_suite(args, suite: str, replays: list[Path]) -> int:
    t_start = time.monotonic()
    results = _check_all(replays, lp_debug=args.lp_debug)
    elapsed = (time.monotonic() - t_start) * 1000

    ordered = [results[r.stem] for r in replays]
    failures = [r["name"] for r in ordered if r["status"] in ("emit_fail", "lp_fail")]
    artifact = {"suite": suite,
                "ok": sum(r["status"] == "ok" for r in ordered),
                "warn": sum(r["status"] == "warn" for r in ordered),
                "fail": len(failures), "failures": failures, "wall_ms": elapsed,
                "emit_ms": sum(r["emit_ms"] for r in ordered),
                "check_ms": sum(r["check_ms"] for r in ordered), "goals": ordered}

    RESULTS_DIR.mkdir(parents=True, exist_ok=True)
    (RESULTS_DIR / f"{suite}.json").write_text(
        json.dumps(artifact, ensure_ascii=False, indent=2), encoding="utf-8")

    if args.json:
        print(json.dumps(artifact, ensure_ascii=False, indent=2))
    else:
        _print_suite_human(args, artifact, {r.stem: r for r in replays})
    return 1 if failures else 0


def _print_suite_human(args, artifact: dict, replay_of: dict) -> None:
    suite, failures = artifact["suite"], artifact["failures"]
    # the failure window (related-file snippets) shows for every failing trace by
    # default; `-q` drops to just the summary line.
    if not args.quiet:
        for res in artifact["goals"]:
            if res["status"] != "ok":
                print()
                _print_trace(res, replay_of[res["name"]])
        print()
    parts = []
    if artifact["ok"]:
        parts.append(f"{green(artifact['ok'])} ✓")
    if artifact["warn"]:
        parts.append(f"{yellow(artifact['warn'])} ⚠")
    if failures:
        parts.append(f"{red(len(failures))} ✗")
    breakdown = dim(f"emit {fmt_ms(artifact['emit_ms'])} / check {fmt_ms(artifact['check_ms'])}")
    print(f"{suite}  {'  '.join(parts)}  {dim(fmt_ms(artifact['wall_ms']))}  {breakdown}")


# ── shared suite evaluation ────────────────────────────────────────────────
def _warm_shared_cache() -> None:
    """Type-check the shared library files (B, Quant, ConjList, Rules → all of
    rules/*) once, serially, so their .lpo objects exist before the parallel
    workers start.  Otherwise each `lambdapi check -c` below races to compile and
    write those same shared objects on a cold cache, corrupting them and giving
    spurious failures (a re-run would then "fix" it).  Warming them first leaves
    the workers only reading the shared objects and writing their own."""
    shared = [ROOT / "lp" / f for f in ("B.lp", "Quant.lp", "ConjList.lp", "Rules.lp")]
    shared = [str(p) for p in shared if p.exists()]
    if not shared:
        return
    try:
        _run_lambdapi(["-c", "-w", *shared])
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass        # a missing/slow lambdapi resurfaces per-trace in the workers below


def _check_all(replays, lp_debug=None) -> dict[str, dict]:
    """Emit+check every replay in parallel; keyed by stem."""
    out: dict[str, dict] = {}
    _warm_shared_cache()
    workers = min(len(replays), (os.cpu_count() or 2))
    with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as ex:
        futs = {ex.submit(check_one, r, lp_debug): r for r in replays}
        for fut in concurrent.futures.as_completed(futs):
            replay = futs[fut]
            try:
                res = fut.result()
            except Exception as e:        # one bad trace must not sink the whole suite
                res = {"name": replay.stem, "lp": rel(replay.with_suffix(".lp")),
                       "emit_ms": 0.0, "check_ms": 0.0, "warnings": [], "status": "emit_fail",
                       "error": {"code": "E_INTERNAL",
                                 "message": f"{type(e).__name__}: {e}"}}
            out[res["name"]] = res
    return out


# ── --gen: krt (Atelier B) generation, ports bench/_krt + gen_* scripts ────
_SATURATION = [
    ("saturation:objects",  r"OBJECTS OVERFLOW"),
    ("saturation:goals",    r"GOAL(?:S)? STACK OVERFLOW"),
    ("saturation:hyps",     r"TOO MANY HYPOTHESES"),
    ("saturation:seq-ids",  r"SEQUENCE ID NUMBERS OVERFLOW"),
    ("saturation:seq-mem",  r"SEQUENCE MEMORY OVERFLOW"),
    ("saturation:symbols",  r"SYMBOLS OVERFLOW"),
    ("saturation:theories", r"MAXIMUM NUMBER OF THEORIES .* REACHED"),
    ("saturation:compiler", r"Compiler Memory Full"),
    ("timer:exceeded",      r"TIMER (?:EXCEEDED|EXPIRED|REAL|VIRTUAL)"),
]
_REPLAY_EXTRA = [
    ("parse:missing-atom", r"missing atomic symbol"),
    ("parse:error",        r"(?m)^\s*line\s+\d+:.*(?:error|missing)"),
]


def find_krt():
    return shutil.which("krt") or next(
        (h for h in ["/opt/atelierb-free-24.04.2/bin/krt"] if os.path.exists(h)), None)


def find_kin(hints):
    return next((str(h) for h in hints if Path(h).exists()), None)


def run_krt(krt, kin, goal_file, cwd, timeout=120.0, timer="R45", patterns=_SATURATION):
    argv = [krt] + (["-i", timer] if timer else []) + ["-b", kin, goal_file]
    try:
        r = subprocess.run(argv, cwd=cwd, capture_output=True, text=True, timeout=timeout)
    except subprocess.TimeoutExpired:
        return False, "", "timeout"
    text = (r.stdout or "") + "\n" + (r.stderr or "")
    for reason, pat in patterns:
        if re.search(pat, text):
            return False, r.stdout, reason
    if r.returncode != 0:
        return False, r.stdout, f"rc={r.returncode}"
    return True, r.stdout, ""


_GEN_KEYWORDS = {"BOOL", "FALSE", "INTEGER", "NAT", "NATURAL", "NATURAL1", "POW",
                 "TRUE", "bool", "card", "dom", "false", "id", "not", "or", "ran", "true"}
_IDENT_RE = re.compile(r"\b[a-z][A-Za-z0-9_]*\b")
_BINDER_RE = re.compile(r"[!#]\s*\(?\s*([a-zA-Z0-9_,\s]+?)\s*\)?\s*\.")


def _free_idents(goal):
    bound = set()
    for m in _BINDER_RE.finditer(goal):
        bound |= {v.strip() for v in m.group(1).split(",") if v.strip()}
    seen, out = set(), []
    for ident in _IDENT_RE.findall(goal):
        if ident in _GEN_KEYWORDS or ident in bound or ident in seen:
            continue
        seen.add(ident); out.append(ident)
    return out


def _rm_benchmark(d: Path) -> None:
    """Remove a benchmark directory and every artifact in it."""
    shutil.rmtree(d, ignore_errors=True)


def gen_buts(suite, force=False):
    """Generate .but files from goals.txt, one per-benchmark dir (SUITE/NAME/NAME.but).
    Content-aware: a .but is rewritten only when its content changes (so unchanged
    goals keep their mtime and the trace stage can skip them); a benchmark whose goal
    left goals.txt is removed wholesale.  Returns (written, total) or None if no goals.txt."""
    goals = BENCH / suite / "goals.txt"
    if not goals.exists():
        return None
    here = BENCH / suite
    wanted: dict[str, str] = {}          # name -> .but content
    for lineno, raw in enumerate(goals.read_text().splitlines(), 1):
        line = raw.split("#", 1)[0].strip()
        if not line:
            continue
        f = [x.strip() for x in line.split("|")]
        if len(f) != 3:
            sys.exit(f"{rel(goals)}:{lineno}: expected 'name | kind | goal'")
        name, kind, goal = f[0], f[1], f[2]
        prefix = "_delta_p" if kind == "prop" else "_delta_e"
        deltas = " & ".join(f"{prefix}({i})" for i in _free_idents(goal))
        hyp = f"({goal})" + (f" & {deltas}" if deltas else "")
        content = (f'Flag(FileOn("{name}.res")) & '
                   f"Set(Valid.1 | Rule(Implication | {hyp} | ? | ? | {goal} | nn))\n")
        wanted[name] = content
    for p in here.glob("*/*.but"):
        if p.stem not in wanted:         # goal removed from goals.txt
            _rm_benchmark(p.parent)
    written = 0
    for name, content in wanted.items():
        d = here / name
        d.mkdir(parents=True, exist_ok=True)
        p = d / f"{name}.but"
        if force or not p.exists() or p.read_text() != content:
            p.write_text(content); written += 1
    return written, len(wanted)


def _strip_flags(content):
    for pat in (r"Flag\(TypeOn\([^)]+\)\)\s*&\s*", r"Flag\(TraceOn\([^)]+\)\)\s*&\s*",
                r"Flag\(FileOn\([^)]+\)\)\s*&\s*"):
        content = re.sub(pat, "", content)
    return content


def gen_traces(suite, krt, force=False):
    pp_kin = find_kin(["/opt/atelierb-free-24.04.2/bin/PP.kin",
                       os.path.expanduser("~/atelierb/bin/PP.kin")])
    if not pp_kin:
        sys.exit("pp2lp: PP.kin not found")
    here = BENCH / suite
    buts = sorted(here.glob("*/*.but"))
    ok = fail = skip = 0
    for but in buts:
        stem, d = but.stem, but.parent
        trace = d / f"{stem}.trace"
        if not force and trace.exists() and trace.stat().st_mtime >= but.stat().st_mtime:
            skip += 1; continue
        content = f'Flag(TraceOn("{stem}.trace")) & Flag(FileOn("{stem}.res")) & ' + _strip_flags(but.read_text())
        goal = d / f"{stem}.goal"
        goal.write_text(content)
        okk, _o, _r = run_krt(krt, pp_kin, goal.name, str(d))
        goal.unlink(missing_ok=True)
        (d / f"{stem}.res").unlink(missing_ok=True)
        if okk and trace.exists() and trace.read_bytes().strip():
            ok += 1
        else:
            trace.unlink(missing_ok=True); fail += 1
    return ok, fail, skip


def gen_replays(suite, krt, force=False):
    replay_kin = find_kin([ROOT / "atelierb/tools/linux_x64/REPLAY.kin",
                           "/opt/atelierb-free-24.04.2/bin/REPLAY.kin"])
    if not replay_kin:
        sys.exit("pp2lp: REPLAY.kin not found")
    here = BENCH / suite
    traces = sorted(here.glob("*/*.trace"))
    ok = fail = skip = dropped = 0
    for tr in traces:
        stem, d = tr.stem, tr.parent
        replay = d / f"{stem}.replay"
        if not force and replay.exists() and replay.stat().st_mtime >= tr.stat().st_mtime:
            skip += 1; continue
        goal = d / f"{stem}.replay.goal"
        goal.write_text(f'Flag(FileOn("{stem}.replay.res")) & ("{tr}")')
        okk, out, _r = run_krt(krt, replay_kin, goal.name, str(d),
                               patterns=_SATURATION + _REPLAY_EXTRA)
        goal.unlink(missing_ok=True)
        (d / f"{stem}.replay.res").unlink(missing_ok=True)
        misc = d / stem
        if misc.is_file() and misc.suffix == "":
            misc.unlink()
        if not (okk and out and len(out) > 10):
            fail += 1; continue
        replay.write_text(out)
        # Hygiene: a REPLAY-truncated replay (the tool dropped the ALL7/XST8
        # continuation) can't be emitted — drop it from the suite, loudly.  Other
        # emit failures are real bugs and kept, to surface at `run` time.
        probe = emit(replay, d / f"{stem}.lp")
        (d / f"{stem}.lp").unlink(missing_ok=True)
        if not probe["ok"] and (probe.get("error") or {}).get("code") == "E_REPLAY_TRUNCATED":
            replay.unlink(missing_ok=True)
            print(yellow(f"  ⚠ dropped {stem}: truncated replay "
                         f"(REPLAY dropped the ALL7/XST8 continuation; prune it from goals.txt)"))
            dropped += 1
        else:
            ok += 1
    return ok, fail, skip, dropped


def cmd_gen(args) -> int:
    """The `gen` verb: (re)generate a suite's inputs via krt.  Incremental by
    default — a stage skips items whose output is newer than its input; pass
    --force to regenerate everything."""
    suite = args.target.split("/", 1)[0]
    if not args.quiet:
        print(dim(f"gen {suite}: {args.only}" + ("  (--force)" if args.force else "")))
    _gen_stages(suite, args.only, force=args.force)
    return 0


def _gen_stages(suite: str, stages_str: str, force: bool = False) -> None:
    here = BENCH / suite
    krt = None

    def get_krt():
        nonlocal krt
        if krt is None:
            krt = find_krt()
            if not krt:
                sys.exit("pp2lp: krt (Atelier B) not found — install it or set it on PATH")
        return krt

    for st in [s.strip() for s in stages_str.split(",") if s.strip()]:
        if st == "buts":
            r = gen_buts(suite, force=force)
            print(dim("  buts:    no goals.txt — skipped") if r is None
                  else dim(f"  buts:    {r[0]} written, {r[1] - r[0]} unchanged"))
        elif st == "traces":
            if not list(here.glob("*/*.but")):
                print(dim("  traces:  no .but files — skipped")); continue
            ok, fail, skip = gen_traces(suite, get_krt(), force=force)
            print(dim(f"  traces:  {ok} ok, {fail} failed, {skip} up-to-date"))
        elif st == "replays":
            if not list(here.glob("*/*.trace")):
                print(dim("  replays: no .trace files — skipped")); continue
            okb, errb = ensure_build()      # replay hygiene shells out to the engine
            if not okb:
                sys.exit(f"pp2lp: engine build failed (needed for replay hygiene):\n{errb}")
            ok, fail, skip, dropped = gen_replays(suite, get_krt(), force=force)
            tail = f", {dropped} dropped (truncated)" if dropped else ""
            print(dim(f"  replays: {ok} ok, {fail} failed, {skip} up-to-date{tail}"))
        else:
            sys.exit(f"pp2lp: unknown --gen stage {st!r} (buts|traces|replays)")


# ── argparse ───────────────────────────────────────────────────────────────
def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="pp2lp",
        description="translate Atelier B Predicate-Prover replays to Lambdapi and type-check them")
    sub = p.add_subparsers(dest="cmd")

    r = sub.add_parser("run", help="emit + type-check a suite or one trace",
                       description="emit + type-check a SUITE (strict gate) or SUITE/NAME "
                                   "(dossier).  A failure shows code-snippet panels from the "
                                   "related files — the .lp, the .replay step, and the "
                                   "lp/rules signature; --lp-debug adds the lambdapi trace.")
    r.add_argument("target", nargs="?", default="og", help="SUITE or SUITE/NAME (default: og)")
    r.add_argument("-q", "--quiet", action="store_true", help="summary only")
    r.add_argument("--lp-debug", nargs="?", const="u", default=None, metavar="CODE",
                   help="on failure, run lambdapi `debug +CODE` scoped to the failing tactic "
                        "and surface the cleaned trace as a <name>.lp.debug snippet.  CODE is "
                        "raw lambdapi flags (u=unification, r=rewrite, t=tactics, w=whnf; "
                        "default u).  avoid i — it crashes lambdapi's printer on our HO goals")
    r.add_argument("--json", action="store_true", help="machine-readable output")
    r.add_argument("--no-build", action="store_true", help="skip the implicit dune build")

    g = sub.add_parser("gen", help="(re)generate suite inputs via Atelier B krt",
                       description="run PP/REPLAY (krt) to (re)build a suite's .but/.trace/.replay")
    g.add_argument("target", nargs="?", default="synth", help="SUITE (default: synth)")
    g.add_argument("--only", default="buts,traces,replays", metavar="STAGES",
                   help="comma-separated subset of buts,traces,replays (default: all)")
    g.add_argument("--force", action="store_true",
                   help="regenerate even when an output is newer than its input")
    g.add_argument("-q", "--quiet", action="store_true", help="suppress per-stage detail")
    return p


def main(argv=None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    if args.cmd == "run":
        return cmd_run(args)
    if args.cmd == "gen":
        return cmd_gen(args)
    parser.print_help(sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main())
