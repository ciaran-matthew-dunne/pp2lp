        (h for h in ["/opt/atelierb-free-24.04.2/bin/krt"] if os.path.exists(h)), None)


def find_kin(hints):
    return next((str(h) for h in hints if Path(h).exists()), None)


# krt children currently running — an interrupt (gen_apero) kills these so
# blocked worker threads return immediately instead of riding out the timer.
_KRT_LIVE: set = set()


def run_krt(krt, kin, goal_file, cwd, timeout=GEN_TIMEOUT, timer="R45", patterns=_SATURATION):
    """Run a krt kernel under the standard child caps — wall-clock `timeout`,
    RLIMIT_AS (PP2LP_CHECK_MEM_GB) + RLIMIT_CPU via _child_limits, and its own
    session group — so a runaway PP/REPLAY can't take down the host."""
    argv = [krt] + (["-i", timer] if timer else []) + ["-b", kin, goal_file]
    p = subprocess.Popen(argv, cwd=cwd, stdout=subprocess.PIPE,
                         stderr=subprocess.PIPE, text=True,
                         preexec_fn=_child_limits(timeout),
                         start_new_session=True)
    _KRT_LIVE.add(p)
    try:
        try:
            out, err = p.communicate(timeout=timeout or None)
        except subprocess.TimeoutExpired:
            p.kill()
            p.communicate()
            return False, "", "timeout"
    finally:
        _KRT_LIVE.discard(p)
    text = (out or "") + "\n" + (err or "")
    for reason, pat in patterns:
        if re.search(pat, text):
            return False, out, reason
    if p.returncode != 0:
        return False, out, f"rc={p.returncode}"
    return True, out, ""


_GEN_KEYWORDS = {"BOOL", "FALSE", "INTEGER", "NAT", "NATURAL", "NATURAL1", "POW",
                 "TRUE", "bool", "card", "dom", "false", "id", "not", "or", "ran", "true"}
_IDENT_RE = re.compile(r"\b[a-z][A-Za-z0-9_]*\b")
_BINDER_RE = re.compile(r"[!#]\s*\(?\s*([a-zA-Z0-9_,\s]+?)\s*\)?\s*\.")


def _free_idents(goal):
    bound = set()
    for m in _BINDER_RE.finditer(goal):
        bound |= {v.strip() for v in m.group(1).split(",") if v.strip()}
    seen, out = set(), []
    for ident in _IDENT_RE.findall(goal):
        if ident in _GEN_KEYWORDS or ident in bound or ident in seen:
            continue
        seen.add(ident); out.append(ident)
    return out


def _rm_benchmark(d: Path) -> None:
    """Remove a benchmark directory and every artifact in it."""
    shutil.rmtree(d, ignore_errors=True)


def _strip_goal_comment(raw: str) -> str:
    """Drop a `#` comment without eating PP's `#` existential binder.

    A full-line comment starts with `#`; a trailing comment is a `#` preceded by
    whitespace and followed by whitespace or end-of-line (`# note`).  PP writes
    existentials as `#x` (no space after `#`), so `=> #x.(P)` is left intact."""
    if raw.lstrip().startswith("#"):
        return ""
    m = re.search(r"\s#(?:\s|$)", raw)
    return raw[:m.start()] if m else raw


def gen_buts(suite, force=False):
    """Generate .but files from goals.txt, one per-benchmark dir (SUITE/NAME/NAME.but).
    Content-aware: a .but is rewritten only when its content changes (so unchanged
    goals keep their mtime and the trace stage can skip them); a benchmark whose goal
    left goals.txt is removed wholesale.  Returns (written, total) or None if no goals.txt."""
    goals = BENCH / suite / "goals.txt"
    if not goals.exists():
        return None
    here = BENCH / suite
    wanted: dict[str, str] = {}          # name -> .but content
    for lineno, raw in enumerate(goals.read_text().splitlines(), 1):
        line = _strip_goal_comment(raw).strip()
        if not line:
            continue
        f = [x.strip() for x in line.split("|")]
        if len(f) != 3:
            sys.exit(f"{rel(goals)}:{lineno}: expected 'name | kind | goal'")
        name, kind, goal = f[0], f[1], f[2]
        if kind not in {"prop", "expr", "bprop", "bexpr"}:
            sys.exit(f"{rel(goals)}:{lineno}: unknown kind {kind!r} "
                     f"(prop, expr, bprop, bexpr)")
        prefix = "_delta_p" if kind.endswith("prop") else "_delta_e"
        deltas = " & ".join(f"{prefix}({i})" for i in _free_idents(goal))
        if kind.startswith("b"):
            # bare kind: no goal-as-hypothesis self-promotion — PP must prove
            # the formula from the identifier deltas alone, so the special
            # rule families (BOOL*, EAXM*, EQC, …) actually fire instead of
            # an immediate AXM8 hypothesis match.
            hyp = deltas if deltas else "1 = 1"
        else:
            hyp = f"({goal})" + (f" & {deltas}" if deltas else "")
        content = (f'Flag(FileOn("{name}.res")) & '
                   f"Set(Valid.1 | Rule(Implication | {hyp} | ? | ? | {goal} | nn))\n")
        wanted[name] = content
    for p in here.glob("*/*.but"):
        if p.stem not in wanted:         # goal removed from goals.txt
            _rm_benchmark(p.parent)
    written = 0
    for name, content in wanted.items():
        d = here / name
        d.mkdir(parents=True, exist_ok=True)
        p = d / f"{name}.but"
        if force or not p.exists() or p.read_text() != content:
            p.write_text(content); written += 1
    return written, len(wanted)


def _strip_flags(content):
    for pat in (r"Flag\(TypeOn\([^)]+\)\)\s*&\s*", r"Flag\(TraceOn\([^)]+\)\)\s*&\s*",
                r"Flag\(FileOn\([^)]+\)\)\s*&\s*"):
        content = re.sub(pat, "", content)
    return content


# ── apero: CLEARSY's open PO corpus (POG XML → PP rule-validation .but) ────
# Dataset: 5 434 .pog files, 36 Atelier B projects (DOI 10.5281/zenodo.7050797).
# Point PP2LP_APERO_POG at the extracted `zenodo-dataset-pog-20220905` dir
# (default: vendor/apero/pog).  There is no Atelier B path from .pog to PP —
# the modern proof-mechanism drivers all target SMT/TPTP — so we render each
# obligation into PP's own rule-validator input, the same .but shape Atelier B
# writes for the prv corpus.
#
# The pipeline is the same five stages the other suites use, one gen verb each:
#   buts    pog2but + selection — gen_apero_buts renders every obligation,
#           applies the premise cap (PP2LP_APERO_MAX_PREMISE), dedups identical
#           content, and writes one NAME/NAME.but per selected goal (wiping dirs
#           outside the selection).  No Atelier B; the corpus + cap are this
#           suite's source of truth, as goals.txt is for the others.
#   traces  PP — gen_apero_traces proves the .but files in parallel
#           (PP2LP_GEN_JOBS, timer PP2LP_APERO_TIMER, default R45) → .trace.
#   replays REPLAY → .replay (shared gen_replays); a .trace with no .replay is a
#           REPLAY loss, left in place and simply skipped by `run`.
# Then `run` emits .lp and type-checks (stages 4–5).  State is per-dir on disk
# (no central ledger): each stage skips inputs whose output is already current.
# The ~600k-goal corpus is gitignored and reproducible from the dataset + cap.

_APERO_NS = "{https://www.atelierb.eu/Formats/pog}"

class _AperoUnsupported(Exception):
    pass

_APERO_CMP = {":": ":", "/:": "/:", "<:": "<:", "/<:": "/<:", "<<:": "<<:",
              "/<<:": "/<<:", "=": "=", "/=": "/=",
              "<=i": "<=", "<i": "<", ">=i": ">=", ">i": ">",
              "<=f": "<=", "<f": "<", ">=f": ">=", ">f": ">",
              "<=": "<=", "<": "<", ">=": ">=", ">": ">"}
_APERO_BIN = {"+i": "+", "-i": "-", "*i": "*", "/i": "/", "**i": "**",
              "+f": "+", "-f": "-", "*f": "*", "/f": "/",
              "-s": "-", "*s": "*", "+s": "+"}
_APERO_UN = {"imax": "max", "imin": "min", "rmax": "max", "rmin": "min"}

# Hypothesis-size selection.  PP proves ~98% of converted obligations regardless
# of size, but REPLAY truncates and lambdapi times out as the hypothesis context
# grows: measured replay-completeness is 72% at <=5 premises, 46% at 25-50, 25%
# at 50-100, and 0% at >=1000 (corpus median is ~580).  Capping the premise
# count (top-level & conjuncts of the rendered hypothesis) keeps gen's PP/REPLAY
# time on the tractable band — ~4k corpus-wide at the default — instead of the
# big-context monsters that always truncate.  0 = no cap (the full corpus).
_APERO_MAX_PREMISE = int(os.environ.get("PP2LP_APERO_MAX_PREMISE", "50"))


def _apero_src() -> Path:
    return Path(os.environ.get("PP2LP_APERO_POG")
                or str(ROOT / "vendor" / "apero" / "pog"))


def _ap_tag(el):
    return el.tag.replace(_APERO_NS, "")


def _ap_exp(el) -> str:
    t = _ap_tag(el)
    if t == "Id":
        v = el.get("value")
        s = el.get("suffix")
        return f"{v}${s}" if s else v
    if t == "Integer_Literal":
        return el.get("value")
    if t == "Boolean_Literal":
        return el.get("value")
    if t == "EmptySet":
        return "{}"
    if t == "EmptySeq":
        return "[]"
    if t == "Boolean_Exp":
        return f"bool({_ap_prd(el[0])})"
    if t == "Unary_Exp":
        op = el.get("op")
        a = _ap_exp(el[0])
        if op == "~":
            return f"({a})~"
        if op in ("-i", "-"):
            return f"(-({a}))"
        return f"{_APERO_UN.get(op, op)}({a})"
    if t == "Binary_Exp":
        op = el.get("op")
        a, b = _ap_exp(el[0]), _ap_exp(el[1])
        if op == "(":
            return f"{a}({b})"
        if op == "[":
            return f"({a})[{b}]"
        if op == "'":
            raise _AperoUnsupported("record field access")
        return f"({a} {_APERO_BIN.get(op, op)} {b})"
    if t == "Nary_Exp":
        op = el.get("op")
        parts = [_ap_exp(c) for c in el]
        if op == "{":
            return "{" + ", ".join(parts) + "}"
        if op == "[":
            return "[" + ", ".join(parts) + "]"
        raise _AperoUnsupported(f"nary exp {op!r}")
    if t == "Quantified_Exp":
        op = el.get("op") or el.get("type")
        name = {"%": "%", "iSIGMA": "SIGMA", "iPI": "PI", "rSIGMA": "SIGMA",
                "UNION": "UNION", "INTER": "INTER"}.get(op)
        if name is None:
            raise _AperoUnsupported(f"quantified exp {op!r}")
        vs = ",".join(_ap_exp(v) for v in el.find(f"{_APERO_NS}Variables"))
        pred = _ap_prd(el.find(f"{_APERO_NS}Pred")[0])
        body = _ap_exp(el.find(f"{_APERO_NS}Body")[0])
        return f"{name}({vs}).({pred} | {body})"
    raise _AperoUnsupported(f"exp node {t}")


def _ap_prd(el) -> str:
    t = _ap_tag(el)
    if t == "Exp_Comparison":
        op = el.get("op")
        if op not in _APERO_CMP:
            raise _AperoUnsupported(f"comparison {op!r}")
        return f"({_ap_exp(el[0])} {_APERO_CMP[op]} {_ap_exp(el[1])})"
    if t == "Nary_Pred":
        op = el.get("op")
        if op not in ("&", "or"):
            raise _AperoUnsupported(f"nary pred {op!r}")
        return "(" + f" {op} ".join(_ap_prd(c) for c in el) + ")"
    if t == "Binary_Pred":
        op = el.get("op")
        if op not in ("=>", "<=>"):
            raise _AperoUnsupported(f"binary pred {op!r}")
        return f"({_ap_prd(el[0])} {op} {_ap_prd(el[1])})"
    if t == "Unary_Pred":
        return f"not({_ap_prd(el[0])})"
    if t == "Quantified_Pred":
        op = el.get("op") or el.get("type")
        if op not in ("!", "#"):
            raise _AperoUnsupported(f"quantifier {op!r}")
        vs = ",".join(_ap_exp(v) for v in el.find(f"{_APERO_NS}Variables"))
        return f"{op}({vs}).({_ap_prd(el.find(f'{_APERO_NS}Body')[0])})"
    if t == "Set":
        enum = el.find(f"{_APERO_NS}Enumerated_Values")
        if enum is None:
            return ""                  # deferred set: no usable hypothesis
        sid = _ap_exp(el.find(f"{_APERO_NS}Id"))
        return f"({sid} = {{{', '.join(_ap_exp(c) for c in enum)}}})"
    raise _AperoUnsupported(f"pred node {t}")


def _ap_premises(el) -> int:
    """Number of top-level conjuncts an element contributes to the hypothesis
    (Nary '&' flattened recursively) — the count PP/REPLAY actually sees."""
    if _ap_tag(el) == "Nary_Pred" and el.get("op") == "&":
        return sum(_ap_premises(c) for c in el)
    return 1


def _apero_goals(pogfile: Path):
    """Yield (name, but_content_or_None, drop_reason) per simple goal, with the
    obligation's full hypothesis set (Definition refs + Hypothesis + the goal's
    Ref_Hyp'd Local_Hyps).  drop_reason is an unsupported-node message, or
    "premises>N" when the premise count exceeds _APERO_MAX_PREMISE."""
    root = ET.parse(pogfile).getroot()
    defs = {d.get("name"): list(d) for d in root.findall(f"{_APERO_NS}Define")}
    proj, stem = pogfile.parent.name, pogfile.stem
    for i, po in enumerate(root.findall(f"{_APERO_NS}Proof_Obligation")):
        hyp_els = []
        for dref in po.findall(f"{_APERO_NS}Definition"):
            hyp_els += defs.get(dref.get("name"), [])
        hyp_els += [h[0] for h in po.findall(f"{_APERO_NS}Hypothesis")]
        loc = {h.get("num"): h for h in po.findall(f"{_APERO_NS}Local_Hyp")}
        base_prem = sum(_ap_premises(h) for h in hyp_els)
        for j, sg in enumerate(po.findall(f"{_APERO_NS}Simple_Goal")):
            name = f"ap_{proj}_{stem}_po{i}_g{j}"
            refs = [loc[r.get("num")][0]
                    for r in sg.findall(f"{_APERO_NS}Ref_Hyp")
                    if r.get("num") in loc]
            try:
                hyps = [s for s in (_ap_prd(h) for h in hyp_els) if s]
                lh = [_ap_prd(r) for r in refs]
                goal = _ap_prd(sg.find(f"{_APERO_NS}Goal")[0])
            except _AperoUnsupported as e:
                yield name, None, str(e)
                continue
            if _APERO_MAX_PREMISE:
                n_prem = base_prem + sum(_ap_premises(r) for r in refs)
                if n_prem > _APERO_MAX_PREMISE:
                    yield name, None, f"premises>{_APERO_MAX_PREMISE}"
                    continue
            hyp = " & ".join(hyps + [s for s in lh if s]) or "1 = 1"
            yield name, f"Set(Valid.1 | Rule(Implication | {hyp} | ? | ? | {goal} | nn))\n", None


def gen_apero_buts(force=False):
    """Stage 1 — pog2but + selection.  Walk the apero POG corpus, render every
    obligation with the pog2but converter, apply the premise cap
    (PP2LP_APERO_MAX_PREMISE), dedup identical content, and materialise one
    NAME/NAME.but per selected goal — wiping apero dirs outside the current
    selection (the corpus + cap are this suite's source of truth, as goals.txt
    is for the others).  No Atelier B; deterministic.  Writes are content-aware,
    so an unchanged .but keeps its mtime and the trace/replay stages can skip it.
    Returns a stats dict."""
    src = _apero_src()
    if not src.is_dir():
        sys.exit(f"pp2lp: apero POG dataset not found at {src}\n"
                 "  extract https://doi.org/10.5281/zenodo.7050797 and point "
                 "PP2LP_APERO_POG at the zenodo-dataset-pog-20220905 directory "
                 "(or symlink it to vendor/apero/pog)")
    here = BENCH / "apero"
    here.mkdir(parents=True, exist_ok=True)
    # One-time migration off the legacy fused-pipeline ledger: those dirs predate
    # the premise cap and the staged layout, so wipe them and rebuild clean.
    legacy = here / ".gen_ledger.json"
    if legacy.exists():
        for d in sorted(p for p in here.iterdir() if p.is_dir()):
            _rm_benchmark(d)
        legacy.unlink()

    files = sorted(src.glob("*/*.pog"), key=lambda p: p.stat().st_size)
    wanted: dict[str, str] = {}        # name -> .but content (deduped by content)
    seen: set[str] = set()             # content hashes
    stats = {"goals": 0, "unsupported": 0, "capped": 0, "dups": 0, "selected": 0}
    unsup_reasons: dict[str, int] = {}
    t0 = time.time()
    last_line = last_tty = 0.0

    def progress(i):
        nonlocal last_line, last_tty
        now = time.time()
        line = (f"pog {i}/{len(files)} files · {stats['goals']} goals · "
                f"{stats['selected']} selected · {stats['dups']} dups · "
                f"{stats['unsupported']} unsup · {stats['capped']} capped · "
                f"{(now - t0) / 60:.0f}m")
        if IS_TTY:
            if now - last_tty >= 0.2:
                sys.stdout.write("\r\033[K  " + dim(line)); sys.stdout.flush()
                last_tty = now
        elif now - last_line >= 60:
            print("  " + line, flush=True); last_line = now

    for i, pog in enumerate(files, 1):
        for name, content, drop in _apero_goals(pog):
            stats["goals"] += 1
            if drop is not None:
                if drop.startswith("premises>"):
                    stats["capped"] += 1
                else:
                    stats["unsupported"] += 1
                    unsup_reasons[drop] = unsup_reasons.get(drop, 0) + 1
                continue
            h = hashlib.sha1(content.encode()).hexdigest()
            if h in seen:
                stats["dups"] += 1; continue
            seen.add(h); wanted[name] = content; stats["selected"] += 1
        progress(i)
    if IS_TTY:
        sys.stdout.write("\r\033[K"); sys.stdout.flush()

    # Wipe dirs outside the selection, then write .but content-aware.
    for p in here.glob("*/*.but"):
        if p.stem not in wanted:
            _rm_benchmark(p.parent)
    written = 0
    for name, content in wanted.items():
        d = here / name; d.mkdir(parents=True, exist_ok=True)
        bp = d / f"{name}.but"
        if force or not bp.exists() or bp.read_text() != content:
            bp.write_text(content); written += 1
    stats["written"] = written
    stats["unsup_reasons"] = dict(sorted(unsup_reasons.items(), key=lambda kv: -kv[1]))
    return stats


def _pp_one_but(krt, pp_kin, timer, but):
    """Prove one selected .but in its own dir; write .trace on success.  Returns
    (stem, verdict) with verdict in proved / no-proof / pp-timeout / saturation*."""
    stem, d = but.stem, but.parent
    content = (f'Flag(TraceOn("{stem}.trace")) & Flag(FileOn("{stem}.res")) & '
               + _strip_flags(but.read_text()))
    goal = d / f"{stem}.goal"
    goal.write_text(content)
    okk, _o, reason = run_krt(krt, pp_kin, goal.name, str(d), timer=timer)
    goal.unlink(missing_ok=True)
    (d / f"{stem}.res").unlink(missing_ok=True)
    trace = d / f"{stem}.trace"
    if okk and trace.exists() and trace.read_bytes().strip():
        return stem, "proved"
    trace.unlink(missing_ok=True)
    if reason.startswith("timer") or reason == "timeout":
        return stem, "pp-timeout"
    if reason.startswith("saturation"):
        return stem, reason
    return stem, "no-proof"


def gen_apero_traces(krt, force=False):
    """Stage 2 — PP.  Prove each selected .but in parallel (PP2LP_GEN_JOBS),
    writing .trace on success; a .but whose .trace is up to date is skipped.
    Records a PP-verdict histogram for the funnel.  Returns a stats dict."""
    pp_kin = find_kin(["/opt/atelierb-free-24.04.2/bin/PP.kin",
                       os.path.expanduser("~/atelierb/bin/PP.kin")])
    if not pp_kin:
        sys.exit("pp2lp: PP.kin not found")
    timer = os.environ.get("PP2LP_APERO_TIMER", "R45")
    jobs = int(os.environ.get("PP2LP_GEN_JOBS") or max(4, (os.cpu_count() or 8) // 2))
    here = BENCH / "apero"
    buts = sorted(here.glob("*/*.but"))
    stats = {"proved": 0, "no-proof": 0, "pp-timeout": 0, "saturation": 0, "skip": 0}
    todo = []
    for but in buts:
        trace = but.parent / f"{but.stem}.trace"
        if not force and trace.exists() and trace.stat().st_mtime >= but.stat().st_mtime:
            stats["skip"] += 1
        else:
            todo.append(but)

    t0 = time.time()
    done = 0
    last_line = last_tty = 0.0
    sig_seen = []

    def _on_sig(signum, _frame):
        sig_seen.append(signum)
        raise KeyboardInterrupt

    def progress():
        nonlocal last_line, last_tty
        now = time.time()
        line = (f"pp {done}/{len(todo)} · {stats['proved']} proved · "
                f"{stats['no-proof']} unproved · {stats['pp-timeout']} t/o · "
                f"{stats['saturation']} sat · {stats['skip']} skip · {(now - t0) / 60:.0f}m")
        if IS_TTY:
            if now - last_tty >= 0.2:
                sys.stdout.write("\r\033[K  " + dim(line)); sys.stdout.flush()
                last_tty = now
        elif now - last_line >= 60:
            print("  " + line, flush=True); last_line = now

    ex = concurrent.futures.ThreadPoolExecutor(max_workers=jobs)
    old_int = signal.signal(signal.SIGINT, _on_sig)
    old_term = signal.signal(signal.SIGTERM, _on_sig)
    interrupted = False
    try:
        futs = {ex.submit(_pp_one_but, krt, pp_kin, timer, b): b for b in todo}
        for f in concurrent.futures.as_completed(futs):
            _stem, verdict = f.result()
            stats[verdict if verdict in stats else "saturation"] += 1
            done += 1
            progress()
    except KeyboardInterrupt:
        interrupted = True
        for p in list(_KRT_LIVE):              # unblock worker threads immediately
            try:
                p.kill()
            except OSError:
                pass
    finally:
        signal.signal(signal.SIGINT, old_int)
        signal.signal(signal.SIGTERM, old_term)
        ex.shutdown(wait=True, cancel_futures=True)
        if IS_TTY:
            sys.stdout.write("\r\033[K"); sys.stdout.flush()
    if interrupted:
        print(yellow(f"  pp:      interrupted — {done} proved-or-decided this run; "
                     f"rerun `pp2lp gen apero --only traces` to resume"))
        sys.exit(128 + (sig_seen[0] if sig_seen else 2))
    return stats


def gen_traces(suite, krt, force=False):
    pp_kin = find_kin(["/opt/atelierb-free-24.04.2/bin/PP.kin",
                       os.path.expanduser("~/atelierb/bin/PP.kin")])
    if not pp_kin:
        sys.exit("pp2lp: PP.kin not found")
    here = BENCH / suite
    buts = sorted(here.glob("*/*.but"))
    ok = fail = skip = 0
    for but in buts:
        stem, d = but.stem, but.parent
        trace = d / f"{stem}.trace"
        if not force and trace.exists() and trace.stat().st_mtime >= but.stat().st_mtime:
            skip += 1; continue
        content = f'Flag(TraceOn("{stem}.trace")) & Flag(FileOn("{stem}.res")) & ' + _strip_flags(but.read_text())
        goal = d / f"{stem}.goal"
        goal.write_text(content)
        okk, _o, _r = run_krt(krt, pp_kin, goal.name, str(d))
        goal.unlink(missing_ok=True)
        (d / f"{stem}.res").unlink(missing_ok=True)
        if okk and trace.exists() and trace.read_bytes().strip():
            ok += 1
        else:
            trace.unlink(missing_ok=True); fail += 1
    return ok, fail, skip


def gen_replays(suite, krt, force=False):
    replay_kin = find_kin([ROOT / "vendor/atelierb/linux_x64/REPLAY.kin",
                           "/opt/atelierb-free-24.04.2/bin/REPLAY.kin"])
    if not replay_kin:
        sys.exit("pp2lp: REPLAY.kin not found")
    here = BENCH / suite
    traces = sorted(here.glob("*/*.trace"))
    ok = fail = skip = dropped = 0
    done, t0 = 0, time.time()
    last_line = last_tty = 0.0

    def _line(stem):
        el = (time.time() - t0) / 60
        return (f"replays {done}/{len(traces)} · {ok} ok · {dropped} dropped · "
                f"{fail} failed · {skip} up-to-date · {el:.0f}m · {stem}")

    def progress(stem, force_draw=False):
        nonlocal last_tty, last_line
        now = time.time()
        if IS_TTY:
            if force_draw or now - last_tty >= 0.2:    # throttle terminal rewrites
                sys.stdout.write("\r\033[K  " + dim(_line(stem)))
                sys.stdout.flush()
                last_tty = now
        elif now - last_line >= 60:                    # piped/nohup: one line a minute
            print("  " + _line(stem), flush=True)
            last_line = now

    def clear_progress():
        if IS_TTY:
            sys.stdout.write("\r\033[K")
            sys.stdout.flush()

    try:
        for tr in traces:
            stem, d = tr.stem, tr.parent
            done += 1
            replay = d / f"{stem}.replay"
            if not force and replay.exists() and replay.stat().st_mtime >= tr.stat().st_mtime:
                skip += 1
                progress(stem)
                continue
            progress(stem, force_draw=True)   # the name on screen is the one running
            goal = d / f"{stem}.replay.goal"
            goal.write_text(f'Flag(FileOn("{stem}.replay.res")) & ("{tr}")')
            okk, out, _r = run_krt(krt, replay_kin, goal.name, str(d),
                                   patterns=_SATURATION + _REPLAY_EXTRA)
            goal.unlink(missing_ok=True)
            (d / f"{stem}.replay.res").unlink(missing_ok=True)
            misc = d / stem
            if misc.is_file() and misc.suffix == "":
                misc.unlink()
            if not (okk and out and len(out) > 10):
                fail += 1; continue
            # tmp+rename: an interrupt must not leave a half-written replay that
            # a resume would then skip as up-to-date.
            tmp = d / f"{stem}.replay.tmp"
            tmp.write_text(out)
            tmp.replace(replay)
            # Hygiene: a REPLAY-truncated replay (the tool dropped the ALL7/XST8
            # continuation) can't be emitted — drop it from the suite, loudly.  Other
            # emit failures are real bugs and kept, to surface at `run` time.
            probe = emit(replay, d / f"{stem}.lp")
            (d / f"{stem}.lp").unlink(missing_ok=True)
            if not probe["ok"] and (probe.get("error") or {}).get("code") == "E_REPLAY_TRUNCATED":
                replay.unlink(missing_ok=True)
                hint = ("prune it from goals.txt"
                        if (BENCH / suite / "goals.txt").exists() else "upstream REPLAY loss")
                clear_progress()
                print(yellow(f"  ⚠ dropped {stem}: truncated replay "
                             f"(REPLAY dropped the ALL7/XST8 continuation; {hint})"))
                dropped += 1
            else:
                ok += 1
    except KeyboardInterrupt:
        clear_progress()
        print(yellow(f"  replays: interrupted at {done}/{len(traces)} — the stage is "
                     f"incremental; rerun `pp2lp gen {suite} --only replays` to resume"))
        sys.exit(130)
    clear_progress()
    return ok, fail, skip, dropped


def cmd_gen(args) -> int:
    """The `gen` verb: (re)generate a suite's inputs via krt.  Incremental by
    default — a stage skips items whose output is newer than its input; pass
    --force to regenerate everything."""
    suite = args.target.split("/", 1)[0]
    if not args.quiet:
        print(dim(f"gen {suite}: {args.only}" + ("  (--force)" if args.force else "")))
    _gen_stages(suite, args.only, force=args.force)
    return 0


def _gen_stages(suite: str, stages_str: str, force: bool = False) -> None:
    here = BENCH / suite
    krt = None

    def get_krt():
        nonlocal krt
        if krt is None:
            krt = find_krt()
            if not krt:
                sys.exit("pp2lp: krt (Atelier B) not found — install it or set it on PATH")
        return krt

    for st in [s.strip() for s in stages_str.split(",") if s.strip()]:
        if st == "buts":
            if suite == "apero":
                s = gen_apero_buts(force=force)
                print(dim(f"  buts:    {s['goals']} goals → {s['selected']} selected "
                          f"({s['written']} written; {s['dups']} dups, "
                          f"{s['unsupported']} unsupported, "
                          f"{s['capped']} capped >{_APERO_MAX_PREMISE} prem)"))
                if s["unsup_reasons"]:
                    top = ", ".join(f"{k} ×{v}"
                                    for k, v in list(s["unsup_reasons"].items())[:6])
                    print(dim(f"           unsupported: {top}"))
                continue
            r = gen_buts(suite, force=force)
            print(dim("  buts:    no goals.txt — skipped") if r is None
                  else dim(f"  buts:    {r[0]} written, {r[1] - r[0]} unchanged"))
        elif st == "traces":
            if not list(here.glob("*/*.but")):
                hint = "run `gen apero --only buts` first" if suite == "apero" else "skipped"
                print(dim(f"  traces:  no .but files — {hint}")); continue
            if suite == "apero":
                s = gen_apero_traces(get_krt(), force=force)
                print(dim(f"  traces:  {s['proved']} proved "
                          f"({s['no-proof']} unproved, {s['pp-timeout']} timeout, "
                          f"{s['saturation']} saturated, {s['skip']} up-to-date)"))
                continue
            ok, fail, skip = gen_traces(suite, get_krt(), force=force)
            print(dim(f"  traces:  {ok} ok, {fail} failed, {skip} up-to-date"))
        elif st == "replays":
            if not list(here.glob("*/*.trace")):
                print(dim("  replays: no .trace files — skipped")); continue
            okb, errb = ensure_build()      # replay hygiene shells out to the engine
            if not okb:
                sys.exit(f"pp2lp: engine build failed (needed for replay hygiene):\n{errb}")
            ok, fail, skip, dropped = gen_replays(suite, get_krt(), force=force)
            tail = f", {dropped} dropped (truncated)" if dropped else ""
            print(dim(f"  replays: {ok} ok, {fail} failed, {skip} up-to-date{tail}"))
        else:
            sys.exit(f"pp2lp: unknown --gen stage {st!r} (buts|traces|replays)")


# ── clean: drop stale .lpo object caches ────────────────────────────────────
def _lambdapi_lib_root() -> Path | None:
    """The lambdapi standard-library root (where the Stdlib `.lpo` cache lives),
    following lambdapi's own resolution order."""
    for env in ("LAMBDAPI_LIB_ROOT", "OPAM_SWITCH_PREFIX"):
        base = os.environ.get(env)
        if base and (p := Path(base) / "lib" / "lambdapi" / "lib_root").is_dir():
            return p
    for p in [Path("/usr/local/lib/lambdapi/lib_root"),
              *sorted(Path.home().glob(".opam/*/lib/lambdapi/lib_root"))]:
        if p.is_dir():
            return p
    return None


def cmd_clean(args) -> int:
    """Remove stale `.lpo` objects — both the project's (lp/) and the shared
    Stdlib's, which go incompatible after a lambdapi rebuild ("File X.lpo is
    incompatible with current binary").  They recompile on the next check."""
    targets = [(ROOT / "lp", "project")]
    if (root := _lambdapi_lib_root()) is not None:
        targets.append((root, "Stdlib"))
    total = 0
    for base, label in targets:
        lpos = list(base.rglob("*.lpo"))
        for f in lpos:
            f.unlink()
        total += len(lpos)
        print(dim(f"  {label}: {len(lpos)} removed under {base}"))
    print(green(f"clean: removed {total} stale .lpo file(s)"))
    return 0


# ── argparse ───────────────────────────────────────────────────────────────
def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="pp2lp",
        description="translate Atelier B Predicate-Prover replays to Lambdapi and type-check them")
    sub = p.add_subparsers(dest="cmd")

    r = sub.add_parser("run", help="emit + type-check a suite or one trace",
                       description="emit + type-check a SUITE (strict gate) or SUITE/NAME "
                                   "(dossier).  Results stream live; a failure shows panels "
                                   "from the related files — the <name>.probe.lp with the "
                                   "lambdapi goal state, the .replay step, and the lp/rules "
                                   "signature; --lp-debug adds the cleaned lambdapi trace.")
    r.add_argument("target", nargs="?", default="og", help="SUITE or SUITE/NAME (default: og)")
    r.add_argument("-q", "--quiet", action="store_true", help="summary only (no live stream)")
    r.add_argument("--lp-debug", nargs="?", const="u", default=None, metavar="CODE",
                   help="on failure, also run lambdapi `debug +CODE` in the goal-state probe "
                        "and surface the cleaned trace.  CODE is raw lambdapi flags "
                        "(u=unification, r=rewrite, t=tactics, w=whnf; default u).  "
                        "avoid i — it crashes lambdapi's printer on our HO goals")
    r.add_argument("--json", action="store_true", help="machine-readable output")
    r.add_argument("--no-build", action="store_true", help="skip the implicit dune build")
    r.add_argument("--filter", metavar="REGEX", default=None,
                   help="restrict a suite run to benchmark names matching REGEX "
                        "(composes with --json/-q)")

    g = sub.add_parser("gen", help="(re)generate suite inputs via Atelier B krt",
                       description="run PP/REPLAY (krt) to (re)build a suite's "
                                   ".but/.trace/.replay.  The apero suite converts the "
                                   "CLEARSY POG corpus instead of a goals.txt "
                                   "(PP2LP_APERO_POG points at the dataset; "
                                   "PP2LP_APERO_TIMER and PP2LP_GEN_JOBS tune the PP pass; "
                                   "resumable, --force resets the ledger)")
    g.add_argument("target", nargs="?", default="claude", help="SUITE (default: claude)")
    g.add_argument("--only", default="buts,traces,replays", metavar="STAGES",
                   help="comma-separated subset of buts,traces,replays (default: all)")
    g.add_argument("--force", action="store_true",
                   help="regenerate even when an output is newer than its input")
    g.add_argument("-q", "--quiet", action="store_true", help="suppress per-stage detail")

    sub.add_parser("clean", help="remove stale .lpo object caches (project lp/ + Stdlib)",
                   description="delete stale lambdapi `.lpo` objects under lp/ and the "
                               "Stdlib lib_root; they recompile on the next check.  Use "
                               "after a lambdapi rebuild reports an incompatible .lpo.")
    return p


def main(argv=None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    if args.cmd == "run":
        return cmd_run(args)
    if args.cmd == "gen":
        return cmd_gen(args)
    if args.cmd == "clean":
        return cmd_clean(args)
    parser.print_help(sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main())
