try:
    import resource  # POSIX-only; caps child address space / CPU
except ImportError:  # pragma: no cover
    resource = None

ROOT = Path(__file__).resolve().parent
ENGINE = ROOT / "ocaml" / "_build" / "default" / "bin" / "main.exe"
BENCH = ROOT / "lp" / "bench"
RESULTS_DIR = BENCH / "results"

# ── Safety caps for child processes (env-tunable; 0 disables) ──────────────
CHECK_TIMEOUT = float(os.environ.get("PP2LP_CHECK_TIMEOUT", "10"))   # lambdapi, s
EMIT_TIMEOUT = float(os.environ.get("PP2LP_EMIT_TIMEOUT", "10"))     # engine emit, s
GEN_TIMEOUT = float(os.environ.get("PP2LP_GEN_TIMEOUT", "10"))       # krt PP/REPLAY, s
CHILD_MEM_GB = float(os.environ.get("PP2LP_CHECK_MEM_GB", "4"))      # RLIMIT_AS, GiB
MAX_FAIL_WINDOWS = int(os.environ.get("PP2LP_MAX_WINDOWS", "15"))    # full failure windows per suite run (0 = no cap)

# ── Colour ─────────────────────────────────────────────────────────────────
IS_TTY = sys.stdout.isatty()
COLOR = IS_TTY and not os.environ.get("NO_COLOR")


def _c(code, t):
    return f"\033[{code}m{t}\033[0m" if COLOR else str(t)


def green(t):  return _c("32", t)
def yellow(t): return _c("33", t)
def red(t):    return _c("31", t)
def dim(t):    return _c("2", t)
def bold(t):   return _c("1", t)


ICON = {"ok": green("✓"), "warn": yellow("⚠"), "emit_fail": red("✗"),
        "lp_fail": red("✗"), "no_lp": yellow("⊘")}

# Statuses that count as a benchmark failure (non-zero exit + by-code histogram):
# emit_fail from `run` (emit), lp_fail/no_lp from `check` (type-check).
FAIL = ("emit_fail", "lp_fail", "no_lp")


def fmt_ms(ms: float) -> str:
    return f"{ms / 1000:.1f}s" if ms >= 1000 else f"{ms:.0f}ms"


# ── Child-process limits ───────────────────────────────────────────────────
def _child_limits(timeout: float):
    if resource is None or os.name != "posix":
        return None

    def apply():
        if CHILD_MEM_GB > 0:
            n = int(CHILD_MEM_GB * 1024 ** 3)
            try:
                resource.setrlimit(resource.RLIMIT_AS, (n, n))
            except (ValueError, OSError):
                pass
        if timeout > 0:
            cpu = int(timeout) + 10
            try:
                resource.setrlimit(resource.RLIMIT_CPU, (cpu, cpu))
            except (ValueError, OSError):
                pass

    return apply


def _run_lambdapi(args, timeout=CHECK_TIMEOUT):
    """Run `lambdapi check <args>` under the standard safety caps: wall-clock
    `timeout` (per-goal CHECK_TIMEOUT by default), RLIMIT_AS/CPU via
    _child_limits, and its own session group so a runaway child can't take
    down the host.  The single place those caps are wired — callers handle
    FileNotFoundError / TimeoutExpired."""
    return subprocess.run(["lambdapi", "check", *args],
                          capture_output=True, text=True,
                          timeout=timeout or None,
                          preexec_fn=_child_limits(timeout),
                          start_new_session=True)


# ── Build the engine ───────────────────────────────────────────────────────
def ensure_build() -> tuple[bool, str]:
    try:
        r = subprocess.run(["dune", "build"], cwd=ROOT / "ocaml",
                           capture_output=True, text=True)
    except FileNotFoundError:
        return False, "dune not found on PATH"
    return r.returncode == 0, r.stderr.strip()


# ── Error classification: engine stderr text → code ────────────────────────
# The engine's messages are stable (we own them).  Map them to a machine code,
# mirroring CLAUDE.md's "Common errors" table.
_ERROR_RULES = [
    (re.compile(r"unknown rule"),               "E_UNKNOWN_RULE"),
    (re.compile(r"unsupported arity"),          "E_ARITY"),
    (re.compile(r"arity \d+ unsupported"),      "E_DISPATCH"),
    # `impossible case in rpl*` is REPLAY itself giving up mid-file (its error
    # text lands verbatim in the .replay) — same upstream-loss family as the
    # dropped ALL7/XST8 continuations, so classify it for the gen-time drop.
    (re.compile(r"no sequent continuation|REPLAY truncated|impossible case in rpl"),
     "E_REPLAY_TRUNCATED"),
    (re.compile(r"INS contradiction"),          "E_INS"),
    (re.compile(r"tree-build error|unconsumed|expected a .*child"), "E_TREE_BUILD"),
    (re.compile(r"parse error|replay-line parse|unrecognised line"), "E_PARSE"),
]


# Engine emit failures carry a stable `E_CODE: message` prefix at the raise
# site (ocaml/src/errors.ml), so classify by that first.  The message-regex
# above stays the fallback for the exception-based parse/tree channel
# (Bad_replay, which dual-classifies to E_REPLAY_TRUNCATED) and for old logs.
_CODE_PREFIX = re.compile(
    r"\bE_(?:UNKNOWN_RULE|ARITY|DISPATCH|TREE_BUILD|PARSE|INS|EMIT)(?=:)")


def classify_error(text: str) -> str:
    m = _CODE_PREFIX.search(text)
    if m:
        return m.group(0)
    for rx, code in _ERROR_RULES:
        if rx.search(text):
            return code
    return "E_EMIT"


# ── Provenance: the engine writes a side-channel line→rule TSV (no comments
#    in the generated .lp); we read it back and join errors to rules. ───────
def read_map(path: Path) -> list[dict]:
    """Parse the engine's provenance TSV: lp_line, rule, replay_line, goal."""
    out = []
    try:
        for line in path.read_text(encoding="utf-8").splitlines():
            parts = line.split("\t", 3)
            if len(parts) == 4:
                out.append({"lp_line": int(parts[0]), "rule": parts[1],
                            "replay_line": int(parts[2]), "goal": parts[3]})
    except (OSError, ValueError):
        pass
    return out


def join_prov(lp_line: int, smap: list[dict]) -> dict | None:
    """Nearest-preceding provenance entry for a given .lp line — i.e. the rule
    whose emitted block the error falls inside."""
    best = None
    for e in smap:
        if e["lp_line"] <= lp_line and (best is None or e["lp_line"] > best["lp_line"]):
            best = e
    return best


# ── Run the engine ─────────────────────────────────────────────────────────
def engine(*engine_args, env=None, timeout=EMIT_TIMEOUT):
    return subprocess.run(
        [str(ENGINE), *engine_args], cwd=ROOT, capture_output=True, text=True,
        timeout=timeout or None, preexec_fn=_child_limits(timeout),
        start_new_session=True, env=env)


def rel(p: Path) -> str:
    return str(p.relative_to(ROOT)) if p.is_relative_to(ROOT) else str(p)


def _collapse(lines: list[str]) -> list[str]:
    """Fold runs of identical lines into one, annotated `… (×N)`, preserving
    first-seen order — so a flood of identical lexer warnings reads as a single
    line instead of burying the real message."""
    counts: dict[str, int] = {}
    for l in lines:
        counts[l] = counts.get(l, 0) + 1
    seen: set[str] = set()
    out: list[str] = []
    for l in lines:
        if l in seen:
            continue
        seen.add(l)
        out.append(f"{l}  (×{counts[l]})" if counts[l] > 1 else l)
    return out


def emit(replay: Path, out: Path, map_path: Path | None = None,
         timeout: float | None = None) -> dict:
    """Emit the clean .lp (no comments) and the side-channel provenance map.
    With `map_path` the map is persisted there — so a later `pp2lp check` can
    join a lambdapi error back to its PP rule — otherwise a temp file is used and
    discarded.  `timeout` overrides EMIT_TIMEOUT (None ⇒ the default).  The .lp is
    written content-aware: it is rewritten only when the emitted text differs, so
    an unchanged emit keeps its mtime (and its `.lpo`) and `check` reuses the
    cached object instead of re-checking.  Returns {ok, warnings, error|None,
    smap, changed}."""
    out.parent.mkdir(parents=True, exist_ok=True)
    eff = timeout if timeout is not None else EMIT_TIMEOUT
    if map_path is None:
        fd, mappath = tempfile.mkstemp(suffix=".provmap")
        os.close(fd)
        mapfile, persist = Path(mappath), False
    else:
        mapfile, persist = map_path, True
    try:
        try:
            r = engine("emit", "--map", str(mapfile), rel(replay), timeout=eff)
        except FileNotFoundError:
            return {"ok": False, "warnings": [],
                    "error": {"code": "E_NO_ENGINE", "message": "engine binary missing"}}
        except subprocess.TimeoutExpired:
            return {"ok": False, "warnings": [],
                    "error": {"code": "E_TIMEOUT",
                              "message": f"emit timed out after {eff:.0f}s"}}
        warns, errors = [], []
        for l in r.stderr.splitlines():
            if not l:
                continue
            if l.startswith("WARNING: "):
                warns.append(l[len("WARNING: "):])
            elif l[:8].lower() == "warning:":      # ocamllex lexer warnings (lowercase)
                warns.append(l[8:].lstrip())
            else:
                errors.append(l)
        warnings = _collapse(warns)
        if r.returncode != 0:
            if persist:
                mapfile.unlink(missing_ok=True)    # a failed emit leaves no usable map
            msg = "\n".join(_collapse(errors)) or r.stderr.strip()
            code = classify_error(msg)
            return {"ok": False, "warnings": warnings,
                    "error": {"code": code, "message": msg}}
        # Content-aware: only rewrite (and invalidate the .lpo) when the text
        # changed.  The provenance map's mtime is irrelevant to lambdapi, so the
        # engine just overwrites it each time.
        changed = (not out.exists()) or out.read_text(encoding="utf-8") != r.stdout
        if changed:
            out.write_text(r.stdout, encoding="utf-8")
            out.with_suffix(".lpo").unlink(missing_ok=True)
        return {"ok": True, "warnings": warnings, "error": None,
                "smap": read_map(mapfile), "changed": changed}
    finally:
        if not persist:
            mapfile.unlink(missing_ok=True)


def lp_check(lp: Path, timeout: float = CHECK_TIMEOUT, gen_obj: bool = True) -> dict:
    """Type-check with lambdapi --json.  Returns {ok, diagnostics, raw, timeout}.
    `--proof-state-on-error` makes a failing tactic carry the structured proof
    state on its diagnostic (`goals_before`, plus `goals_after` for a subproof-
    count mismatch) and keeps the `message` bare (no re-dumped goals).  `timeout`
    and `gen_obj` (the `-c` object-writing flag) are parameters so the editor hook
    can reuse this exact invocation — same flags, caps, and stdout+stderr parsing —
    with a longer budget and without writing a `.lpo` at edit time
    (see .claude/hooks/lp_check.py)."""
    args = ["--json", "--proof-state-on-error"]
    if gen_obj:
        args.append("-c")
    args.append(str(lp))
    try:
        r = _run_lambdapi(args, timeout=timeout)
    except FileNotFoundError:
        return {"ok": False, "diagnostics": [], "raw": [], "timeout": False,
                "no_lambdapi": True}
    except subprocess.TimeoutExpired:
        return {"ok": False, "diagnostics": [], "raw": [], "timeout": True}
    diagnostics, raw = [], []
    for line in (r.stdout + "\n" + r.stderr).splitlines():
        line = line.rstrip()
        if not line:
            continue
        try:
            ev = json.loads(line)
        except json.JSONDecodeError:
            raw.append(line)
            continue
        if ev.get("kind") == "diagnostic":
            diagnostics.append(ev)
    return {"ok": r.returncode == 0, "diagnostics": diagnostics,
            "raw": raw, "timeout": False}


def diag_loc(ev: dict) -> tuple[str, int | None, int | None]:
    rng = ev.get("range") or {}
    start = rng.get("start") or {}
    return ev.get("file", "?"), start.get("line"), start.get("col")


# ── Phase 1 — emit (`pp2lp run`): parse + translate + write ────────────────
def emit_one(replay: Path, timeout: float | None = None) -> dict:
    """Translate one trace to its `.lp` and persist the provenance map alongside
    it.  No lambdapi.  The `.lp` is written content-aware (rewritten only when the
    emitted text changes), so an unchanged emit keeps its mtime — which is what
    lets `check -i` skip it.  `timeout` overrides PP2LP_EMIT_TIMEOUT.  Status:
    ok / warn (emit warnings) / emit_fail."""
    out = replay.with_suffix(".lp")
    prov_path = replay.with_suffix(".provmap")
    # legacy debug-trace / probe debris only — the .lp/.lpo/.provmap are managed
    # content-aware by emit() (success) or cleared below (failure).
    for stale in (*out.parent.glob(f"{out.stem}.lp.*"),
                  *out.parent.glob(f"{out.stem}.probe.lp*")):
        stale.unlink(missing_ok=True)
    t0 = time.monotonic()
    em = emit(replay, out, map_path=prov_path, timeout=timeout)
    res = {"name": replay.stem, "lp": rel(out),
           "emit_ms": (time.monotonic() - t0) * 1000, "warnings": em["warnings"]}
    if not em["ok"]:
        # Drop any stale artifacts so a now-failing benchmark can't be checked
        # from a previous run's .lp (check → no_lp, surfacing the emit failure).
        for f in (out, out.with_suffix(".lpo"), prov_path):
            f.unlink(missing_ok=True)
        res["status"], res["error"] = "emit_fail", em["error"]
    else:
        res["status"], res["error"] = ("warn" if em["warnings"] else "ok"), None
        res["changed"] = em.get("changed", True)
    return res


# ── Phase 2 — check (`pp2lp check`): type-check the emitted .lp ─────────────
def check_one(replay: Path, timeout: float | None = None,
              incremental: bool = False, dep_mtime: float = 0.0) -> dict:
    """Type-check one trace's already-emitted `.lp` with lambdapi, joining any
    error back to its PP rule via the persisted provenance map.  Reports `no_lp`
    when the `.lp` is missing (emit failed, or `pp2lp run` was never run for it).
    With `incremental`, a benchmark whose `.lpo` is newer than both its `.lp` and
    the shared library objects (`dep_mtime`) is skipped as cached — lambdapi only
    writes a `.lpo` on success, so this skips exactly the unchanged, previously
    passing benchmarks (a failure left no object, so it always re-runs).  The
    non-incremental path drops the object first, so a real check always runs and
    the `.lpo` stays an honest "last check passed" marker.  `timeout` overrides
    PP2LP_CHECK_TIMEOUT.  Status: ok / lp_fail / no_lp."""
    out = replay.with_suffix(".lp")
    prov_path = replay.with_suffix(".provmap")
    lpo = out.with_suffix(".lpo")
    res = {"name": replay.stem, "lp": rel(out), "check_ms": 0.0, "warnings": []}
    if not out.exists():
        res["status"] = "no_lp"
        res["error"] = {"code": "E_NO_LP",
                        "message": "no .lp emitted — run `pp2lp run` first"}
        return res
    if incremental and lpo.exists():
        m = lpo.stat().st_mtime
        if m >= out.stat().st_mtime and m >= dep_mtime:    # unchanged + deps unchanged
            res["status"], res["error"], res["cached"] = "ok", None, True
            return res
    # Real check: drop any prior object so success writes a fresh one and a
    # failure leaves none — keeping the `.lpo` an honest pass-marker for `-i`.
    lpo.unlink(missing_ok=True)
    smap = read_map(prov_path)          # side-channel map; powers the join

    eff = timeout if timeout is not None else CHECK_TIMEOUT
    t1 = time.monotonic()
    chk = lp_check(out, timeout=eff)
    res["check_ms"] = (time.monotonic() - t1) * 1000
    if chk.get("no_lambdapi"):
        res["status"] = "lp_fail"
        res["error"] = {"code": "E_NO_LAMBDAPI",
                        "message": "lambdapi not found on PATH"}
        return res
    if chk["timeout"]:
        res["status"] = "lp_fail"
        res["error"] = {"code": "E_LP_TIMEOUT",
                        "message": f"lambdapi timed out after {eff:.0f}s"}
        return res
    if not chk["ok"]:
        errs = [e for e in chk["diagnostics"] if e.get("severity") != "warning"]
        diags = []
        for e in errs:
            f, line, col = diag_loc(e)
            prov = join_prov(line, smap) if line is not None else None
            diags.append({"lp_loc": f"{Path(f).name}:{line}:{col}" if line else Path(f).name,
                          "message": (e.get("message") or "").strip(),
                          "provenance": prov,
                          # structured proof state from --proof-state-on-error
                          # (present for tactic-step and subproof-count failures)
                          "goals_before": e.get("goals_before"),
                          "goals_after": e.get("goals_after")})
        res["status"] = "lp_fail"
        head = (errs[0].get("message") or "").strip().splitlines() if errs else []
        res["error"] = {"code": "E_LP_CHECK",
                        # summary only; the full body lives in diagnostics[].message
                        "message": head[0] if head else "type-check failed",
                        "diagnostics": diags,
                        "raw": chk["raw"] if not errs else []}
        return res
    res["status"] = "ok"
    res["error"] = None
    return res


# ── Target resolution ──────────────────────────────────────────────────────
def _suite_names() -> list[str]:
    """Bench subdirs that look like suites (skip dotfiles, __pycache__, and the
    run-results dir that now lives alongside the suites)."""
    return [p.name for p in sorted(BENCH.iterdir())
            if p.is_dir() and p.name != "results"
            and not p.name.startswith((".", "_"))]


def resolve_target(target: str):
    """Return ('suite', suite, [replays]) or ('single', suite, replay).
    Each benchmark lives in its own directory, at any nesting depth:
    SUITE/NAME/NAME.replay (og/prv/claude) or SUITE/PROJ/NAME/NAME.replay (apero)."""
    if "/" in target:
        suite, name = target.split("/", 1)
        sdir = BENCH / suite
        if not sdir.is_dir():
            sys.exit(f"pp2lp: no such suite '{suite}' (available: {', '.join(_suite_names())})")
        replay = sdir / name / f"{name}.replay"
        if not replay.exists():            # nested layout (apero) — find by stem
            hits = sorted(sdir.rglob(f"{name}.replay"))
            if hits:
                replay = hits[0]
        if not replay.exists():
            names = [p.stem for p in sorted(sdir.rglob("*.replay"))]
            guess = difflib.get_close_matches(name, names, n=1, cutoff=0.6)
            if guess:
                tail = f" — did you mean '{guess[0]}'?"
            elif names:
                tail = f" ({len(names)} available; `pp2lp run {suite}` lists them)"
            else:
                tail = " (no .replay files yet — run `pp2lp gen`)"
            sys.exit(f"pp2lp: no replay '{name}' in suite '{suite}'{tail}")
        return "single", suite, replay
    suite = target
    d = BENCH / suite
    if not d.is_dir():
        sys.exit(f"pp2lp: no such suite '{suite}' (available: {', '.join(_suite_names())})")
    replays = sorted(d.rglob("*.replay"))   # one benchmark per (possibly nested) subdir
    if not replays:
        sys.exit(f"pp2lp: no .replay files under {rel(d)} (run `pp2lp gen {suite}`)")
    return "suite", suite, replays


# ── Printing ───────────────────────────────────────────────────────────────


def _clip(s: str, n: int = 200) -> str:
    return s if len(s) <= n else s[:n - 1] + "…"


_TERM_W = min(shutil.get_terminal_size((90, 24)).columns, 100)


def _numbered(lines: list[str], start: int, indent: str, mark=(), color=None,
              clip: int | None = 200) -> None:
    """Print `lines` with a line-number gutter (1-based, from `start`).  Numbers in
    `mark` get a red `>`; `color` styles each line; `clip` caps line width (None
    means full width)."""
    width = max(len(str(start + len(lines) - 1)), 1)
    for k, text in enumerate(lines):
        n = start + k
        marker = red(">") if n in mark else " "
        shown = _clip(text, clip) if clip else text
        print(f"{indent}  {marker} {n:>{width}} | {color(shown) if color else shown}")


def _error_headline(msg: str) -> str:
    """Condense a lambdapi diagnostic for the error panel.  `Missing subproofs (…):
    <context> ──── 0. …` and kin re-print the goal state the window already shows —
    keep only the headline up to the colon; otherwise flow the wrapped message to
    one line."""
    msg = (msg or "").strip()
    head, sep, rest = msg.partition(":")
    if sep and ("subproof" in head.lower() or re.search(r"-{4,}", rest)):
        return f"{head.strip()}:"
    return " ".join(msg.split())


def _goal_state_for(diag: dict) -> dict:
    """The goal state to show in the failure window, as the {hyps, goals} shape
    _print_goal_state renders, from lambdapi's structured goals on the diagnostic
    (`--proof-state-on-error`): `goals_after` for a subproof-count mismatch (the
    subgoals left without a proof), else `goals_before` (the goal the failing
    tactic faced).  Empty when the failure carries no goals (e.g. "proof is not
    finished", which the flag doesn't cover — its message embeds the goals)."""
    src = diag.get("goals_after") or diag.get("goals_before")
    if not src:
        return {"hyps": [], "goals": []}
    g0 = src[0]
    hyps = [f"{h.get('name', '?')} : {h.get('type', '')}"
            for h in (g0.get("hyps") or [])]
    goals = [g.get("concl") or g.get("constr") or "" for g in src]
    return {"hyps": hyps, "goals": goals}


def _print_emit_locations(message: str, replay: Path, indent: str,
                          max_rules: int = 2, max_hits: int = 2) -> None:
    """Locate an emit-side failure, which carries no line→rule map: find the
    rule(s) the error message blames that actually head a line in this `.replay`
    and show each in context, plus the rule's lp/rules signature.  Best-effort —
    the emit error doesn't pin which occurrence, so a repeated rule shows the
    first few."""
    try:
        lines = replay.read_text(encoding="utf-8").splitlines()
    except OSError:
        return
    heads: dict[str, list[int]] = {}            # rule name → 1-based lines it heads
    for i, ln in enumerate(lines, 1):
        m = re.match(r"\s*\[([A-Za-z_][A-Za-z0-9_]*)", ln)
        if m:
            heads.setdefault(m.group(1), []).append(i)
    blamed: list[str] = []                       # rules named in the message that occur here
    for tok in re.findall(r"[A-Za-z_][A-Za-z0-9_]*", message):
        if tok in heads and tok not in blamed:
            blamed.append(tok)
    for rule in blamed[:max_rules]:
        hits = heads[rule]
        shown = hits[:max_hits]
        for k, lineno in enumerate(shown):
            tag = (f"  ({len(hits)} occurrences; showing {len(shown)})"
                   if k == 0 and len(hits) > len(shown) else "")
            _section(f"{replay.name}:{lineno}{tag}")
            _print_source_context(replay, lineno, indent, 2)
        sig = _rule_signature(rule)
        if sig:
            path, start, end = sig
            _section(f"{path.name}:{start}")
            _numbered(path.read_text(encoding="utf-8").splitlines()[start - 1:end],
                      start, indent, mark={start})


def print_failure(res: dict, replay: Path, indent: str = "   ", context: int = 2) -> None:
    """The default failure window: a source snippet at the failing `.lp` line, the
    goal state lambdapi was in (from its `--proof-state-on-error` diagnostic, when
    the failure carries one), the lambdapi error, then the .replay step that
    produced it and the failing rule's lp/rules signature."""
    err = res.get("error") or {}
    diags = err.get("diagnostics", [])
    if not diags:                       # emit_fail / timeout / unstructured
        first = (err.get("message") or "").splitlines()
        if err.get("code"):
            print(f"{indent}{red(err['code'])}  {first[0] if first else ''}")
            first = first[1:]
        for line in first:
            print(f"{indent}  {_clip(line)}")
        raw = err.get("raw") or []                  # unstructured lambdapi output
        for line in raw[:20]:
            print(f"{indent}  {dim(_clip(line))}")
        if len(raw) > 20:
            print(f"{indent}  {dim('… (+%d more lines)' % (len(raw) - 20))}")
        # An emit failure carries no line→rule map (it's written only after a
        # successful reconstruct), so locate it by the rule the message blames.
        _print_emit_locations(err.get("message") or "", replay, indent)
        return
    # ── one snippet panel per related file, each headed by filename:position ──
    d0 = diags[0]
    prov0 = d0.get("provenance")
    gs = _goal_state_for(d0)
    has_goals = bool(gs["hyps"] or gs["goals"])
    _section(d0["lp_loc"])                              # e.g. name.lp:23:4
    m = re.match(r".*:(\d+):", d0["lp_loc"])
    if m:
        _print_source_context(ROOT / res["lp"], int(m.group(1)), indent, context)
    if has_goals:                                       # the goal state, from the diagnostic
        _section("goal state")
        _print_goal_state(gs, indent)
    _section("lambdapi error")
    if has_goals:                                       # flag-covered: a bare reason
        print(f"{indent}  {red(_clip(_error_headline(d0.get('message')), 300))}")
    else:                                               # uncovered (e.g. "proof not finished"):
        for line in (d0.get("message") or "").splitlines() or [""]:   # the message embeds the
            print(f"{indent}  {red(_clip(line, 500))}")               # goals — surface it whole
    if prov0:
        _section(f"{replay.name}:{prov0['replay_line']}")
        _print_source_context(replay, prov0["replay_line"], indent, 3)
        sig = _rule_signature(prov0["rule"])
        if sig:
            path, start, end = sig
            _section(f"{path.name}:{start}")
            _numbered(path.read_text(encoding="utf-8").splitlines()[start - 1:end], start,
                      indent, mark={start})
        else:
            _section(prov0["rule"])
            print(f"{indent}  {dim('(symbol %s not found under lp/rules/)' % prov0['rule'])}")
    else:
        print(f"{indent}  {dim('(no PP rule maps to this line)')}")
    if len(diags) > 1:
        more = len(diags) - 1
        print(f"{indent}  {dim('(+%d more lambdapi error%s)' % (more, '' if more == 1 else 's'))}")


def _print_goal_state(gs: dict, indent: str) -> None:
    """Prettify the lambdapi proof state: the hypotheses as an aligned `name : type`
    table, a turnstile rule separating them from the goals, then each goal — the
    focused one (goal 0) flagged with a bold `▶`, the rest dim and numbered."""
    hyps, goals = gs.get("hyps", []), gs.get("goals", [])
    if not hyps and not goals:
        print(f"{indent}  {dim('(goal state unavailable)')}")
        return
    pairs = [(h.split(":", 1)[0].strip(), h.split(":", 1)[1].strip() if ":" in h else "")
             for h in hyps]
    w = max((len(n) for n, _ in pairs), default=0)
    for n, typ in pairs:
        print(f"{indent}  {bold(f'{n:<{w}}')} {dim(':')} {_clip(typ, 500)}")
    print(f"{indent}  {dim('─' * min(48, max(12, _TERM_W - len(indent) - 4)))}")  # context │ goals
    if not goals:
        print(f"{indent}  {green('(no remaining goals)')}")
        return
    if len(goals) == 1:                                  # the sole goal — no index needed
        print(f"{indent}{bold('▶ ⊢')} {_clip(goals[0], 500)}")
        return
    for k, g in enumerate(goals):                        # several goals — number them all,
        mark = bold("▶") if k == 0 else " "              # flag goal 0 (the focused one)
        body = f"{k}. ⊢ {_clip(g, 500)}"
        print(f"{indent}{mark} {body if k == 0 else dim(body)}")


def _print_source_context(src: Path, line: int, indent, context):
    try:
        lines = src.read_text(encoding="utf-8").splitlines()
    except OSError:
        return
    if not (1 <= line <= len(lines)):
        return
    lo = max(0, line - 1 - context)
    hi = min(len(lines), line + context)
    _numbered(lines[lo:hi], lo + 1, indent, mark={line})


# ── Rule signature lookup (lp/rules/*.lp) ──────────────────────────────────
def _rule_signature(rule: str):
    """The failing rule's declaration in lp/rules/*.lp as (path, start_line, end_line)
    — the `symbol …` line through the line holding its `≔`/`;`.  None if not found."""
    name = rule.lstrip("@")
    rx = re.compile(r"(?:opaque\s+|sequential\s+|injective\s+|constant\s+)*symbol\s+"
                    + re.escape(name) + r"\b.*?(?=≔|;)", re.DOTALL)
    for f in sorted((ROOT / "lp" / "rules").glob("*.lp")):
        text = f.read_text(encoding="utf-8")
        m = rx.search(text)
        if m:
            start = text.count("\n", 0, m.start()) + 1
            end = text.count("\n", 0, m.end()) + 1
            return f, start, end
    return None


# ── Per-trace printing + single-trace dossier ──────────────────────────────
def _timing(res: dict) -> str:
    """The `emit … / check …` tail, including only the phase(s) that ran (run
    sets emit_ms, check sets check_ms), with a leading two-space gap or empty."""
    parts = []
    if res.get("emit_ms"):
        parts.append(f"emit {fmt_ms(res['emit_ms'])}")
    if res.get("check_ms"):
        parts.append(f"check {fmt_ms(res['check_ms'])}")
    return "  " + " / ".join(parts) if parts else ""


def _print_trace(res: dict, replay: Path, timing: bool = False) -> None:
    """A heavy-ruled header for the trace (so one benchmark is clearly delimited
    from the next), its warnings, and — on failure — the snippet window."""
    timing_txt = _timing(res) if timing else ""
    visible = 6 + len(res["name"]) + len(timing_txt)   # "━━ " + icon + " " + name + timing + " "
    print(f"━━ {ICON[res['status']]} {bold(res['name'])}{dim(timing_txt)} "
          + "━" * max(3, _TERM_W - visible))
    for w in res["warnings"]:
        print(f"   {dim(w)}")
    if res["status"] in FAIL:
        print_failure(res, replay)


def dossier(replay: Path, res: dict):
    """Everything an agent needs about one trace, in one call — the failure window
    of related-file snippets, the goal state, and the lambdapi error."""
    _print_trace(res, replay, timing=True)


def _section(title):
    pad = max(3, _TERM_W - len(title) - 7)      # "   " indent + "── " + " " before dashes
    print(f"   {dim(f'── {title} ' + '─' * pad)}")


# ── --filter (shared by run + check) ───────────────────────────────────────
def _apply_filter(args, suite: str, replays: list[Path]) -> list[Path]:
    """Restrict a suite to benchmark names matching --filter (a regex, or with
    --exact a comma/space-separated literal set), surfacing the matched count so
    an over-matching substring regex is obvious.  No --filter ⇒ unchanged."""
    if not getattr(args, "filter", None):
        return replays
    n_all = len(replays)
    if getattr(args, "exact", False):
        wanted = set(re.split(r"[,\s]+", args.filter.strip()))
        replays = [r for r in replays if r.stem in wanted]
    else:
        rx = re.compile(args.filter)
        replays = [r for r in replays if rx.search(r.stem)]
    if not replays:
        sys.exit(f"pp2lp: --filter {args.filter!r} matched no benchmark in suite {suite!r}")
    print(dim(f"  filter matched {len(replays)}/{n_all} benchmarks"), file=sys.stderr)
    return replays


# ── The `run` command (emit: parse + translate + write .lp) ────────────────
def cmd_run(args) -> int:
    if not args.no_build:
        ok, err = ensure_build()
        if not ok:
            if args.json:
                print(json.dumps({"ok": False, "error": {"code": "E_BUILD", "message": err}}))
            else:
                print(red("build failed:"))
                print(err)
            return 1

    kind, suite, target = resolve_target(args.target)
    if kind == "single":
        res = emit_one(target, timeout=args.timeout)
        if args.json:
            print(json.dumps(res, ensure_ascii=False, indent=2))
        else:
            dossier(target, res)
        return 0 if res["status"] in ("ok", "warn") else 1
    return _run_suite(args, suite, _apply_filter(args, suite, target), "emit")


# ── The `check` command (type-check the emitted .lp with lambdapi) ──────────
def cmd_check(args) -> int:
    # No engine build: check consumes the .lp `run` already wrote — it never
    # touches the OCaml emitter, only lambdapi.
    kind, suite, target = resolve_target(args.target)
    if kind == "single":
        res = check_one(target, timeout=args.timeout, incremental=args.incremental,
                        dep_mtime=_lp_dep_mtime() if args.incremental else 0.0)
        if args.json:
            print(json.dumps(res, ensure_ascii=False, indent=2))
        else:
            dossier(target, res)
        return 0 if res["status"] == "ok" else 1
    return _run_suite(args, suite, _apply_filter(args, suite, target), "check")


class _Stream:
    """Live per-result printer.  On a TTY, passes only advance a single in-place
    counter line (no scrollback flood at suite scale); redirected, passes become
    one compact line each so CI/pipes stay greppable.  A failure unfolds its full
    `━━` window — unless `--code` is set and the failure's error code doesn't
    match, or the per-run window cap (`PP2LP_MAX_WINDOWS`) is already reached, in
    which case the failure is still counted (it lands in the histogram) but its
    window is skipped.  Warnings always surface."""

    def __init__(self, suite: str, total: int, code_rx=None,
                 max_windows: int = MAX_FAIL_WINDOWS):
        self.suite, self.total, self.done, self.fail = suite, total, 0, 0
        self.code_rx = code_rx              # --code: which failures earn a full window
        self.max_windows = max_windows      # cap on full windows (0 = no cap)
        self.shown = 0                      # full windows printed so far
        self.over_budget = 0                # wanted windows the cap suppressed

    def _counter(self) -> str:
        tail = red(f"  {self.fail} ✗") if self.fail else ""
        return dim(f"  {self.suite}  {self.done}/{self.total}") + tail

    def _matches(self, res: dict) -> bool:
        """Does this failure pass the --code filter? (no filter ⇒ every failure.)"""
        if self.code_rx is None:
            return True
        return bool(self.code_rx.search((res.get("error") or {}).get("code") or ""))

    def _unfold(self, res: dict, replay: Path) -> None:
        if res["status"] in FAIL:                           # a failure
            if not self._matches(res):
                return                                       # filtered out by --code
            if self.max_windows and self.shown >= self.max_windows:
                self.over_budget += 1                        # wanted, but over the cap
                return
            print()
            _print_trace(res, replay, timing=True)           # the heavy window
            self.shown += 1
        else:                                               # warn: compact + its warnings
            print(f"{ICON['warn']} {res['name']}")
            for w in res["warnings"]:
                print(f"   {dim(w)}")

    def _compact(self, res: dict) -> None:                  # a passing trace, one line
        print(f"{ICON[res['status']]} {res['name']}{dim(_timing(res))}")

    def __call__(self, res: dict, replay: Path) -> None:
        self.done += 1
        notable = res["status"] != "ok"                     # failures + warnings get shown
        self.fail += res["status"] in FAIL
        if IS_TTY:
            sys.stdout.write("\r\033[K")                    # drop the counter line first
            if notable:
                self._unfold(res, replay)
            sys.stdout.write("\r" + self._counter())
            sys.stdout.flush()
        elif notable:
            self._unfold(res, replay)
        else:
            self._compact(res)

    def finish(self) -> None:
        if IS_TTY:
            sys.stdout.write("\r\033[K")
            sys.stdout.flush()
        if self.over_budget:                                # cap hit: steer to a narrower view
            what = "matching --code " if self.code_rx is not None else ""
            print(dim(f"… {self.over_budget} more {what}failure window(s) elided "
                      f"(window cap {self.max_windows}); narrow with --filter/--code, "
                      f"or read lp/bench/results/{self.suite}.json"))
        elif self.code_rx is not None and self.shown == 0 and self.fail:
            print(dim("… no failures matched --code; the by-code histogram is below"))


class _Heartbeat:
    """Throttled progress on stderr for -q/--json runs (which don't stream
    per-result), so a long suite stays observable while stdout/json stay clean.
    On a TTY it rewrites one line in place; redirected, it prints at most one
    line every `every` seconds so a piped log stays short."""

    def __init__(self, suite: str, total: int, every: float = 3.0):
        self.suite, self.total, self.every = suite, total, every
        self.done = self.fail = 0
        self.last = time.monotonic()

    def __call__(self, res: dict, replay: Path) -> None:
        self.done += 1
        self.fail += res["status"] in FAIL
        now = time.monotonic()
        if now - self.last < self.every and self.done != self.total:
            return
        self.last = now
        tail = f"  {self.fail} ✗" if self.fail else ""
        line = f"  {self.suite}  {self.done}/{self.total}{tail}"
        sys.stderr.write(("\r\033[K" + line) if sys.stderr.isatty() else line + "\n")
        sys.stderr.flush()

    def finish(self) -> None:
        if sys.stderr.isatty():
            sys.stderr.write("\r\033[K")
            sys.stderr.flush()


def _failure_histogram(goals: list[dict]) -> dict:
    """Counts per error code over the failed goals (emit_fail / lp_fail)."""
    hist: dict[str, int] = {}
    for g in goals:
        if g["status"] in FAIL:
            code = (g.get("error") or {}).get("code") or "E_EMIT"
            hist[code] = hist.get(code, 0) + 1
    return hist


def _run_suite(args, suite: str, replays: list[Path], phase: str) -> int:
    """Run one phase over a suite in parallel — `phase="emit"` (`run`, via
    emit_one) or `phase="check"` (`check`, via check_one) — stream results live,
    write the per-run JSON, and exit non-zero iff any benchmark failed.  Emit
    writes `<suite>.json`; check writes `<suite>.check.json` (so the two phases
    keep separate baselines); a --filter run gets the `.filter.json` variant."""
    t_start = time.monotonic()
    code_rx = None
    if getattr(args, "code", None):
        try:
            code_rx = re.compile(args.code, re.I)
        except re.error as e:
            sys.exit(f"pp2lp: bad --code regex {args.code!r}: {e}")
    # human run: stream each result live (completion order).  -q/--json don't
    # stream, but still get a throttled progress heartbeat on stderr so long runs
    # stay observable (stdout/json output stays clean).
    stream = (_Stream(suite, len(replays), code_rx=code_rx)
              if not (args.json or args.quiet) else _Heartbeat(suite, len(replays)))
    to = getattr(args, "timeout", None)
    if phase == "emit":
        def worker(r): return emit_one(r, timeout=to)
    else:
        # Warm the shared library objects once (serial, before the parallel
        # workers) and read the dependency clock from them, so an incremental
        # check can tell a rule edit from an untouched library.
        _warm_shared_cache()
        incr = getattr(args, "incremental", False)
        dep_mtime = _lp_dep_mtime() if incr else 0.0
        def worker(r): return check_one(r, timeout=to, incremental=incr, dep_mtime=dep_mtime)
    results = _check_all(replays, worker, on_result=stream)
    stream.finish()
    elapsed = (time.monotonic() - t_start) * 1000

    ordered = [results[r.stem] for r in replays]
    failures = [r["name"] for r in ordered if r["status"] in FAIL]
    artifact = {"suite": suite, "phase": phase,
                "ok": sum(r["status"] == "ok" for r in ordered),
                "warn": sum(r["status"] == "warn" for r in ordered),
                "fail": len(failures), "failures": failures, "wall_ms": elapsed,
                "by_code": _failure_histogram(ordered),
                # emit only: how many .lp the content-aware write actually rewrote
                "changed": sum(bool(r.get("changed")) for r in ordered),
                # check -i only: how many were skipped as cached vs really checked
                "cached": sum(bool(r.get("cached")) for r in ordered),
                "checked": sum(r["status"] in ("ok", "lp_fail") and not r.get("cached")
                               for r in ordered),
                "emit_ms": sum(r.get("emit_ms", 0.0) for r in ordered),
                "check_ms": sum(r.get("check_ms", 0.0) for r in ordered), "goals": ordered}

    RESULTS_DIR.mkdir(parents=True, exist_ok=True)
    # Emit and check keep separate baselines (`<suite>.json` vs
    # `<suite>.check.json`); a filtered run holds only a subset, so it lands in a
    # `.filter.json` variant and never clobbers the canonical baseline.
    base = f"{suite}.check" if phase == "check" else suite
    out_name = f"{base}.filter.json" if getattr(args, "filter", None) else f"{base}.json"
    (RESULTS_DIR / out_name).write_text(
        json.dumps(artifact, ensure_ascii=False, indent=2), encoding="utf-8")

    if args.json:
        print(json.dumps(artifact, ensure_ascii=False, indent=2))
    else:
        _print_summary(artifact)
    return 1 if failures else 0


def _print_summary(artifact: dict) -> None:
    """The trailing one-line tally.  The per-trace output already streamed live
    (unless `-q`, which shows only this line)."""
    suite, failures = artifact["suite"], artifact["failures"]
    phase = artifact.get("phase")
    print()
    parts = []
    if artifact["ok"]:
        parts.append(f"{green(artifact['ok'])} ✓")
    if artifact["warn"]:
        parts.append(f"{yellow(artifact['warn'])} ⚠")
    if failures:
        parts.append(f"{red(len(failures))} ✗")
    if phase == "emit":
        breakdown = dim(f"emit {fmt_ms(artifact['emit_ms'])}")
    elif phase == "check":
        breakdown = dim(f"check {fmt_ms(artifact['check_ms'])}")
    else:
        breakdown = dim(f"emit {fmt_ms(artifact['emit_ms'])} / check {fmt_ms(artifact['check_ms'])}")
    print(f"{suite}  {'  '.join(parts)}  {dim(fmt_ms(artifact['wall_ms']))}  {breakdown}")
    if failures:
        hist = artifact.get("by_code") or {}
        tally = "  ".join(f"{code}×{n}" for code, n in
                          sorted(hist.items(), key=lambda kv: (-kv[1], kv[0])))
        if tally:
            print(f"  {red('✗ by code:')} {tally}")
    if phase == "emit":      # the emitted .lp still needs type-checking
        done = artifact["ok"] + artifact["warn"]
        ch = artifact.get("changed", done)
        unchanged = f", {done - ch} unchanged" if done and ch < done else ""
        print(dim(f"  {ch} .lp (re)written{unchanged} → type-check with: pp2lp check {suite}"))
    elif phase == "check" and artifact.get("cached"):
        print(dim(f"  {artifact['cached']} cached (-i); {artifact['checked']} re-checked"))


# ── shared suite evaluation ────────────────────────────────────────────────
def _lp_dep_mtime() -> float:
    """Newest mtime among the shared library objects (B, lemmas/*, Prelude,
    rules/*) — the dependency clock an incremental `check` compares each
    benchmark's own `.lpo` against, so a rule/lemma edit invalidates the cache.
    Call after `_warm_shared_cache` so it reflects the current library."""
    mt = 0.0
    for pat in ("*.lpo", "lemmas/*.lpo", "rules/*.lpo"):
        for f in (ROOT / "lp").glob(pat):
            mt = max(mt, f.stat().st_mtime)
    return mt


def _warm_shared_cache() -> None:
    """Type-check the shared library files (B, lemmas/*, Prelude → all of rules/*)
    once, serially, so their .lpo objects exist before the parallel workers
    start.  Otherwise each `lambdapi check -c` below races to compile and write
    those same shared objects on a cold cache, corrupting them and giving
    spurious failures (a re-run would then "fix" it).  Warming them first leaves
    the workers only reading the shared objects and writing their own."""
    shared = [ROOT / "lp" / f for f in
              ("B.lp", "lemmas/Int.lp", "lemmas/Tuple.lp", "lemmas/ConjList.lp",
               "Prelude.lp")]
    shared = [str(p) for p in shared if p.exists()]
    if not shared:
        return
    try:
        # The one-off serial library compile is exempt from the per-goal
        # CHECK_TIMEOUT: cold (post `*.lpo`-purge) it takes far longer than a
        # single goal, and timing out here would resurrect the very .lpo write
        # race this warm-up exists to prevent.
        _run_lambdapi(["-c", "-w", *shared], timeout=max(120.0, CHECK_TIMEOUT))
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass        # a missing/slow lambdapi resurfaces per-trace in the workers below


def _check_all(replays, worker, on_result=None) -> dict[str, dict]:
    """Run `worker(replay)` (emit_one or check_one) over every replay in parallel;
    keyed by stem.  `on_result(res, replay)` fires on the main thread as each trace
    finishes (completion order) so callers can stream live.  The caller is
    responsible for any one-off setup (e.g. the check phase warms the shared
    library objects before calling)."""
    out: dict[str, dict] = {}
    workers = min(len(replays), (os.cpu_count() or 2))
    with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as ex:
        futs = {ex.submit(worker, r): r for r in replays}
        for fut in concurrent.futures.as_completed(futs):
            replay = futs[fut]
            try:
                res = fut.result()
            except Exception as e:        # one bad trace must not sink the whole suite
                res = {"name": replay.stem, "lp": rel(replay.with_suffix(".lp")),
                       "emit_ms": 0.0, "check_ms": 0.0, "warnings": [], "status": "emit_fail",
                       "error": {"code": "E_INTERNAL",
                                 "message": f"{type(e).__name__}: {e}"}}
            out[res["name"]] = res
            if on_result:
                on_result(res, replay)
    return out


