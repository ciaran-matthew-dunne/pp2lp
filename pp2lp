#!/usr/bin/env python3
"""pp2lp — translate Atelier B Predicate-Prover replays to Lambdapi and type-check them.

Round trip: formula → PP → .trace → REPLAY → .replay → pp2lp → .lp → lambdapi check.
Drive it with `pp2lp run` (emit the .lp), then `pp2lp check` (type-check it), and
`pp2lp gen` (regenerate inputs via krt); the OCaml engine under ocaml/_build/ is an
internal detail.  See CLAUDE.md for the design, or `pp2lp <cmd> --help` for options.
"""
from __future__ import annotations

