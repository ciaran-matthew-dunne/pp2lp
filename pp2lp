#!/usr/bin/env python3
"""pp2lp — translate Atelier B Predicate-Prover replays to Lambdapi and type-check them.

Round trip: formula → PP → .trace → REPLAY → .replay → pp2lp → .lp → lambdapi check.
Drive it with `pp2lp run` (emit + check) and `pp2lp gen` (regenerate inputs via krt);
the OCaml engine under ocaml/_build/ is an internal detail.  See CLAUDE.md for the
design, or `pp2lp run --help` / `pp2lp gen --help` for options.
"""
from __future__ import annotations

import argparse
import concurrent.futures
import difflib
import hashlib
import json
import os
import re
import shutil
import signal
import subprocess
import sys
import tempfile
import time
import xml.etree.ElementTree as ET
from pathlib import Path

try:
    import resource  # POSIX-only; caps child address space / CPU
except ImportError:  # pragma: no cover
    resource = None

ROOT = Path(__file__).resolve().parent
ENGINE = ROOT / "ocaml" / "_build" / "default" / "bin" / "main.exe"
BENCH = ROOT / "lp" / "bench"
RESULTS_DIR = ROOT / "bench" / "results"

# ── Safety caps for child processes (env-tunable; 0 disables) ──────────────
CHECK_TIMEOUT = float(os.environ.get("PP2LP_CHECK_TIMEOUT", "10"))   # lambdapi, s
EMIT_TIMEOUT = float(os.environ.get("PP2LP_EMIT_TIMEOUT", "10"))     # engine emit, s
GEN_TIMEOUT = float(os.environ.get("PP2LP_GEN_TIMEOUT", "10"))       # krt PP/REPLAY, s
CHILD_MEM_GB = float(os.environ.get("PP2LP_CHECK_MEM_GB", "4"))      # RLIMIT_AS, GiB

# ── Colour ─────────────────────────────────────────────────────────────────
IS_TTY = sys.stdout.isatty()
COLOR = IS_TTY and not os.environ.get("NO_COLOR")


def _c(code, t):
    return f"\033[{code}m{t}\033[0m" if COLOR else str(t)


def green(t):  return _c("32", t)
def yellow(t): return _c("33", t)
def red(t):    return _c("31", t)
def dim(t):    return _c("2", t)
def bold(t):   return _c("1", t)


ICON = {"ok": green("✓"), "warn": yellow("⚠"), "emit_fail": red("✗"), "lp_fail": red("✗")}


def fmt_ms(ms: float) -> str:
    return f"{ms / 1000:.1f}s" if ms >= 1000 else f"{ms:.0f}ms"


# ── Child-process limits ───────────────────────────────────────────────────
def _child_limits(timeout: float):
    if resource is None or os.name != "posix":
        return None

    def apply():
        if CHILD_MEM_GB > 0:
            n = int(CHILD_MEM_GB * 1024 ** 3)
            try:
                resource.setrlimit(resource.RLIMIT_AS, (n, n))
            except (ValueError, OSError):
                pass
        if timeout > 0:
            cpu = int(timeout) + 10
            try:
                resource.setrlimit(resource.RLIMIT_CPU, (cpu, cpu))
            except (ValueError, OSError):
                pass

    return apply


def _run_lambdapi(args, timeout=CHECK_TIMEOUT):
    """Run `lambdapi check <args>` under the standard safety caps: wall-clock
    `timeout` (per-goal CHECK_TIMEOUT by default), RLIMIT_AS/CPU via
    _child_limits, and its own session group so a runaway child can't take
    down the host.  The single place those caps are wired — callers handle
    FileNotFoundError / TimeoutExpired."""
    return subprocess.run(["lambdapi", "check", *args],
                          capture_output=True, text=True,
                          timeout=timeout or None,
                          preexec_fn=_child_limits(timeout),
                          start_new_session=True)


# ── Build the engine ───────────────────────────────────────────────────────
def ensure_build() -> tuple[bool, str]:
    try:
        r = subprocess.run(["dune", "build"], cwd=ROOT / "ocaml",
                           capture_output=True, text=True)
    except FileNotFoundError:
        return False, "dune not found on PATH"
    return r.returncode == 0, r.stderr.strip()


# ── Error classification: engine stderr text → code ────────────────────────
# The engine's messages are stable (we own them).  Map them to a machine code,
# mirroring CLAUDE.md's "Common errors" table.
_ERROR_RULES = [
    (re.compile(r"unknown rule"),               "E_UNKNOWN_RULE"),
    (re.compile(r"unsupported arity"),          "E_ARITY"),
    (re.compile(r"arity \d+ unsupported"),      "E_DISPATCH"),
    # `impossible case in rpl*` is REPLAY itself giving up mid-file (its error
    # text lands verbatim in the .replay) — same upstream-loss family as the
    # dropped ALL7/XST8 continuations, so classify it for the gen-time drop.
    (re.compile(r"no sequent continuation|REPLAY truncated|impossible case in rpl"),
     "E_REPLAY_TRUNCATED"),
    (re.compile(r"INS contradiction"),          "E_INS"),
    (re.compile(r"tree-build error|unconsumed|expected a .*child"), "E_TREE_BUILD"),
    (re.compile(r"parse error|replay-line parse|unrecognised line"), "E_PARSE"),
]


# Engine emit failures carry a stable `E_CODE: message` prefix at the raise
# site (ocaml/src/errors.ml), so classify by that first.  The message-regex
# above stays the fallback for the exception-based parse/tree channel
# (Bad_replay, which dual-classifies to E_REPLAY_TRUNCATED) and for old logs.
_CODE_PREFIX = re.compile(
    r"\bE_(?:UNKNOWN_RULE|ARITY|DISPATCH|TREE_BUILD|PARSE|INS|EMIT)(?=:)")


def classify_error(text: str) -> str:
    m = _CODE_PREFIX.search(text)
    if m:
        return m.group(0)
    for rx, code in _ERROR_RULES:
        if rx.search(text):
            return code
    return "E_EMIT"


# ── Provenance: the engine writes a side-channel line→rule TSV (no comments
#    in the generated .lp); we read it back and join errors to rules. ───────
def read_map(path: Path) -> list[dict]:
    """Parse the engine's provenance TSV: lp_line, rule, replay_line, goal."""
    out = []
    try:
        for line in path.read_text(encoding="utf-8").splitlines():
            parts = line.split("\t", 3)
            if len(parts) == 4:
                out.append({"lp_line": int(parts[0]), "rule": parts[1],
                            "replay_line": int(parts[2]), "goal": parts[3]})
    except (OSError, ValueError):
        pass
    return out


def join_prov(lp_line: int, smap: list[dict]) -> dict | None:
    """Nearest-preceding provenance entry for a given .lp line — i.e. the rule
    whose emitted block the error falls inside."""
    best = None
    for e in smap:
        if e["lp_line"] <= lp_line and (best is None or e["lp_line"] > best["lp_line"]):
            best = e
    return best


# ── Run the engine ─────────────────────────────────────────────────────────
def engine(*engine_args, env=None, timeout=EMIT_TIMEOUT):
    return subprocess.run(
        [str(ENGINE), *engine_args], cwd=ROOT, capture_output=True, text=True,
        timeout=timeout or None, preexec_fn=_child_limits(timeout),
        start_new_session=True, env=env)


def rel(p: Path) -> str:
    return str(p.relative_to(ROOT)) if p.is_relative_to(ROOT) else str(p)


def _collapse(lines: list[str]) -> list[str]:
    """Fold runs of identical lines into one, annotated `… (×N)`, preserving
    first-seen order — so a flood of identical lexer warnings reads as a single
    line instead of burying the real message."""
    counts: dict[str, int] = {}
    for l in lines:
        counts[l] = counts.get(l, 0) + 1
    seen: set[str] = set()
    out: list[str] = []
    for l in lines:
        if l in seen:
            continue
        seen.add(l)
        out.append(f"{l}  (×{counts[l]})" if counts[l] > 1 else l)
    return out


def emit(replay: Path, out: Path) -> dict:
    """Emit the clean .lp (no comments) and read the side-channel provenance
    map.  Returns {ok, warnings, error|None, smap}."""
    out.parent.mkdir(parents=True, exist_ok=True)
    fd, mappath = tempfile.mkstemp(suffix=".provmap")
    os.close(fd)
    mapfile = Path(mappath)
    try:
        try:
            r = engine("emit", "--map", str(mapfile), rel(replay), timeout=EMIT_TIMEOUT)
        except FileNotFoundError:
            return {"ok": False, "warnings": [],
                    "error": {"code": "E_NO_ENGINE", "message": "engine binary missing"}}
        except subprocess.TimeoutExpired:
            return {"ok": False, "warnings": [],
                    "error": {"code": "E_TIMEOUT",
                              "message": f"emit timed out after {EMIT_TIMEOUT:.0f}s"}}
        warns, errors = [], []
        for l in r.stderr.splitlines():
            if not l:
                continue
            if l.startswith("WARNING: "):
                warns.append(l[len("WARNING: "):])
            elif l[:8].lower() == "warning:":      # ocamllex lexer warnings (lowercase)
                warns.append(l[8:].lstrip())
            else:
                errors.append(l)
        warnings = _collapse(warns)
        if r.returncode != 0:
            msg = "\n".join(_collapse(errors)) or r.stderr.strip()
            code = classify_error(msg)
            return {"ok": False, "warnings": warnings,
                    "error": {"code": code, "message": msg}}
        out.write_text(r.stdout, encoding="utf-8")
        return {"ok": True, "warnings": warnings, "error": None, "smap": read_map(mapfile)}
    finally:
        mapfile.unlink(missing_ok=True)


def lp_check(lp: Path) -> dict:
    """Type-check with lambdapi --json.  Returns {ok, diagnostics, raw, timeout}."""
    try:
        r = _run_lambdapi(["--json", "-c", str(lp)])
    except FileNotFoundError:
        return {"ok": False, "diagnostics": [], "raw": [], "timeout": False,
                "no_lambdapi": True}
    except subprocess.TimeoutExpired:
        return {"ok": False, "diagnostics": [], "raw": [], "timeout": True}
    diagnostics, raw = [], []
    for line in (r.stdout + "\n" + r.stderr).splitlines():
        line = line.rstrip()
        if not line:
            continue
        try:
            ev = json.loads(line)
        except json.JSONDecodeError:
            raw.append(line)
            continue
        if ev.get("kind") == "diagnostic":
            diagnostics.append(ev)
    return {"ok": r.returncode == 0, "diagnostics": diagnostics,
            "raw": raw, "timeout": False}


def diag_loc(ev: dict) -> tuple[str, int | None, int | None]:
    rng = ev.get("range") or {}
    start = rng.get("start") or {}
    return ev.get("file", "?"), start.get("line"), start.get("col")


# ── Check one trace (emit + check + provenance join) ───────────────────────
def check_one(replay: Path, lp_debug: str | None = None, want_probe: bool = True) -> dict:
    out = replay.with_suffix(".lp")
    for stale in (*out.parent.glob(f"{out.stem}.lp.*"),       # last run's debug trace
                  *out.parent.glob(f"{out.stem}.probe.lp*")):  # and last run's probe
        stale.unlink(missing_ok=True)
    t0 = time.monotonic()
    em = emit(replay, out)
    t_emit = (time.monotonic() - t0) * 1000
    res = {"name": replay.stem, "lp": rel(out),
           "emit_ms": t_emit, "check_ms": 0.0, "warnings": em["warnings"]}
    if not em["ok"]:
        res["status"] = "emit_fail"
        res["error"] = em["error"]
        return res

    smap = em["smap"]                   # side-channel map; powers the join

    t1 = time.monotonic()
    chk = lp_check(out)
    res["check_ms"] = (time.monotonic() - t1) * 1000
    if chk.get("no_lambdapi"):
        res["status"] = "lp_fail"
        res["error"] = {"code": "E_NO_LAMBDAPI",
                        "message": "lambdapi not found on PATH"}
        return res
    if chk["timeout"]:
        res["status"] = "lp_fail"
        res["error"] = {"code": "E_LP_TIMEOUT",
                        "message": f"lambdapi timed out after {CHECK_TIMEOUT:.0f}s"}
        return res
    if not chk["ok"]:
        errs = [e for e in chk["diagnostics"] if e.get("severity") != "warning"]
        diags = []
        for e in errs:
            f, line, col = diag_loc(e)
            prov = join_prov(line, smap) if line is not None else None
            diags.append({"lp_loc": f"{Path(f).name}:{line}:{col}" if line else Path(f).name,
                          "message": (e.get("message") or "").strip(),
                          "provenance": prov})
        res["status"] = "lp_fail"
        head = (errs[0].get("message") or "").strip().splitlines() if errs else []
        res["error"] = {"code": "E_LP_CHECK",
                        # summary only; the full body lives in diagnostics[].message
                        "message": head[0] if head else "type-check failed",
                        "diagnostics": diags,
                        "raw": chk["raw"] if not errs else []}
        if want_probe and diags:
            m = re.match(r".*:(\d+):", diags[0]["lp_loc"])
            if m:
                res["probe"] = build_probe(out, int(m.group(1)), lp_debug)
        return res
    res["status"] = "warn" if em["warnings"] else "ok"
    res["error"] = None
    return res


# ── Target resolution ──────────────────────────────────────────────────────
def _suite_names() -> list[str]:
    """Bench subdirs that look like suites (skip dotfiles / __pycache__)."""
    return [p.name for p in sorted(BENCH.iterdir())
            if p.is_dir() and not p.name.startswith((".", "_"))]


def resolve_target(target: str):
    """Return ('suite', suite, [replays]) or ('single', suite, replay).
    Each benchmark lives in its own directory: SUITE/NAME/NAME.replay."""
    if "/" in target:
        suite, name = target.split("/", 1)
        sdir = BENCH / suite
        if not sdir.is_dir():
            sys.exit(f"pp2lp: no such suite '{suite}' (available: {', '.join(_suite_names())})")
        replay = sdir / name / f"{name}.replay"
        if not replay.exists():
            names = [p.stem for p in sorted(sdir.glob("*/*.replay"))]
            guess = difflib.get_close_matches(name, names, n=1, cutoff=0.6)
            if guess:
                tail = f" — did you mean '{guess[0]}'?"
            elif names:
                tail = f" ({len(names)} available; `pp2lp run {suite}` lists them)"
            else:
                tail = " (no .replay files yet — run `pp2lp gen`)"
            sys.exit(f"pp2lp: no replay '{name}' in suite '{suite}'{tail}")
        return "single", suite, replay
    suite = target
    d = BENCH / suite
    if not d.is_dir():
        sys.exit(f"pp2lp: no such suite '{suite}' (available: {', '.join(_suite_names())})")
    replays = sorted(d.glob("*/*.replay"))   # one benchmark per subdirectory
    if not replays:
        sys.exit(f"pp2lp: no .replay files under {rel(d)} (run `pp2lp gen {suite}`)")
    return "suite", suite, replays


# ── Printing ───────────────────────────────────────────────────────────────


def _clip(s: str, n: int = 200) -> str:
    return s if len(s) <= n else s[:n - 1] + "…"


_TERM_W = min(shutil.get_terminal_size((90, 24)).columns, 100)
_TRACE_HOT = ("failed", "unsolved", "Unsolvable", "no unif_rule", "internal error")


def _numbered(lines: list[str], start: int, indent: str, mark=(), color=None,
              clip: int | None = 200) -> None:
    """Print `lines` with a line-number gutter (1-based, from `start`).  Numbers in
    `mark` get a red `>`; `color` styles each line; `clip` caps line width — None
    means full width, used for the untruncated debug traces."""
    width = max(len(str(start + len(lines) - 1)), 1)
    for k, text in enumerate(lines):
        n = start + k
        marker = red(">") if n in mark else " "
        shown = _clip(text, clip) if clip else text
        print(f"{indent}  {marker} {n:>{width}} | {color(shown) if color else shown}")


def _trace_style(t: str) -> str:
    """Per-line styling for a debug trace: red for the failure line, plain for a
    `≡` constraint, dim for the rest."""
    if any(k in t for k in _TRACE_HOT):
        return red(t)
    return t if "≡" in t else dim(t)


def _error_headline(msg: str) -> str:
    """Condense a lambdapi diagnostic for the error panel.  `Missing subproofs (…):
    <context> ──── 0. …` and kin re-print the goal state the window already shows —
    keep only the headline up to the colon; otherwise flow the wrapped message to
    one line."""
    msg = (msg or "").strip()
    head, sep, rest = msg.partition(":")
    if sep and ("subproof" in head.lower() or re.search(r"-{4,}", rest)):
        return f"{head.strip()}:"
    return " ".join(msg.split())


def print_failure(res: dict, replay: Path, indent: str = "   ", context: int = 2) -> None:
    """The default failure window: a code snippet from each related file, headed by
    its `filename:position` — the <name>.probe.lp at the error line (with the goal
    state lambdapi was in), the .replay step that produced it, and the failing
    rule's lp/rules signature.  `--lp-debug=CODE` adds the cleaned lambdapi trace."""
    err = res.get("error") or {}
    diags = err.get("diagnostics", [])
    if not diags:                       # emit_fail / timeout / unstructured
        first = (err.get("message") or "").splitlines()
        if err.get("code"):
            print(f"{indent}{red(err['code'])}  {first[0] if first else ''}")
            first = first[1:]
        for line in first:
            print(f"{indent}  {_clip(line)}")
        raw = err.get("raw") or []                  # unstructured lambdapi output
        for line in raw[:20]:
            print(f"{indent}  {dim(_clip(line))}")
        if len(raw) > 20:
            print(f"{indent}  {dim('… (+%d more lines)' % (len(raw) - 20))}")
        return
    # ── one snippet panel per related file, each headed by filename:position ──
    d0 = diags[0]
    prov0 = d0.get("provenance")
    probe = res.get("probe")
    if probe:                                          # the .probe.lp snippet + goal state
        _section(f"{Path(probe['path']).name}:{probe['fail_line']}")
        _print_source_context(ROOT / probe["path"], probe["fail_line"], indent, context)
        _section("goal state")
        _print_goal_state(probe["goal_state"], indent)
    else:                                              # no probe (e.g. -q): the bare .lp
        _section(d0["lp_loc"])                          # e.g. name.lp:23:4
        m = re.match(r".*:(\d+):", d0["lp_loc"])
        if m:
            _print_source_context(ROOT / res["lp"], int(m.group(1)), indent, context)
    msg = _error_headline(d0.get("message"))           # what lambdapi said, minus any re-dumped state
    if msg:
        _section("lambdapi error")
        print(f"{indent}  {red(_clip(msg, 300))}")
    if prov0:
        _section(f"{replay.name}:{prov0['replay_line']}")
        _print_source_context(replay, prov0["replay_line"], indent, 3)
        sig = _rule_signature(prov0["rule"])
        if sig:
            path, start, end = sig
            _section(f"{path.name}:{start}")
            _numbered(path.read_text(encoding="utf-8").splitlines()[start - 1:end], start,
                      indent, mark={start})
        else:
            _section(prov0["rule"])
            print(f"{indent}  {dim('(symbol %s not found under lp/rules/)' % prov0['rule'])}")
    else:
        print(f"{indent}  {dim('(no PP rule maps to this line)')}")
    if probe and probe["debug_trace"]:                 # the --lp-debug trace, prettified
        _section(f"debug +{probe['code']}")
        _print_debug_trace(probe["debug_trace"], indent)
    if len(diags) > 1:
        more = len(diags) - 1
        print(f"{indent}  {dim('(+%d more lambdapi error%s)' % (more, '' if more == 1 else 's'))}")


def _distill(out: list) -> list[str]:
    """Clean a scoped lambdapi debug trace: keep the `[tag] …` entries, drop the
    giant `[tag] solve {…metas…}` state dump, surface (rather than spew) a crash."""
    cleaned = []
    for l in out:
        s = l.rstrip()
        if "Assertion failed" in s or s.lstrip().startswith("Uncaught"):
            cleaned.append("(lambdapi internal error on this debug code)")
            break
        t = s.strip()
        tag = re.match(r"\[[a-z]+\] ", t)
        if tag and not t.startswith(tag.group(0) + "solve {"):
            cleaned.append(t)
    return cleaned or ["(no debug activity captured for this code)"]


def _parse_goal_state(out: list[str]) -> dict:
    """Pull the lambdapi proof state out of a probe run's output.  `print` emits the
    context as `name: type` lines, a dashed separator, then goals `N. ?meta: type`;
    with `debug +CODE` the `[tag] …` lines follow the goals.  Returns {hyps, goals}
    (goals stripped of their `N. ?meta:` prefix)."""
    hyps, goals, phase = [], [], None
    for l in out:
        t = l.strip()
        if phase is None:                       # wait for the proof banner
            if t.startswith("Start checking"):
                phase = "hyps"
            continue
        if re.fullmatch(r"-{5,}", t):           # context │ goals separator
            phase = "goals"
            continue
        if t.startswith("["):                   # [tag] debug or [file:…] error → done
            break
        if not t or re.fullmatch(r"debug [+-]\w+", t):
            continue
        (hyps if phase == "hyps" else goals).append(t)
    goals = [re.sub(r"^\d+\.\s*(?:\?\w+\s*:\s*)?", "", g) for g in goals]
    return {"hyps": hyps, "goals": goals}


def build_probe(lp_path: Path, fail_line: int, code: str | None) -> dict | None:
    """Copy the emitted `.lp` to a persisted, re-checkable `<stem>.probe.lp` with
    `print;` (and `debug +<code>;` when given) spliced *into* the failing tactic
    line, run lambdapi once, and capture both the proof state and — when a debug
    code is set — the cleaned `[tag]` trace.  The splice keeps the line number
    (so provenance still maps); print_failure surfaces the probe in place of the
    bare `.lp`."""
    lines = lp_path.read_text(encoding="utf-8").splitlines()
    i = fail_line - 1
    if not (0 <= i < len(lines)):
        return None
    tac = (f"debug +{code}; " if code else "") + "print;"
    # A "proof is not finished" error is reported at the `end` terminator: the
    # tactics all *succeeded*, but a goal is left open.  `print` there is a syntax
    # error — step back to the last real tactic and splice `print` *after* it (the
    # tactic isn't failing; we want the goals that remain once it has run).  For a
    # genuine failing tactic, `print` goes *before* it, to show the goal it faces.
    after = lines[i].lstrip().startswith(("end", "abort", "admitted")) or not lines[i].strip()
    while i >= 0 and (not lines[i].strip()
                      or lines[i].lstrip().startswith(("end", "abort", "admitted"))):
        i -= 1
    if i < 0:
        return None
    if after:                                  # ` … tactic; print; } }` (before the close-braces)
        m = re.match(r"(.*?)(\s*(?:\}\s*)+)$", lines[i])
        if m and m.group(1).strip():
            lines[i] = f"{m.group(1).rstrip().rstrip(';')}; {tac}{m.group(2)}"
        else:                                  # only braces on this line — fall back to before
            after = False
    if not after:                              # `{ … print; tactic …` (after openers, before tactic)
        pre = re.match(r"\s*(?:\{\s*)*", lines[i]).group(0)
        lines[i] = f"{pre}{tac} {lines[i][len(pre):]}"
    fail_line = i + 1                          # the line we actually probed
    probe = lp_path.with_name(lp_path.stem + ".probe.lp")
    probe.write_text("\n".join(lines) + "\n", encoding="utf-8")
    try:
        r = _run_lambdapi(["--no-colors", "-w", str(probe)])
        out = (r.stdout + r.stderr).splitlines()
    except subprocess.TimeoutExpired:
        out = ["(probe timed out)"]
    probe.with_suffix(".lpo").unlink(missing_ok=True)   # keep the .probe.lp source only
    return {"path": rel(probe), "fail_line": fail_line, "code": code,
            "goal_state": _parse_goal_state(out),
            "debug_trace": _distill(out) if code else []}


def _print_goal_state(gs: dict, indent: str) -> None:
    """Prettify the lambdapi proof state: the hypotheses as an aligned `name : type`
    table, a turnstile rule separating them from the goals, then each goal — the
    focused one (goal 0) flagged with a bold `▶`, the rest dim and numbered."""
    hyps, goals = gs.get("hyps", []), gs.get("goals", [])
    if not hyps and not goals:
        print(f"{indent}  {dim('(goal state unavailable — see the .probe.lp)')}")
        return
    pairs = [(h.split(":", 1)[0].strip(), h.split(":", 1)[1].strip() if ":" in h else "")
             for h in hyps]
    w = max((len(n) for n, _ in pairs), default=0)
    for n, typ in pairs:
        print(f"{indent}  {bold(f'{n:<{w}}')} {dim(':')} {_clip(typ, 500)}")
    print(f"{indent}  {dim('─' * min(48, max(12, _TERM_W - len(indent) - 4)))}")  # context │ goals
    if not goals:
        print(f"{indent}  {green('(no remaining goals)')}")
        return
    if len(goals) == 1:                                  # the sole goal — no index needed
        print(f"{indent}{bold('▶ ⊢')} {_clip(goals[0], 500)}")
        return
    for k, g in enumerate(goals):                        # several goals — number them all,
        mark = bold("▶") if k == 0 else " "              # flag goal 0 (the focused one)
        body = f"{k}. ⊢ {_clip(g, 500)}"
        print(f"{indent}{mark} {body if k == 0 else dim(body)}")


def _print_debug_trace(lines: list[str], indent: str) -> None:
    """Prettify the distilled `debug` trace: drop the `[tag]` prefix into a dim
    label, style the body (red for a failure, plain for an `≡` constraint, dim
    otherwise).  Full width, untruncated."""
    for l in lines:
        m = re.match(r"\[([a-z]+)\]\s*(.*)", l)
        if m:
            print(f"{indent}  {dim(m.group(1) + ' │')} {_trace_style(m.group(2))}")
        else:
            print(f"{indent}  {_trace_style(l)}")


def _print_source_context(src: Path, line: int, indent, context):
    try:
        lines = src.read_text(encoding="utf-8").splitlines()
    except OSError:
        return
    if not (1 <= line <= len(lines)):
        return
    lo = max(0, line - 1 - context)
    hi = min(len(lines), line + context)
    _numbered(lines[lo:hi], lo + 1, indent, mark={line})


# ── Rule signature lookup (lp/rules/*.lp) ──────────────────────────────────
def _rule_signature(rule: str):
    """The failing rule's declaration in lp/rules/*.lp as (path, start_line, end_line)
    — the `symbol …` line through the line holding its `≔`/`;`.  None if not found."""
    name = rule.lstrip("@")
    rx = re.compile(r"(?:opaque\s+|sequential\s+|injective\s+|constant\s+)*symbol\s+"
                    + re.escape(name) + r"\b.*?(?=≔|;)", re.DOTALL)
    for f in sorted((ROOT / "lp" / "rules").glob("*.lp")):
        text = f.read_text(encoding="utf-8")
        m = rx.search(text)
        if m:
            start = text.count("\n", 0, m.start()) + 1
            end = text.count("\n", 0, m.end()) + 1
            return f, start, end
    return None


# ── Per-trace printing + single-trace dossier ──────────────────────────────
def _print_trace(res: dict, replay: Path, timing: bool = False) -> None:
    """A heavy-ruled header for the trace (so one benchmark is clearly delimited
    from the next), its warnings, and — on failure — the snippet window."""
    timing_txt = (f"  emit {fmt_ms(res['emit_ms'])} / check {fmt_ms(res['check_ms'])}"
                  if timing else "")
    visible = 6 + len(res["name"]) + len(timing_txt)   # "━━ " + icon + " " + name + timing + " "
    print(f"━━ {ICON[res['status']]} {bold(res['name'])}{dim(timing_txt)} "
          + "━" * max(3, _TERM_W - visible))
    for w in res["warnings"]:
        print(f"   {dim(w)}")
    if res["status"] in ("emit_fail", "lp_fail"):
        print_failure(res, replay)


def dossier(replay: Path, res: dict):
    """Everything an agent needs about one trace, in one call — the failure window
    of related-file snippets, the goal state, and (with --lp-debug) the trace."""
    _print_trace(res, replay, timing=True)


def _section(title):
    pad = max(3, _TERM_W - len(title) - 7)      # "   " indent + "── " + " " before dashes
    print(f"   {dim(f'── {title} ' + '─' * pad)}")


# ── The `run` command ──────────────────────────────────────────────────────
def cmd_run(args) -> int:
    if args.lp_debug is not None and not re.fullmatch(r"[a-zA-Z]+", args.lp_debug):
        sys.exit(f"pp2lp: --lp-debug code {args.lp_debug!r} must be lambdapi flags (letters "
                 f"like u/r/t/w) — put the target before it, e.g. "
                 f"`pp2lp run SUITE/NAME --lp-debug=u`")
    if not args.no_build:
        ok, err = ensure_build()
        if not ok:
            if args.json:
                print(json.dumps({"ok": False, "error": {"code": "E_BUILD", "message": err}}))
            else:
                print(red("build failed:"))
                print(err)
            return 1

    kind, suite, target = resolve_target(args.target)
    if kind == "single":
        res = check_one(target, args.lp_debug)
        if args.json:
            print(json.dumps(res, ensure_ascii=False, indent=2))
        else:
            dossier(target, res)
        return 0 if res["status"] in ("ok", "warn") else 1

    # ── suite: parallel emit+check, strict gate ──
    if getattr(args, "filter", None):
        rx = re.compile(args.filter)
        target = [r for r in target if rx.search(r.stem)]
        if not target:
            sys.exit(f"pp2lp: --filter {args.filter!r} matched no benchmark "
                     f"in suite {suite!r}")
    return _run_suite(args, suite, target)


class _Stream:
    """Live per-result printer.  On a TTY, passes only advance a single in-place
    counter line (no scrollback flood at suite scale) and failures still unfold
    their full `━━` window; redirected, passes become one compact line each so
    CI/pipes stay greppable.  Warnings always surface."""

    def __init__(self, suite: str, total: int):
        self.suite, self.total, self.done, self.fail = suite, total, 0, 0

    def _counter(self) -> str:
        tail = red(f"  {self.fail} ✗") if self.fail else ""
        return dim(f"  {self.suite}  {self.done}/{self.total}") + tail

    def _unfold(self, res: dict, replay: Path) -> None:
        if res["status"] in ("emit_fail", "lp_fail"):       # the heavy failure window
            print()
            _print_trace(res, replay, timing=True)
        else:                                               # warn: compact + its warnings
            print(f"{ICON['warn']} {res['name']}")
            for w in res["warnings"]:
                print(f"   {dim(w)}")

    def _compact(self, res: dict) -> None:                  # a passing trace, one line
        timing = dim(f"  emit {fmt_ms(res['emit_ms'])} / check {fmt_ms(res['check_ms'])}")
        print(f"{ICON[res['status']]} {res['name']}{timing}")

    def __call__(self, res: dict, replay: Path) -> None:
        self.done += 1
        notable = res["status"] != "ok"                     # failures + warnings get shown
        self.fail += res["status"] in ("emit_fail", "lp_fail")
        if IS_TTY:
            sys.stdout.write("\r\033[K")                    # drop the counter line first
            if notable:
                self._unfold(res, replay)
            sys.stdout.write("\r" + self._counter())
            sys.stdout.flush()
        elif notable:
            self._unfold(res, replay)
        else:
            self._compact(res)

    def finish(self) -> None:
        if IS_TTY:
            sys.stdout.write("\r\033[K")
            sys.stdout.flush()


def _failure_histogram(goals: list[dict]) -> dict:
    """Counts per error code over the failed goals (emit_fail / lp_fail)."""
    hist: dict[str, int] = {}
    for g in goals:
        if g["status"] in ("emit_fail", "lp_fail"):
            code = (g.get("error") or {}).get("code") or "E_EMIT"
            hist[code] = hist.get(code, 0) + 1
    return hist


def _run_suite(args, suite: str, replays: list[Path]) -> int:
    t_start = time.monotonic()
    # human run: stream each result live (completion order); -q and --json don't.
    stream = _Stream(suite, len(replays)) if not (args.json or args.quiet) else None
    want_probe = (not args.quiet) or args.json     # goal-state probe powers the window / JSON
    results = _check_all(replays, lp_debug=args.lp_debug,
                         want_probe=want_probe, on_result=stream)
    if stream:
        stream.finish()
    elapsed = (time.monotonic() - t_start) * 1000

    ordered = [results[r.stem] for r in replays]
    failures = [r["name"] for r in ordered if r["status"] in ("emit_fail", "lp_fail")]
    artifact = {"suite": suite,
                "ok": sum(r["status"] == "ok" for r in ordered),
                "warn": sum(r["status"] == "warn" for r in ordered),
                "fail": len(failures), "failures": failures, "wall_ms": elapsed,
                "by_code": _failure_histogram(ordered),
                "emit_ms": sum(r["emit_ms"] for r in ordered),
                "check_ms": sum(r["check_ms"] for r in ordered), "goals": ordered}

    RESULTS_DIR.mkdir(parents=True, exist_ok=True)
    (RESULTS_DIR / f"{suite}.json").write_text(
        json.dumps(artifact, ensure_ascii=False, indent=2), encoding="utf-8")

    if args.json:
        print(json.dumps(artifact, ensure_ascii=False, indent=2))
    else:
        _print_summary(artifact)
    return 1 if failures else 0


def _print_summary(artifact: dict) -> None:
    """The trailing one-line tally.  The per-trace output already streamed live
    (unless `-q`, which shows only this line)."""
    suite, failures = artifact["suite"], artifact["failures"]
    print()
    parts = []
    if artifact["ok"]:
        parts.append(f"{green(artifact['ok'])} ✓")
    if artifact["warn"]:
        parts.append(f"{yellow(artifact['warn'])} ⚠")
    if failures:
        parts.append(f"{red(len(failures))} ✗")
    breakdown = dim(f"emit {fmt_ms(artifact['emit_ms'])} / check {fmt_ms(artifact['check_ms'])}")
    print(f"{suite}  {'  '.join(parts)}  {dim(fmt_ms(artifact['wall_ms']))}  {breakdown}")
    if failures:
        hist = artifact.get("by_code") or {}
        tally = "  ".join(f"{code}×{n}" for code, n in
                          sorted(hist.items(), key=lambda kv: (-kv[1], kv[0])))
        if tally:
            print(f"  {red('✗ by code:')} {tally}")


# ── shared suite evaluation ────────────────────────────────────────────────
def _warm_shared_cache() -> None:
    """Type-check the shared library files (B, Quant, ConjList, Rules → all of
    rules/*) once, serially, so their .lpo objects exist before the parallel
    workers start.  Otherwise each `lambdapi check -c` below races to compile and
    write those same shared objects on a cold cache, corrupting them and giving
    spurious failures (a re-run would then "fix" it).  Warming them first leaves
    the workers only reading the shared objects and writing their own."""
    shared = [ROOT / "lp" / f for f in ("B.lp", "Quant.lp", "ConjList.lp", "Rules.lp")]
    shared = [str(p) for p in shared if p.exists()]
    if not shared:
        return
    try:
        # The one-off serial library compile is exempt from the per-goal
        # CHECK_TIMEOUT: cold (post `*.lpo`-purge) it takes far longer than a
        # single goal, and timing out here would resurrect the very .lpo write
        # race this warm-up exists to prevent.
        _run_lambdapi(["-c", "-w", *shared], timeout=max(120.0, CHECK_TIMEOUT))
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass        # a missing/slow lambdapi resurfaces per-trace in the workers below


def _check_all(replays, lp_debug=None, want_probe=True, on_result=None) -> dict[str, dict]:
    """Emit+check every replay in parallel; keyed by stem.  `on_result(res, replay)`
    fires on the main thread as each trace finishes (completion order) so callers
    can stream live; `want_probe` builds the goal-state probe on failure."""
    out: dict[str, dict] = {}
    _warm_shared_cache()
    workers = min(len(replays), (os.cpu_count() or 2))
    with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as ex:
        futs = {ex.submit(check_one, r, lp_debug, want_probe): r for r in replays}
        for fut in concurrent.futures.as_completed(futs):
            replay = futs[fut]
            try:
                res = fut.result()
            except Exception as e:        # one bad trace must not sink the whole suite
                res = {"name": replay.stem, "lp": rel(replay.with_suffix(".lp")),
                       "emit_ms": 0.0, "check_ms": 0.0, "warnings": [], "status": "emit_fail",
                       "error": {"code": "E_INTERNAL",
                                 "message": f"{type(e).__name__}: {e}"}}
            out[res["name"]] = res
            if on_result:
                on_result(res, replay)
    return out


